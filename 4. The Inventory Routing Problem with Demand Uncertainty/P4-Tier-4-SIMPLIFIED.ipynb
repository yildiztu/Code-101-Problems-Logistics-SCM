    "## Step 2 — Q-Learning Agent\n",
    "\n",
    "Now we implement a simple Q-learning agent that learns optimal policies through experience replay."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ----------------------------\n",
    "# Q-Learning Agent\n",
    "# ----------------------------\n",
    "# Simple Q-learning implementation with experience replay.\n",
    "\n",
    "class QLearningAgent:\n",
    "    \"\"\"Q-Learning agent with experience replay.\"\"\"\n",
    "    \n",
    "    def __init__(self, env, learning_rate=0.1, discount_factor=0.95, epsilon=1.0, epsilon_decay=0.995, epsilon_min=0.01):\n",
    "        self.env = env\n",
    "        self.learning_rate = learning_rate\n",
    "        self.discount_factor = discount_factor\n",
    "        self.epsilon = epsilon\n",
    "        self.epsilon_decay = epsilon_decay\n",
    "        self.epsilon_min = epsilon_min\n",
    "        \n",
    "        # Initialize Q-table\n",
    "        self.q_table = np.zeros((len(env.states), len(env.actions)))\n",
    "        \n",
    "        # Experience replay buffer\n",
    "        self.replay_buffer = deque(maxlen=10000)\n",
    "        self.batch_size = 32\n",
    "        \n",
    "        # Training statistics\n",
    "        self.training_episodes = 0\n",
    "        self.training_steps = 0\n",
    "        self.episode_rewards = []\n",
    "        self.epsilon_history = []\n",
    "    \n",
    "    def act(self, state, training=True):\n",
    "        \"\"\"Choose action using epsilon-greedy policy.\"\"\"\n",
    "        state_idx = self.env.state_to_idx[state]\n",
    "        \n",
    "        if training and np.random.random() < self.epsilon:\n",
    "            # Explore: random action\n",
    "            action_idx = np.random.randint(0, len(self.env.actions))\n",
    "        else:\n",
    "            # Exploit: best action according to Q-table\n",
    "            action_idx = np.argmax(self.q_table[state_idx])\n",
    "        \n",
    "        return action_idx\n",
    "    \n",
    "    def remember(self, state, action_idx, reward, next_state, done):\n",
    "        \"\"\"Store experience in replay buffer.\"\"\"\n",
    "        state_idx = self.env.state_to_idx[state]\n",
    "        next_state_idx = self.env.state_to_idx[next_state]\n",
    "        \n",
    "        experience = (state_idx, action_idx, reward, next_state_idx, done)\n",
    "        self.replay_buffer.append(experience)\n",
    "    \n",
    "    def replay(self):\n",
    "        \"\"\"Train Q-table using experience replay.\"\"\"\n",
    "        if len(self.replay_buffer) < self.batch_size:\n",
    "            return\n",
    "        \n",
    "        # Sample batch from replay buffer\n",
    "        batch = random.sample(list(self.replay_buffer), self.batch_size)\n",
    "        \n",
    "        for state_idx, action_idx, reward, next_state_idx, done in batch:\n",
    "            # Q-learning update rule\n",
    "            if done:\n",
    "                target = reward\n",
    "            else:\n",
    "                target = reward + self.discount_factor * np.max(self.q_table[next_state_idx])\n",
    "            \n",
    "            # Update Q-value\n",
    "            old_value = self.q_table[state_idx, action_idx]\n",
    "            self.q_table[state_idx, action_idx] = old_value + self.learning_rate * (target - old_value)\n",
    "    \n",
    "    def train_episode(self):\n",
    "        \"\"\"Train agent for one episode.\"\"\"\n",
    "        state = self.env.reset()\n",
    "        total_reward = 0.0\n",
    "        done = False\n",
    "        steps = 0\n",
    "        \n",
    "        while not done and steps < 20:  # Prevent infinite episodes\n",
    "            # Choose action\n",
    "            action_idx = self.act(state, training=True)\n",
    "            \n",
    "            # Take step\n",
    "            next_state, reward, done, info = self.env.step(action_idx)\n",
    "            \n",
    "            # Store experience\n",
    "            self.remember(state, action_idx, reward, next_state, done)\n",
    "            \n",
    "            # Update state\n",
    "            state = next_state\n",
    "            total_reward += reward\n",
    "            steps += 1\n",
    "            \n",
    "            # Train from experience\n",
    "            self.replay()\n",
    "        \n",
    "        # Update epsilon\n",
    "        if self.epsilon > self.epsilon_min:\n",
    "            self.epsilon *= self.epsilon_decay\n",
    "        \n",
    "        self.training_episodes += 1\n",
    "        self.episode_rewards.append(total_reward)\n",
    "        self.epsilon_history.append(self.epsilon)\n",
    "        \n",
    "        return total_reward, steps\n",
    "    \n",
    "    def evaluate_episode(self):\n",
    "        \"\"\"Evaluate agent performance (no exploration).\"\"\"\n",
    "        state = self.env.reset()\n",
    "        total_reward = 0.0\n",
    "        done = False\n",
    "        steps = 0\n",
    "        \n",
    "        while not done and steps < 20:\n",
    "            # Choose action (no exploration)\n",
    "            action_idx = self.act(state, training=False)\n",
    "            \n",
    "            # Take step\n",
    "            next_state, reward, done, info = self.env.step(action_idx)\n",
    "            \n",
    "            # Update state\n",
    "            state = next_state\n",
    "            total_reward += reward\n",
    "            steps += 1\n",
    "        \n",
    "        return total_reward, steps\n",
    "\n",
    "\n",
    "# Test agent\n",
    "print(\"=== Q-LEARNING AGENT TEST ===\")\n",
    "agent = QLearningAgent(env)\n",
    "\n",
    "# Test single episode\n",
    "reward, steps = agent.train_episode()\n",
    "\n",
    "print(f\"Training episode reward: {reward:.2f}\")\n",
    "print(f\"Training episode steps: {steps}\")\n",
    "print(f\"Current epsilon: {agent.epsilon:.3f}\")\n",
    "print(f\"Replay buffer size: {len(agent.replay_buffer)}\")\n",
    "\n",
    "print(f\"\\n✓ Q-Learning agent working correctly\")"
   ]
  },
