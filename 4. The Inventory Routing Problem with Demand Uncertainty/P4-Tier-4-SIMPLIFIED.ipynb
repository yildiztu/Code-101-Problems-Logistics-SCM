    "## Step 1 — Simplified RL Environment\n",
    "\n",
    "We define a simplified RL environment with discrete states and actions for easier learning demonstration."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ----------------------------\n",
    "# Simplified RL Environment\n",
    "# ----------------------------\n",
    "# Simple Q-learning environment for demonstration.\n",
    "\n",
    "class SimpleInventoryRoutingEnvironment:\n",
    "    \"\"\"Simplified RL environment for inventory routing.\"\"\"\n",
    "    \n",
    "    def __init__(self):\n",
    "        self.current_period = 1\n",
    "        self.current_inventories = {c.id: c.initial_inventory for c in CUSTOMERS}\n",
    "        self.current_scenario = np.random.choice(SCENARIOS, p=[s.probability for s in SCENARIOS])\n",
    "        self.episode_step = 0\n",
    "        self.max_steps = len(PERIODS)\n",
    "        \n",
    "        # Simplified state and action spaces\n",
    "        self.state_dim = len(CUSTOMERS) + 1  # inventory levels + period\n",
    "        self.action_dim = len(CUSTOMERS)  # delivery to each customer (0 or 1)\n",
    "        \n",
    "        # Precompute all possible states for Q-table\n",
    "        self._initialize_state_space()\n",
    "        self._initialize_action_space()\n",
    "    \n",
    "    def _initialize_state_space(self):\n",
    "        \"\"\"Create discrete state space for Q-table.\"\"\"\n",
    "        self.states = []\n",
    "        \n",
    "        # Discretize inventory levels (low, medium, high)\n",
    "        inventory_levels = ['low', 'medium', 'high']\n",
    "        \n",
    "        for period in PERIODS:\n",
    "            for inv_combination in itertools.product(inventory_levels, repeat=len(CUSTOMERS)):\n",
    "                state = (period,) + inv_combination\n",
    "                self.states.append(state)\n",
    "        \n",
    "        self.state_to_idx = {state: i for i, state in enumerate(self.states)}\n",
    "        self.idx_to_state = {i: state for i, state in enumerate(self.states)}\n",
    "    \n",
    "    def _initialize_action_space(self):\n",
    "        \"\"\"Create discrete action space for Q-table.\"\"\"\n",
    "        self.actions = []\n",
    "        \n",
    "        # Binary actions: deliver to each customer (0=no, 1=yes)\n",
    "        for action_bits in itertools.product([0, 1], repeat=len(CUSTOMERS)):\n",
    "            # Only allow actions that respect vehicle capacity\n",
    "            total_delivery = sum(action_bits) * 20  # 20 units per delivery\n",
    "            if total_delivery <= VEHICLE_CAPACITY:\n",
    "                self.actions.append(action_bits)\n",
    "        \n",
    "        self.action_to_idx = {action: i for i, action in enumerate(self.actions)}\n",
    "        self.idx_to_action = {i: action for i, action in enumerate(self.actions)}\n",
    "    \n",
    "    def reset(self):\n",
    "        \"\"\"Reset environment for new episode.\"\"\"\n",
    "        self.current_period = 1\n",
    "        self.current_inventories = {c.id: c.initial_inventory for c in CUSTOMERS}\n",
    "        self.current_scenario = np.random.choice(SCENARIOS, p=[s.probability for s in SCENARIOS])\n",
    "        self.episode_step = 0\n",
    "        return self._get_state()\n",
    "    \n",
    "    def _get_state(self):\n",
    "        \"\"\"Get current state representation.\"\"\"\n",
    "        state = []\n",
    "        \n",
    "        # Current period\n",
    "        state.append(self.current_period)\n",
    "        \n",
    "        # Discretize inventory levels\n",
    "        for customer in CUSTOMERS:\n",
    "            inventory = self.current_inventories[customer.id]\n",
    "            capacity = customer.capacity\n",
    "            \n",
    "            if inventory < capacity * 0.3:\n",
    "                state.append('low')\n",
    "            elif inventory < capacity * 0.7:\n",
    "                state.append('medium')\n",
    "            else:\n",
    "                state.append('high')\n",
    "        \n",
    "        return tuple(state)\n",
    "    \n",
    "    def step(self, action_idx):\n",
    "        \"\"\"Execute action and return (next_state, reward, done, info).\"\"\"\n",
    "        \n",
    "        action = self.idx_to_action[action_idx]\n",
    "        \n",
    "        # Calculate reward (negative of costs)\n",
    "        reward = self._calculate_reward(action)\n",
    "        \n",
    "        # Apply deliveries and demand\n",
    "        self._apply_deliveries_and_demand(action)\n",
    "        \n",
    "        # Update episode step\n",
    "        self.episode_step += 1\n",
    "        \n",
    "        # Check if episode is done\n",
    "        done = (self.current_period > len(PERIODS))\n",
    "        \n",
    "        # Get next state\n",
    "        next_state = self._get_state()\n",
    "        \n",
    "        # Info dictionary\n",
    "        info = {\n",
    "            'deliveries': action,\n",
    "            'inventories': self.current_inventories.copy(),\n",
    "            'period': self.current_period,\n",
    "            'scenario': self.current_scenario.id if self.current_scenario else None\n",
    "        }\n",
    "        \n",
    "        return next_state, reward, done, info\n",
    "    \n",
    "    def _calculate_reward(self, action):\n",
    "        \"\"\"Calculate reward based on delivery decisions.\"\"\"\n",
    "        total_cost = 0.0\n",
    "        \n",
    "        # Transportation cost (simplified)\n",
    "        customers_with_deliveries = [i for i, deliver in enumerate(action) if deliver == 1]\n",
    "        if customers_with_deliveries:\n",
    "            transport_cost = len(customers_with_deliveries) * 10.0 * TRANSPORT_COST_PER_UNIT\n",
    "            total_cost += transport_cost\n",
    "        \n",
    "        # Inventory costs (projected)\n",
    "        for i, customer in enumerate(CUSTOMERS):\n",
    "            if action[i] == 1:  # If delivering to this customer\n",
    "                projected_inventory = self.current_inventories[customer.id] + 20.0\n",
    "            else:\n",
    "                projected_inventory = self.current_inventories[customer.id]\n",
    "            \n",
    "            # Apply expected demand\n",
    "            mean_demand = demand_stats[customer.id]['mean']\n",
    "            projected_inventory -= mean_demand\n",
    "            \n",
    "            # Holding cost\n",
    "            if projected_inventory > 0:\n",
    "                total_cost += projected_inventory * customer.holding_cost\n",
    "            \n",
    "            # Shortage cost (if below safety stock)\n",
    "            safety_stock = safety_stocks[customer.id]\n",
    "            if projected_inventory < safety_stock:\n",
    "                shortage_probability = 0.05\n",
    "                expected_shortage = (safety_stock - projected_inventory) * shortage_probability\n",
    "                total_cost += expected_shortage * customer.shortage_cost\n",
    "        \n",
    "        return -total_cost  # Negative cost = reward\n",
    "    \n",
    "    def _apply_deliveries_and_demand(self, action):\n",
    "        \"\"\"Apply deliveries and demand to update state.\"\"\"\n",
    "        \n",
    "        # Apply deliveries\n",
    "        for i, customer in enumerate(CUSTOMERS):\n",
    "            if action[i] == 1:\n",
    "                self.current_inventories[customer.id] += 20.0\n",
    "        \n",
    "        # Apply demand from current scenario\n",
    "        if self.current_scenario:\n",
    "            for customer in CUSTOMERS:\n",
    "                demand = self.current_scenario.demands[customer.id]\n",
    "                self.current_inventories[customer.id] -= demand\n",
    "        else:\n",
    "            # Use mean demand if no scenario\n",
    "            for customer in CUSTOMERS:\n",
    "                mean_demand = demand_stats[customer.id]['mean']\n",
    "                self.current_inventories[customer.id] -= mean_demand\n",
    "        \n",
    "        # Move to next period\n",
    "        self.current_period += 1\n",
    "        \n",
    "        # Select new scenario for next period\n",
    "        if self.current_period <= len(PERIODS):\n",
    "            self.current_scenario = np.random.choice(SCENARIOS, p=[s.probability for s in SCENARIOS])\n",
    "\n",
    "\n",
    "# Test environment\n",
    "print(\"=== SIMPLIFIED RL ENVIRONMENT TEST ===\")\n",
    "env = SimpleInventoryRoutingEnvironment()\n",
    "\n",
    "print(f\"State space size: {len(env.states)}\")\n",
    "print(f\"Action space size: {len(env.actions)}\")\n",
    "print(f\"State dimension: {env.state_dim}\")\n",
    "print(f\"Action dimension: {env.action_dim}\")\n",
    "\n",
    "# Test reset and step\n",
    "state = env.reset()\n",
    "print(f\"\\nInitial state: {state}\")\n",
    "\n",
    "# Test random action\n",
    "random_action_idx = random.randint(0, len(env.actions))\n",
    "next_state, reward, done, info = env.step(random_action_idx)\n",
    "\n",
    "print(f\"Random action: {env.idx_to_action[random_action_idx]}\")\n",
    "print(f\"Reward: {reward:.2f}\")\n",
    "print(f\"Done: {done}\")\n",
    "print(f\"Next state: {next_state}\")\n",
    "\n",
    "print(f\"\\n✓ Simplified environment working correctly\")"
   ]
  },
