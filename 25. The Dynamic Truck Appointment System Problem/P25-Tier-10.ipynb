    "@dataclass\n",
    "class CustomerSegment:\n",
    "    \"\"\"Represents a customer segment with specific characteristics\"\"\"\n",
    "    segment_id: str\n",
    "    segment_name: str\n",
    "    price_elasticity: float  # -1.0 to 0.0 (negative indicates price sensitivity)\n",
    "    time_flexibility: float  # 0.0 to 1.0 (how flexible with timing)\n",
    "    volume_share: float  # percentage of total volume\n",
    "    strategic_importance: int  # 1=low, 2=medium, 3=high\n",
    "    preferred_time_windows: List[Tuple[int, int]]  # (start_hour, end_hour)\n",
    "\n",
    "@dataclass\n",
    "class PricingStrategy:\n",
    "    \"\"\"Dynamic pricing strategy for different time slots and customer segments\"\"\"\n",
    "    base_price: float\n",
    "    peak_premium: float  # percentage increase for peak times\n",
    "    off_peak_discount: float  # percentage discount for off-peak times\n",
    "    strategic_partner_discount: float  # discount for strategic partners\n",
    "    volume_discount_threshold: int  # minimum volume for volume discounts\n",
    "    volume_discount_rate: float  # discount rate per threshold unit\n",
    "\n",
    "@dataclass\n",
    "class CapacityAllocation:\n",
    "    \"\"\"Strategic capacity allocation across time slots and customer types\"\"\"\n",
    "    total_capacity: int\n",
    "    strategic_reserve_percentage: float  # capacity reserved for strategic partners\n",
    "    premium_capacity_percentage: float  # capacity for premium pricing\n",
    "    standard_capacity_percentage: float  # capacity for standard pricing\n",
    "    time_slot_allocations: Dict[int, Dict[str, int]]  # slot -> {strategic, premium, standard}\n",
    "\n",
    "@dataclass\n",
    "class PartnershipProgram:\n",
    "    \"\"\"Strategic partnership program with benefits and requirements\"\"\"\n",
    "    program_id: str\n",
    "    program_name: str\n",
    "    required_off_peak_percentage: float  # minimum off-peak usage required\n",
    "    guaranteed_capacity: int  # guaranteed capacity per period\n",
    "    priority_service_level: int  # 1-5 priority level\n",
    "    discount_rate: float  # program discount rate\n",
    "    commitment_period: int  # months\n",
    "\n",
    "@dataclass\n",
    "class MarketInfluence:\n",
    "    \"\"\"Market influence mechanism and its impact\"\"\"\n",
    "    influence_type: str  # 'pricing', 'capacity', 'partnership', 'incentive'\n",
    "    target_segment: str\n",
    "    mechanism: Dict[str, Any]\n",
    "    expected_impact: Dict[str, float]\n",
    "    actual_impact: Dict[str, float] = field(default_factory=dict)\n",
    "\n",
    "class ProactiveDemandShapingSystem:\n",
    "    \"\"\"System for proactive demand shaping and market influence\"\"\"\n",
    "    \n",
    "    def __init__(self, total_daily_capacity: int = 200):\n",
    "        self.total_capacity = total_daily_capacity\n",
    "        self.customer_segments = []\n",
    "        self.pricing_strategy = None\n",
    "        self.capacity_allocation = None\n",
    "        self.partnership_programs = []\n",
    "        self.market_influences = []\n",
    "        self.historical_data = []\n",
    "        \n",
    "        # Initialize system\n",
    "        self._initialize_customer_segments()\n",
    "        self._initialize_pricing_strategy()\n",
    "        self._initialize_capacity_allocation()\n",
    "        self._initialize_partnership_programs()\n",
    "    \n",
    "    def _initialize_customer_segments(self):\n",
    "        \"\"\"Initialize customer segments with realistic characteristics\"\"\"\n",
    "        \n",
    "        segments = [\n",
    "            CustomerSegment(\n",
    "                segment_id=\"premium\",\n",
    "                segment_name=\"Premium Strategic Partners\",\n",
    "                price_elasticity=-0.3,  # Low price sensitivity\n",
    "                time_flexibility=0.4,  # Moderate flexibility\n",
    "                volume_share=0.25,  # 25% of volume\n",
    "                strategic_importance=3,  # High importance\n",
    "                preferred_time_windows=[(8, 12), (14, 18)]\n",
    "            ),\n",
    "            CustomerSegment(\n",
    "                segment_id=\"regular\",\n",
    "                segment_name=\"Regular Commercial\",\n",
    "                price_elasticity=-0.7,  # Moderate price sensitivity\n",
    "                time_flexibility=0.6,  # Good flexibility\n",
    "                volume_share=0.45,  # 45% of volume\n",
    "                strategic_importance=2,  # Medium importance\n",
    "                preferred_time_windows=[(9, 17)]\n",
    "            ),\n",
    "            CustomerSegment(\n",
    "                segment_id=\"price_sensitive\",\n",
    "                segment_name=\"Price-Sensitive Small Business\",\n",
    "                price_elasticity=-1.2,  # High price sensitivity\n",
    "                time_flexibility=0.8,  # High flexibility\n",
    "                volume_share=0.30,  # 30% of volume\n",
    "                strategic_importance=1,  # Low importance\n",
    "                preferred_time_windows=[(7, 19)]  # Very flexible\n",
    "            ),\n",
    "        ]\n",
    "        \n",
    "        self.customer_segments = segments\n",
    "    \n",
    "    def _initialize_pricing_strategy(self):\n",
    "        \"\"\"Initialize dynamic pricing strategy\"\"\"\n",
    "        \n",
    "        self.pricing_strategy = PricingStrategy(\n",
    "            base_price=100.0,\n",
    "            peak_premium=0.20,  # 20% premium for peak times\n",
    "            off_peak_discount=0.15,  # 15% discount for off-peak\n",
    "            strategic_partner_discount=0.10,  # 10% discount for strategic partners\n",
    "            volume_discount_threshold=50,  # 50 appointments per month\n",
    "            volume_discount_rate=0.02  # 2% additional discount per threshold\n",
    "        )\n",
    "    \n",
    "    def _initialize_capacity_allocation(self):\n",
    "        \"\"\"Initialize strategic capacity allocation\"\"\"\n",
    "        \n",
    "        allocation = CapacityAllocation(\n",
    "            total_capacity=self.total_capacity,\n",
    "            strategic_reserve_percentage=0.35,  # 35% for strategic partners\n",
    "            premium_capacity_percentage=0.25,  # 25% for premium pricing\n",
    "            standard_capacity_percentage=0.40,  # 40% for standard pricing\n",
    "            time_slot_allocations={}\n",
    "        )\n",
    "        \n",
    "        # Allocate capacity across 24-hour time slots (6 AM to 11 PM)\n",
    "        for hour in range(6, 24):\n",
    "            if 10 <= hour <= 14:  # Peak hours\n",
    "                strategic = int(allocation.total_capacity * 0.30)\n",
    "                premium = int(allocation.total_capacity * 0.35)\n",
    "                standard = int(allocation.total_capacity * 0.35)\n",
    "            elif 7 <= hour <= 9 or 15 <= hour <= 17:  # Off-peak preferred\n",
    "                strategic = int(allocation.total_capacity * 0.40)\n",
    "                premium = int(allocation.total_capacity * 0.20)\n",
    "                standard = int(allocation.total_capacity * 0.40)\n",
    "            else:  # Other hours\n",
    "                strategic = int(allocation.total_capacity * 0.25)\n",
    "                premium = int(allocation.total_capacity * 0.15)\n",
    "                standard = int(allocation.total_capacity * 0.60)\n",
    "            \n",
    "            allocation.time_slot_allocations[hour] = {\n",
    "                'strategic': strategic,\n",
    "                'premium': premium,\n",
    "                'standard': standard\n",
    "            }\n",
    "        \n",
    "        self.capacity_allocation = allocation\n",
    "    \n",
    "    def _initialize_partnership_programs(self):\n",
    "        \"\"\"Initialize strategic partnership programs\"\"\"\n",
    "        \n",
    "        programs = [\n",
    "            PartnershipProgram(\n",
    "                program_id=\"flexship\",\n",
    "                program_name=\"FlexShip Partnership\",\n",
    "                required_off_peak_percentage=0.30,  # 30% off-peak required\n",
    "                guaranteed_capacity=60,  # 60 guaranteed appointments per day\n",
    "                priority_service_level=5,  # Highest priority\n",
    "                discount_rate=0.12,  # 12% discount\n",
    "                commitment_period=12  # 12 months\n",
    "            ),\n",
    "            PartnershipProgram(\n",
    "                program_id=\"priority\",\n",
    "                program_name=\"Priority Access Program\",\n",
    "                required_off_peak_percentage=0.20,  # 20% off-peak required\n",
    "                guaranteed_capacity=40,  # 40 guaranteed appointments per day\n",
    "                priority_service_level=4,  # High priority\n",
    "                discount_rate=0.08,  # 8% discount\n",
    "                commitment_period=6  # 6 months\n",
    "            ),\n",
    "        ]\n",
    "        \n",
    "        self.partnership_programs = programs\n",
    "    \n",
    "    def calculate_price(self, hour: int, segment_id: str, is_partner: bool = False, \n",
    "                      volume: int = 0) -> float:\n",
    "        \"\"\"Calculate price for given conditions\"\"\"\n",
    "        \n",
    "        base_price = self.pricing_strategy.base_price\n",
    "        \n",
    "        # Time-based adjustment\n",
    "        if 10 <= hour <= 14:  # Peak hours\n",
    "            price_adjustment = 1 + self.pricing_strategy.peak_premium\n",
    "        elif 7 <= hour <= 9 or 15 <= hour <= 17:  # Off-peak preferred\n",
    "            price_adjustment = 1 - self.pricing_strategy.off_peak_discount\n",
    "        else:  # Other hours\n",
    "            price_adjustment = 1 - self.pricing_strategy.off_peak_discount * 0.5\n",
    "        \n",
    "        price = base_price * price_adjustment\n",
    "        \n",
    "        # Segment-based adjustment\n",
    "        segment = next((s for s in self.customer_segments if s.segment_id == segment_id), None)\n",
    "        if segment:\n",
    "            if segment.strategic_importance == 3 and is_partner:\n",
    "                price *= (1 - self.pricing_strategy.strategic_partner_discount)\n",
    "        \n",
    "        # Volume discount\n",
    "        if volume >= self.pricing_strategy.volume_discount_threshold:\n",
    "            discount_tiers = volume // self.pricing_strategy.volume_discount_threshold\n",
    "            price *= (1 - discount_tiers * self.pricing_strategy.volume_discount_rate)\n",
    "        \n",
    "        return max(price, 10.0)  # Minimum price floor\n",
    "    \n",
    "    def simulate_demand_response(self, base_demand: Dict[int, int], \n",
    "                                price_changes: Dict[int, float]) -> Dict[int, int]:\n",
    "        \"\"\"Simulate demand response to price changes\"\"\"\n",
    "        \n",
    "        new_demand = {}\n",
    "        \n",
    "        for hour, base_volume in base_demand.items():\n",
    "            if hour in price_changes:\n",
    "                price_change = price_changes[hour]\n",
    "                \n",
    "                # Weighted average elasticity across segments\n",
    "                weighted_elasticity = sum(s.price_elasticity * s.volume_share \n",
    "                                         for s in self.customer_segments)\n",
    "                \n",
    "                # Demand response: % change in demand = elasticity * % change in price\n",
    "                demand_change = weighted_elasticity * price_change\n",
    "                new_volume = int(base_volume * (1 + demand_change))\n",
    "                new_demand[hour] = max(0, new_volume)\n",
    "            else:\n",
    "                new_demand[hour] = base_volume\n",
    "        \n",
    "        return new_demand\n",
    "    \n",
    "    def apply_market_influence(self, influence_type: str, target_segment: str, \n",
    "                              mechanism: Dict[str, Any]) -> MarketInfluence:\n",
    "        \"\"\"Apply market influence mechanism\"\"\"\n",
    "        \n",
    "        influence = MarketInfluence(\n",
    "            influence_type=influence_type,\n",
    "            target_segment=target_segment,\n",
    "            mechanism=mechanism,\n",
    "            expected_impact=mechanism.get('expected_impact', {})\n",
    "        )\n",
    "        \n",
    "        self.market_influences.append(influence)\n",
    "        \n",
    "        return influence\n",
    "    \n",
    "    def run_strategic_simulation(self, days: int = 30) -> Dict[str, Any]:\n",
    "        \"\"\"Run strategic simulation with demand shaping\"\"\"\n",
    "        \n",
    "        print(f\"Running strategic demand shaping simulation for {days} days...\")\n",
    "        \n",
    "        # Generate base demand pattern (without influence)\n",
    "        base_demand = self._generate_base_demand_pattern()\n",
    "        \n",
    "        # Apply market influences\n",
    "        simulation_results = {\n",
    "            'daily_results': [],\n",
    "            'total_revenue': 0,\n",
    "            'total_appointments': 0,\n",
    "            'peak_congestion': [],\n",
    "            'off_peak_utilization': [],\n",
    "            'strategic_partner_revenue': 0,\n",
    "        }\n",
    "        \n",
    "        for day in range(days):\n",
    "            daily_result = self._simulate_day(base_demand, day)\n",
    "            simulation_results['daily_results'].append(daily_result)\n",
    "            \n",
    "            # Aggregate results\n",
    "            simulation_results['total_revenue'] += daily_result['revenue']\n",
    "            simulation_results['total_appointments'] += daily_result['appointments']\n",
    "            simulation_results['peak_congestion'].append(daily_result['peak_congestion'])\n",
    "            simulation_results['off_peak_utilization'].append(daily_result['off_peak_utilization'])\n",
    "            simulation_results['strategic_partner_revenue'] += daily_result['strategic_revenue']\n",
    "            \n",
    "            if (day + 1) % 10 == 0:\n",
    "                print(f\"  Day {day+1}/{days}: Revenue ${daily_result['revenue']:.0f}, \"\n",
    "                      f\"Appointments {daily_result['appointments']}, \"\n",
    "                      f\"Peak Congestion {daily_result['peak_congestion']:.1%}\")\n",
    "        \n",
    "        return simulation_results\n",
    "    \n",
    "    def _generate_base_demand_pattern(self) -> Dict[int, int]:\n",
    "        \"\"\"Generate base demand pattern without market influence\"\"\"\n",
    "        \n",
    "        base_demand = {}\n",
    "        \n",
    "        for hour in range(6, 24):\n",
    "            if 10 <= hour <= 14:  # Peak hours - high demand\n",
    "                base_demand[hour] = random.randint(15, 25)\n",
    "            elif 7 <= hour <= 9 or 15 <= hour <= 17:  # Off-peak preferred - moderate demand\n",
    "                base_demand[hour] = random.randint(8, 15)\n",
    "            else:  # Other hours - low demand\n",
    "                base_demand[hour] = random.randint(2, 8)\n",
    "        \n",
    "        return base_demand\n",
    "    \n",
    "    def _simulate_day(self, base_demand: Dict[int, int], day: int) -> Dict[str, Any]:\n",
    "        \n",
    "        # Calculate prices for each hour\n",
    "        prices = {}\n",
    "        for hour in range(6, 24):\n",
    "            # Mix of customer segments\n",
    "            segment_mix = random.choices(\n",
    "                ['premium', 'regular', 'price_sensitive'],\n",
    "                weights=[0.25, 0.45, 0.30]\n",
    "            )[0]\n",
    "            \n",
    "            is_partner = random.random() < 0.4  # 40% are partners\n",
    "            volume = random.randint(20, 100)  # Monthly volume\n",
    "            \n",
    "            prices[hour] = self.calculate_price(hour, segment_mix, is_partner, volume)\n",
    "        \n",
    "        # Calculate price changes from base price\n",
    "        price_changes = {}\n",
    "        for hour, price in prices.items():\n",
    "            price_change = (price - self.pricing_strategy.base_price) / self.pricing_strategy.base_price\n",
    "            price_changes[hour] = price_change\n",
    "        \n",
    "        # Simulate demand response\n",
    "        actual_demand = self.simulate_demand_response(base_demand, price_changes)\n",
    "        \n",
    "        # Apply capacity constraints\n",
    "        final_demand = {}\n",
    "        total_appointments = 0\n",
    "        total_revenue = 0\n",
    "        strategic_revenue = 0\n",
    "        \n",
    "        for hour in range(6, 24):\n",
    "            capacity = self.capacity_allocation.total_capacity // 18  # Per hour capacity\n",
    "            final_demand[hour] = min(actual_demand[hour], capacity)\n",
    "            \n",
    "            # Calculate revenue\n",
    "            hour_revenue = final_demand[hour] * prices[hour]\n",
    "            total_revenue += hour_revenue\n",
    "            total_appointments += final_demand[hour]\n",
    "            \n",
    "            # Strategic partner revenue (simplified)\n",
    "            if 10 <= hour <= 14:  # Peak hours\n",
    "                strategic_revenue += hour_revenue * 0.35  # 35% from strategic partners\n",
    "        \n",
    "        # Calculate metrics\n",
    "        peak_hours = [10, 11, 12, 13, 14]\n",
    "        peak_demand = sum(final_demand[hour] for hour in peak_hours)\n",
    "        peak_capacity = len(peak_hours) * (self.capacity_allocation.total_capacity // 18)\n",
    "        peak_congestion = peak_demand / peak_capacity if peak_capacity > 0 else 0\n",
    "        \n",
    "        off_peak_hours = [7, 8, 9, 15, 16, 17]\n",
    "        off_peak_demand = sum(final_demand[hour] for hour in off_peak_hours)\n",
    "        off_peak_capacity = len(off_peak_hours) * (self.capacity_allocation.total_capacity // 18)\n",
    "        off_peak_utilization = off_peak_demand / off_peak_capacity if off_peak_capacity > 0 else 0\n",
    "        \n",
    "        return {\n",
    "            'day': day + 1,\n",
    "            'appointments': total_appointments,\n",
    "            'revenue': total_revenue,\n",
    "            'strategic_revenue': strategic_revenue,\n",
    "            'peak_congestion': peak_congestion,\n",
    "            'off_peak_utilization': off_peak_utilization,\n",
    "            'prices': prices,\n",
    "            'demand': final_demand\n",
    "        }\n",
    "    \n",
    "    def analyze_strategic_impact(self, results: Dict[str, Any]) -> Dict[str, Any]:\n",
    "        \"\"\"Analyze the strategic impact of demand shaping\"\"\"\n",
    "        \n",
    "        print(\"\\n=== Strategic Impact Analysis ===\")\n",
    "        \n",
    "        # Revenue analysis\n",
    "        avg_daily_revenue = results['total_revenue'] / len(results['daily_results'])\n",
    "        strategic_revenue_ratio = results['strategic_partner_revenue'] / results['total_revenue']\n",
    "        \n",
    "        print(f\"\\nRevenue Analysis:\")\n",
    "        print(f\"  Average daily revenue: ${avg_daily_revenue:,.0f}\")\n",
    "        print(f\"  Strategic partner revenue ratio: {strategic_revenue_ratio:.1%}\")\n",
    "        \n",
    "        # Congestion analysis\n",
    "        avg_peak_congestion = np.mean(results['peak_congestion'])\n",
    "        avg_off_peak_utilization = np.mean(results['off_peak_utilization'])\n",
    "        \n",
    "        print(f\"\\nCongestion Analysis:\")\n",
    "        print(f\"  Average peak congestion: {avg_peak_congestion:.1%}\")\n",
    "        print(f\"  Average off-peak utilization: {avg_off_peak_utilization:.1%}\")\n",
    "        \n",
    "        # Efficiency improvement\n",
    "        congestion_reduction = max(0, 0.8 - avg_peak_congestion) / 0.8  # Assuming 80% baseline\n",
    "        utilization_improvement = max(0, avg_off_peak_utilization - 0.4) / 0.4  # Assuming 40% baseline\n",
    "        \n",
    "        print(f\"\\nEfficiency Improvements:\")\n",
    "        print(f\"  Peak congestion reduction: {congestion_reduction:.1%}\")\n",
    "        print(f\"  Off-peak utilization improvement: {utilization_improvement:.1%}\")\n",
    "        \n",
    "        # Market position analysis\n",
    "        market_leadership_score = (strategic_revenue_ratio * 0.4 + \n",
    "                                  congestion_reduction * 0.3 + \n",
    "                                  utilization_improvement * 0.3)\n",
    "        \n",
    "        print(f\"\\nMarket Position:\")\n",
    "        print(f\"  Market leadership score: {market_leadership_score:.3f}\")\n",
    "        \n",
    "        if market_leadership_score > 0.7:\n",
    "            print(\"  Status: Market Leader\")\n",
    "        elif market_leadership_score > 0.5:\n",
    "            print(\"  Status: Strong Competitor\")\n",
    "        else:\n",
    "            print(\"  Status: Market Participant\")\n",
    "        \n",
    "        return {\n",
    "            'avg_daily_revenue': avg_daily_revenue,\n",
    "            'strategic_revenue_ratio': strategic_revenue_ratio,\n",
    "            'avg_peak_congestion': avg_peak_congestion,\n",
    "            'avg_off_peak_utilization': avg_off_peak_utilization,\n",
    "            'congestion_reduction': congestion_reduction,\n",
    "            'utilization_improvement': utilization_improvement,\n",
    "            'market_leadership_score': market_leadership_score\n",
    "        }"
