    "# Initialize the Multi-Agent Ecosystem\n",
    "print(\"Initializing Multi-Agent Ecosystem...\")\n",
    "ecosystem = MultiAgentEcosystem(num_trucks=15, num_terminals=3, num_brokers=2)\n",
    "\n",
    "print(f\"Ecosystem initialized:\")\n",
    "agent_counts = defaultdict(int)\n",
    "for agent in ecosystem.agents.values():\n",
    "    agent_counts[agent.agent_type] += 1\n",
    "\n",
    "for agent_type, count in agent_counts.items():\n",
    "    print(f\"  {agent_type.title()} agents: {count}\")\n",
    "\n",
    "print(f\"\\nTotal agents: {len(ecosystem.agents)}\")\n",
    "print(f\"Communication network: Fully connected\")"
   ]
