    "def create_multi_agent_visualizations(ecosystem: MultiAgentEcosystem, \n",
    "                                      history: List[Dict], \n",
    "                                      analysis: Dict):\n",
    "    \"\"\"Create comprehensive visualizations of multi-agent system\"\"\"\n",
    "    \n",
    "    fig, axes = plt.subplots(2, 2, figsize=(16, 12))\n",
    "    fig.suptitle('Multi-Agent Ecosystem for Truck Appointment Management', fontsize=16, fontweight='bold')\n",
    "    \n",
    "    # 1. System Convergence Over Time\n",
    "    ax1 = axes[0, 0]\n",
    "    steps = [state['time_step'] for state in history]\n",
    "    utilities = [state['total_utility'] for state in history]\n",
    "    appointments = [state['appointments_made'] for state in history]\n",
    "    \n",
    "    ax1_twin = ax1.twinx()\n",
    "    \n",
    "    line1 = ax1.plot(steps, utilities, 'b-', linewidth=2, label='System Utility')\n",
    "    line2 = ax1_twin.plot(steps, appointments, 'r-', linewidth=2, label='Appointments Made')\n",
    "    \n",
    "    ax1.set_xlabel('Time Step')\n",
    "    ax1.set_ylabel('Total Utility', color='b')\n",
    "    ax1_twin.set_ylabel('Appointments Made', color='r')\n",
    "    ax1.set_title('System Convergence and Performance')\n",
    "    ax1.grid(True, alpha=0.3)\n",
    "    \n",
    "    # Combine legends\n",
    "    lines = line1 + line2\n",
    "    labels = [l.get_label() for l in lines]\n",
    "    ax1.legend(lines, labels, loc='upper left')\n",
    "    \n",
    "    # 2. Agent Communication Network\n",
    "    ax2 = axes[0, 1]\n",
    "    \n",
    "    # Create communication matrix\n",
    "    agent_ids = list(ecosystem.agents.keys())\n",
    "    comm_matrix = np.zeros((len(agent_ids), len(agent_ids)))\n",
    "    \n",
    "    # Count messages between agents\n",
    "    for message in ecosystem.message_bus:\n",
    "        if message.sender_id in agent_ids and message.receiver_id in agent_ids:\n",
    "            sender_idx = agent_ids.index(message.sender_id)\n",
    "            receiver_idx = agent_ids.index(message.receiver_id)\n",
    "            comm_matrix[sender_idx, receiver_idx] += 1\n",
    "    \n",
    "    # Create agent type colors\n",
    "    agent_colors = []\n",
    "    for agent_id in agent_ids:\n",
    "        agent = ecosystem.agents[agent_id]\n",
    "        if agent.agent_type == 'truck':\n",
    "            agent_colors.append('blue')\n",
    "        elif agent.agent_type == 'terminal':\n",
    "            agent_colors.append('green')\n",
    "        else:  # broker\n",
    "            agent_colors.append('orange')\n",
    "    \n",
    "    # Create heatmap\n",
    "    im = ax2.imshow(comm_matrix, cmap='YlOrRd', aspect='auto')\n",
    "    \n",
    "    # Add agent type indicators\n",
    "    for i, color in enumerate(agent_colors):\n",
    "        ax2.add_patch(plt.Rectangle((-0.5, i-0.5), 1, 1, fill=False, \n",
    "                                edgecolor=color, linewidth=2))\n",
    "    \n",
    "    ax2.set_xlabel('Receiver Agent')\n",
    "    ax2.set_ylabel('Sender Agent')\n",
    "    ax2.set_title('Agent Communication Network')\n",
    "    \n",
    "    # Add colorbar\n",
    "    cbar = plt.colorbar(im, ax=ax2)\n",
    "    cbar.set_label('Message Count', rotation=270, labelpad=15)\n",
    "    \n",
    "    # 3. Market Price Distribution\n",
    "    ax3 = axes[1, 0]\n",
    "    \n",
    "    transactions = analysis['market_transactions']\n",
    "    if transactions:\n",
    "        df_transactions = pd.DataFrame(transactions)\n",
    "        \n",
    "        # Create box plot by cargo type\n",
    "        cargo_types = df_transactions['cargo_type'].unique()\n",
    "        price_data = [df_transactions[df_transactions['cargo_type'] == ct]['price'].values \n",
    "                       for ct in cargo_types]\n",
    "        \n",
    "        bp = ax3.boxplot(price_data, labels=cargo_types, patch_artist=True)\n",
    "        \n",
    "        # Color the boxes\n",
    "        colors = plt.cm.Set3(np.linspace(0, 1, len(cargo_types)))\n",
    "        for patch, color in zip(bp['boxes'], colors):\n",
    "            patch.set_facecolor(color)\n",
    "        \n",
    "        ax3.set_xlabel('Cargo Type')\n",
    "        ax3.set_ylabel('Price ($)')\n",
    "        ax3.set_title('Market Price Distribution by Cargo Type')\n",
    "        ax3.grid(True, alpha=0.3)\n",
    "    else:\n",
    "        ax3.text(0.5, 0.5, 'No transactions recorded', \n",
    "                ha='center', va='center', transform=ax3.transAxes)\n",
    "        ax3.set_title('Market Price Distribution')\n",
    "    \n",
    "    # 4. Agent Utility Distribution\n",
    "    ax4 = axes[1, 1]\n",
    "    \n",
    "    # Calculate utilities by agent type\n",
    "    agent_utilities = defaultdict(list)\n",
    "    for agent in ecosystem.agents.values():\n",
    "        utility = agent.calculate_utility()\n",
    "        agent_utilities[agent.agent_type].append(utility)\n",
    "    \n",
    "    # Create violin plot\n",
    "    utility_data = []\n",
    "    utility_labels = []\n",
    "    \n",
    "    for agent_type, utilities in agent_utilities.items():\n",
    "        utility_data.extend(utilities)\n",
    "        utility_labels.extend([agent_type.title()] * len(utilities))\n",
    "    \n",
    "    df_utilities = pd.DataFrame({'Utility': utility_data, 'Agent Type': utility_labels})\n",
    "    \n",
    "    # Create grouped box plot\n",
    "    agent_types = list(agent_utilities.keys())\n",
    "    grouped_data = [agent_utilities[agent_type] for agent_type in agent_types]\n",
    "    \n",
    "    bp = ax4.boxplot(grouped_data, labels=[at.title() for at in agent_types], \n",
    "                   patch_artist=True)\n",
    "    \n",
    "    # Color the boxes\n",
    "    colors = ['lightblue', 'lightgreen', 'lightsalmon']\n",
    "    for patch, color in zip(bp['boxes'], colors):\n",
    "        patch.set_facecolor(color)\n",
    "    \n",
    "    ax4.set_xlabel('Agent Type')\n",
    "    ax4.set_ylabel('Utility')\n",
    "    ax4.set_title('Agent Utility Distribution')\n",
    "    ax4.grid(True, alpha=0.3)\n",
    "    \n",
    "    # Add statistics\n",
    "    for i, (agent_type, utilities) in enumerate(agent_utilities.items()):\n",
    "        mean_utility = np.mean(utilities)\n",
    "        ax4.text(i+1, mean_utility + max(utilities)*0.02, f'{mean_utility:.1f}', \n",
    "                ha='center', va='bottom', fontsize=9)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "# Create visualizations\n",
    "create_multi_agent_visualizations(ecosystem, simulation_history, emergent_analysis)"
   ]
  },
