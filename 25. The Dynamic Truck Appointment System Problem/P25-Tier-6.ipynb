    "def analyze_emergent_behavior(ecosystem: MultiAgentEcosystem, history: List[Dict]):\n",
    "    \"\"\"Analyze emergent behaviors and market dynamics\"\"\"\n",
    "    \n",
    "    print(\"\\n=== Emergent Behavior Analysis ===\")\n",
    "    \n",
    "    # Market price dynamics\n",
    "    broker_agents = [agent for agent in ecosystem.agents.values() if agent.agent_type == 'broker']\n",
    "    all_transactions = []\n",
    "    \n",
    "    for broker in broker_agents:\n",
    "        for cargo_type, transactions in broker.market_data.items():\n",
    "            for transaction in transactions:\n",
    "                all_transactions.append({\n",
    "                    'cargo_type': cargo_type,\n",
    "                    'price': transaction['price'],\n",
    "                    'timestamp': transaction['timestamp']\n",
    "                })\n",
    "    \n",
    "    if all_transactions:\n",
    "        print(\"\\nMarket Dynamics:\")\n",
    "        df_transactions = pd.DataFrame(all_transactions)\n",
    "        \n",
    "        for cargo_type in df_transactions['cargo_type'].unique():\n",
    "            cargo_data = df_transactions[df_transactions['cargo_type'] == cargo_type]\n",
    "            print(f\"  {cargo_type.title()}: Avg price = ${cargo_data['price'].mean():.2f}, \"\n",
    "                  f\"Range = ${cargo_data['price'].min():.2f}-${cargo_data['price'].max():.2f}\")\n",
    "    \n",
    "    # Appointment patterns\n",
    "    truck_agents = [agent for agent in ecosystem.agents.values() if agent.agent_type == 'truck']\n",
    "    appointment_times = []\n",
    "    urgency_appointments = defaultdict(list)\n",
    "    \n",
    "    for truck in truck_agents:\n",
    "        if truck.appointment:\n",
    "            appointment_times.append(truck.appointment['time_slot'])\n",
    "            urgency_appointments[truck.urgency_level].append(truck.appointment['time_slot'])\n",
    "    \n",
    "    print(\"\\nAppointment Patterns:\")\n",
    "    if appointment_times:\n",
    "        print(f\"  Average appointment time: {np.mean(appointment_times):.1f}\")\n",
    "        print(f\"  Time range: {min(appointment_times)} - {max(appointment_times)}\")\n",
    "        \n",
    "        for urgency in sorted(urgency_appointments.keys()):\n",
    "            times = urgency_appointments[urgency]\n",
    "            if times:\n",
    "                print(f\"  Urgency {urgency}: Avg time = {np.mean(times):.1f} ({len(times)} trucks)\")\n",
    "    \n",
    "    # System convergence\n",
    "    utilities_over_time = [state['total_utility'] for state in history]\n",
    "    appointments_over_time = [state['appointments_made'] for state in history]\n",
    "    \n",
    "    print(\"\\nSystem Convergence:\")\n",
    "    print(f\"  Initial utility: {utilities_over_time[0]:.1f}\")\n",
    "    print(f\"  Final utility: {utilities_over_time[-1]:.1f}\")\n",
    "    print(f\"  Utility improvement: {((utilities_over_time[-1] - utilities_over_time[0]) / utilities_over_time[0] * 100):.1f}%\")\n",
    "    \n",
    "    # Check for equilibrium\n",
    "    recent_utilities = utilities_over_time[-20:]  # Last 20 steps\n",
    "    utility_variance = np.var(recent_utilities)\n",
    "    \n",
    "    if utility_variance < 10:\n",
    "        print(f\"  System appears to be converging (variance: {utility_variance:.2f})\")\n",
    "    else:\n",
    "        print(f\"  System still adapting (variance: {utility_variance:.2f})\")\n",
    "    \n",
    "    return {\n",
    "        'market_transactions': all_transactions,\n",
    "        'appointment_patterns': appointment_times,\n",
    "        'convergence_metrics': {\n",
    "            'utility_improvement': (utilities_over_time[-1] - utilities_over_time[0]) / utilities_over_time[0],\n",
    "            'final_variance': utility_variance\n",
    "        }\n",
    "    }\n",
    "\n",
    "# Analyze emergent behavior\n",
    "emergent_analysis = analyze_emergent_behavior(ecosystem, simulation_history)"
   ]
