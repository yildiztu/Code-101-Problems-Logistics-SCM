    "@dataclass\n",
    "class AgentMessage:\n",
    "    \"\"\"Message passed between agents\"\"\"\n",
    "    sender_id: str\n",
    "    receiver_id: str\n",
    "    message_type: str  # 'request', 'bid', 'award', 'reject', 'inform'\n",
    "    content: Dict[str, Any]\n",
    "    timestamp: datetime\n",
    "    priority: int = 1  # 1=low, 2=medium, 3=high\n",
    "\n",
    "@dataclass\n",
    "class Contract:\n",
    "    \"\"\"Contract between agents for service provision\"\"\"\n",
    "    contract_id: str\n",
    "    client_agent: str\n",
    "    service_agent: str\n",
    "    service_type: str\n",
    "    terms: Dict[str, Any]\n",
    "    price: float\n",
    "    start_time: datetime\n",
    "    end_time: datetime\n",
    "    status: str  # 'pending', 'active', 'completed', 'cancelled'\n",
    "\n",
    "class Agent:\n",
    "    \"\"\"Base class for all agents in the ecosystem\"\"\"\n",
    "    \n",
    "    def __init__(self, agent_id: str, agent_type: str):\n",
    "        self.agent_id = agent_id\n",
    "        self.agent_type = agent_type\n",
    "        self.inbox = []\n",
    "        self.outbox = []\n",
    "        self.contracts = []\n",
    "        self.utility_history = []\n",
    "        self.neighbors = []  # Connected agents\n",
    "        \n",
    "    def send_message(self, receiver_id: str, message_type: str, \n",
    "                     content: Dict[str, Any], priority: int = 1):\n",
    "        \"\"\"Send message to another agent\"\"\"\n",
    "        message = AgentMessage(\n",
    "            sender_id=self.agent_id,\n",
    "            receiver_id=receiver_id,\n",
    "            message_type=message_type,\n",
    "            content=content,\n",
    "            timestamp=datetime.now(),\n",
    "            priority=priority\n",
    "        )\n",
    "        self.outbox.append(message)\n",
    "    \n",
    "    def receive_message(self, message: AgentMessage):\n",
    "        \"\"\"Receive message from another agent\"\"\"\n",
    "        self.inbox.append(message)\n",
    "    \n",
    "    def process_messages(self):\n",
    "        \"\"\"Process all messages in inbox\"\"\"\n",
    "        while self.inbox:\n",
    "            message = self.inbox.pop(0)\n",
    "            self.handle_message(message)\n",
    "    \n",
    "    def handle_message(self, message: AgentMessage):\n",
    "        \"\"\"Handle incoming message - to be overridden by subclasses\"\"\"\n",
    "        pass\n",
    "    \n",
    "    def calculate_utility(self) -> float:\n",
    "        \"\"\"Calculate current utility - to be overridden by subclasses\"\"\"\n",
    "        return 0.0\n",
    "\n",
    "class TruckAgent(Agent):\n",
    "    \"\"\"Agent representing a truck with appointment needs\"\"\"\n",
    "    \n",
    "    def __init__(self, agent_id: str, cargo_type: str, urgency_level: int, \n",
    "                 preferred_time_window: Tuple[int, int]):\n",
    "        super().__init__(agent_id, 'truck')\n",
    "        self.cargo_type = cargo_type\n",
    "        self.urgency_level = urgency_level  # 1=low, 2=medium, 3=high\n",
    "        self.preferred_time_window = preferred_time_window  # (start_hour, end_hour)\n",
    "        self.current_location = 'en_route'\n",
    "        self.budget = 100.0 + urgency_level * 50  # Higher urgency = higher budget\n",
    "        self.deadline = datetime.now() + timedelta(hours=random.uniform(2, 8))\n",
    "        self.appointment = None\n",
    "        \n",
    "    def handle_message(self, message: AgentMessage):\n",
    "        \"\"\"Handle messages from other agents\"\"\"\n",
    "        if message.message_type == 'award':\n",
    "            # Contract awarded - accept and confirm\n",
    "            contract_id = message.content['contract_id']\n",
    "            self.send_message(message.sender_id, 'accept', \n",
    "                           {'contract_id': contract_id}, priority=3)\n",
    "            self.appointment = message.content\n",
    "            \n",
    "        elif message.message_type == 'reject':\n",
    "            # Bid rejected - try alternative\n",
    "            self.seek_appointment()\n",
    "    \n",
    "    def seek_appointment(self):\n",
    "        \"\"\"Send appointment requests to terminal agents\"\"\"\n",
    "        # Create request with requirements\n",
    "        request_content = {\n",
    "            'cargo_type': self.cargo_type,\n",
    "            'urgency_level': self.urgency_level,\n",
    "            'preferred_window': self.preferred_time_window,\n",
    "            'deadline': self.deadline,\n",
    "            'max_price': self.budget\n",
    "        }\n",
    "        \n",
    "        # Send to all terminal resource agents\n",
    "        for neighbor in self.neighbors:\n",
    "            if neighbor.agent_type == 'terminal':\n",
    "                self.send_message(neighbor.agent_id, 'request', request_content, priority=self.urgency_level)\n",
    "    \n",
    "    def calculate_utility(self) -> float:\n",
    "        \"\"\"Calculate utility based on appointment satisfaction\"\"\"\n",
    "        if not self.appointment:\n",
    "            return -10.0  # Penalty for no appointment\n",
    "        \n",
    "        utility = 0.0\n",
    "        \n",
    "        # Time window preference\n",
    "        appt_time = self.appointment['time_slot']\n",
    "        if self.preferred_time_window[0] <= appt_time <= self.preferred_time_window[1]:\n",
    "            utility += 5.0\n",
    "        else:\n",
    "            # Penalty for outside preferred window\n",
    "            deviation = min(abs(appt_time - self.preferred_time_window[0]),\n",
    "                          abs(appt_time - self.preferred_time_window[1]))\n",
    "            utility -= deviation * 0.5\n",
    "        \n",
    "        # Budget satisfaction\n",
    "        price = self.appointment['price']\n",
    "        if price <= self.budget:\n",
    "            utility += (self.budget - price) * 0.1\n",
    "        else:\n",
    "            utility -= (price - self.budget) * 0.2\n",
    "        \n",
    "        # Urgency satisfaction\n",
    "        if self.urgency_level == 3 and appt_time <= 12:  # High urgency gets early slot\n",
    "            utility += 3.0\n",
    "        \n",
    "        return utility\n",
    "\n",
    "class TerminalAgent(Agent):\n",
    "    \"\"\"Agent representing terminal resources (docks, cranes)\"\"\"\n",
    "    \n",
    "    def __init__(self, agent_id: str, capacity: int, base_price: float):\n",
    "        super().__init__(agent_id, 'terminal')\n",
    "        self.capacity = capacity\n",
    "        self.base_price = base_price\n",
    "        self.current_load = 0\n",
    "        self.price_multiplier = 1.0\n",
    "        self.available_slots = list(range(1, 25))  # 24 time slots (hourly)\n",
    "        self.slot_assignments = {}  # slot -> truck_id\n",
    "        \n",
    "    def handle_message(self, message: AgentMessage):\n",
    "        \"\"\"Handle appointment requests and bids\"\"\"\n",
    "        if message.message_type == 'request':\n",
    "            # Evaluate request and send bid if suitable\n",
    "            self.evaluate_request(message)\n",
    "            \n",
    "        elif message.message_type == 'accept':\n",
    "            # Contract accepted - finalize appointment\n",
    "            contract_id = message.content['contract_id']\n",
    "            self.finalize_contract(contract_id)\n",
    "    \n",
    "    def evaluate_request(self, message: AgentMessage):\n",
    "        \"\"\"Evaluate appointment request and send bid if appropriate\"\"\"\n",
    "        request = message.content\n",
    "        \n",
    "        # Check if we can accommodate the request\n",
    "        if self.current_load >= self.capacity:\n",
    "            return  # At capacity\n",
    "        \n",
    "        # Find suitable time slot\n",
    "        preferred_window = request['preferred_window']\n",
    "        suitable_slots = [slot for slot in self.available_slots \n",
    "                          if preferred_window[0] <= slot <= preferred_window[1] and \n",
    "                          slot not in self.slot_assignments]\n",
    "        \n",
    "        if not suitable_slots:\n",
    "            return  # No suitable slots available\n",
    "        \n",
    "        # Calculate dynamic price based on demand and urgency\n",
    "        demand_factor = self.current_load / self.capacity\n",
    "        urgency_premium = request['urgency_level'] * 0.2\n",
    "        \n",
    "        # Dynamic pricing\n",
    "        price = self.base_price * (1 + demand_factor + urgency_premium)\n",
    "        \n",
    "        # Check if within budget\n",
    "        if price > request['max_price']:\n",
    "            return  # Too expensive\n",
    "        \n",
    "        # Select best slot\n",
    "        best_slot = min(suitable_slots)  # Earliest available slot\n",
    "        \n",
    "        # Send bid\n",
    "        bid_content = {\n",
    "            'truck_id': message.sender_id,\n",
    "            'time_slot': best_slot,\n",
    "            'price': price,\n",
    "            'services': ['loading', 'unloading', 'storage'],\n",
    "            'estimated_duration': 2  # hours\n",
    "        }\n",
    "        \n",
    "        self.send_message(message.sender_id, 'bid', bid_content, priority=2)\n",
    "    \n",
    "    def finalize_contract(self, contract_id: str):\n",
    "        \"\"\"Finalize an accepted contract\"\"\"\n",
    "        # Update slot assignments\n",
    "        for contract in self.contracts:\n",
    "            if contract.contract_id == contract_id:\n",
    "                slot = contract.terms['time_slot']\n",
    "                truck_id = contract.client_agent\n",
    "                self.slot_assignments[slot] = truck_id\n",
    "                self.current_load += 1\n",
    "                break\n",
    "    \n",
    "    def calculate_utility(self) -> float:\n",
    "        \"\"\"Calculate utility based on resource utilization and revenue\"\"\"\n",
    "        # Utilization component\n",
    "        utilization_utility = (self.current_load / self.capacity) * 10\n",
    "        \n",
    "        # Revenue component\n",
    "        total_revenue = sum(contract.price for contract in self.contracts \n",
    "                          if contract.status == 'active')\n",
    "        revenue_utility = total_revenue * 0.01\n",
    "        \n",
    "        # Load balancing component\n",
    "        if self.current_load > self.capacity * 0.9:\n",
    "            utilization_utility -= 5  # Penalty for over-utilization\n",
    "        \n",
    "        return utilization_utility + revenue_utility\n",
    "\n",
    "class BrokerAgent(Agent):\n",
    "    \"\"\"Agent that facilitates negotiations between trucks and terminals\"\"\"\n",
    "    \n",
    "    def __init__(self, agent_id: str):\n",
    "        super().__init__(agent_id, 'broker')\n",
    "        self.market_data = defaultdict(list)\n",
    "        self.commission_rate = 0.05  # 5% commission\n",
    "        \n",
    "    def handle_message(self, message: AgentMessage):\n",
    "        \"\"\"Facilitate market transactions\"\"\"\n",
    "        if message.message_type == 'bid':\n",
    "            # Forward bid to truck with commission\n",
    "            bid = message.content.copy()\n",
    "            bid['original_price'] = bid['price']\n",
    "            bid['price'] = bid['price'] * (1 + self.commission_rate)\n",
    "            bid['broker_id'] = self.agent_id\n",
    "            \n",
    "            self.send_message(message.sender_id, 'bid', bid, priority=2)\n",
    "            \n",
    "        elif message.message_type == 'accept':\n",
    "            # Process contract completion\n",
    "            self.process_contract_completion(message.content)\n",
    "    \n",
    "    def process_contract_completion(self, contract_info: Dict):\n",
    "        \"\"\"Process completed contract and update market data\"\"\"\n",
    "        price = contract_info.get('price', 0)\n",
    "        cargo_type = contract_info.get('cargo_type', 'unknown')\n",
    "        \n",
    "        # Record market data\n",
    "        self.market_data[cargo_type].append({\n",
    "            'price': price,\n",
    "            'timestamp': datetime.now()\n",
    "        })\n",
    "    \n",
    "    def calculate_utility(self) -> float:\n",
    "        \"\"\"Calculate utility based on commission earnings\"\"\"\n",
    "        total_commission = 0\n",
    "        for cargo_type, transactions in self.market_data.items():\n",
    "            for transaction in transactions:\n",
    "                total_commission += transaction['price'] * self.commission_rate\n",
    "        \n",
    "        return total_commission * 0.1  # Scale utility\n",
    "\n",
    "class MultiAgentEcosystem:\n",
    "    \"\"\"Ecosystem managing all agents and their interactions\"\"\"\n",
    "    \n",
    "    def __init__(self, num_trucks: int = 20, num_terminals: int = 4, num_brokers: int = 2):\n",
    "        self.agents = {}\n",
    "        self.message_bus = []\n",
    "        self.time_step = 0\n",
    "        self.system_history = []\n",
    "        \n",
    "        # Create agents\n",
    "        self._create_agents(num_trucks, num_terminals, num_brokers)\n",
    "        self._establish_connections()\n",
    "    \n",
    "    def _create_agents(self, num_trucks: int, num_terminals: int, num_brokers: int):\n",
    "        \"\"\"Create all agents in the ecosystem\"\"\"\n",
    "        \n",
    "        # Create truck agents\n",
    "        cargo_types = ['container', 'bulk', 'refrigerated', 'hazardous']\n",
    "        for i in range(num_trucks):\n",
    "            truck = TruckAgent(\n",
    "                agent_id=f\"Truck_{i+1:03d}\",\n",
    "                cargo_type=random.choice(cargo_types),\n",
    "                urgency_level=random.choices([1, 2, 3], weights=[0.6, 0.3, 0.1])[0],\n",
    "                preferred_time_window=(random.randint(6, 10), random.randint(14, 18))\n",
    "            )\n",
    "            self.agents[truck.agent_id] = truck\n",
    "        \n",
    "        # Create terminal agents\n",
    "        for i in range(num_terminals):\n",
    "            terminal = TerminalAgent(\n",
    "                agent_id=f\"Terminal_{i+1}\",\n",
    "                capacity=random.randint(8, 15),\n",
    "                base_price=random.uniform(80, 120)\n",
    "            )\n",
    "            self.agents[terminal.agent_id] = terminal\n",
    "        \n",
    "        # Create broker agents\n",
    "        for i in range(num_brokers):\n",
    "            broker = BrokerAgent(agent_id=f\"Broker_{i+1}\")\n",
    "            self.agents[broker.agent_id] = broker\n",
    "    \n",
    "    def _establish_connections(self):\n",
    "        \"\"\"Establish communication connections between agents\"\"\"\n",
    "        for agent_id, agent in self.agents.items():\n",
    "            # Connect to all other agents (fully connected network)\n",
    "            agent.neighbors = [a for a in self.agents.values() if a.agent_id != agent_id]\n",
    "    \n",
    "    def step(self):\n",
    "        \"\"\"Execute one time step of the ecosystem\"\"\"\n",
    "        self.time_step += 1\n",
    "        \n",
    "        # Trucks seeking appointments\n",
    "        for agent in self.agents.values():\n",
    "            if agent.agent_type == 'truck' and not agent.appointment:\n",
    "                if self.time_step % 5 == 0:  # Seek every 5 steps\n",
    "                    agent.seek_appointment()\n",
    "        \n",
    "        # Process all messages\n",
    "        self._deliver_messages()\n",
    "        \n",
    "        # Agents process their messages\n",
    "        for agent in self.agents.values():\n",
    "            agent.process_messages()\n",
    "        \n",
    "        # Record system state\n",
    "        self._record_system_state()\n",
    "    \n",
    "    def _deliver_messages(self):\n",
    "        \"\"\"Deliver messages from outboxes to inboxes\"\"\"\n",
    "        for agent in self.agents.values():\n",
    "            while agent.outbox:\n",
    "                message = agent.outbox.pop(0)\n",
    "                if message.receiver_id in self.agents:\n",
    "                    self.agents[message.receiver_id].receive_message(message)\n",
    "                    self.message_bus.append(message)\n",
    "    \n",
    "    def _record_system_state(self):\n",
    "        \"\"\"Record current system state for analysis\"\"\"\n",
    "        state = {\n",
    "            'time_step': self.time_step,\n",
    "            'total_utility': sum(agent.calculate_utility() for agent in self.agents.values()),\n",
    "            'appointments_made': sum(1 for agent in self.agents.values() \n",
    "                                  if agent.agent_type == 'truck' and agent.appointment),\n",
    "            'total_trucks': sum(1 for agent in self.agents.values() if agent.agent_type == 'truck'),\n",
    "            'total_terminals': sum(1 for agent in self.agents.values() if agent.agent_type == 'terminal'),\n",
    "            'avg_terminal_utilization': np.mean([agent.current_load / agent.capacity \n",
    "                                             for agent in self.agents.values() \n",
    "                                             if agent.agent_type == 'terminal']),\n",
    "            'message_count': len(self.message_bus)\n",
    "        }\n",
    "        self.system_history.append(state)\n",
    "    \n",
    "    def run_simulation(self, num_steps: int = 100):\n",
    "        \"\"\"Run the multi-agent simulation\"\"\"\n",
    "        print(f\"Running Multi-Agent Ecosystem simulation for {num_steps} steps...\")\n",
    "        \n",
    "        for step in range(num_steps):\n",
    "            self.step()\n",
    "            \n",
    "            if (step + 1) % 20 == 0:\n",
    "                state = self.system_history[-1]\n",
    "                print(f\"  Step {step+1}/{num_steps}: {state['appointments_made']}/{state['total_trucks']} appointments, \"\n",
    "                      f\"Avg utilization: {state['avg_terminal_utilization']:.2%}\")\n",
    "        \n",
    "        return self.system_history"
   ]
