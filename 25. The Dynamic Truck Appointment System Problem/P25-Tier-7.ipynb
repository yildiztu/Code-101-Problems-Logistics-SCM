    "@dataclass\n",
    "class TruckAppointment:\n",
    "    \"\"\"Represents a truck appointment request\"\"\"\n",
    "    appointment_id: str\n",
    "    truck_id: str\n",
    "    customer_id: str\n",
    "    cargo_type: str\n",
    "    urgency_level: int  # 1=low, 2=medium, 3=high\n",
    "    current_slot: int\n",
    "    requested_slot: Optional[int] = None\n",
    "    special_requirements: List[str] = field(default_factory=list)\n",
    "    relationship_priority: str = 'standard'  # 'standard', 'premium', 'strategic'\n",
    "    deadline: datetime = field(default_factory=lambda: datetime.now() + timedelta(hours=4))\n",
    "\n",
    "@dataclass\n",
    "class AIRecommendation:\n",
    "    \"\"\"AI-generated recommendation with explanations\"\"\"\n",
    "    recommendation_id: str\n",
    "    appointment_id: str\n",
    "    action: str  # 'maintain', 'reschedule', 'prioritize', 'cancel'\n",
    "    recommended_slot: Optional[int]\n",
    "    confidence_score: float  # 0.0 to 1.0\n",
    "    reasoning: Dict[str, Any]\n",
    "    alternative_options: List[Dict[str, Any]]\n",
    "    expected_outcomes: Dict[str, float]\n",
    "    created_at: datetime = field(default_factory=datetime.now)\n",
    "\n",
    "@dataclass\n",
    "class HumanDecision:\n",
    "    \"\"\"Human decision on AI recommendation\"\"\"\n",
    "    decision_id: str\n",
    "    recommendation_id: str\n",
    "    action: str  # 'accept', 'reject', 'modify'\n",
    "    reasoning: str\n",
    "    contextual_factors: List[str]\n",
    "    final_slot: Optional[int]\n",
    "    confidence_in_decision: int  # 1-5 scale\n",
    "    decision_time: datetime = field(default_factory=datetime.now)\n",
    "\n",
    "@dataclass\n",
    "class DecisionOutcome:\n",
    "    \"\"\"Outcome of human-AI collaborative decision\"\"\"\n",
    "    outcome_id: str\n",
    "    appointment_id: str\n",
    "    final_action: str\n",
    "    final_slot: int\n",
    "    actual_cost: float\n",
    "    actual_wait_time: int\n",
    "    customer_satisfaction: int  # 1-5 scale\n",
    "    ai_accuracy: float  # How accurate AI prediction was\n",
    "    human_value_add: float  # Value added by human intervention\n",
    "    timestamp: datetime = field(default_factory=datetime.now)\n",
    "\n",
    "class ExplainableAI:\n",
    "    \"\"\"Explainable AI system for truck appointment management\"\"\"\n",
    "    \n",
    "    def __init__(self):\n",
    "        self.decision_history = []\n",
    "        self.learning_patterns = defaultdict(list)\n",
    "        self.confidence_threshold = 0.7\n",
    "        \n",
    "    def analyze_appointment(self, appointment: TruckAppointment, \n",
    "                           system_state: Dict[str, Any]) -> AIRecommendation:\n",
    "        \"\"\"Analyze appointment and generate explainable recommendation\"\"\"\n",
    "        \n",
    "        # Calculate factors for decision\n",
    "        factors = self._calculate_decision_factors(appointment, system_state)\n",
    "        \n",
    "        # Generate recommendation\n",
    "        action, recommended_slot = self._determine_action(appointment, factors)\n",
    "        \n",
    "        # Calculate confidence\n",
    "        confidence = self._calculate_confidence(factors)\n",
    "        \n",
    "        # Create reasoning explanation\n",
    "        reasoning = self._create_reasoning(factors)\n",
    "        \n",
    "        # Generate alternatives\n",
    "        alternatives = self._generate_alternatives(appointment, factors)\n",
    "        \n",
    "        # Predict outcomes\n",
    "        outcomes = self._predict_outcomes(action, recommended_slot, factors)\n",
    "        \n",
    "        recommendation = AIRecommendation(\n",
    "            recommendation_id=f\"AI_REC_{datetime.now().strftime('%Y%m%d_%H%M%S')}\",\n",
    "            appointment_id=appointment.appointment_id,\n",
    "            action=action,\n",
    "            recommended_slot=recommended_slot,\n",
    "            confidence_score=confidence,\n",
    "            reasoning=reasoning,\n",
    "            alternative_options=alternatives,\n",
    "            expected_outcomes=outcomes\n",
    "        )\n",
    "        \n",
    "        return recommendation\n",
    "    \n",
    "    def _calculate_decision_factors(self, appointment: TruckAppointment, \n",
    "                                system_state: Dict[str, Any]) -> Dict[str, Any]:\n",
    "        \"\"\"Calculate all factors influencing the decision\"\"\"\n",
    "        \n",
    "        factors = {\n",
    "            'urgency_score': appointment.urgency_level * 10,\n",
    "            'relationship_score': {'standard': 0, 'premium': 5, 'strategic': 10}[appointment.relationship_priority],\n",
    "            'slot_utilization': system_state.get('slot_utilization', {}).get(appointment.current_slot, 0.5),\n",
    "            'traffic_conditions': system_state.get('traffic_congestion', 0.3),\n",
    "            'weather_impact': system_state.get('weather_severity', 0.1),\n",
    "            'resource_availability': system_state.get('crane_availability', {}).get(appointment.current_slot, 0.8),\n",
    "            'time_pressure': max(0, (appointment.deadline - datetime.now()).total_seconds() / 3600 - 2) / 8,\n",
    "            'special_requirements': len(appointment.special_requirements) * 2,\n",
    "        }\n",
    "        \n",
    "        return factors\n",
    "    \n",
    "    def _determine_action(self, appointment: TruckAppointment, \n",
    "                        factors: Dict[str, Any]) -> Tuple[str, Optional[int]]:\n",
    "        \"\"\"Determine recommended action based on factors\"\"\"\n",
    "        \n",
    "        urgency = factors['urgency_score']\n",
    "        relationship = factors['relationship_score']\n",
    "        utilization = factors['slot_utilization']\n",
    "        time_pressure = factors['time_pressure']\n",
    "        \n",
    "        # Decision logic\n",
    "        if urgency >= 20 and time_pressure > 0.7:\n",
    "            # High urgency, time pressure - prioritize\n",
    "            if factors['resource_availability'] > 0.7:\n",
    "                best_slot = self._find_best_available_slot(appointment, factors)\n",
    "                return 'prioritize', best_slot\n",
    "            else:\n",
    "                return 'reschedule', appointment.current_slot + 1\n",
    "        \n",
    "        elif utilization > 0.8 and relationship < 5:\n",
    "            # High utilization, standard relationship - reschedule\n",
    "            best_slot = self._find_best_available_slot(appointment, factors)\n",
    "            return 'reschedule', best_slot\n",
    "        \n",
    "        elif time_pressure > 0.8:\n",
    "            # High time pressure - expedite\n",
    "            return 'prioritize', appointment.current_slot\n",
    "        \n",
    "        else:\n",
    "            # Maintain current schedule\n",
    "            return 'maintain', appointment.current_slot\n",
    "    \n",
    "    def _find_best_available_slot(self, appointment: TruckAppointment, \n",
    "                                 factors: Dict[str, Any]) -> int:\n",
    "        \"\"\"Find best available alternative slot\"\"\"\n",
    "        \n",
    "        # Simple heuristic: find slot with lowest utilization that meets requirements\n",
    "        available_slots = list(range(6, 24))  # Slots 6-23 (6 AM to 11 PM)\n",
    "        \n",
    "        best_slot = appointment.current_slot\n",
    "        best_score = -1\n",
    "        \n",
    "        for slot in available_slots:\n",
    "            slot_utilization = factors.get('slot_utilization', 0.5)\n",
    "            \n",
    "            # Score based on low utilization and time preference\n",
    "            time_preference = 1.0 if 9 <= slot <= 17 else 0.5  # Prefer business hours\n",
    "            score = (1 - slot_utilization) * time_preference\n",
    "            \n",
    "            if score > best_score:\n",
    "                best_score = score\n",
    "                best_slot = slot\n",
    "        \n",
    "        return best_slot\n",
    "    \n",
    "    def _calculate_confidence(self, factors: Dict[str, Any]) -> float:\n",
    "        \"\"\"Calculate confidence score for recommendation\"\"\"\n",
    "        \n",
    "        # Base confidence\n",
    "        confidence = 0.7\n",
    "        \n",
    "        # Adjust based on factor clarity\n",
    "        if factors['urgency_score'] >= 20:\n",
    "            confidence += 0.1  # High urgency increases confidence\n",
    "        \n",
    "        if factors['relationship_score'] >= 8:\n",
    "            confidence -= 0.1  # Strategic relationships require human judgment\n",
    "        \n",
    "        if factors['special_requirements'] > 0:\n",
    "            confidence -= 0.05 * factors['special_requirements']  # Special requirements reduce confidence\n",
    "        \n",
    "        # Weather and traffic uncertainty\n",
    "        if factors['weather_impact'] > 0.3 or factors['traffic_conditions'] > 0.6:\n",
    "            confidence -= 0.15  # External uncertainty reduces confidence\n",
    "        \n",
    "        return max(0.3, min(1.0, confidence))\n",
    "    \n",
    "    def _create_reasoning(self, factors: Dict[str, Any]) -> Dict[str, Any]:\n",
    "        \"\"\"Create explainable reasoning for the recommendation\"\"\"\n",
    "        \n",
    "        reasoning = {\n",
    "            'primary_factors': [],\n",
    "            'secondary_factors': [],\n",
    "            'risk_assessment': {},\n",
    "            'cost_benefit_analysis': {}\n",
    "        }\n",
    "        \n",
    "        # Primary factors\n",
    "        if factors['urgency_score'] >= 20:\n",
    "            reasoning['primary_factors'].append(\n",
    "                f\"High urgency level ({factors['urgency_score']:.1f}) requires priority handling\"\n",
    "            )\n",
    "        \n",
    "        if factors['slot_utilization'] > 0.8:\n",
    "            reasoning['primary_factors'].append(\n",
    "                f\"High slot utilization ({factors['slot_utilization']:.1%}) suggests rescheduling\"\n",
    "            )\n",
    "        \n",
    "        if factors['relationship_score'] >= 8:\n",
    "            reasoning['primary_factors'].append(\n",
    "                f\"Strategic customer relationship ({factors['relationship_score']}) requires special consideration\"\n",
    "            )\n",
    "        \n",
    "        # Secondary factors\n",
    "        if factors['traffic_conditions'] > 0.5:\n",
    "            reasoning['secondary_factors'].append(\n",
    "                f\"Traffic congestion ({factors['traffic_conditions']:.1%}) may impact delivery times\"\n",
    "            )\n",
    "        \n",
    "        if factors['weather_impact'] > 0.2:\n",
    "            reasoning['secondary_factors'].append(\n",
    "                f\"Weather conditions ({factors['weather_impact']:.1f}) affect operations\"\n",
    "            )\n",
    "        \n",
    "        # Risk assessment\n",
    "        reasoning['risk_assessment'] = {\n",
    "            'delay_probability': min(0.9, factors['traffic_conditions'] + factors['weather_impact']),\n",
    "            'customer_satisfaction_risk': max(0, (5 - factors['relationship_score']) / 5),\n",
    "            'deadline_miss_risk': factors['time_pressure']\n",
    "        }\n",
    "        \n",
    "        # Cost-benefit analysis\n",
    "        reasoning['cost_benefit_analysis'] = {\n",
    "            'estimated_savings': factors['urgency_score'] * 10 if factors['urgency_score'] >= 20 else 0,\n",
    "            'additional_costs': 50 if factors['relationship_score'] >= 8 else 0,\n",
    "            'efficiency_gain': (1 - factors['slot_utilization']) * 100,\n",
    "        }\n",
    "        \n",
    "        return reasoning\n",
    "    \n",
    "    def _generate_alternatives(self, appointment: TruckAppointment, \n",
    "                              factors: Dict[str, Any]) -> List[Dict[str, Any]]:\n",
    "        \"\"\"Generate alternative options for consideration\"\"\"\n",
    "        \n",
    "        alternatives = []\n",
    "        \n",
    "        # Alternative 1: Expedited processing\n",
    "        if factors['urgency_score'] >= 15:\n",
    "            alternatives.append({\n",
    "                'option': 'expedited_processing',\n",
    "                'description': 'Process with overtime costs for faster completion',\n",
    "                'additional_cost': 100,\n",
    "                'time_savings': 2,  # hours\n",
    "                'confidence': 0.8\n",
    "            })\n",
    "        \n",
    "        # Alternative 2: Alternative slot\n",
    "        alternative_slot = self._find_best_available_slot(appointment, factors)\n",
    "        if alternative_slot != appointment.current_slot:\n",
    "            alternatives.append({\n",
    "                'option': 'alternative_slot',\n",
    "                'description': f'Reschedule to slot {alternative_slot}',\n",
    "                'additional_cost': 25,\n",
    "                'time_impact': abs(alternative_slot - appointment.current_slot) * 0.5,\n",
    "                'confidence': 0.7\n",
    "            })\n",
    "        \n",
    "        # Alternative 3: Priority service\n",
    "        if factors['relationship_score'] >= 5:\n",
    "            alternatives.append({\n",
    "                'option': 'priority_service',\n",
    "                'description': 'Provide priority processing with premium service',\n",
    "                'additional_cost': 75,\n",
    "                'service_improvement': 0.3,\n",
    "                'confidence': 0.6\n",
    "            })\n",
    "        \n",
    "        return alternatives\n",
    "    \n",
    "    def _predict_outcomes(self, action: str, slot: int, factors: Dict[str, Any]) -> Dict[str, float]:\n",
    "        \"\"\"Predict expected outcomes of the recommendation\"\"\"\n",
    "        \n",
    "        outcomes = {\n",
    "            'estimated_cost': 50.0,  # Base cost\n",
    "            'estimated_wait_time': 30,  # Base wait time in minutes\n",
    "            'customer_satisfaction': 3.5,  # Base satisfaction\n",
    "            'efficiency_score': 0.7,  # Base efficiency\n",
    "        }\n",
    "        \n",
    "        # Adjust outcomes based on action\n",
    "        if action == 'prioritize':\n",
    "            outcomes['estimated_cost'] += 25  # Priority service cost\n",
    "            outcomes['estimated_wait_time'] -= 15  # Faster processing\n",
    "            outcomes['customer_satisfaction'] += 1.0  # Better service\n",
    "            outcomes['efficiency_score'] -= 0.1  # Slightly less efficient\n",
    "        \n",
    "        elif action == 'reschedule':\n",
    "            outcomes['estimated_cost'] += 10  # Rescheduling cost\n",
    "            outcomes['estimated_wait_time'] += 10  # Longer wait due to reschedule\n",
    "            outcomes['customer_satisfaction'] -= 0.5  # Inconvenience\n",
    "            outcomes['efficiency_score'] += 0.1  # Better efficiency\n",
    "        \n    \n",
    "        # Adjust based on factors\n",
    "        if factors['relationship_score'] >= 8:\n",
    "            outcomes['customer_satisfaction'] += 0.5  # Strategic customers\n",
    "        \n",
    "        if factors['urgency_score'] >= 20:\n",
    "            outcomes['customer_satisfaction'] -= 0.3 if action != 'prioritize' else 0.5\n",
    "        \n",
    "        return outcomes\n",
    "    \n",
    "    def learn_from_outcome(self, recommendation: AIRecommendation, \n",
    "                           decision: HumanDecision, outcome: DecisionOutcome):\n",
    "        \"\"\"Learn from human-AI collaborative outcomes\"\"\"\n",
    "        \n",
    "        # Record the interaction\n    \n",
    "        interaction = {\n",
    "            'timestamp': decision.decision_time,\n",
    "            'recommendation_confidence': recommendation.confidence_score,\n",
    "            'human_action': decision.action,\n",
    "            'human_reasoning': decision.reasoning,\n",
    "            'contextual_factors': decision.contextual_factors,\n",
    "            'actual_outcome': {\n",
    "                'cost': outcome.actual_cost,\n",
    "                'satisfaction': outcome.customer_satisfaction,\n",
    "                'efficiency': outcome.efficiency_score\n",
    "            },\n",
    "            'predicted_outcome': recommendation.expected_outcomes,\n",
    "            'ai_accuracy': outcome.ai_accuracy,\n",
    "            'human_value_add': outcome.human_value_add\n",
    "        }\n",
    "        \n",
    "        self.decision_history.append(interaction)\n",
    "        \n",
    "        # Update learning patterns\n",
    "        self._update_learning_patterns(interaction)\n",
    "    \n",
    "    def _update_learning_patterns(self, interaction: Dict[str, Any]):\n",
    "        \"\"\"Update learning patterns based on interaction\"\"\"\n",
    "        \n",
    "        # Learn from contextual factors\n",
    "        for factor in interaction['contextual_factors']:\n",
    "            self.learning_patterns[factor].append({\n",
    "                'human_value_add': interaction['human_value_add'],\n",
    "                'ai_accuracy': interaction['ai_accuracy'],\n",
    "                'timestamp': interaction['timestamp']\n",
    "            })\n",
    "        \n",
    "        # Learn from confidence accuracy\n",
    "        confidence = interaction['recommendation_confidence']\n",
    "        accuracy = interaction['ai_accuracy']\n",
    "        \n",
    "        if confidence > 0.8 and accuracy < 0.6:\n",
    "            # High confidence but low accuracy - reduce confidence in similar situations\n    \n",
    "class HumanAISystem:\n",
    "    \"\"\"Human-AI Symbiotic Partnership System\"\"\"\n",
    "    \n",
    "    def __init__(self, num_appointments: int = 50):\n",
    "        self.ai_system = ExplainableAI()\n",
    "        self.appointments = []\n",
    "        self.recommendations = []\n",
    "        self.human_decisions = []\n",
    "        self.outcomes = []\n",
    "        \n",
    "        # Create sample appointments\n",
    "        self._create_sample_appointments(num_appointments)\n",
    "    \n",
    "    def _create_sample_appointments(self, num_appointments: int):\n",
    "        \"\"\"Create sample truck appointments\"\"\"\n",
    "        \n",
    "        customers = ['Maersk', 'MSC', 'CMA CGM', 'Hapag-Lloyd', 'ONE', 'Cosco', 'Evergreen']\n",
    "        cargo_types = ['container', 'refrigerated', 'hazardous', 'bulk', 'project_cargo']\n",
    "        \n",
    "        for i in range(num_appointments):\n",
    "            appointment = TruckAppointment(\n",
    "                appointment_id=f\"APT_{i+1:03d}\",\n",
    "                truck_id=f\"T{i+1:03d}\",\n",
    "                customer_id=random.choice(customers),\n",
    "                cargo_type=random.choice(cargo_types),\n",
    "                urgency_level=random.choices([1, 2, 3], weights=[0.6, 0.3, 0.1])[0],\n",
    "                current_slot=random.randint(6, 23),\n",
    "                relationship_priority=random.choices(['standard', 'premium', 'strategic'], \n",
    "                                          weights=[0.7, 0.2, 0.1])[0]\n",
    "                special_requirements=random.sample(['temperature_control', 'hazardous_materials', \n",
    "                                                'oversized_cargo', 'time_critical'], \n",
    "                                                k=random.randint(0, 2))\n",
    "            )\n",
    "            \n",
    "            self.appointments.append(appointment)\n",
    "    \n",
    "    def process_appointment(self, appointment: TruckAppointment, \n",
    "                          system_state: Dict[str, Any]) -> Dict[str, Any]:\n",
    "        \"\"\"Process a single appointment through human-AI collaboration\"\"\"\n",
    "        \n",
    "        # Step 1: AI analyzes and recommends\n",
    "        recommendation = self.ai_system.analyze_appointment(appointment, system_state)\n",
    "        self.recommendations.append(recommendation)\n",
    "        \n",
    "        # Step 2: Human evaluates and decides\n",
    "        human_decision = self._human_evaluate_recommendation(recommendation, appointment)\n",
    "        self.human_decisions.append(human_decision)\n",
    "        \n",
    "        # Step 3: Implement decision and track outcome\n",
    "        outcome = self._implement_decision(appointment, human_decision)\n",
    "        self.outcomes.append(outcome)\n",
    "        \n",
    "        # Step 4: AI learns from outcome\n",
    "        self.ai_system.learn_from_outcome(recommendation, human_decision, outcome)\n",
    "        \n",
    "        return {\n",
    "            'appointment_id': appointment.appointment_id,\n",
    "            'ai_recommendation': recommendation,\n",
    "            'human_decision': human_decision,\n",
    "            'final_outcome': outcome\n",
    "        }\n",
    "    \n",
    "    def _human_evaluate_recommendation(self, recommendation: AIRecommendation, \n",
    "                                    appointment: TruckAppointment) -> HumanDecision:\n",
    "        \"\"\"Simulate human evaluation of AI recommendation\"\"\"\n",
    "        \n",
    "        # Human decision logic based on context and AI confidence\n",
    "        \n",
    "        # High confidence AI recommendations are usually accepted\n",
    "        if recommendation.confidence_score > 0.85:\n",
    "            action = 'accept'\n",
    "            reasoning = \"High confidence AI recommendation with clear reasoning\"\n",
    "            contextual_factors = ['AI confidence']\n",
    "        \n",
    "        # Strategic customers often require human consideration\n    ",
    "        elif appointment.relationship_priority == 'strategic' and random.random() < 0.7:\n",
    "            action = 'modify'\n",
    "            reasoning = \"Strategic customer relationship requires special consideration\"\n",
    "            contextual_factors = ['strategic_relationship', 'customer_loyalty']\n",
    "        \n",
    "        # Low confidence recommendations are reviewed carefully\n",
    "        elif recommendation.confidence_score < 0.5:\n",
    "            action = 'reject'\n",
    "            reasoning = \"Low confidence AI recommendation requires human judgment\"\n",
    "            contextual_factors = ['low_confidence', 'risk_assessment']\n",
    "        \n",
    "        else:\n",
    "            action = 'accept'\n",
    "            reasoning = \"AI recommendation aligns with operational requirements\"\n",
    "            contextual_factors = ['standard_procedure']\n",
    "        \n",
    "        # Final slot determination\n",
    "        if action == 'accept':\n",
    "            final_slot = recommendation.recommended_slot\n",
    "        elif action == 'modify':\n",
    "            # Human chooses alternative or maintains current\n",
    "            if random.random() < 0.5:\n",
    "                final_slot = appointment.current_slot  # Maintain current\n",
    "            else:\n",
    "                final_slot = recommendation.recommended_slot  # Accept AI recommendation\n",
    "        else:  # reject\n",
    "            final_slot = appointment.current_slot  # Maintain current\n",
    "        \n",
    "        return HumanDecision(\n",
    "            decision_id=f\"HUM_DEC_{datetime.now().strftime('%Y%m%d_%H%M%S')}\",\n",
    "            recommendation_id=recommendation.recommendation_id,\n",
    "            action=action,\n",
    "            reasoning=reasoning,\n",
    "            contextual_factors=contextual_factors,\n",
    "            final_slot=final_slot,\n",
    "            confidence_in_decision=random.randint(3, 5)\n",
    "        )\n",
    "    \n",
    "    def _implement_decision(self, appointment: TruckAppointment, \n",
    "                          decision: HumanDecision) -> DecisionOutcome:\n",
    "        \"\"\"Implement the human decision and track outcomes\"\"\"\n",
    "        \n",
    "        # Simulate actual costs and outcomes\n    ",
    "        base_cost = 50.0\n",
    "        \n",
    "        if decision.action == 'modify' and decision.final_slot != appointment.current_slot:\n",
    "            actual_cost = base_cost + 25  # Modification cost\n",
    "        elif decision.action == 'reject':\n",
    "            actual_cost = base_cost  # No change\n",
    "        else:\n",
    "            actual_cost = base_cost\n",
    "        \n",
    "        # Calculate wait time\n",
    "        if decision.final_slot <= 12:  # Morning slot\n",
    "            actual_wait_time = random.randint(15, 30)\n",
    "        else:  # Afternoon/evening slot\n",
    "            actual_wait_time = random.randint(30, 60)\n",
    "        \n",
    "        # Customer satisfaction based on handling\n",
    "        if appointment.relationship_priority == 'strategic' and decision.action == 'accept':\n",
    "            customer_satisfaction = 5  # Excellent\n",
    "        elif appointment.urgency_level == 3 and decision.action == 'prioritize':\n",
    "            customer_satisfaction = 5  # Excellent\n",
    "        elif decision.action == 'reject':\n",
    "            customer_satisfaction = 2  # Poor\n",
    "        else:\n",
    "            customer_satisfaction = 4  # Good\n",
    "        \n",
    "        # Calculate AI accuracy\n",
    "        ai_outcome_cost = recommendation.expected_outcomes.get('estimated_cost', base_cost) if 'recommendation' in locals() else base_cost\n",
    "        ai_accuracy = max(0, 1 - abs(actual_cost - ai_outcome_cost) / ai_outcome_cost)\n",
    "        \n",
    "        # Calculate human value add\n",
    "        human_value_add = 0\n",
    "        if appointment.relationship_priority == 'strategic' and decision.action == 'modify':\n",
    "            human_value_add = 100  # Strategic relationship value\n",
    "        elif decision.action == 'modify' and customer_satisfaction > 4:\n",
    "            human_value_add = 50  # Improved satisfaction\n",
    "        \n",
    "        return DecisionOutcome(\n",
    "            outcome_id=f\"OUTCOME_{datetime.now().strftime('%Y%m%d_%H%M%S')}\",\n",
    "            appointment_id=appointment.appointment_id,\n",
    "            final_action=decision.action,\n",
    "            final_slot=decision.final_slot,\n",
    "            actual_cost=actual_cost,\n",
    "            actual_wait_time=actual_wait_time,\n",
    "            customer_satisfaction=customer_satisfaction,\n",
    "            ai_accuracy=ai_accuracy,\n",
    "            human_value_add=human_value_add\n",
    "        )\n",
    "    \n",
    "    def run_simulation(self, num_iterations: int = 100):\n",
    "        \"\"\"Run the human-AI collaboration simulation\"\"\"\n",
    "        \n",
    "        print(f\"Running Human-AI Symbiotic Partnership simulation for {num_iterations} appointments...\")\n",
    "        \n",
    "        simulation_results = []\n",
    "        system_state = {\n",
    "            'slot_utilization': {i: random.uniform(0.3, 0.9) for i in range(6, 24)},\n",
    "            'traffic_congestion': random.uniform(0.2, 0.8),\n",
    "            'weather_severity': random.uniform(0.0, 0.4),\n",
    "            'crane_availability': {i: random.uniform(0.5, 0.9) for i in range(6, 24)},\n",
    "        }\n",
    "        \n",
    "        for i in range(min(num_iterations, len(self.appointments)):\n",
    "            appointment = self.appointments[i]\n",
    "            \n",
    "            # Update system state\n",
    "            system_state['slot_utilization'][appointment.current_slot] = min(1.0, \n",
    "                system_state['slot_utilization'][appointment.current_slot] + 0.1)\n",
    "            \n",
    "            # Process appointment\n",
    "            result = self.process_appointment(appointment, system_state)\n",
    "            simulation_results.append(result)\n",
    "            \n",
    "            if (i + 1) % 20 == 0:\n",
    "                print(f\"  Processed {i+1}/{min(num_iterations, len(self.appointments)) appointments\")\n",
    "        \n",
    "        return simulation_results"
   ]
  },
