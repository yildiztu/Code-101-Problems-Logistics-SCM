    "            ax4.annotate(f'Improvement: {improvement:+.1f}%', \n    ",
    "                        xy=(len(moving_avg_accuracy), final_accuracy), \n    ",
    "                        xytext=(len(moving_avg_accuracy)*0.7, (initial_accuracy + final_accuracy)/2),\n    ",
    "                        fontsize=12, color='green', fontweight='bold')\n    ",
    "    else:\n    ",
    "        ax4.text(0.5, 0.5, 'Insufficient data for learning analysis', \n    ",
    "                ha='center', va='center', transform=ax4.transAxes)\n    ",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "# Create visualizations\n",
