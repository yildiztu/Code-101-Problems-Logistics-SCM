   "outputs": [],
   "source": [
    "# Import required libraries for mathematical optimization\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from itertools import product\n",
    "import pulp\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Set style for better visualizations\n",
    "plt.style.use('seaborn-v0_8')\n",
    "sns.set_palette(\"husl\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Data structures for the gate automation problem\n",
    "from dataclasses import dataclass\n",
    "from typing import List, Dict, Tuple\n",
    "\n",
    "@dataclass\n",
    "class Gate:\n",
    "    \"\"\"Represents a gate with its characteristics\"\"\"\n",
    "    id: int\n",
    "    demand_vehicles_per_hour: int\n",
    "    downtime_cost_per_hour: float\n",
    "    \n",
    "@dataclass\n",
    "class Sensor:\n",
    "    \"\"\"Represents a sensor type with its characteristics\"\"\"\n",
    "    id: str\n",
    "    monitoring_cost_per_hour: float\n",
    "    failure_rate_monitored: float\n",
    "    failure_rate_unmonitored: float\n",
    "    maintenance_interval_hours: int\n",
    "\n",
    "@dataclass\n",
    "class ProblemInstance:\n",
    "    \"\"\"Complete problem instance definition\"\"\"\n",
    "    gates: List[Gate]\n",
    "    sensors: List[Sensor]\n",
    "    time_periods: int\n",
    "    monitoring_budget_per_hour: float"
   ]
  },
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create the concrete example from the source text\n",
    "def create_concrete_example():\n",
    "    \"\"\"\n",
    "    Create the facility example from the source:\n",
    "    - 2 gates with different demand levels and downtime costs\n",
    "    - 3 sensor types with uniform costs and failure rates\n",
    "    - 24-hour operation period\n",
    "    \"\"\"\n",
    "    \n",
    "    # Define gates from the example\n",
    "    gates = [\n",
    "        Gate(id=1, demand_vehicles_per_hour=150, downtime_cost_per_hour=15000),\n",
    "        Gate(id=2, demand_vehicles_per_hour=100, downtime_cost_per_hour=10000)\n",
    "    ]\n",
    "    \n",
    "    # Define sensor types (photo-eye, ground loop, safety beam)\n",
    "    sensors = [\n",
    "        Sensor(id=\"photo_eye\", monitoring_cost_per_hour=5, \n",
    "              failure_rate_monitored=0.02, failure_rate_unmonitored=0.06,\n",
    "              maintenance_interval_hours=8),\n",
    "        Sensor(id=\"ground_loop\", monitoring_cost_per_hour=5,\n",
    "              failure_rate_monitored=0.02, failure_rate_unmonitored=0.06,\n",
    "              maintenance_interval_hours=12),\n",
    "        Sensor(id=\"safety_beam\", monitoring_cost_per_hour=5,\n",
    "              failure_rate_monitored=0.02, failure_rate_unmonitored=0.06,\n",
    "              maintenance_interval_hours=6)\n",
    "    ]\n",
    "    \n",
    "    return ProblemInstance(\n",
    "        gates=gates,\n",
    "        sensors=sensors,\n",
    "        time_periods=24,\n",
    "        monitoring_budget_per_hour=50  # Budget for monitoring all critical sensors\n",
    "    )\n",
    "\n",
    "# Create the problem instance\n",
    "instance = create_concrete_example()\n",
    "print(f\"Problem created: {len(instance.gates)} gates, {len(instance.sensors)} sensors, {instance.time_periods} periods\")\n",
    "print(f\"Total daily demand: {sum(g.demand_vehicles_per_hour for g in instance.gates) * instance.time_periods:,} vehicles\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class GateAutomationOptimizer:\n",
    "    \"\"\"\n",
    "    Mixed-Integer Programming optimizer for gate automation and damage detection\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self, instance: ProblemInstance):\n",
    "        self.instance = instance\n",
    "        self.model = None\n",
    "        self.solution = None\n",
    "        \n",
    "    def formulate_mip(self):\n",
    "        \"\"\"\n",
    "        Formulate the mixed-integer programming model\n",
    "        Based on the mathematical formulation in the source document\n",
    "        \"\"\"\n",
    "        # Create the optimization model\n",
    "        self.model = pulp.LpProblem(\"Gate_Automation_Optimization\", pulp.LpMinimize)\n",
    "        \n",
    "        # Decision variables\n",
    "        # x_{gst} = 1 if sensor s at gate g is monitored in period t\n",
    "        self.monitor = {}\n",
    "        for g, s, t in product(range(len(self.instance.gates)), \n",
    "                              range(len(self.instance.sensors)), \n",
    "                              range(self.instance.time_periods)):\n",
    "            self.monitor[(g, s, t)] = pulp.LpVariable(f\"monitor_{g}_{s}_{t}\", cat='Binary')\n",
    "        \n",
    "        # y_{gtf} = 1 if failure mode f occurs at gate g in period t\n",
    "        # Simplified: single failure mode per gate-sensor combination\n",
    "        self.failure = {}\n",
    "        for g, t in product(range(len(self.instance.gates)), range(self.instance.time_periods)):\n",
    "            self.failure[(g, t)] = pulp.LpVariable(f\"failure_{g}_{t}\", cat='Binary')\n",
    "        \n",
    "        # z_{gt} = 1 if gate g is operational in period t\n",
    "        self.operational = {}\n",
    "        for g, t in product(range(len(self.instance.gates)), range(self.instance.time_periods)):\n",
    "            self.operational[(g, t)] = pulp.LpVariable(f\"operational_{g}_{t}\", cat='Binary')\n",
    "        \n",
    "        # w_{gst} = sensor health index for sensor s at gate g in period t\n",
    "        self.health = {}\n",
    "        for g, s, t in product(range(len(self.instance.gates)), \n",
    "                              range(len(self.instance.sensors)), \n",
    "                              range(self.instance.time_periods)):\n",
    "            self.health[(g, s, t)] = pulp.LpVariable(f\"health_{g}_{s}_{t}\", lowBound=0, upBound=1)\n",
    "        \n",
    "        # Objective function: minimize total cost (monitoring + downtime)\n",
    "        total_monitoring_cost = pulp.lpSum([\n",
    "            self.instance.sensors[s].monitoring_cost_per_hour * self.monitor[(g, s, t)]\n",
    "            for g, s, t in product(range(len(self.instance.gates)), \n",
    "                                  range(len(self.instance.sensors)), \n",
    "                                  range(self.instance.time_periods))\n",
    "        ])\n",
    "        \n",
    "        total_downtime_cost = pulp.lpSum([\n",
    "            self.instance.gates[g].downtime_cost_per_hour * (1 - self.operational[(g, t)]) * \n",
    "            self.instance.gates[g].demand_vehicles_per_hour\n",
    "            for g, t in product(range(len(self.instance.gates)), range(self.instance.time_periods))\n",
    "        ])\n",
    "        \n",
    "        self.model += total_monitoring_cost + total_downtime_cost, \"Total_Cost\"\n",
    "        \n",
    "        # Constraints\n",
    "        \n",
    "        # 1. Sensor monitoring requirement: at least one sensor per gate per period\n",
    "        for g, t in product(range(len(self.instance.gates)), range(self.instance.time_periods)):\n",
    "            self.model += pulp.lpSum([self.monitor[(g, s, t)] \n",
    "                                   for s in range(len(self.instance.sensors))]) >= 1\n",
    "        \n",
    "        # 2. Monitoring budget constraint\n",
    "        for t in range(self.instance.time_periods):\n",
    "            monitoring_cost_t = pulp.lpSum([\n",
    "                self.instance.sensors[s].monitoring_cost_per_hour * self.monitor[(g, s, t)]\n",
    "                for g, s in product(range(len(self.instance.gates)), range(len(self.instance.sensors)))\n",
    "            ])\n",
    "            self.model += monitoring_cost_t <= self.instance.monitoring_budget_per_hour\n",
    "        \n",
    "        # 3. Gate operational status linked to failures\n",
    "        for g, t in product(range(len(self.instance.gates)), range(self.instance.time_periods)):\n",
    "            self.model += self.operational[(g, t)] <= 1 - pulp.lpSum([self.failure[(g, t, f)] \n",
    "                                                                for f in range(1)])  # Single failure mode\n",
    "        \n",
    "        # 4. Sensor health degradation: simplified model\n",
    "        for g, s, t in product(range(len(self.instance.gates)), \n",
    "                              range(len(self.instance.sensors)), \n",
    "                              range(self.instance.time_periods)):\n",
    "            if t == 0:\n",
    "                # Initial health is perfect\n",
    "                self.model += self.health[(g, s, t)] == 1.0\n",
    "            else:\n",
    "                # Health degrades based on monitoring and random failures\n",
    "                degradation = 0.01 * (1 - self.monitor[(g, s, t - 1)])  # Faster degradation if not monitored\n",
    "                self.model += self.health[(g, s, t)] <= self.health[(g, s, t-1)] - degradation\n",
    "                self.model += self.health[(g, s, t)] >= self.health[(g, s, t-1)] - 0.1  # Max degradation per period\n",
    "        \n",
    "        # 5. Sensor health bounds\n",
    "        for g, s, t in product(range(len(self.instance.gates)), \n",
    "                              range(len(self.instance.sensors)), \n",
    "                              range(self.instance.time_periods)):\n",
    "            self.model += self.health[(g, s, t)] >= 0\n",
    "            self.model += self.health[(g, s, t)] <= 1"
   ]
