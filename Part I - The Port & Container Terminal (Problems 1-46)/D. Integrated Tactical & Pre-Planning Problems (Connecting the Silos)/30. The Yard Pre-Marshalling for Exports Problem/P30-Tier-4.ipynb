    "        if (stack, tier) not in used_positions:\n",
    "            used_positions.add((stack, tier))\n",
    "            break\n",
    "    config3.append(Container(f'C{i+1}', i+1, stack, tier))\n",
    "test_configs.append(config3)\n",
    "\n",
    "# Run generalization test\n",
