    "class DQNAgent:\n",
    "    \"\"\"DQN Agent for pre-marshalling\"\"\"\n",
    "    \n",
    "    def __init__(self, environment: PreMarshallingEnvironment, config: DQNConfig):\n",
    "        self.env = environment\n",
    "        self.config = config\n",
    "        \n",
    "        # Action space (simplified - fixed size for demonstration)\n",
    "        self.action_size = 100  # Approximate maximum number of possible actions\n",
    "        \n",
    "        # DQN networks\n",
    "        self.dqn = DeepQNetwork(environment.state_shape, self.action_size, config)\n",
    "        \n",
    "        # Experience replay buffer\n",
    "        self.memory = deque(maxlen=config.memory_size)\n",
    "        \n",
    "        # Training metrics\n",
    "        self.training_history = {\n",
    "            'episode_rewards': [],\n",
    "            'episode_lengths': [],\n",
    "            'losses': [],\n",
    "            'epsilon_history': []\n",
    "        }\n",
    "        \n",
    "        # Exploration parameters\n",
    "        self.epsilon = config.epsilon_start\n",
    "        \n",
    "    def act(self, state: np.ndarray, valid_actions: List[Action]) -> Action:\n",
    "        \"\"\"Select action using epsilon-greedy policy\"\"\"\n",
    "        if not valid_actions:\n",
    "            return None\n",
    "        \n",
    "        # Epsilon-greedy action selection\n",
    "        if random.random() < self.epsilon:\n",
    "            # Random exploration\n",
    "            return random.choice(valid_actions)\n",
    "        else:\n",
    "            # Greedy action selection\n",
    "            q_values = self.dqn.predict(state)\n",
    "            \n",
    "            # Find best valid action\n",
    "            best_action = None\n",
    "            best_q_value = -float('inf')\n",
    "            \n",
    "            for action in valid_actions:\n",
    "                action_index = self.dqn._action_to_index(action)\n",
    "                if action_index < len(q_values) and q_values[action_index] > best_q_value:\n",
    "                    best_q_value = q_values[action_index]\n",
    "                    best_action = action\n",
    "            \n",
    "            return best_action if best_action else random.choice(valid_actions)\n",
    "    \n",
    "    def remember(self, experience: Experience):\n",
    "        \"\"\"Store experience in replay buffer\"\"\"\n",
    "        self.memory.append(experience)\n",
    "    \n",
    "    def replay(self) -> float:\n",
    "        \"\"\"Train model on replay buffer\"\"\"\n",
    "        if len(self.memory) < self.config.batch_size:\n",
    "            return 0.0\n",
    "        \n",
    "        return self.dqn.train(list(self.memory))\n",
    "    \n",
    "    def update_epsilon(self):\n",
    "        \"\"\"Update exploration rate\"\"\"\n",
    "        self.epsilon = max(self.config.epsilon_end, self.epsilon * self.config.epsilon_decay)\n",
    "    \n",
    "    def train(self, num_episodes: int) -> Dict[str, List]:\n",
    "        \"\"\"Train the agent\"\"\"\n",
    "        print(f\"Starting DQN training for {num_episodes} episodes...\")\n",
    "        \n",
    "        for episode in range(num_episodes):\n",
    "            state = self.env.reset()\n",
    "            total_reward = 0\n",
    "            episode_length = 0\n",
    "            done = False\n",
    "            \n",
    "            while not done:\n",
    "                # Get valid actions\n",
    "                valid_actions = self.env.get_valid_actions()\n",
    "                \n",
    "                if not valid_actions:\n",
    "                    break\n",
    "                \n",
    "                # Select action\n",
    "                action = self.act(state, valid_actions)\n",
    "                \n",
    "                if action is None:\n",
    "                    break\n",
    "                \n",
    "                # Execute action\n",
    "                next_state, reward, done, info = self.env.step(action)\n",
    "                \n",
    "                # Store experience\n",
    "                experience = Experience(state, action, reward, next_state, done)\n",
    "                self.remember(experience)\n",
    "                \n",
    "                # Update metrics\n",
    "                total_reward += reward\n",
    "                episode_length += 1\n",
    "                state = next_state\n",
    "                \n",
    "                # Train agent\n",
    "                loss = self.replay()\n",
    "                if loss > 0:\n",
    "                    self.training_history['losses'].append(loss)\n",
    "            \n",
    "            # Update exploration rate\n",
    "            self.update_epsilon()\n",
    "            \n",
    "            # Record episode metrics\n",
    "            self.training_history['episode_rewards'].append(total_reward)\n",
    "            self.training_history['episode_lengths'].append(episode_length)\n",
    "            self.training_history['epsilon_history'].append(self.epsilon)\n",
    "            \n",
    "            # Update target network\n",
    "            if episode % self.config.target_update_freq == 0:\n",
    "                self.dqn.update_target_network()\n",
    "            \n",
    "            # Print progress\n",
    "            if (episode + 1) % 100 == 0:\n",
    "                avg_reward = np.mean(self.training_history['episode_rewards'][-100:])\n",
    "                avg_length = np.mean(self.training_history['episode_lengths'][-100:])\n",
    "                print(f\"Episode {episode + 1}/{num_episodes}, \"\n",
    "                      f\"Avg Reward: {avg_reward:.2f}, \"\n",
    "                      f\"Avg Length: {avg_length:.1f}, \"\n",
    "                      f\"Epsilon: {self.epsilon:.3f}\")\n",
    "        \n",
    "        return self.training_history\n",
    "    \n",
    "    def evaluate(self, num_episodes: int = 10) -> Dict[str, float]:\n",
    "        \"\"\"Evaluate agent performance\"\"\"\n",
    "        total_rewards = []\n",
    "        total_moves = []\n",
    "        success_rate = 0\n",
    "        \n",
    "        original_epsilon = self.epsilon\n",
    "        self.epsilon = 0.0  # No exploration during evaluation\n",
    "        \n",
    "        for episode in range(num_episodes):\n",
    "            state = self.env.reset()\n",
    "            total_reward = 0\n",
    "            done = False\n",
    "            \n",
    "            while not done:\n",
    "                valid_actions = self.env.get_valid_actions()\n",
    "                if not valid_actions:\n",
    "                    break\n",
    "                \n",
    "                action = self.act(state, valid_actions)\n",
    "                if action is None:\n",
    "                    break\n",
    "                \n",
    "                next_state, reward, done, info = self.env.step(action)\n",
    "                total_reward += reward\n",
    "                state = next_state\n",
    "            \n",
    "            total_rewards.append(total_reward)\n",
    "            total_moves.append(info['moves'])\n",
    "            \n",
    "            if info['violations'] == 0:\n",
    "                success_rate += 1\n",
    "        \n",
    "        self.epsilon = original_epsilon  # Restore epsilon\n",
    "        \n",
    "        return {\n",
    "            'avg_reward': np.mean(total_rewards),\n",
    "            'avg_moves': np.mean(total_moves),\n",
    "            'success_rate': success_rate / num_episodes,\n",
    "            'reward_std': np.std(total_rewards)\n",
    "        }"
   ]
