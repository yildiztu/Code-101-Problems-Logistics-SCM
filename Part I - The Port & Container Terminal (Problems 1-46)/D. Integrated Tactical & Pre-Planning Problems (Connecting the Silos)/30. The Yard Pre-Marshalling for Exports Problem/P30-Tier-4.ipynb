    "\n",
    "# Simple greedy baseline\n",
    "def greedy_baseline(env: PreMarshallingEnvironment) -> Dict[str, Any]:\n",
    "    state = env.reset()\n",
    "    total_reward = 0\n",
    "    moves = 0\n",
    "    done = False\n",
    "    \n",
    "    while not done:\n",
    "        valid_actions = env.get_valid_actions()\n",
    "        if not valid_actions:\n",
    "            break\n",
    "        \n",
    "        # Simple greedy: choose action with smallest distance\n",
    "        best_action = min(valid_actions, key=lambda a: abs(a.from_stack - a.to_stack))\n",
    "        \n",
    "        next_state, reward, done, info = env.step(best_action)\n",
    "        total_reward += reward\n",
    "        moves += 1\n",
    "        state = next_state\n",
    "    \n",
    "    return {\n",
    "        'reward': total_reward,\n",
    "        'moves': moves,\n",
    "        'success': info['violations'] == 0,\n",
    "        'violations': info['violations']\n",
    "    }\n",
    "\n",
    "# Run baseline comparison\n",
    "baseline_results = []\n",
    "for _ in range(20):\n",
    "    result = greedy_baseline(env)\n",
