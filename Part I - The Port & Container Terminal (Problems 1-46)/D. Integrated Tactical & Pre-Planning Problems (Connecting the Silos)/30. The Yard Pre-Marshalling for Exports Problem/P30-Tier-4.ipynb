    "    Container('C', 3, 1, 0), Container('D', 4, 1, 1),\n",
    "    Container('E', 5, 2, 0), Container('F', 6, 2, 1)\n",
    "]\n",
    "test_configs.append(config2)\n",
    "\n",
    "# Configuration 3: Random arrangement\n",
    "config3 = []\n",
    "used_positions = set()\n",
    "for i in range(12):\n",
    "    while True:\n",
    "        stack = random.randint(0, 3)\n",
