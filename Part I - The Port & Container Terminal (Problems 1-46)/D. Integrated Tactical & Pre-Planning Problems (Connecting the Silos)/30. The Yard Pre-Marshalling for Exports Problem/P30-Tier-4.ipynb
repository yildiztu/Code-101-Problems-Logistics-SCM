    "    Container('G', 7, 2, 0), Container('H', 8, 2, 1), Container('I', 9, 2, 2),\n",
    "    Container('J', 10, 3, 0), Container('K', 11, 3, 1), Container('L', 12, 3, 2)\n",
    "]\n",
    "test_configs.append(config1)\n",
    "\n",
