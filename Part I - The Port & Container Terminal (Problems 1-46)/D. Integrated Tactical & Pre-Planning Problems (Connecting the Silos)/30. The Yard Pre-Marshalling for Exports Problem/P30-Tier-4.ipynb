    "class PreMarshallingEnvironment:\n",
    "    \"\"\"Environment for pre-marshalling reinforcement learning\"\"\"\n",
    "    \n",
    "    def __init__(self, stacks: int, tiers: int, containers: List[Container]):\n",
    "        self.stacks = stacks\n",
    "        self.tiers = tiers\n",
    "        self.initial_containers = containers.copy()\n",
    "        self.containers = containers.copy()\n",
    "        self.max_moves = len(containers) * 2  # Reasonable upper bound\n",
    "        self.move_count = 0\n",
    "        \n",
    "        # State space dimensions\n",
    "        self.state_shape = (stacks, tiers, 4)  # 4 feature channels\n",
    "        \n",
    "    def reset(self) -> np.ndarray:\n",
    "        \"\"\"Reset environment to initial state\"\"\"\n",
    "        self.containers = deepcopy(self.initial_containers)\n",
    "        self.move_count = 0\n",
    "        return self.get_state()\n",
    "    \n",
    "    def get_state(self) -> np.ndarray:\n",
    "        \"\"\"Get current state representation\"\"\"\n",
    "        state = np.zeros(self.state_shape)\n",
    "        \n",
    "        # Channel 0: Container presence (binary)\n",
    "        # Channel 1: Priority values (normalized)\n",
    "        # Channel 2: Moveable container mask (top containers only)\n",
    "        # Channel 3: Stack height encoding\n",
    "        \n",
    "        for container in self.containers:\n",
    "            if container.current_tier < self.tiers:\n",
    "                # Container presence\n",
    "                state[container.current_stack, container.current_tier, 0] = 1.0\n",
    "                \n",
    "                # Normalized priority (lower priority = higher value)\n",
    "                max_priority = max(c.priority for c in self.containers)\n",
    "                normalized_priority = (max_priority - container.priority + 1) / max_priority\n",
    "                state[container.current_stack, container.current_tier, 1] = normalized_priority\n",
    "                \n",
    "                # Check if container is moveable (top of its stack)\n",
    "                is_top = self.is_top_container(container)\n",
    "                if is_top:\n",
    "                    state[container.current_stack, container.current_tier, 2] = 1.0\n",
    "        \n",
    "        # Stack height encoding\n",
    "        for stack in range(self.stacks):\n",
    "            stack_height = self.get_stack_height(stack)\n",
    "            normalized_height = stack_height / self.tiers\n",
    "            for tier in range(self.tiers):\n",
    "                state[stack, tier, 3] = normalized_height\n",
    "        \n",
    "        return state\n",
    "    \n",
    "    def is_top_container(self, container: Container) -> bool:\n",
    "        \"\"\"Check if container is at the top of its stack\"\"\"\n",
    "        stack_containers = [c for c in self.containers if c.current_stack == container.current_stack]\n",
    "        if not stack_containers:\n",
    "            return False\n",
    "        max_tier = max(c.current_tier for c in stack_containers)\n",
    "        return container.current_tier == max_tier\n",
    "    \n",
    "    def get_stack_height(self, stack: int) -> int:\n",
    "        \"\"\"Get height of a stack\"\"\"\n",
    "        stack_containers = [c for c in self.containers if c.current_stack == stack]\n",
    "        return len(stack_containers)\n",
    "    \n",
    "    def get_valid_actions(self) -> List[Action]:\n",
    "        \"\"\"Get list of valid actions in current state\"\"\"\n",
    "        actions = []\n",
    "        \n",
    "        for container in self.containers:\n",
    "            if not self.is_top_container(container):\n",
    "                continue  # Can only move top containers\n",
    "            \n",
    "            # Try moving to all other stacks\n",
    "            for target_stack in range(self.stacks):\n",
    "                if target_stack == container.current_stack:\n",
    "                    continue\n",
    "                \n",
    "                # Check if target stack has space\n",
    "                target_height = self.get_stack_height(target_stack)\n",
    "                if target_height < self.tiers:\n",
    "                    action = Action(\n",
    "                        container_id=container.id,\n",
    "                        from_stack=container.current_stack,\n",
    "                        from_tier=container.current_tier,\n",
    "                        to_stack=target_stack,\n",
    "                        to_tier=target_height\n",
    "                    )\n",
    "                    actions.append(action)\n",
    "        \n",
    "        return actions\n",
    "    \n",
    "    def step(self, action: Action) -> Tuple[np.ndarray, float, bool, Dict]:\n",
    "        \"\"\"Execute action and return next state, reward, done, info\"\"\"\n",
    "        # Get current state for comparison\n",
    "        previous_violations = self.count_priority_violations()\n",
    "        \n",
    "        # Execute action\n",
    "        for container in self.containers:\n",
    "            if container.id == action.container_id:\n",
    "                container.current_stack = action.to_stack\n",
    "                container.current_tier = action.to_tier\n",
    "                break\n",
    "        \n",
    "        self.move_count += 1\n",
    "        \n",
    "        # Calculate reward\n",
    "        reward = self.calculate_reward(previous_violations, action)\n",
    "        \n",
    "        # Check if episode is done\n",
    "        done = self.is_done()\n",
    "        \n",
    "        # Get next state\n",
    "        next_state = self.get_state()\n",
    "        \n",
    "        # Additional info\n",
    "        info = {\n",
    "            'violations': self.count_priority_violations(),\n",
    "            'moves': self.move_count,\n",
    "            'action_valid': True\n",
    "        }\n",
    "        \n",
    "        return next_state, reward, done, info\n",
    "    \n",
    "    def count_priority_violations(self) -> int:\n",
    "        \"\"\"Count priority violations in current configuration\"\"\"\n",
    "        violations = 0\n",
    "        \n",
    "        # Create grid representation\n",
    "        grid = [[None for _ in range(self.tiers)] for _ in range(self.stacks)]\n",
    "        for container in self.containers:\n",
    "            if container.current_tier < self.tiers:\n",
    "                grid[container.current_stack][container.current_tier] = container.priority\n",
    "        \n",
    "        # Check each stack for priority violations\n",
    "        for stack in range(self.stacks):\n",
    "            for tier in range(self.tiers - 1):\n",
    "                lower_container = grid[stack][tier]\n",
    "                upper_container = grid[stack][tier + 1]\n",
    "                \n",
    "                if lower_container is not None and upper_container is not None:\n",
    "                    if lower_container > upper_container:  # Priority violation\n",
    "                        violations += 1\n",
    "        \n",
    "        return violations\n",
    "    \n",
    "    def calculate_reward(self, previous_violations: int, action: Action) -> float:\n",
    "        \"\"\"Calculate reward for action\"\"\"\n",
    "        current_violations = self.count_priority_violations()\n",
    "        \n",
    "        # Reward components\n",
    "        reward = 0.0\n",
    "        \n",
    "        # Violation reduction reward (most important)\n",
    "        violation_reduction = previous_violations - current_violations\n",
    "        reward += 50 * violation_reduction  # Positive reward for reducing violations\n",
    "        \n",
    "        # Move cost (small penalty for each move)\n",
    "        reward -= 10  # Base cost for any move\n",
    "        \n",
    "        # Distance penalty (prefer shorter moves)\n",
    "        distance = abs(action.from_stack - action.to_stack)\n",
    "        reward -= 2 * distance\n",
    "        \n",
    "        # Completion bonus\n",
    "        if current_violations == 0:\n",
    "            reward += 100  # Large bonus for eliminating all violations\n",
    "        \n",
    "        # Efficiency bonus (fewer moves is better)\n",
    "        if current_violations == 0 and self.move_count <= len(self.containers):\n",
    "            reward += 50  # Bonus for efficient solution\n",
    "        \n",
    "        return reward\n",
    "    \n",
    "    def is_done(self) -> bool:\n",
    "        \"\"\"Check if episode is done\"\"\"\n",
    "        # Done if no violations or exceeded move limit\n",
    "        violations = self.count_priority_violations()\n",
    "        return violations == 0 or self.move_count >= self.max_moves"
   ],
