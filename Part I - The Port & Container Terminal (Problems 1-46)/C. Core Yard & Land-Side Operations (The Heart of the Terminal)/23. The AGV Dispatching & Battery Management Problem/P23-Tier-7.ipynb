    "# Human-AI Symbiotic System data structures\n",
    "@dataclass\n",
    "class HumanOperator:\n",
    "    \"\"\"Human operator with expertise and decision-making capabilities\"\"\"\n",
    "    id: str\n",
    "    name: str\n",
    "    expertise_level: float  # 0.0 to 1.0\n",
    "    workload_capacity: int  # Maximum concurrent decisions\n",
    "    current_workload: int = 0\n",
    "    decisions_made: List[Dict[str, Any]] = field(default_factory=list)\n",
    "    override_history: List[Dict[str, Any]] = field(default_factory=list)\n",
    "    satisfaction_score: float = 0.8  # Initial satisfaction\n",
    "    \n",
    "@dataclass\n",
    "class AIDecision:\n",
    "    \"\"\"AI decision with explainable reasoning\"\"\"\n",
    "    decision_id: str\n",
    "    decision_type: str\n",
    "    recommended_action: str\n",
    "    confidence: float\n",
    "    reasoning: List[str]\n",
    "    supporting_data: Dict[str, Any]\n",
    "    alternatives: List[Dict[str, Any]] = field(default_factory=list)\n",
    "    requires_human_approval: bool = False\n",
    "    priority: str = \"medium\"  # low, medium, high, critical\n",
    "    \n",
    "@dataclass\n",
    "class HumanAICollaboration:\n",
    "    \"\"\"Record of human-AI collaboration event\"\"\"\n",
    "    timestamp: datetime\n",
    "    human_id: str\n",
    "    ai_decision_id: str\n",
    "    human_action: str  # approve, modify, override, delegate\n",
    "    final_decision: str\n",
    "    reasoning: str\n",
    "    outcome_score: float  # Measured after execution\n",
    "    \n",
    "@dataclass\n",
    "class AnomalyAlert:\n",
    "    \"\"\"Anomaly detected by AI requiring human attention\"\"\"\n",
    "    alert_id: str\n",
    "    anomaly_type: str\n",
    "    severity: str  # low, medium, high, critical\n",
    "    description: str\n",
    "    affected_assets: List[str]\n",
    "    recommended_actions: List[str]\n",
    "    confidence: float\n",
    "    timestamp: datetime = field(default_factory=datetime.now)\n",
    "    status: str = \"pending\"  # pending, acknowledged, resolved\n",
    "    \n",
    "@dataclass\n",
    "class StrategicGoal:\n",
    "    \"\"\"High-level strategic goal set by human operator\"\"\"\n",
    "    goal_id: str\n",
    "    description: str\n",
    "    priority: float  # 0.0 to 1.0\n",
    "    target_metrics: Dict[str, float]\n",
    "    time_horizon: timedelta\n",
    "    set_by: str\n",
    "    progress: float = 0.0\n",
    "    status: str = \"active\"  # active, completed, paused\n",
    "    \n",
    "@dataclass\n",
    "class LearningFeedback:\n",
    "    \"\"\"Feedback for system learning from human decisions\"\"\"\n",
