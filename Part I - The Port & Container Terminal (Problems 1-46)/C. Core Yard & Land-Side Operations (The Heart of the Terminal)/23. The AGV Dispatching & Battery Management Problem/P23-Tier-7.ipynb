    "            if human_action == 'approve':\n",
    "                human_approved_decisions += 1\n",
    "            elif human_action == 'modify':\n",
    "                human_modified_decisions += 1\n",
    "            elif human_action == 'override':\n",
    "                human_override_decisions += 1\n",
    "    \n",
