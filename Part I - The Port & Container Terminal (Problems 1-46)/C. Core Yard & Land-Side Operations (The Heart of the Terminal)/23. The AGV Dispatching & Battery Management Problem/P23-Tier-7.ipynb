   "source": [
    "# Simulation Environment\n",
    "class HumanAISimulation:\n",
    "    \"\"\"Simulation environment for Human-AI Symbiotic System\"\"\"\n",
    "    \n",
    "    def __init__(self):\n",
    "        self.control_tower = HumanControlTower()\n",
    "        self.current_time = datetime.now()\n",
    "        self.simulation_step = 0\n",
    "        self.max_steps = 50\n",
    "        \n",
    "        # System state\n",
    "        self.agv_fleet = self._initialize_agv_fleet()\n",
    "        self.task_queue = []\n",
    "        self.system_metrics = {\n",
    "            'efficiency': 0.8,\n",
    "            'avg_battery': 75,\n",
    "            'congestion': 0.3,\n",
    "            'time_pressure': 0.5\n",
    "        }\n",
    "        \n",
    "        # Performance tracking\n",
    "        self.decision_history = []\n",
    "        self.performance_timeline = []\n",
    "        \n",
    "    def _initialize_agv_fleet(self) -> List[Dict[str, Any]]:\n",
    "        \"\"\"Initialize AGV fleet with varying conditions\"\"\"\n",
    "        fleet = []\n",
    "        for i in range(8):\n",
    "            fleet.append({\n",
    "                'id': f'AGV-{i+1}',\n",
    "                'battery': random.uniform(20, 100),\n",
    "                'status': random.choice(['idle', 'moving', 'charging', 'servicing']),\n",
    "                'location': (random.uniform(0, 10), random.uniform(0, 8)),\n",
    "                'current_task': None\n",
    "            })\n",
    "        return fleet\n",
    "    \n",
    "    def simulate_step(self):\n",
    "        \"\"\"Simulate one step of the human-AI system\"\"\"\n",
    "        self.simulation_step += 1\n",
    "        self.current_time += timedelta(minutes=5)\n",
    "        \n",
    "        print(f\"\\n=== Step {self.simulation_step} - {self.current_time.strftime('%H:%M')} ===\")\n",
    "        \n",
    "        # Update system state\n",
    "        self._update_system_state()\n",
    "        \n",
    "        # Generate tasks\n",
    "        if random.random() < 0.3:  # 30% chance of new tasks\n",
    "            self._generate_tasks()\n",
    "        \n",
    "        # Create situation data for AI analysis\n",
    "        situation_data = self._create_situation_data()\n",
    "        \n",
    "        # Process situation through control tower\n",
    "        result = self.control_tower.process_situation(situation_data)\n",
    "        \n",
    "        # Simulate decision execution\n",
    "        self._execute_decision(result)\n",
    "        \n",
    "        # Record decision\n",
    "        self.decision_history.append({\n",
    "            'step': self.simulation_step,\n",
    "            'timestamp': self.current_time,\n",
    "            'result': result\n",
    "        })\n",
    "        \n",
    "        # Update performance timeline\n",
    "        self._update_performance_timeline()\n",
    "        \n",
    "        # Print summary\n",
    "        self._print_step_summary(result)\n",
    "    \n",
    "    def _update_system_state(self):\n",
    "        \"\"\"Update AGV fleet and system metrics\"\"\"\n",
    "        \n",
    "        # Update AGV states\n",
    "        for agv in self.agv_fleet:\n",
    "            # Battery consumption\n",
    "            if agv['status'] in ['moving', 'servicing']:\n",
    "                agv['battery'] = max(0, agv['battery'] - random.uniform(1, 3))\n",
    "            elif agv['status'] == 'charging':\n",
    "                agv['battery'] = min(100, agv['battery'] + random.uniform(2, 5))\n",
    "            \n",
    "            # Random status changes\n",
    "            if random.random() < 0.1:\n",
    "                agv['status'] = random.choice(['idle', 'moving', 'servicing'])\n",
    "        \n",
    "        # Update system metrics\n",
    "        self.system_metrics['avg_battery'] = np.mean([agv['battery'] for agv in self.agv_fleet])\n",
    "        self.system_metrics['efficiency'] = max(0.4, min(0.95, \n",
    "            self.system_metrics['efficiency'] + random.uniform(-0.05, 0.05)))\n",
    "        self.system_metrics['congestion'] = max(0.1, min(0.9, \n",
    "            self.system_metrics['congestion'] + random.uniform(-0.1, 0.1)))\n",
    "        self.system_metrics['time_pressure'] = max(0.2, min(0.9, \n",
    "            self.system_metrics['time_pressure'] + random.uniform(-0.1, 0.1)))\n",
    "    \n",
    "    def _generate_tasks(self):\n",
    "        \"\"\"Generate new transport tasks\"\"\"\n",
    "        num_tasks = random.randint(1, 3)\n",
    "        \n",
    "        for i in range(num_tasks):\n",
    "            task = {\n",
    "                'id': f'TASK-{len(self.task_queue) + 1}',\n",
    "                'priority': random.uniform(0.5, 1.0),\n",
    "                'pickup': f'P{random.randint(1, 4)}',\n",
    "                'dropoff': f'D{random.randint(1, 4)}',\n",
    "                'deadline': self.current_time + timedelta(minutes=random.randint(20, 60))\n",
    "            }\n",
    "            self.task_queue.append(task)\n",
    "        \n",
    "        print(f\"Generated {num_tasks} new tasks. Total pending: {len(self.task_queue)}\")\n",
    "    \n",
    "    def _create_situation_data(self) -> Dict[str, Any]:\n",
    "        \"\"\"Create situation data for AI analysis\"\"\"\n",
    "        \n",
    "        low_battery_agvs = [agv['id'] for agv in self.agv_fleet if agv['battery'] < 25]\n",
    "        delayed_tasks = [task['id'] for task in self.task_queue \n",
    "                       if task['deadline'] < self.current_time + timedelta(minutes=15)]\n",
    "        \n",
    "        return {\n",
    "            'num_agvs': len(self.agv_fleet),\n",
    "            'num_tasks': len(self.task_queue),\n",
    "            'avg_battery': self.system_metrics['avg_battery'],\n",
    "            'efficiency': self.system_metrics['efficiency'],\n",
    "            'congestion': self.system_metrics['congestion'],\n",
    "            'time_pressure': self.system_metrics['time_pressure'],\n",
    "            'low_battery_agvs': low_battery_agvs,\n",
    "            'delayed_tasks': delayed_tasks,\n",
    "            'anomalies': [],\n",
    "            'goals': [goal.description for goal in self.control_tower.strategic_goals]\n",
    "        }\n",
    "    \n",
    "    def _execute_decision(self, result: Dict[str, Any]):\n",
    "        \"\"\"Simulate execution of the decision\"\"\"\n",
    "        \n",
    "        collaboration_type = result.get('collaboration_type', 'unknown')\n",
    "        \n",
    "        if collaboration_type == 'human_processed':\n",
    "            human_decision = result.get('human_decision', {})\n",
    "            action = human_decision.get('final_action', 'no_action')\n",
    "            \n",
    "            # Simulate human decision outcome\n",
    "            outcome_score = random.uniform(0.6, 1.0)  # Human decisions generally good\n",
    "            \n",
    "            # Apply decision effects\n",
    "            if 'optimize' in action:\n",
    "                self.system_metrics['efficiency'] = min(0.95, self.system_metrics['efficiency'] + 0.05)\n",
    "            elif 'charging' in action:\n",
    "                for agv in self.agv_fleet:\n",
    "                    if agv['battery'] < 30:\n",
    "                        agv['status'] = 'charging'\n",
    "            elif 'reroute' in action:\n",
    "                self.system_metrics['congestion'] = max(0.1, self.system_metrics['congestion'] - 0.1)\n",
    "            \n",
    "        elif collaboration_type == 'autonomous':\n",
    "            action = result.get('final_decision', 'no_action')\n",
    "            success = result.get('success', True)\n",
    "            \n",
    "            # Simulate autonomous decision outcome\n",
    "            outcome_score = 0.8 if success else 0.4\n",
    "            \n",
    "            # Apply decision effects\n",
    "            if success:\n",
    "                if 'optimize' in action:\n",
    "                    self.system_metrics['efficiency'] = min(0.95, self.system_metrics['efficiency'] + 0.03)\n",
    "                elif 'charging' in action:\n",
    "                    low_battery_agvs = [agv for agv in self.agv_fleet if agv['battery'] < 30]\n",
    "                    if low_battery_agvs:\n",
    "                        low_battery_agvs[0]['status'] = 'charging'\n",
    "        \n",
    "        # Process some tasks\n",
    "        if self.task_queue and random.random() < 0.2:\n",
    "            self.task_queue.pop(0)\n",
    "    \n",
    "    def _update_performance_timeline(self):\n",
    "        \"\"\"Update performance timeline for analysis\"\"\"\n",
    "        \n",
    "        self.performance_timeline.append({\n",
    "            'step': self.simulation_step,\n",
    "            'timestamp': self.current_time,\n",
    "            'efficiency': self.system_metrics['efficiency'],\n",
    "            'avg_battery': self.system_metrics['avg_battery'],\n",
    "            'congestion': self.system_metrics['congestion'],\n",
    "            'pending_tasks': len(self.task_queue),\n",
    "            'collaboration_score': self.control_tower.performance_metrics['collaboration_score']\n",
    "        })\n",
    "    \n",
    "    def _print_step_summary(self, result: Dict[str, Any]):\n",
    "        \"\"\"Print summary of current step\"\"\"\n",
    "        \n",
    "        collaboration_type = result.get('collaboration_type', 'unknown')\n",
    "        ai_decision = result.get('ai_decision')\n",
    "        \n",
    "        print(f\"  Collaboration Type: {collaboration_type}\")\n",
    "        \n",
    "        if ai_decision:\n",
    "            print(f\"  AI Recommendation: {ai_decision.recommended_action}\")\n",
    "            print(f\"  AI Confidence: {ai_decision.confidence:.1%}\")\n",
    "            print(f\"  Priority: {ai_decision.priority}\")\n",
    "        \n",
    "        if collaboration_type == 'human_processed':\n",
    "            human_decision = result.get('human_decision', {})\n",
    "            print(f\"  Human Action: {human_decision.get('action', 'unknown')}\")\n",
    "            print(f\"  Final Decision: {human_decision.get('final_action', 'unknown')}\")\n",
    "        \n",
    "        print(f\"  System Efficiency: {self.system_metrics['efficiency']:.1%}\")\n",
    "        print(f\"  Average Battery: {self.system_metrics['avg_battery']:.1f}%\")\n",
    "        print(f\"  Pending Tasks: {len(self.task_queue)}\")\n",
    "    \n",
    "    def run_simulation(self, steps=30):\n",
    "        \"\"\"Run the human-AI simulation\"\"\"\n",
    "        \n",
    "        print(\"=\"*60)\n",
    "        print(\"HUMAN-AI SYMBIOTIC SYSTEM SIMULATION\")\n",
    "        print(\"=\"*60)\n",
    "        \n",
    "        # Set initial strategic goals\n",
    "        self.control_tower.set_strategic_goal(\n",
    "            \"Maintain system efficiency above 85%\",\n",
    "            0.9,\n",
    "            {'efficiency': 0.85},\n",
    "            timedelta(hours=8),\n",
    "            \"HOP-1\"\n",
    "        )\n",
    "        \n",
    "        self.control_tower.set_strategic_goal(\n",
    "            \"Minimize battery-related disruptions\",\n",
    "            0.8,\n",
    "            {'low_battery_incidents': 2},\n",
    "            timedelta(hours=4),\n",
    "            \"HOP-2\"\n",
    "        )\n",
    "        \n",
    "        # Run simulation steps\n",
    "        for step in range(steps):\n",
    "            self.simulate_step()\n",
    "            \n",
    "            # Check termination conditions\n",
    "            if self.simulation_step >= self.max_steps:\n",
    "                break\n",
    "        \n",
    "        # Print final summary\n",
    "        self._print_final_summary()\n",
    "        \n",
    "        return self.performance_timeline\n",
    "    \n",
    "    def _print_final_summary(self):\n",
    "        \"\"\"Print final simulation summary\"\"\"\n",
    "        \n",
    "        print(\"\\n\" + \"=\"*60)\n",
    "        print(\"SIMULATION COMPLETE - FINAL RESULTS\")\n",
    "        print(\"=\"*60)\n",
    "        \n",
    "        # Get final status report\n",
    "        status = self.control_tower.get_status_report()\n",
    "        \n",
    "        print(\"\\nHuman Operator Performance:\")\n",
    "        for op_id, op_data in status['operators'].items():\n",
    "            print(f\"  {op_data['name']} ({op_id}):\")\n",
    "            print(f\"    Expertise: {op_data['expertise']:.1%}\")\n",
    "            print(f\"    Decisions Made: {op_data['decisions_made']}\")\n",
    "            print(f\"    AI Overrides: {op_data['overrides']}\")\n",
    "            print(f\"    Current Workload: {op_data['workload']}\")\n",
    "        \n",
    "        print(\"\\nAI System Performance:\")\n",
    "        ai_data = status['ai_system']\n",
    "        print(f\"  Decisions Made: {ai_data['decisions_made']}\")\n",
    "        print(f\"  Learning Entries: {ai_data['learning_entries']}\")\n",
    "        print(f\"  Pattern Recognition: {ai_data['pattern_recognition']:.1%}\")\n",
    "        \n",
    "        print(\"\\nOverall System Performance:\")\n",
    "        perf = status['performance']\n",
    "        total = perf['total_decisions']\n",
    "        print(f\"  Total Decisions: {total}\")\n",
    "        print(f\"  AI Autonomous: {perf['ai_autonomous']} ({perf['ai_autonomous']/total:.1%})\")\n",
    "        print(f\"  Human Overrides: {perf['human_overrides']} ({perf['human_overrides']/total:.1%})\")\n",
    "        print(f\"  Collaboration Score: {perf['collaboration_score']:.3f}\")\n",
    "        print(f\"  Learning Effectiveness: {perf['learning_effectiveness']:.3f}\")\n",
    "        \n",
    "        print(f\"\\nFinal System State:\")\n",
    "        print(f\"  System Efficiency: {self.system_metrics['efficiency']:.1%}\")\n",
    "        print(f\"  Average Battery: {self.system_metrics['avg_battery']:.1f}%\")\n",
    "        print(f\"  Congestion Level: {self.system_metrics['congestion']:.1%}\")\n",
    "        print(f\"  Pending Tasks: {len(self.task_queue)}\")\n",
    "    \n",
    "    def visualize_results(self):\n",
    "        \"\"\"Create comprehensive visualization of human-AI collaboration\"\"\"\n",
    "        \n",
    "        if not self.performance_timeline:\n",
    "            return None\n",
    "        \n",
    "        fig, axes = plt.subplots(2, 2, figsize=(16, 12))\n",
    "        fig.suptitle('Human-AI Symbiotic System - Performance Analysis', \n",
    "                     fontsize=14, fontweight='bold')\n",
    "        \n",
    "        # Extract timeline data\n",
    "        steps = [p['step'] for p in self.performance_timeline]\n",
    "        efficiency = [p['efficiency'] for p in self.performance_timeline]\n",
    "        battery = [p['avg_battery'] for p in self.performance_timeline]\n",
    "        congestion = [p['congestion'] for p in self.performance_timeline]\n",
    "        tasks = [p['pending_tasks'] for p in self.performance_timeline]\n",
    "        collaboration = [p['collaboration_score'] for p in self.performance_timeline]\n",
    "        \n",
    "        # Plot 1: System Efficiency and Collaboration Score\n",
    "        ax1 = axes[0, 0]\n",
    "        ax1_twin = ax1.twinx()\n",
    "        \n",
    "        line1 = ax1.plot(steps, efficiency, 'b-', linewidth=2, label='System Efficiency')\n",
    "        line2 = ax1_twin.plot(steps, collaboration, 'r-', linewidth=2, label='Collaboration Score')\n",
    "        \n",
    "        ax1.set_xlabel('Simulation Step')\n",
    "        ax1.set_ylabel('System Efficiency', color='blue')\n",
    "        ax1_twin.set_ylabel('Collaboration Score', color='red')\n",
    "        ax1.set_title('System Performance & Collaboration Quality')\n",
    "        ax1.grid(True, alpha=0.3)\n",
    "        \n",
    "        # Combined legend\n",
    "        lines = line1 + line2\n",
    "        labels = [l.get_label() for l in lines]\n",
    "        ax1.legend(lines, labels, loc='upper left')\n",
    "        \n",
    "        # Plot 2: Battery Levels and Congestion\n",
    "        ax2 = axes[0, 1]\n",
    "        ax2_twin = ax2.twinx()\n",
    "        \n",
    "        line1 = ax2.plot(steps, battery, 'g-', linewidth=2, label='Avg Battery Level')\n",
    "        line2 = ax2_twin.plot(steps, congestion, 'orange', linewidth=2, label='Congestion Level')\n",
    "        \n",
    "        ax2.set_xlabel('Simulation Step')\n",
    "        ax2.set_ylabel('Battery Level (%)', color='green')\n",
    "        ax2_twin.set_ylabel('Congestion Level', color='orange')\n",
    "        ax2.set_title('Battery Management & Traffic Control')\n",
    "        ax2.grid(True, alpha=0.3)\n",
    "        ax2.set_ylim(0, 100)\n",
    "        \n",
    "        # Combined legend\n",
    "        lines = line1 + line2\n",
    "        labels = [l.get_label() for l in lines]\n",
    "        ax2.legend(lines, labels, loc='upper left')\n",
    "        \n",
    "        # Plot 3: Decision Distribution\n",
    "        ax3 = axes[1, 0]\n",
    "        \n",
    "        # Count decision types\n",
    "        decision_types = {'Autonomous': 0, 'Human Approved': 0, 'Human Modified': 0, 'Human Override': 0}\n",
    "        \n",
    "        for decision in self.decision_history:\n",
    "            result = decision['result']\n",
    "            collab_type = result.get('collaboration_type', '')\n",
    "            \n",
    "            if collab_type == 'autonomous':\n",
    "                decision_types['Autonomous'] += 1\n",
    "            elif collab_type == 'human_processed':\n",
    "                human_action = result.get('human_decision', {}).get('action', '')\n",
    "                if human_action == 'approve':\n",
    "                    decision_types['Human Approved'] += 1\n",
    "                elif human_action == 'modify':\n",
    "                    decision_types['Human Modified'] += 1\n",
    "                elif human_action == 'override':\n",
    "                    decision_types['Human Override'] += 1\n",
    "        \n",
    "        categories = list(decision_types.keys())\n",
    "        values = list(decision_types.values())\n",
    "        colors = ['lightblue', 'lightgreen', 'yellow', 'salmon']\n",
    "        \n",
    "        bars = ax3.bar(categories, values, color=colors, alpha=0.7)\n",
    "        ax3.set_xlabel('Decision Type')\n",
    "        ax3.set_ylabel('Number of Decisions')\n",
    "        ax3.set_title('Decision Type Distribution')\n",
    "        ax3.tick_params(axis='x', rotation=45)\n",
    "        ax3.grid(True, alpha=0.3)\n",
    "        \n",
    "        # Add value labels on bars\n",
    "        for bar, value in zip(bars, values):\n",
    "            height = bar.get_height()\n",
    "            ax3.text(bar.get_x() + bar.get_width()/2., height,\n",
    "                   f'{value}', ha='center', va='bottom', fontweight='bold')\n",
    "        \n",
    "        # Plot 4: Task Queue Management\n",
    "        ax4 = axes[1, 1]\n",
    "        \n",
    "        ax4.plot(steps, tasks, 'purple', linewidth=2, marker='o', markersize=4)\n",
    "        ax4.set_xlabel('Simulation Step')\n",
    "        ax4.set_ylabel('Pending Tasks')\n",
    "        ax4.set_title('Task Queue Management')\n",
    "        ax4.grid(True, alpha=0.3)\n",
    "        ax4.fill_between(steps, 0, tasks, alpha=0.3, color='purple')\n",
    "        \n",
    "        plt.tight_layout()\n",
    "        plt.show()\n",
    "        \n",
    "        return fig"
