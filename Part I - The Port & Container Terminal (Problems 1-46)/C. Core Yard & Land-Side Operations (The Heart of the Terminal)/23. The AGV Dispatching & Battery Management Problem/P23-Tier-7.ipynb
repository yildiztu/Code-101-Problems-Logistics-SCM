    "# Human Control Tower\n",
    "class HumanControlTower:\n",
    "    \"\"\"Central hub for human-AI collaboration and decision management\"\"\"\n",
    "    \n",
    "    def __init__(self):\n",
    "        self.human_operators = {}\n",
    "        self.ai_system = ExplainableAI()\n",
    "        self.pending_decisions = deque()\n",
    "        self.collaboration_history = []\n",
    "        self.strategic_goals = []\n",
    "        self.active_alerts = []\n",
    "        self.metrics_history = []\n",
    "        \n",
    "        # Initialize human operators\n",
    "        self._initialize_operators()\n",
    "        \n",
    "        # Performance tracking\n",
    "        self.performance_metrics = {\n",
    "            'total_decisions': 0,\n",
    "            'human_overrides': 0,\n",
    "            'ai_autonomous': 0,\n",
    "            'collaboration_score': 0.8,\n",
    "            'anomaly_detection_rate': 0.9,\n",
    "            'learning_effectiveness': 0.7\n",
    "        }\n",
    "    \n",
    "    def _initialize_operators(self):\n",
    "        \"\"\"Initialize human operators with different expertise levels\"\"\"\n",
    "        operators = [\n",
    "            HumanOperator(\"HOP-1\", \"Sarah Chen\", 0.95, 5),  # Expert operator\n",
    "            HumanOperator(\"HOP-2\", \"Marcus Johnson\", 0.85, 4)  # Experienced operator\n",
    "        ]\n",
    "        \n",
    "        for op in operators:\n",
    "            self.human_operators[op.id] = op\n",
    "        \n",
    "        print(f\"Initialized {len(self.human_operators)} human operators\")\n",
    "    \n",
    "    def set_strategic_goal(self, description: str, priority: float, target_metrics: Dict[str, float], \n",
    "                          time_horizon: timedelta, operator_id: str):\n",
    "        \"\"\"Set a strategic goal for the system\"\"\"\n",
    "        \n",
    "        goal = StrategicGoal(\n",
    "            goal_id=f\"GOAL-{len(self.strategic_goals) + 1}\",\n",
    "            description=description,\n",
    "            priority=priority,\n",
    "            target_metrics=target_metrics,\n",
    "            time_horizon=time_horizon,\n",
    "            set_by=operator_id\n",
    "        )\n",
    "        \n",
    "        self.strategic_goals.append(goal)\n",
    "        print(f\"Strategic goal set: {description} by {operator_id}\")\n",
    "        \n",
    "        return goal\n",
    "    \n",
    "    def process_situation(self, situation_data: Dict[str, Any]) -> Dict[str, Any]:\n",
    "        \"\"\"Process current situation and coordinate human-AI decision making\"\"\"\n",
    "        \n",
    "        # AI analyzes situation\n",
    "        ai_decision = self.ai_system.analyze_situation(situation_data)\n",
    "        \n",
    "        # Detect anomalies\n",
    "        anomalies = self.ai_system.anomaly_detector.detect_anomalies(situation_data)\n",
    "        self.active_alerts.extend(anomalies)\n",
    "        \n",
    "        # Determine decision path\n",
    "        if ai_decision.requires_human_approval:\n",
    "            result = self._route_to_human(ai_decision, situation_data)\n",
    "        else:\n",
    "            result = self._execute_autonomous(ai_decision, situation_data)\n",
    "        \n",
    "        # Update metrics\n",
    "        self._update_metrics(ai_decision, result)\n",
    "        \n",
    "        return {\n",
    "            'ai_decision': ai_decision,\n",
    "            'anomalies': anomalies,\n",
    "            'final_decision': result,\n",
    "            'collaboration_type': 'human_required' if ai_decision.requires_human_approval else 'autonomous'\n",
    "        }\n",
    "    \n",
    "    def _route_to_human(self, ai_decision: AIDecision, situation_data: Dict[str, Any]) -> Dict[str, Any]:\n",
    "        \"\"\"Route decision to appropriate human operator\"\"\"\n",
    "        \n",
    "        # Select best available operator\n",
    "        selected_operator = self._select_operator(ai_decision)\n",
    "        \n",
    "        if not selected_operator:\n",
    "            # No available operators, queue decision\n",
    "            self.pending_decisions.append(ai_decision)\n",
    "            return {\n",
    "                'status': 'queued',\n",
    "                'reason': 'no_available_operator',\n",
    "                'decision': ai_decision\n",
    "            }\n",
    "        \n",
    "        # Simulate human decision process\n",
    "        human_decision = self._simulate_human_decision(selected_operator, ai_decision, situation_data)\n",
    "        \n",
    "        # Record collaboration\n",
    "        collaboration = HumanAICollaboration(\n",
    "            timestamp=datetime.now(),\n",
    "            human_id=selected_operator.id,\n",
    "            ai_decision_id=ai_decision.decision_id,\n",
    "            human_action=human_decision['action'],\n",
    "            final_decision=human_decision['final_action'],\n",
    "            reasoning=human_decision['reasoning'],\n",
    "            outcome_score=0.0  # Will be updated after execution\n",
    "        )\n",
    "        \n",
    "        self.collaboration_history.append(collaboration)\n",
    "        \n",
    "        return {\n",
    "            'status': 'human_processed',\n",
    "            'operator': selected_operator.id,\n",
    "            'human_decision': human_decision,\n",
    "            'collaboration': collaboration\n",
    "        }\n",
    "    \n",
    "    def _select_operator(self, ai_decision: AIDecision) -> Optional[HumanOperator]:\n",
    "        \"\"\"Select the best available human operator for this decision\"\"\"\n",
    "        \n",
    "        available_operators = [\n",
    "            op for op in self.human_operators.values() \n",
    "            if op.current_workload < op.workload_capacity\n",
    "        ]\n",
    "        \n",
    "        if not available_operators:\n",
    "            return None\n",
    "        \n",
    "        # Select operator with highest expertise for this decision type\n",
    "        best_operator = max(\n",
    "            available_operators, \n",
    "            key=lambda op: op.expertise_level * (1 - op.current_workload / op.workload_capacity)\n",
    "        )\n",
    "        \n",
    "        return best_operator\n",
    "    \n",
    "    def _simulate_human_decision(self, operator: HumanOperator, ai_decision: AIDecision, \n",
    "                                situation_data: Dict[str, Any]) -> Dict[str, Any]:\n",
    "        \n",
    "        # Increase operator workload\n",
    "        operator.current_workload += 1\n",
    "        \n",
    "        # Simulate human decision based on expertise and AI confidence\n",
    "        acceptance_probability = operator.expertise_level * ai_decision.confidence\n",
    "        \n",
    "        if random.random() < acceptance_probability:\n",
    "            # Human agrees with AI\n",
    "            action = 'approve'\n",
    "            final_action = ai_decision.recommended_action\n",
    "            reasoning = f\"Agreed with AI recommendation based on {ai_decision.confidence:.1%} confidence and clear reasoning.\"\n",
    "        else:\n",
    "            # Human modifies or overrides AI\n",
    "            if random.random() < 0.7:\n",
    "                action = 'modify'\n",
    "                # Select alternative from AI suggestions\n",
    "                if ai_decision.alternatives:\n",
    "                    alternative = random.choice(ai_decision.alternatives)\n",
    "                    final_action = alternative['action']\n",
    "                    reasoning = f\"Modified AI recommendation to better suit current conditions. Chose alternative with {alternative['confidence']:.1%} confidence.\"\n",
    "                else:\n",
    "                    final_action = ai_decision.recommended_action\n",
    "                    reasoning = \"Minor modification to AI recommendation.\"\n",
    "            else:\n",
    "                action = 'override'\n",
    "                final_action = 'manual_intervention_required'\n",
    "                reasoning = \"Overrode AI recommendation due to contextual factors not captured in the analysis.\"\n",
    "                \n",
    "                # Record override\n",
    "                operator.override_history.append({\n",
    "                    'timestamp': datetime.now(),\n",
    "                    'ai_decision': ai_decision.decision_id,\n",
    "                    'ai_recommendation': ai_decision.recommended_action,\n",
    "                    'human_decision': final_action,\n",
    "                    'reason': reasoning\n",
    "                })\n",
    "        \n",
    "        # Record decision\n",
    "        operator.decisions_made.append({\n",
    "            'timestamp': datetime.now(),\n",
    "            'ai_decision_id': ai_decision.decision_id,\n",
    "            'action': action,\n",
    "            'final_action': final_action,\n",
    "            'reasoning': reasoning\n",
    "        })\n",
    "        \n",
    "        # Decrease workload after decision\n",
    "        operator.current_workload = max(0, operator.current_workload - 1)\n",
    "        \n",
    "        return {\n",
    "            'action': action,\n",
    "            'final_action': final_action,\n",
    "            'reasoning': reasoning,\n",
    "            'operator_expertise': operator.expertise_level\n",
    "        }\n",
    "    \n",
    "    def _execute_autonomous(self, ai_decision: AIDecision, situation_data: Dict[str, Any]) -> Dict[str, Any]:\n",
    "        \"\"\"Execute AI decision autonomously\"\"\"\n",
    "        \n",
    "        # Simulate autonomous execution\n",
    "        execution_success = ai_decision.confidence > 0.7\n",
    "        \n",
    "        return {\n",
    "            'status': 'executed_autonomously',\n",
    "            'action': ai_decision.recommended_action,\n",
    "            'confidence': ai_decision.confidence,\n",
    "            'success': execution_success,\n",
    "            'execution_time': random.randint(1, 10)  # minutes\n",
    "        }\n",
    "    \n",
    "    def _update_metrics(self, ai_decision: AIDecision, result: Dict[str, Any]):\n",
    "        \"\"\"Update performance metrics\"\"\"\n",
    "        \n",
    "        self.performance_metrics['total_decisions'] += 1\n",
    "        \n",
    "        if result.get('status') == 'human_processed':\n",
    "            human_action = result.get('human_decision', {}).get('action', '')\n",
    "            if human_action == 'override':\n",
    "                self.performance_metrics['human_overrides'] += 1\n",
    "        elif result.get('status') == 'executed_autonomously':\n",
    "            self.performance_metrics['ai_autonomous'] += 1\n",
    "        \n",
    "        # Calculate collaboration score\n",
    "        total = self.performance_metrics['total_decisions']\n",
    "        if total > 0:\n",
    "            autonomous_ratio = self.performance_metrics['ai_autonomous'] / total\n",
    "            override_ratio = self.performance_metrics['human_overrides'] / total\n",
    "            \n",
    "            # Optimal balance: high autonomy, low overrides\n",
    "            self.performance_metrics['collaboration_score'] = autonomous_ratio * 0.7 + (1 - override_ratio) * 0.3\n",
    "    \n",
    "    def collect_feedback(self, collaboration_id: str, outcome_score: float, lesson: str):\n",
    "        \"\"\"Collect feedback on human-AI collaboration for learning\"\"\"\n",
    "        \n",
    "        # Find the collaboration\n",
    "        collaboration = None\n",
    "        for collab in self.collaboration_history:\n",
    "            if str(collab.timestamp) == collaboration_id:  # Simplified matching\n",
    "                collaboration = collab\n",
    "                break\n",
    "        \n",
    "        if collaboration:\n",
    "            collaboration.outcome_score = outcome_score\n",
    "            \n",
    "            # Create learning feedback\n",
    "            feedback = LearningFeedback(\n",
    "                feedback_id=f\"FEEDBACK-{len(self.ai_system.learning_database) + 1}\",\n",
    "                human_id=collaboration.human_id,\n",
    "                original_ai_recommendation=\"\",  # Would be populated from AI decision\n",
    "                human_decision=collaboration.final_decision,\n",
    "                decision_outcome=outcome_score,\n",
    "                lesson_learned=lesson\n",
    "            )\n",
    "            \n",
    "            self.ai_system.learn_from_feedback(feedback)\n",
    "            self.performance_metrics['learning_effectiveness'] = min(1.0, \n",
    "                self.performance_metrics['learning_effectiveness'] + 0.01)\n",
    "    \n",
    "    def get_status_report(self) -> Dict[str, Any]:\n",
    "        \"\"\"Get comprehensive status report of the human-AI system\"\"\"\n",
    "        \n",
    "        return {\n",
    "            'operators': {\n",
    "                op.id: {\n",
    "                    'name': op.name,\n",
    "                    'expertise': op.expertise_level,\n",
    "                    'workload': f\"{op.current_workload}/{op.workload_capacity}\",\n",
    "                    'decisions_made': len(op.decisions_made),\n",
    "                    'overrides': len(op.override_history)\n",
    "                } for op in self.human_operators.values()\n",
    "            },\n",
    "            'ai_system': {\n",
    "                'decisions_made': len(self.ai_system.decision_history),\n",
    "                'learning_entries': len(self.ai_system.learning_database),\n",
    "                'pattern_recognition': self.ai_system.pattern_recognition_accuracy\n",
    "            },\n",
    "            'performance': self.performance_metrics,\n",
    "            'active_alerts': len(self.active_alerts),\n",
    "            'strategic_goals': len(self.strategic_goals),\n",
    "            'pending_decisions': len(self.pending_decisions)\n",
    "        }"
   ]
