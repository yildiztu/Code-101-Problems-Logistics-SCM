    "# Explainable AI System\n",
    "class ExplainableAI:\n",
    "    \"\"\"AI system with explainable decision-making capabilities\"\"\"\n",
    "    \n",
    "    def __init__(self, ai_id: str = \"XAI-Controller\"):\n",
    "        self.ai_id = ai_id\n",
    "        self.decision_history = []\n",
    "        self.learning_database = []\n",
    "        self.anomaly_detector = AnomalyDetector()\n",
    "        \n",
    "        # AI capabilities\n",
    "        self.pattern_recognition_accuracy = 0.85\n",
    "        self.prediction_confidence_threshold = 0.7\n",
    "        self.explainability_level = 0.9  # How well it can explain decisions\n",
    "        \n",
    "        # Decision-making policies\n",
    "        self.autonomous_threshold = 0.8  # Confidence level for autonomous decisions\n",
    "        self.human_intervention_rules = self._load_intervention_rules()\n",
    "        \n",
    "    def _load_intervention_rules(self) -> List[Dict[str, Any]]:\n",
    "        \"\"\"Load rules for when human intervention is required\"\"\"\n",
    "        return [\n",
    "            {\n",
    "                'condition': 'safety_critical',\n",
    "                'threshold': 0.9,\n",
    "                'action': 'require_human_approval'\n",
    "            },\n",
    "            {\n",
    "                'condition': 'novel_situation',\n",
    "                'threshold': 0.6,\n",
    "                'action': 'recommend_human_review'\n",
    "            },\n",
    "            {\n",
    "                'condition': 'high_value_decision',\n",
    "                'threshold': 0.7,\n",
    "                'action': 'suggest_human_override'\n",
    "            }\n",
    "        ]\n",
    "    \n",
    "    def analyze_situation(self, situation_data: Dict[str, Any]) -> AIDecision:\n",
    "        \"\"\"Analyze current situation and make explainable decision\"\"\"\n",
    "        \n",
    "        # Extract key features from situation\n",
    "        features = self._extract_features(situation_data)\n",
    "        \n",
    "        # Pattern recognition\n",
    "        pattern_match = self._recognize_patterns(features)\n",
    "        \n",
    "        # Generate decision alternatives\n",
    "        alternatives = self._generate_alternatives(features, pattern_match)\n",
    "        \n",
    "        # Evaluate alternatives\n",
    "        evaluated_alternatives = self._evaluate_alternatives(alternatives)\n",
    "        \n",
    "        # Select best action\n",
    "        best_action = max(evaluated_alternatives, key=lambda x: x['score'])\n",
    "        \n",
    "        # Generate explanation\n",
    "        explanation = self._generate_explanation(features, pattern_match, best_action)\n",
    "        \n",
    "        # Determine if human approval needed\n",
    "        requires_human = self._requires_human_approval(features, best_action)\n",
    "        \n",
    "        # Create AI decision\n",
    "        decision = AIDecision(\n",
    "            decision_id=f\"AI-{len(self.decision_history) + 1}\",\n",
    "            decision_type=best_action['type'],\n",
    "            recommended_action=best_action['action'],\n",
    "            confidence=best_action['confidence'],\n",
    "            reasoning=explanation,\n",
    "            supporting_data=best_action['data'],\n",
    "            alternatives=evaluated_alternatives,\n",
    "            requires_human_approval=requires_human,\n",
    "            priority=self._determine_priority(best_action)\n",
    "        )\n",
    "        \n",
    "        self.decision_history.append(decision)\n",
    "        return decision\n",
    "    \n",
    "    def _extract_features(self, situation_data: Dict[str, Any]) -> Dict[str, Any]:\n",
    "        \"\"\"Extract relevant features from situation data\"\"\"\n",
    "        features = {\n",
    "            'num_agvs': situation_data.get('num_agvs', 0),\n",
    "            'num_tasks': situation_data.get('num_tasks', 0),\n",
    "            'avg_battery': situation_data.get('avg_battery', 100),\n",
    "            'system_efficiency': situation_data.get('efficiency', 0.8),\n",
    "            'time_pressure': situation_data.get('time_pressure', 0.5),\n",
    "            'congestion_level': situation_data.get('congestion', 0.3),\n",
    "            'anomaly_indicators': situation_data.get('anomalies', []),\n",
    "            'strategic_goals': situation_data.get('goals', [])\n",
    "        }\n",
    "        return features\n",
    "    \n",
    "    def _recognize_patterns(self, features: Dict[str, Any]) -> Dict[str, Any]:\n",
    "        \"\"\"Recognize patterns in current situation\"\"\"\n",
    "        patterns = {\n",
    "            'high_demand': features['num_tasks'] > 10,\n",
    "            'low_battery': features['avg_battery'] < 30,\n",
    "            'congestion_detected': features['congestion_level'] > 0.7,\n",
    "            'time_critical': features['time_pressure'] > 0.8,\n",
    "            'anomaly_present': len(features['anomaly_indicators']) > 0,\n",
    "            'efficiency_drop': features['system_efficiency'] < 0.6\n",
    "        }\n",
    "        return patterns\n",
    "    \n",
    "    def _generate_alternatives(self, features: Dict[str, Any], patterns: Dict[str, Any]) -> List[Dict[str, Any]]:\n",
    "        \"\"\"Generate decision alternatives based on patterns\"\"\"\n",
    "        alternatives = []\n",
    "        \n",
    "        # Base alternatives\n",
    "        alternatives.append({\n",
    "            'type': 'resource_allocation',\n",
    "            'action': 'optimize_agv_assignment',\n",
    "            'description': 'Rebalance AGV assignments for better efficiency'\n",
    "        })\n",
    "        \n",
    "        alternatives.append({\n",
    "            'type': 'battery_management',\n",
    "            'action': 'prioritize_charging',\n",
    "            'description': 'Send low-battery AGVs to charging stations'\n",
    "        })\n",
    "        \n",
    "        alternatives.append({\n",
    "            'type': 'congestion_control',\n",
    "            'action': 'reroute_agvs',\n",
    "            'description': 'Reroute AGVs to avoid congested areas'\n",
    "        })\n",
    "        \n",
    "        # Pattern-specific alternatives\n",
    "        if patterns['time_critical']:\n",
    "            alternatives.append({\n",
    "                'type': 'urgent_response',\n",
    "                'action': 'expedite_critical_tasks',\n",
    "                'description': 'Prioritize time-critical tasks'\n",
    "            })\n",
    "        \n",
    "        if patterns['anomaly_present']:\n",
    "            alternatives.append({\n",
    "                'type': 'anomaly_response',\n",
    "                'action': 'investigate_anomaly',\n",
    "                'description': 'Investigate and resolve detected anomalies'\n",
    "            })\n",
    "        \n",
    "        return alternatives\n",
    "    \n",
    "    def _evaluate_alternatives(self, alternatives: List[Dict[str, Any]]) -> List[Dict[str, Any]]:\n",
    "        \"\"\"Evaluate each alternative with score and confidence\"\"\"\n",
    "        evaluated = []\n",
    "        \n",
    "        for alt in alternatives:\n",
    "            # Calculate score based on multiple factors\n",
    "            score = random.uniform(0.6, 0.95)  # Simulated evaluation\n",
    "            confidence = min(score + random.uniform(-0.1, 0.1), 1.0)\n",
    "            \n",
    "            evaluated.append({\n",
    "                **alt,\n",
    "                'score': score,\n",
    "                'confidence': confidence,\n",
    "                'data': {\n",
    "                    'expected_improvement': score * 20,  # Percentage improvement\n",
    "                    'risk_level': 'low' if score > 0.8 else 'medium',\n",
    "                    'implementation_time': random.randint(5, 30)  # minutes\n",
    "                }\n",
    "            })\n",
    "        \n",
    "        return evaluated\n",
    "    \n",
    "    def _generate_explanation(self, features: Dict[str, Any], patterns: Dict[str, Any], action: Dict[str, Any]) -> List[str]:\n",
    "        \"\"\"Generate human-readable explanation for the decision\"\"\"\n",
    "        explanation = []\n",
    "        \n",
    "        # Main reasoning\n",
    "        explanation.append(f\"Recommended {action['description']} with {action['confidence']:.1%} confidence.\")\n",
    "        \n",
    "        # Pattern-based reasoning\n",
    "        active_patterns = [k for k, v in patterns.items() if v]\n",
    "        if active_patterns:\n",
    "            explanation.append(f\"Detected patterns: {', '.join(active_patterns).replace('_', ' ').title()}\")\n",
    "        \n",
    "        # Feature-based reasoning\n",
    "        if features['avg_battery'] < 50:\n",
    "            explanation.append(f\"Average battery level is low ({features['avg_battery']:.1f}%), requiring attention to energy management.\")\n",
    "        \n",
    "        if features['system_efficiency'] < 0.7:\n",
    "            explanation.append(f\"System efficiency ({features['system_efficiency']:.1%}) is below optimal, suggesting need for optimization.\")\n",
    "        \n",
    "        # Expected outcome\n",
    "        improvement = action['data']['expected_improvement']\n",
    "        explanation.append(f\"Expected to improve system performance by approximately {improvement:.1f}%.\")\n",
    "        \n",
    "        # Risk assessment\n",
    "        risk = action['data']['risk_level']\n",
    "        explanation.append(f\"Risk level assessed as {risk} based on current conditions.\")\n",
    "        \n",
    "        return explanation\n",
    "    \n",
    "    def _requires_human_approval(self, features: Dict[str, Any], action: Dict[str, Any]) -> bool:\n",
    "        \"\"\"Determine if human approval is required for this decision\"\"\"\n",
    "        \n",
    "        # Check intervention rules\n",
    "        for rule in self.human_intervention_rules:\n",
    "            if self._evaluate_rule(rule, features, action):\n",
    "                return True\n",
    "        \n",
    "        # High-stakes decisions always require human approval\n",
    "        if action['type'] in ['safety_critical', 'major_system_change']:\n",
    "            return True\n",
    "        \n",
    "        # Low confidence decisions require human review\n",
    "        if action['confidence'] < self.autonomous_threshold:\n",
    "            return True\n",
    "        \n",
    "        return False\n",
    "    \n",
    "    def _evaluate_rule(self, rule: Dict[str, Any], features: Dict[str, Any], action: Dict[str, Any]) -> bool:\n",
    "        \"\"\"Evaluate if an intervention rule is triggered\"\"\"\n",
    "        condition = rule['condition']\n",
    "        threshold = rule['threshold']\n",
    "        \n",
    "        if condition == 'safety_critical':\n",
    "            return features.get('safety_risk', 0) > threshold\n",
    "        elif condition == 'novel_situation':\n",
    "            return len(features.get('anomaly_indicators', [])) > 0\n",
    "        elif condition == 'high_value_decision':\n",
    "            return action['data']['expected_improvement'] > threshold * 100\n",
    "        \n",
    "        return False\n",
    "    \n",
    "    def _determine_priority(self, action: Dict[str, Any]) -> str:\n",
    "        \"\"\"Determine priority level of the decision\"\"\"\n",
    "        if action['type'] == 'anomaly_response':\n",
    "            return 'critical'\n",
    "        elif action['type'] == 'urgent_response':\n",
    "            return 'high'\n",
    "        elif action['confidence'] > 0.8:\n",
    "            return 'medium'\n",
    "        else:\n",
    "            return 'low'\n",
    "    \n",
    "    def learn_from_feedback(self, feedback: LearningFeedback):\n",
    "        \"\"\"Learn from human feedback to improve future decisions\"\"\"\n",
    "        self.learning_database.append(feedback)\n",
    "        \n",
    "        # Update decision patterns based on feedback\n",
    "        if feedback.decision_outcome > 0.8:\n",
    "            # Positive outcome - reinforce this pattern\n",
    "            self._reinforce_pattern(feedback.original_ai_recommendation, feedback.human_decision)\n",
    "        elif feedback.decision_outcome < 0.5:\n",
    "            # Negative outcome - adjust this pattern\n",
    "            self._adjust_pattern(feedback.original_ai_recommendation, feedback.human_decision)\n",
    "    \n",
    "    def _reinforce_pattern(self, ai_rec: str, human_dec: str):\n",
    "        \"\"\"Reinforce successful decision patterns\"\"\"\n",
    "        # In a real system, this would update ML models\n",
    "        pass\n",
    "    \n",
    "    def _adjust_pattern(self, ai_rec: str, human_dec: str):\n",
    "        \"\"\"Adjust unsuccessful decision patterns\"\"\"\n",
    "        # In a real system, this would update ML models\n",
    "        pass\n",
    "\n",
    "# Anomaly Detector\n",
    "class AnomalyDetector:\n",
    "    \"\"\"Detects anomalies in system behavior requiring human attention\"\"\"\n",
    "    \n",
    "    def __init__(self):\n",
    "        self.baseline_metrics = {\n",
    "            'avg_efficiency': 0.8,\n",
    "            'avg_battery_level': 70,\n",
    "            'avg_task_completion_time': 15,\n",
    "            'communication_frequency': 10\n",
    "        }\n",
    "        self.anomaly_thresholds = {\n",
    "            'efficiency_drop': 0.2,  # 20% drop from baseline\n",
    "            'battery_critical': 20,    # Below 20%\n",
    "            'task_delay': 30,         # 30 minutes delay\n",
    "            'communication_silence': 5  # 5 minutes without communication\n",
    "        }\n",
    "    \n",
    "    def detect_anomalies(self, current_metrics: Dict[str, Any]) -> List[AnomalyAlert]:\n",
    "        \"\"\"Detect anomalies in current system metrics\"\"\"\n",
    "        anomalies = []\n",
    "        \n",
    "        # Check efficiency drop\n",
    "        if current_metrics.get('efficiency', 0) < self.baseline_metrics['avg_efficiency'] - self.anomaly_thresholds['efficiency_drop']:\n",
    "            anomalies.append(AnomalyAlert(\n",
    "                alert_id=f\"ANOM-EFF-{len(anomalies)+1}\",\n",
    "                anomaly_type=\"efficiency_drop\",\n",
    "                severity=\"high\",\n",
    "                description=f\"System efficiency dropped to {current_metrics['efficiency']:.1%}\",\n",
    "                affected_assets=[\"all_agvs\"],\n",
    "                recommended_actions=[\"investigate_causes\", \"optimize_routing\", \"check_maintenance\"],\n",
    "                confidence=0.9\n",
    "            ))\n",
    "        \n",
    "        # Check critical battery levels\n",
    "        low_battery_agvs = current_metrics.get('low_battery_agvs', [])\n",
    "        if len(low_battery_agvs) > 2:  # More than 2 AGVs with critical battery\n",
    "            anomalies.append(AnomalyAlert(\n",
    "                alert_id=f\"ANOM-BAT-{len(anomalies)+1}\",\n",
    "                anomaly_type=\"battery_critical\",\n",
    "                severity=\"critical\",\n",
    "                description=f\"{len(low_battery_agvs)} AGVs with critical battery levels\",\n",
    "                affected_assets=low_battery_agvs,\n",
    "                recommended_actions=[\"prioritize_charging\", \"reroute_tasks\", \"activate_backup_agvs\"],\n",
    "                confidence=0.95\n",
    "            ))\n",
    "        \n",
    "        # Check task completion delays\n",
    "        delayed_tasks = current_metrics.get('delayed_tasks', [])\n",
    "        if len(delayed_tasks) > 3:\n",
    "            anomalies.append(AnomalyAlert(\n",
    "                alert_id=f\"ANOM-DELAY-{len(anomalies)+1}\",\n",
    "                anomaly_type=\"task_delays\",\n",
    "                severity=\"medium\",\n",
    "                description=f\"{len(delayed_tasks)} tasks experiencing significant delays\",\n",
    "                affected_assets=delayed_tasks,\n",
    "                recommended_actions=[\"reallocate_resources\", \"extend_deadlines\", \"prioritize_critical_tasks\"],\n",
    "                confidence=0.8\n",
    "            ))\n",
    "        \n",
    "        return anomalies"
   ]
