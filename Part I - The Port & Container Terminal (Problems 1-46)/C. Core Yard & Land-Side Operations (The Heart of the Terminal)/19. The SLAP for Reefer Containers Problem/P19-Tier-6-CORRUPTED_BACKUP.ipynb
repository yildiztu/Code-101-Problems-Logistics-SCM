    "@dataclass\n",
    "class ContainerAgent:\n",
    "    \"\"\"Autonomous agent representing a reefer container\"\"\"\n",
    "    id: int\n",
    "    energy: float\n",
    "    temp_req: float\n",
    "    temp_tolerance: float\n",
    "    dwell_time: float\n",
    "    cargo_type: str\n",
    "    cargo_value: float\n",
    "    urgency: float  # 0.1-1.0 (low to high urgency)\n",
    "    flexibility: float  # 0.1-1.0 (rigid to flexible)\n",
    "    budget: float  # Maximum willing to pay for assignment\n",
    "    preferences: Dict[str, float]  # Location type preferences\n",
    "    \n",
    "    def __post_init__(self):\n",
    "        self.current_location = None\n",
    "        self.assigned = False\n",
    "        self.utility = 0.0\n",
    "        self.satisfaction = 0.5  # Initial satisfaction level\n",
    "        self.learning_rate = 0.1\n",
    "        self.experience = []  # Past assignment experiences\n",
    "        self.reputation = 0.5  # Reputation score from 0-1\n",
    "\n",
    "class LocationAgent:\n",
    "    \"\"\"Autonomous agent representing a storage location\"\"\"\n",
    "    id: int\n",
    "    power_cap: float\n",
    "    temp_min: float\n",
    "    temp_max: float\n",
    "    base_cost: float\n",
    "    backup_power: bool\n",
    "    location_type: str\n",
    "    \n",
    "    def __post_init__(self):\n",
    "        self.assigned_containers = []\n",
    "        self.power_usage = 0.0\n",
    "        self.utilization = 0.0\n",
    "        self.revenue = 0.0\n",
    "        self.market_price = self.base_cost  # Initial market price\n",
    "        self.demand_history = deque(maxlen=100)\n",
    "        self.learning_rate = 0.05\n",
    "        self.reputation = 0.5\n",
    "    \n",
    "class Auctioneer:\n",
    "    \"\"\"Auctioneer for managing distributed auctions\"\"\"\n",
    "    def __init__(self):\n",
    "        self.current_auction = None\n",
    "        self.auction_history = []\n",
    "        self.market_statistics = defaultdict(list)\n",
    "        \n",
    "class Contract:\n",
    "    \"\"\"Contract between container and location\"\"\"\n",
    "    def __init__(self, container_id: int, location_id: int, price: float, duration: float):\n",
    "        self.container_id = container_id\n",
    "        self.location_id = location_id\n",
    "        self.price = price\n",
    "        self.duration = duration\n",
    "        self.satisfaction_score = 0.5\n",
    "        self.termination_clause = False\n",
    "        \n",
    "class Message:\n",
    "    \"\"\"Communication message between agents\"\"\"\n",
    "    def __init__(self, sender: str, receiver: str, message_type: str, content: Any):\n",
    "        self.sender = sender\n",
    "        self.receiver = receiver\n",
    "self.message_type = message_type\n",
    "        self.content = content\n",
    "        self.timestamp = time.time()\n",
    "        self.priority = 1.0\n",
    "        \n",
    "print(\"Agent classes defined for Autonomous Ecosystem\")"
   ]
