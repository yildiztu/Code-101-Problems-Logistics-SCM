   "source": [
    "def visualize_multi_agent_results(peak_completed, peak_auctions, peak_system):\n",
    "    \"\"\"Create comprehensive multi-agent visualization\"\"\"\n",
    "    \n",
    "    fig, axes = plt.subplots(2, 2, figsize=(16, 12))\n",
    "    fig.suptitle('Smart Container Terminal - Multi-Agent System Analysis', fontsize=16, fontweight='bold')\n",
    "    \n",
    "    # 1. Agent Performance Comparison\n",
    "    ax1 = axes[0, 0]\n",
    "    if peak_completed:\n",
    "        df_completed = pd.DataFrame(peak_completed)\n",
    "        agent_performance = df_completed.groupby('agent_id').size()\n",
    "        \n",
    "        agent_performance.plot(kind='bar', ax=ax1, color='lightblue', alpha=0.7)\n",
    "        ax1.set_ylabel('Jobs Completed')\n",
    "        ax1.set_title('Agent Performance Comparison')\n",
    "        ax1.grid(True, alpha=0.3)\n",
    "        ax1.set_xticklabels(ax1.get_xticklabels(), rotation=45)\n",
    "    \n",
    "    # 2. Auction Competition\n",
    "    ax2 = axes[0, 1]\n",
    "    if peak_auctions:\n",
    "        bid_counts = [auction['num_bids'] for auction in peak_auctions]\n",
    "        ax2.hist(bid_counts, bins=10, alpha=0.7, color='green')\n",
    "        ax2.set_xlabel('Number of Bids per Job')\n",
    "        ax2.set_ylabel('Frequency')\n",
    "        ax2.set_title('Auction Competition Distribution')\n",
    "        ax2.grid(True, alpha=0.3)\n",
    "    \n",
    "    # 3. System Utilities\n",
    "    ax3 = axes[1, 0]\n",
    "    if peak_auctions:\n",
    "        utilities = [auction['best_utility'] for auction in peak_auctions]\n",
    "        ax3.plot(utilities, 'b-', alpha=0.7, linewidth=2)\n",
    "        ax3.set_xlabel('Auction Number')\n",
    "        ax3.set_ylabel('Winning Utility')\n",
    "        ax3.set_title('Utility Evolution Over Time')\n",
    "        ax3.grid(True, alpha=0.3)\n",
    "    \n",
    "    # 4. Agent Specialization\n",
    "    ax4 = axes[1, 1]\n",
    "    \n",
    "    # Create specialization matrix\n",
    "    specialization_data = []\n",
    "    agent_names = []\n",
    "    \n",
    "    for agent_id, agent in peak_system.agents.items():\n",
    "        agent_names.append(agent_id)\n",
    "        specializations = list(agent.agent.specialization_score.values())\n",
    "        specialization_data.append(specializations)\n",
    "    \n",
    "    if specialization_data:\n",
    "        specialization_matrix = np.array(specialization_data)\n",
    "        \n",
    "        im = ax4.imshow(specialization_matrix, cmap='YlOrRd', aspect='auto')\n",
    "        ax4.set_xticks(range(4))\n",
    "        ax4.set_xticklabels(['High Priority', 'Bulk', 'Emergency', 'Standard'])\n",
    "        ax4.set_yticks(range(len(agent_names)))\n",
    "        ax4.set_yticklabels(agent_names)\n",
    "        ax4.set_title('Agent Specialization Matrix')\n",
    "        \n",
    "        # Add colorbar\n",
    "        plt.colorbar(im, ax=ax4, fraction=0.046, pad=0.04)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "# Visualize multi-agent results\n",
    "visualize_multi_agent_results(peak_completed, peak_auctions, peak_system)"
   ]
