    "def visualize_multi_agent_results(peak_df, peak_performance, disruption_df, disruption_performance, \n",
    "                                peak_system, disruption_system):\n",
    "    \"\"\"Create comprehensive multi-agent visualization\"\"\"\n",
    "    \n",
    "    fig, axes = plt.subplots(3, 3, figsize=(18, 15))\n",
    "    fig.suptitle('Smart Container Terminal - Multi-Agent System Analysis', fontsize=16, fontweight='bold')\n",
    "    \n",
    "    # 1. Agent Performance Comparison\n",
    "    ax1 = axes[0, 0]\n",
    "    if not peak_performance.empty and not disruption_performance.empty:\n",
    "        agents = list(set(peak_performance.index) | set(disruption_performance.index))\n",
    "        \n",
    "        peak_success = [peak_performance.loc[agent, 'success_rate'] if agent in peak_performance.index else 0 for agent in agents]\n",
    "        disruption_success = [disruption_performance.loc[agent, 'success_rate'] if agent in disruption_performance.index else 0 for agent in agents]\n",
    "        \n",
    "        x = np.arange(len(agents))\n",
    "        width = 0.35\n",
    "        \n",
    "        ax1.bar(x - width/2, peak_success, width, label='Peak Period', alpha=0.7, color='lightblue')\n",
    "        ax1.bar(x + width/2, disruption_success, width, label='Dynamic Disruption', alpha=0.7, color='lightcoral')\n",
    "        ax1.set_ylabel('Success Rate')\n",
    "        ax1.set_title('Agent Success Rate Comparison')\n",
    "        ax1.set_xticks(x)\n",
    "        ax1.set_xticklabels(agents, rotation=45)\n",
    "        ax1.legend()\n",
    "        ax1.grid(True, alpha=0.3)\n",
    "    \n",
    "    # 2. Job Completion Over Time\n",
    "    ax2 = axes[0, 1]\n",
    "    if peak_df is not None and not peak_df.empty:\n",
    "        peak_timeline = peak_df.groupby('agent_id').size().sort_index()\n",
    "        ax2.plot(peak_timeline.index, peak_timeline.values, 'b-o', label='Peak Period', linewidth=2, markersize=6)\n",
    "    \n",
    "    if disruption_df is not None and not disruption_df.empty:\n",
    "        disruption_timeline = disruption_df.groupby('agent_id').size().sort_index()\n",
    "        ax2.plot(disruption_timeline.index, disruption_timeline.values, 'r-s', label='Dynamic Disruption', linewidth=2, markersize=6)\n",
    "    \n",
    "    ax2.set_ylabel('Jobs Completed')\n",
    "    ax2.set_title('Job Completion by Agent')\n",
    "    ax2.legend()\n",
    "    ax2.grid(True, alpha=0.3)\n",
    "    \n",
    "    # 3. Role Distribution\n",
    "    ax3 = axes[0, 2]\n",
    "    \n",
    "    # Get role distributions\n",
    "    peak_roles = peak_df['agent_role'].value_counts() if peak_df is not None else pd.Series()\n",
    "    disruption_roles = disruption_df['agent_role'].value_counts() if disruption_df is not None else pd.Series()\n",
    "    \n",
    "    all_roles = list(set(peak_roles.index) | set(disruption_roles.index))\n",
    "    \n",
    "    x = np.arange(len(all_roles))\n",
    "    width = 0.35\n",
    "    \n",
    "    peak_counts = [peak_roles.get(role, 0) for role in all_roles]\n",
    "    disruption_counts = [disruption_roles.get(role, 0) for role in all_roles]\n",
    "    \n",
    "    ax3.bar(x - width/2, peak_counts, width, label='Peak Period', alpha=0.7, color='lightgreen')\n",
    "    ax3.bar(x + width/2, disruption_counts, width, label='Dynamic Disruption', alpha=0.7, color='lightyellow')\n",
    "    ax3.set_ylabel('Number of Jobs')\n",
    "    ax3.set_title('Role Distribution')\n",
    "    ax3.set_xticks(x)\n",
    "    ax3.set_xticklabels(all_roles, rotation=45, ha='right')\n",
    "    ax3.legend()\n",
    "    ax3.grid(True, alpha=0.3)\n",
    "    \n",
    "    # 4. Auction Competition\n",
    "    ax4 = axes[1, 0]\n",
    "    if peak_auctions:\n",
    "        peak_bids = [auction['num_bids'] for auction in peak_auctions]\n",
    "        ax4.hist(peak_bids, bins=10, alpha=0.7, color='blue', label='Peak Period')\n",
    "    \n",
    "    if disruption_auctions:\n",
    "        disruption_bids = [auction['num_bids'] for auction in disruption_auctions]\n",
    "        ax4.hist(disruption_bids, bins=10, alpha=0.7, color='red', label='Dynamic Disruption')\n",
    "    \n",
    "    ax4.set_xlabel('Number of Bids per Job')\n",
    "    ax4.set_ylabel('Frequency')\n",
    "    ax4.set_title('Auction Competition Distribution')\n",
    "    ax4.legend()\n",
    "    ax4.grid(True, alpha=0.3)\n",
    "    \n",
    "    # 5. System Utilities\n",
    "    ax5 = axes[1, 1]\n",
    "    if peak_auctions and disruption_auctions:\n",
    "        peak_utilities = [auction['best_utility'] for auction in peak_auctions]\n",
    "        disruption_utilities = [auction['best_utility'] for auction in disruption_auctions]\n",
    "        \n",
    "        ax5.plot(peak_utilities, 'b-', alpha=0.7, label='Peak Period', linewidth=1)\n",
    "        ax5.plot(disruption_utilities, 'r-', alpha=0.7, label='Dynamic Disruption', linewidth=1)\n",
    "        \n",
    "        ax5.set_xlabel('Auction Number')\n",
    "        ax5.set_ylabel('Winning Utility')\n",
    "        ax5.set_title('Utility Evolution Over Time')\n",
    "        ax5.legend()\n",
    "        ax5.grid(True, alpha=0.3)\n",
    "    \n",
    "    # 6. Agent Specialization Heatmap\n",
    "    ax6 = axes[1, 2]\n",
