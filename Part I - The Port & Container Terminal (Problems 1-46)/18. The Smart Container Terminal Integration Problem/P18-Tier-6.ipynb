    "class AutonomousCraneAgent:\n",
    "    \"\"\"Intelligent autonomous crane agent\"\"\"\n",
    "    \n",
    "    def __init__(self, agent_id: str, crane_id: int, position: Tuple[float, float], \n",
    "                 capacity: float, speed: float):\n",
    "        self.agent = CraneAgent(\n",
    "            agent_id=agent_id,\n",
    "            crane_id=crane_id,\n",
    "            position=position,\n",
    "            capacity=capacity,\n",
    "            speed=speed\n",
    "        )\n",
    "        \n",
    "        # Initialize agent capabilities\n",
    "        self._initialize_capabilities()\n",
    "    \n",
    "    def _initialize_capabilities(self):\n",
    "        \"\"\"Initialize agent capabilities and preferences\"\"\"\n",
    "        # Random initial specialization tendencies\n",
    "        specializations = ['high_priority', 'bulk', 'emergency', 'standard']\n",
    "        total = 0.0\n",
    "        \n",
    "        for spec in specializations:\n",
    "            value = np.random.uniform(0.1, 0.4)\n",
    "            self.agent.specialization_score[spec] = value\n",
    "            total += value\n",
    "        \n",
    "        # Normalize to sum to 1.0\n",
    "        for spec in specializations:\n",
    "            self.agent.specialization_score[spec] /= total\n",
    "    \n",
    "    def calculate_bid(self, job: Job) -> Optional[Bid]:\n",
    "        \"\"\"Calculate bid for a job\"\"\"\n",
    "        # Check capacity constraint\n",
    "        if job.required_capacity > self.agent.capacity:\n",
    "            return None\n",
    "        \n",
    "        # Calculate distance to job\n",
    "        distance = np.sqrt((self.agent.position[0] - job.location[0])**2 + \n",
    "                          (self.agent.position[1] - job.location[1])**2)\n",
    "        \n",
    "        # Calculate travel time\n",
    "        travel_time = distance / self.agent.speed\n",
    "        \n",
    "        # Calculate total completion time\n",
    "        availability_delay = max(0, self.agent.workload * 30)  # Workload delay\n",
    "        total_time = travel_time + job.processing_time + availability_delay\n",
    "        \n",
    "        # Calculate cost (time + energy consumption)\n",
    "        cost = total_time * 10  # $10 per minute\n",
    "        \n",
    "        # Calculate confidence based on experience and specialization\n",
    "        specialization_match = 0.2  # Base specialization\n",
    "        \n",
    "        if job.priority == 3 and 'high_priority' in self.agent.specialization_score:\n",
    "            specialization_match += self.agent.specialization_score['high_priority']\n",
    "        elif job.job_type == 'bulk' and 'bulk' in self.agent.specialization_score:\n",
    "            specialization_match += self.agent.specialization_score['bulk']\n",
    "        elif job.priority == 3 and 'emergency' in self.agent.specialization_score:\n",
    "            specialization_match += self.agent.specialization_score['emergency']\n",
    "        else:\n",
    "            specialization_match += self.agent.specialization_score['standard']\n",
    "        \n",
    "        confidence = (self.agent.experience_level * 0.7 + \n",
    "                     specialization_match * 0.3)\n",
    "        confidence = min(1.0, confidence)\n",
    "        \n",
    "        # Calculate specialization bonus\n",
    "        specialization_bonus = specialization_match\n",
    "        \n",
    "        return Bid(\n",
    "            agent_id=self.agent.agent_id,\n",
    "            job_id=job.job_id,\n",
    "            cost=cost,\n",
    "            confidence=confidence,\n",
    "            availability_time=int(availability_delay),\n",
    "            specialization_bonus=specialization_bonus\n",
    "    \n",
    "    def update_role(self, recent_jobs: List[Job]):\n",
    "        \"\"\"Update agent role based on recent performance\"\"\"\n",
    "        if not recent_jobs:\n",
    "            return\n",
    "        \n",
    "        # Analyze recent job types\n",
    "        high_priority_count = sum(1 for job in recent_jobs if job.priority == 3)\n",
    "        bulk_count = sum(1 for job in recent_jobs if job.job_type == 'bulk')\n",
    "        emergency_count = sum(1 for job in recent_jobs if job.priority == 3 and \n",
    "                            job.deadline and job.deadline < datetime.now() + timedelta(hours=2))\n",
    "        \n",
    "        total_jobs = len(recent_jobs)\n",
    "        \n",
    "        # Update role based on performance patterns\n",
    "        if emergency_count / total_jobs > 0.6:\n",
    "            self.agent.role = AgentRole.EMERGENCY_RESPONDER\n",
    "        elif high_priority_count / total_jobs > 0.7:\n",
    "            self.agent.role = AgentRole.HIGH_PRIORITY_SPECIALIST\n",
    "        elif bulk_count / total_jobs > 0.6:\n",
    "            self.agent.role = AgentRole.BULK_HANDLER\n",
    "        else:\n",
    "            self.agent.role = AgentRole.GENERALIST\n",
    "        \n",
    "        # Update specialization scores based on role\n",
    "        if self.agent.role == AgentRole.EMERGENCY_RESPONDER:\n",
    "            self.agent.specialization_score['emergency'] = 0.6\n",
    "            self.agent.specialization_score['high_priority'] = 0.3\n",
    "            self.agent.specialization_score['standard'] = 0.1\n",
    "            self.agent.specialization_score['bulk'] = 0.0\n",
    "        elif self.agent.role == AgentRole.HIGH_PRIORITY_SPECIALIST:\n",
    "            self.agent.specialization_score['high_priority'] = 0.7\n",
    "            self.agent.specialization_score['emergency'] = 0.2\n",
    "            self.agent.specialization_score['standard'] = 0.1\n",
    "            self.agent.specialization_score['bulk'] = 0.0\n",
    "        elif self.agent.role == AgentRole.BULK_HANDLER:\n",
    "            self.agent.specialization_score['bulk'] = 0.6\n",
    "            self.agent.specialization_score['standard'] = 0.3\n",
    "            self.agent.specialization_score['high_priority'] = 0.1\n",
    "            self.agent.specialization_score['emergency'] = 0.0\n",
    "    \n",
    "    def learn_from_experience(self, job: Job, success: bool, actual_time: float):\n",
    "        \"\"\"Learn from job completion experience\"\"\"\n",
    "        # Update experience level\n",
    "        if success:\n",
    "            self.agent.experience_level = min(1.0, \n",
    "                self.agent.experience_level + self.agent.adaptation_rate * 0.1)\n",
    "            self.agent.success_rate = (self.agent.success_rate * 0.9 + 1.0 * 0.1)\n",
    "        else:\n",
    "            self.agent.experience_level = max(0.1, \n",
    "                self.agent.experience_level - self.agent.adaptation_rate * 0.05)\n",
    "            self.agent.success_rate = (self.agent.success_rate * 0.9 + 0.0 * 0.1)\n",
    "        \n",
    "        # Update specialization based on job type and success\n",
    "        if success:\n",
    "            if job.priority == 3:\n",
    "                self.agent.specialization_score['high_priority'] += 0.01\n",
    "            if job.job_type == 'bulk':\n",
    "                self.agent.specialization_score['bulk'] += 0.01\n",
    "            if job.deadline and job.deadline < datetime.now() + timedelta(hours=2):\n",
    "                self.agent.specialization_score['emergency'] += 0.01\n",
    "        \n",
    "        # Normalize specialization scores\n",
    "        total = sum(self.agent.specialization_score.values())\n",
    "        for spec in self.agent.specialization_score:\n",
    "            self.agent.specialization_score[spec] /= total\n",
    "        \n",
    "        # Add to job history\n",
    "        self.agent.job_history.append(job.job_id)\n",
    "        \n",
    "        # Keep only recent jobs for role update\n",
    "        if len(self.agent.job_history) > 20:\n",
    "            self.agent.job_history = self.agent.job_history[-20:]\n",
    "    \n",
    "    def communicate_with_neighbors(self, message: Message):\n",
    "        \"\"\"Send message to neighboring agents\"\"\"\n",
    "        # In a real implementation, this would use actual communication protocols\n",
    "        # For simulation, we'll just track messages\n",
    "        pass\n",
    "    \n",
    "    def process_messages(self):\n",
    "        \"\"\"Process messages in queue\"\"\"\n",
    "        processed_messages = []\n",
    "        \n",
    "        for message in self.agent.message_queue:\n",
    "            if message.message_type == 'job_award':\n",
    "                # Process job award\n",
    "                job_id = message.content.get('job_id')\n",
    "                if job_id:\n",
    "                    self.agent.current_job = job_id\n",
    "                    self.agent.status = 'active'\n",
    "                    \n",
    "            elif message.message_type == 'job_complete':\n",
    "                # Process job completion\n",
    "                self.agent.current_job = None\n",
    "                self.agent.status = 'idle'\n",
    "                self.agent.workload = max(0, self.agent.workload - 0.2)\n",
    "                \n",
    "            processed_messages.append(message)\n",
    "        \n",
    "        # Remove processed messages\n",
    "        for message in processed_messages:\n",
    "            self.agent.message_queue.remove(message)\n",
    "\n",
    "print(\"✅ Autonomous Crane Agent class defined!\")"
   ]
