    "### Game Theory Analysis and Nash Equilibrium"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def analyze_game_theory_properties(completed_jobs, auction_history, system):\n",
    "    \"\"\"Analyze game-theoretic properties of the multi-agent system\"\"\"\n",
    "    \n",
    "    print(\"\\n🎮 GAME THEORY ANALYSIS\")\n",
    "    print(\"=\" * 40)\n",
    "    \n",
    "    if not auction_history or not completed_jobs:\n",
    "        print(\"❌ Insufficient data for game theory analysis\")\n",
    "        return\n",
    "    \n",
    "    # 1. Nash Equilibrium Analysis\n",
    "    print(\"\\n🎯 NASH EQUILIBRIUM ANALYSIS:\")\n",
    "    \n",
    "    df_auctions = pd.DataFrame(auction_history)\n",
    "    df_completed = pd.DataFrame(completed_jobs)\n",
    "    \n",
    "    # Calculate utility variance over time\n",
    "    utilities = df_auctions['best_utility'].values\n",
    "    \n",
    "    # Split into halves to compare stability\n",
    "    mid_point = len(utilities) // 2\n",
    "    early_utilities = utilities[:mid_point]\n",
    "    late_utilities = utilities[mid_point:]\n",
    "    \n",
    "    early_variance = np.var(early_utilities)\n",
    "    late_variance = np.var(late_utilities)\n",
    "    \n",
    "    print(f\"  Early phase utility variance: {early_variance:.6f}\")\n",
    "    print(f\"  Late phase utility variance: {late_variance:.6f}\")\n",
    "    print(f\"  Variance reduction: {((early_variance - late_variance) / early_variance * 100):.1f}%\")\n",
    "    \n",
    "    if late_variance < 0.01:\n",
    "        print(\"  ✅ System appears to have reached Nash equilibrium\")\n",
    "    else:\n",
    "        print(\"  ⚠️ System has not yet reached Nash equilibrium\")\n",
    "    \n",
    "    # 2. Strategy Analysis\n",
    "    print(\"\\n🧠 STRATEGY ANALYSIS:\")\n",
    "    \n",
    "    # Analyze bidding strategies\n",
    "    agent_strategies = {}\n",
    "    \n",
    "    for agent_id in system.agents.keys():\n",
    "        agent_auctions = df_auctions[df_auctions['winning_bid'].apply(lambda x: x.agent_id if x else None) == agent_id]\n",
    "        \n",
    "        if not agent_auctions.empty:\n",
    "            avg_utility = agent_auctions['best_utility'].mean()\n",
    "            avg_bids_competition = agent_auctions['num_bids'].mean()\n",
    "            win_rate = len(agent_auctions) / len(df_auctions)\n",
    "            \n",
    "            agent_strategies[agent_id] = {\n",
    "                'avg_utility': avg_utility,\n",
    "                'avg_competition': avg_bids_competition,\n",
    "                'win_rate': win_rate\n",
    "            }\n",
    "    \n",
    "    # Sort agents by utility\n",
    "    sorted_agents = sorted(agent_strategies.items(), key=lambda x: x[1]['avg_utility'], reverse=True)\n",
    "    \n",
    "    print(\"  Agent Performance Rankings:\")\n",
    "    for i, (agent_id, strategy) in enumerate(sorted_agents, 1):\n",
    "        print(f\"    {i}. {agent_id}: Utility={strategy['avg_utility']:.3f}, Win Rate={strategy['win_rate']:.2%}\")\n",
    "    \n",
    "    # 3. Pareto Efficiency Analysis\n",
    "    print(\"\\n⚖️ PARETO EFFICIENCY ANALYSIS:\")\n",
    "    \n",
    "    # Calculate system-wide metrics\n",
    "    total_success_rate = df_completed['success'].mean()\n",
    "    total_completion_time = df_completed['actual_time'].mean()\n",
    "    total_utility = df_auctions['best_utility'].mean()\n",
    "    \n",
    "    print(f\"  System success rate: {total_success_rate:.3f}\")\n",
    "    print(f\"  System completion time: {total_completion_time:.2f} minutes\")\n",
    "    print(f\"  System utility: {total_utility:.3f}\")\n",
    "    \n",
    "    # Check if any agent is significantly underperforming\n",
    "    utilities_by_agent = [strategy['avg_utility'] for strategy in agent_strategies.values()]\n",
    "    utility_std = np.std(utilities_by_agent)\n",
    "    utility_mean = np.mean(utilities_by_agent)\n",
    "    \n",
    "    print(f\"  Utility distribution: Mean={utility_mean:.3f}, Std={utility_std:.3f}\")\n",
    "    \n",
    "    if utility_std < 0.1:\n",
    "        print(\"  ✅ System appears Pareto efficient (low utility variance)\")\n",
    "    else:\n",
    "        print(\"  ⚠️ System may not be Pareto efficient (high utility variance)\")\n",
    "    \n",
    "    # 4. Cooperative vs Competitive Behavior\n",
    "    print(\"\\n🤝 COOPERATIVE VS COMPETITIVE ANALYSIS:\")\n",
    "    \n",
    "    # Analyze bidding competition\n",
    "    avg_bids_per_job = df_auctions['num_bids'].mean()\n",
    "    max_bids_per_job = df_auctions['num_bids'].max()\n",
    "    \n",
    "    print(f\"  Average bids per job: {avg_bids_per_job:.2f}\")\n",
    "    print(f\"  Maximum bids per job: {max_bids_per_job}\")\n",
    "    \n",
    "    if avg_bids_per_job > len(system.agents) * 0.8:\n",
    "        print(\"  🏆 System shows highly competitive behavior\")\n",
    "    elif avg_bids_per_job > len(system.agents) * 0.5:\n",
    "        print(\"  ⚖️ System shows balanced competitive/cooperative behavior\")\n",
    "    else:\n",
    "        print(\"  🤝 System shows cooperative behavior\")\n",
    "    \n",
    "    return {\n",
    "        'nash_equilibrium': late_variance < 0.01,\n",
    "        'pareto_efficient': utility_std < 0.1,\n",
    "        'competitive_level': avg_bids_per_job / len(system.agents),\n",
    "        'agent_strategies': agent_strategies\n",
    "    }\n",
    "\n",
    "# Analyze game theory properties for both scenarios\n",
    "print(\"\\n🎮 PEAK PERIOD GAME THEORY ANALYSIS\")\n",
    "peak_game_analysis = analyze_game_theory_properties(peak_completed, peak_auctions, peak_system)\n",
    "\n",
    "print(\"\\n🎮 DYNAMIC DISRUPTION GAME THEORY ANALYSIS\")\n",
    "disruption_game_analysis = analyze_game_theory_properties(disruption_completed, disruption_auctions, disruption_system)"
   ]
