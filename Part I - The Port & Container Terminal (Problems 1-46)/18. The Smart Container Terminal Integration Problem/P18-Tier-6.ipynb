    "def analyze_multi_agent_performance(completed_jobs, auction_history, system):\n",
    "    \"\"\"Analyze multi-agent system performance\"\"\"\n",
    "    \n",
    "    print(\"\\n📊 MULTI-AGENT PERFORMANCE ANALYSIS\")\n",
    "    print(\"=\" * 40)\n",
    "    \n",
    "    if not completed_jobs:\n",
    "        print(\"❌ No completed jobs to analyze\")\n",
    "        return\n",
    "    \n",
    "    # Convert to DataFrame for analysis\n",
    "    df_completed = pd.DataFrame(completed_jobs)\n",
    "    \n",
    "    # Agent performance analysis\n",
    "    print(\"\\n🤖 AGENT PERFORMANCE:\")\n",
    "    agent_performance = df_completed.groupby('agent_id').agg({\n",
    "        'job_id': 'count',\n",
    "        'success': 'mean',\n",
    "        'actual_time': 'mean'\n",
    "    }).rename(columns={\n",
    "        'job_id': 'jobs_completed',\n",
    "        'success': 'success_rate',\n",
    "        'actual_time': 'avg_completion_time'\n",
    "    })\n",
    "    \n",
    "    print(agent_performance.round(3))\n",
    "    \n",
    "    # Role distribution analysis\n",
    "    print(\"\\n🎭 ROLE DISTRIBUTION:\")\n",
    "    role_distribution = df_completed.groupby('agent_role').size()\n",
    "    for role, count in role_distribution.items():\n",
    "        percentage = (count / len(df_completed)) * 100\n",
    "        print(f\"  {role}: {count} jobs ({percentage:.1f}%)\")\n",
    "    \n",
    "    # Auction analysis\n",
    "    if auction_history:\n",
    "        print(\"\\n🏆 AUCTION ANALYSIS:\")\n",
    "        df_auctions = pd.DataFrame(auction_history)\n",
    "        \n",
    "        avg_bids_per_job = df_auctions['num_bids'].mean()\n",
    "        avg_utility = df_auctions['best_utility'].mean()\n",
    "        \n",
    "        print(f\"  Average bids per job: {avg_bids_per_job:.2f}\")\n",
    "        print(f\"  Average winning utility: {avg_utility:.3f}\")\n",
    "        print(f\"  Total auctions: {len(auction_history)}\")\n",
    "    \n",
    "    # System efficiency\n",
    "    overall_success_rate = df_completed['success'].mean()\n",
    "    avg_completion_time = df_completed['actual_time'].mean()\n",
    "    \n",
    "    print(\"\\n⚡ SYSTEM EFFICIENCY:\")\n",
    "    print(f\"  Overall success rate: {overall_success_rate:.3f}\")\n",
    "    print(f\"  Average completion time: {avg_completion_time:.2f} minutes\")\n",
    "    print(f\"  Coordination overhead: {system.coordination_overhead:.2f} minutes\")\n",
    "    print(f\"  Nash equilibrium: {'Achieved' if system.nash_equilibrium_achieved else 'Not Achieved'}\")\n",
    "    \n",
    "    # Emergent behaviors\n",
    "    if system.emergent_behaviors:\n",
    "        print(\"\\n🌟 EMERGENT BEHAVIORS:\")\n",
    "        for behavior in system.emergent_behaviors:\n",
    "            print(f\"  - {behavior}\")\n",
    "    \n",
    "    return df_completed, agent_performance\n",
    "\n",
    "# Analyze both scenarios\n",
    "print(\"\\n🔍 PEAK PERIOD ANALYSIS\")\n",
    "peak_df, peak_performance = analyze_multi_agent_performance(peak_completed, peak_auctions, peak_system)\n",
    "\n",
    "print(\"\\n🔍 DYNAMIC DISRUPTION ANALYSIS\")\n",
    "disruption_df, disruption_performance = analyze_multi_agent_performance(disruption_completed, disruption_auctions, disruption_system)"
