    "def create_peak_period_scenario():\n",
    "    \"\"\"Create a peak period scenario with high job volume\"\"\"\n",
    "    print(\"📈 Creating Peak Period Scenario...\")\n",
    "    \n",
    "    # Initialize multi-agent system with 6 agents\n",
    "    mas_system = MultiAgentCoordinationSystem(num_agents=6)\n",
    "    \n",
    "    # Generate jobs for peak period\n",
    "    jobs = []\n",
    "    \n",
    "    # High priority emergency jobs\n",
    "    for i in range(15):\n",
    "        job = Job(\n",
    "            job_id=f\"emergency_{i+1}\",\n",
    "            job_type=\"emergency\",\n",
    "            priority=3,\n",
    "            location=(np.random.uniform(0, 1000), np.random.uniform(0, 500)),\n",
    "            processing_time=np.random.randint(5, 15),\n",
    "            deadline=mas_system.current_time + timedelta(hours=np.random.uniform(0.5, 2)),\n",
    "            required_capacity=np.random.uniform(20, 40),\n",
    "            specialization_requirements={'emergency': 0.8, 'high_priority': 0.6}\n",
    "        )\n",
    "        jobs.append(job)\n",
    "    \n",
    "    # High priority regular jobs\n",
    "    for i in range(25):\n",
    "        job = Job(\n",
    "            job_id=f\"high_priority_{i+1}\",\n",
    "            job_type=\"standard\",\n",
    "            priority=3,\n",
    "            location=(np.random.uniform(0, 1000), np.random.uniform(0, 500)),\n",
    "            processing_time=np.random.randint(8, 20),\n",
    "            deadline=mas_system.current_time + timedelta(hours=np.random.uniform(2, 4)),\n",
    "            required_capacity=np.random.uniform(15, 35),\n",
    "            specialization_requirements={'high_priority': 0.7}\n",
    "        )\n",
    "        jobs.append(job)\n",
    "    \n",
    "    # Bulk jobs\n",
    "    for i in range(20):\n",
    "        job = Job(\n",
    "            job_id=f\"bulk_{i+1}\",\n",
    "            job_type=\"bulk\",\n",
    "            priority=2,\n",
    "            location=(np.random.uniform(0, 1000), np.random.uniform(0, 500)),\n",
    "            processing_time=np.random.randint(15, 30),\n",
    "            deadline=mas_system.current_time + timedelta(hours=np.random.uniform(4, 8)),\n",
    "            required_capacity=np.random.uniform(30, 50),\n",
    "            specialization_requirements={'bulk': 0.8}\n",
    "        )\n",
    "        jobs.append(job)\n",
    "    \n",
    "    # Standard jobs\n",
    "    for i in range(30):\n",
    "        job = Job(\n",
    "            job_id=f\"standard_{i+1}\",\n",
    "            job_type=\"standard\",\n",
    "            priority=1,\n",
    "            location=(np.random.uniform(0, 1000), np.random.uniform(0, 500)),\n",
    "            processing_time=np.random.randint(10, 25),\n",
    "            deadline=mas_system.current_time + timedelta(hours=np.random.uniform(6, 12)),\n",
    "            required_capacity=np.random.uniform(10, 30),\n",
    "            specialization_requirements={'standard': 0.5}\n",
    "        )\n",
    "        jobs.append(job)\n",
    "    \n",
    "    # Shuffle jobs to simulate random arrival\n",
    "    np.random.shuffle(jobs)\n",
    "    \n",
    "    # Add jobs to system\n",
    "    for job in jobs:\n",
    "        mas_system.add_job(job)\n",
    "    \n",
    "    print(f\"✅ Created {len(jobs)} jobs:\")\n",
    "    print(f\"   - 15 emergency jobs (priority 3)\")\n",
    "    print(f\"   - 25 high priority jobs (priority 3)\")\n",
    "    print(f\"   - 20 bulk jobs (priority 2)\")\n",
    "    print(f\"   - 30 standard jobs (priority 1)\")\n",
    "    \n",
    "    return mas_system\n",
    "\n",
    "def create_dynamic_disruption_scenario():\n",
    "    \"\"\"Create a dynamic disruption scenario\"\"\"\n",
    "    print(\"⚡ Creating Dynamic Disruption Scenario...\")\n",
    "    \n",
    "    # Initialize multi-agent system with 5 agents\n",
    "    mas_system = MultiAgentCoordinationSystem(num_agents=5)\n",
    "    \n",
    "    # Simulate agent failure (set one agent to maintenance)\n",
    "    if mas_system.agents:\n",
    "        failed_agent_id = list(mas_system.agents.keys())[0]\n",
    "        mas_system.agents[failed_agent_id].agent.status = 'maintenance'\n",
    "        print(f\"⚠️ Agent {failed_agent_id} in maintenance (simulated failure)\")\n",
    "    \n",
    "    # Generate mixed priority jobs\n",
    "    jobs = []\n",
    "    \n",
    "    for i in range(40):\n",
    "        priority = np.random.choice([1, 2, 3], p=[0.4, 0.3, 0.3])\n",
    "        job_type = np.random.choice(['standard', 'bulk', 'emergency'], p=[0.6, 0.3, 0.1])\n",
    "        \n",
    "        job = Job(\n",
    "            job_id=f\"dynamic_{i+1}\",\n",
    "            job_type=job_type,\n",
    "            priority=priority,\n",
    "            location=(np.random.uniform(0, 1000), np.random.uniform(0, 500)),\n",
    "            processing_time=np.random.randint(5, 25),\n",
    "            deadline=mas_system.current_time + timedelta(hours=np.random.uniform(1, 6)) if priority > 1 else None,\n",
    "            required_capacity=np.random.uniform(15, 45)\n",
    "        )\n",
    "        jobs.append(job)\n",
    "    \n",
    "    # Add jobs to system\n",
    "    for job in jobs:\n",
    "        mas_system.add_job(job)\n",
    "    \n",
    "    print(f\"✅ Created {len(jobs)} mixed priority jobs\")\n",
    "    print(f\"🔧 Operating with {len(mas_system.agents) - 1} active agents (1 in maintenance)\")\n",
    "    \n",
    "    return mas_system\n",
    "\n",
    "print(\"✅ Scenario generators defined!\")"
   ]
