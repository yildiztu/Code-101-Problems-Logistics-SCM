    "        specialization_data.append(specializations)\n",
    "    \n",
    "    if specialization_data:\n",
    "        specialization_matrix = np.array(specialization_data)\n",
    "        \n",
    "        im = ax6.imshow(specialization_matrix, cmap='YlOrRd', aspect='auto')\n",
    "        ax6.set_xticks(range(4))\n",
    "        ax6.set_xticklabels(['High Priority', 'Bulk', 'Emergency', 'Standard'])\n",
    "        ax6.set_yticks(range(len(agent_names)))\n",
    "        ax6.set_yticklabels(agent_names)\n",
    "        ax6.set_title('Agent Specialization Matrix')\n",
    "        \n",
    "        # Add colorbar\n",
    "        plt.colorbar(im, ax=ax6, fraction=0.046, pad=0.04)\n",
    "    \n",
    "    # 7. Communication Network\n",
    "    ax7 = axes[2, 0]\n",
    "    \n",
    "    # Visualize agent communication network\n",
    "    positions = {}\n",
    "    for i, agent_id in enumerate(peak_system.agents.keys()):\n",
    "        angle = 2 * np.pi * i / len(peak_system.agents)\n",
    "        positions[agent_id] = (np.cos(angle), np.sin(angle))\n",
    "    \n",
    "    # Draw nodes\n",
    "    for agent_id, pos in positions.items():\n",
    "        agent = peak_system.agents[agent_id]\n",
    "        color = 'green' if agent.agent.status == 'idle' else 'red'\n",
    "        ax7.scatter(pos[0], pos[1], s=200, c=color, alpha=0.7)\n",
    "        ax7.text(pos[0], pos[1] + 0.15, agent_id.split('_')[1], ha='center', fontsize=8)\n",
    "    \n",
    "    # Draw edges\n",
    "    for agent_id, agent in peak_system.agents.items():\n",
    "        for neighbor_id in agent.agent.neighbors:\n",
    "            if neighbor_id in positions:\n",
    "                pos1 = positions[agent_id]\n",
    "                pos2 = positions[neighbor_id]\n",
    "                ax7.plot([pos1[0], pos2[0]], [pos1[1], pos2[1]], 'gray', alpha=0.3, linewidth=1)\n",
    "    \n",
    "    ax7.set_xlim(-1.5, 1.5)\n",
    "    ax7.set_ylim(-1.5, 1.5)\n",
    "    ax7.set_aspect('equal')\n",
    "    ax7.set_title('Agent Communication Network')\n",
    "    ax7.axis('off')\n",
    "    \n",
    "    # 8. Nash Equilibrium Convergence\n",
    "    ax8 = axes[2, 1]\n",
    "    \n",
    "    if peak_auctions and len(peak_auctions) > 10:\n",
    "        # Calculate moving average of utilities to show convergence\n",
    "        utilities = [auction['best_utility'] for auction in peak_auctions]\n",
    "        window_size = 10\n",
    "        moving_avg = []\n",
    "        \n",
    "        for i in range(len(utilities)):\n",
    "            start_idx = max(0, i - window_size + 1)\n",
    "            avg = np.mean(utilities[start_idx:i+1])\n",
    "            moving_avg.append(avg)\n",
    "        \n",
    "        ax8.plot(moving_avg, 'g-', linewidth=2)\n",
    "        ax8.axhline(y=moving_avg[-1], color='red', linestyle='--', alpha=0.7, label='Final Equilibrium')\n",
    "        ax8.set_xlabel('Auction Number')\n",
    "        ax8.set_ylabel('Moving Average Utility')\n",
    "        ax8.set_title('Nash Equilibrium Convergence')\n",
    "        ax8.legend()\n",
    "        ax8.grid(True, alpha=0.3)\n",
    "    \n",
    "    # 9. Performance Metrics Comparison\n",
    "    ax9 = axes[2, 2]\n",
    "    \n",
    "    # Calculate key metrics\n",
    "    metrics = ['success_rate', 'avg_completion_time', 'coordination_overhead']\n",
    "    metric_names = ['Success Rate', 'Avg Completion Time', 'Coordination Overhead']\n",
    "    \n",
    "    peak_values = []\n",
    "    disruption_values = []\n",
    "    \n",
    "    # Success rate\n",
    "    peak_success = peak_df['success'].mean() if peak_df is not None else 0\n",
