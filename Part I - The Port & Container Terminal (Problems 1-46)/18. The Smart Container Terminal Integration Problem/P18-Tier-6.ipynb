    "    ax9.bar(x + width/2, disruption_values, width, label='Dynamic Disruption', alpha=0.7, color='lightcoral')\n",
    "    ax9.set_ylabel('Metric Value')\n",
    "    ax9.set_title('Performance Metrics Comparison')\n",
    "    ax9.set_xticks(x)\n",
    "    ax9.set_xticklabels(metric_names, rotation=45, ha='right')\n",
    "    ax9.legend()\n",
    "    ax9.grid(True, alpha=0.3)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
