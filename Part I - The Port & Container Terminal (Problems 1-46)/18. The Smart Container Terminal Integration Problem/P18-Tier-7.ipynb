    "def analyze_trust_development(sessions: List[CollaborationSession], experts: Dict[str, HumanExpertSystem]):\n",
    "    \"\"\"Analyze trust development over time\"\"\"\n",
    "    \n",
    "    print(\"\\n🤝 TRUST DEVELOPMENT ANALYSIS\")\n",
    "    print(\"=\" * 40)\n",
    "    \n",
    "    # Track trust level changes over sessions\n",
    "    trust_evolution = {}\n",
    "    \n",
    "    for expert_id, expert_system in experts.items():\n",
    "        expert = expert_system.expert\n",
    "        trust_evolution[expert_id] = {\n",
    "            'name': expert.name,\n",
    "            'initial_trust': TrustLevel.MEDIUM,  # All start at medium\n",
    "            'final_trust': expert.trust_level,\n",
    "            'total_decisions': expert.decisions_made,\n",
    "            'ai_agreements': expert.ai_agreements,\n",
    "            'successful_overrides': expert.successful_overrides,\n",
    "            'agreement_rate': expert.ai_agreements / expert.decisions_made if expert.decisions_made > 0 else 0\n",
    "        }\n",
    "    \n",
    "    print(\"\\n📈 TRUST EVOLUTION BY EXPERT:\")\n",
    "    for expert_id, evolution in trust_evolution.items():\n",
    "        print(f\"\\n  {evolution['name']}:\")\n",
    "        print(f\"    Initial Trust: {evolution['initial_trust'].value}\")\n",
    "        print(f\"    Final Trust: {evolution['final_trust'].value}\")\n",
    "        print(f\"    Total Decisions: {evolution['total_decisions']}\")\n",
    "        print(f\"    AI Agreements: {evolution['ai_agreements']} ({evolution['agreement_rate']:.1%})\")\n",
    "        print(f\"    Successful Overrides: {evolution['successful_overrides']}\")\n",
    "        \n",
    "        # Determine trust change\n",
    "        trust_change = \"No Change\"\n",
    "        if evolution['final_trust'].value > evolution['initial_trust'].value:\n",
    "            trust_change = \"Increased\"\n",
    "        elif evolution['final_trust'].value < evolution['initial_trust'].value:\n",
    "            trust_change = \"Decreased\"\n",
    "        \n",
    "        print(f\"    Trust Change: {trust_change}\")\n",
    "    \n",
    "    # Overall trust statistics\n",
    "    final_trust_levels = [evolution['final_trust'].value for evolution in trust_evolution.values()]\n",
    "    trust_distribution = pd.Series(final_trust_levels).value_counts()\n",
    "    \n",
    "    print(\"\\n🎯 FINAL TRUST DISTRIBUTION:\")\n",
    "    for trust_level, count in trust_distribution.items():\n",
    "        percentage = (count / len(trust_evolution)) * 100\n",
    "        print(f\"  {trust_level}: {count} experts ({percentage:.1f}%)\")\n",
    "    \n",
    "    # Correlate trust with performance\n",
    "    print(\"\\n📊 TRUST-PERFORMANCE CORRELATION:\")\n",
    "    \n",
    "    trust_performance_data = []\n",
    "    for expert_id, expert_system in experts.items():\n",
    "        expert = expert_system.expert\n",
    "        \n",
    "        # Get expert's decisions and outcomes\n",
    "        expert_decisions = [d for session in sessions for d in session.decisions if d.expert_id == expert_id]\n",
    "        \n",
    "        if expert_decisions:\n",
    "            # Calculate average performance for this expert\n",
    "            expert_sessions = [s for s in sessions if any(d.expert_id == expert_id for d in s.decisions)]\n",
    "            avg_performance = np.mean([s.satisfaction_score for s in expert_sessions])\n",
    "            \n",
    "            # Map trust to numeric\n",
    "            trust_numeric = {\n",
    "                TrustLevel.VERY_LOW: 0.1,\n",
    "                TrustLevel.LOW: 0.3,\n",
    "                TrustLevel.MEDIUM: 0.5,\n",
    "                TrustLevel.HIGH: 0.7,\n",
    "                TrustLevel.VERY_HIGH: 0.9\n",
    "            }[expert.trust_level]\n",
    "            \n",
    "            trust_performance_data.append({\n",
    "                'expert': expert.name,\n",
    "                'trust_numeric': trust_numeric,\n",
    "                'avg_performance': avg_performance,\n",
    "                'agreement_rate': expert.ai_agreements / expert.decisions_made if expert.decisions_made > 0 else 0\n",
    "            })\n",
    "    \n",
    "    if trust_performance_data:\n",
    "        df_tp = pd.DataFrame(trust_performance_data)\n",
    "        \n",
    "        # Calculate correlations\n",
    "        trust_performance_corr = df_tp['trust_numeric'].corr(df_tp['avg_performance'])\n",
    "        trust_agreement_corr = df_tp['trust_numeric'].corr(df_tp['agreement_rate'])\n",
    "        \n",
    "        print(f\"  Trust-Performance Correlation: {trust_performance_corr:.3f}\")\n",
    "        print(f\"  Trust-Agreement Correlation: {trust_agreement_corr:.3f}\")\n",
    "        \n",
    "        print(\"\\n  Individual Expert Data:\")\n",
    "        for _, row in df_tp.iterrows():\n",
    "            print(f\"    {row['expert']}: Trust={row['trust_numeric']:.2f}, Performance={row['avg_performance']:.3f}, Agreement={row['agreement_rate']:.2f}\")\n",
    "    \n",
    "    return trust_evolution, trust_performance_data\n",
    "\n",
    "# Analyze trust development\n",
    "trust_evolution, trust_performance_data = analyze_trust_development(sessions, collab_system.experts)"
   ]
