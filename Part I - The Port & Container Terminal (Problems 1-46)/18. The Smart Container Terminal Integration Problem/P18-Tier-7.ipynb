   "source": [
    "### Human-AI Partnership Data Structures"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class TrustLevel(Enum):\n",
    "    \"\"\"Trust level in AI recommendations\"\"\"\n",
    "    VERY_LOW = \"very_low\"\n",
    "    LOW = \"low\"\n",
    "    MEDIUM = \"medium\"\n",
    "    HIGH = \"high\"\n",
    "    VERY_HIGH = \"very_high\"\n",
    "\n",
    "class DecisionType(Enum):\n",
    "    \"\"\"Type of decision made\"\"\"\n",
    "    AI_ONLY = \"ai_only\"\n",
    "    HUMAN_ONLY = \"human_only\"\n",
    "    AI_SUGGESTED_HUMAN_APPROVED = \"ai_suggested_human_approved\"\n",
    "    AI_SUGGESTED_HUMAN_MODIFIED = \"ai_suggested_human_modified\"\n",
    "    HUMAN_AI_COLLABORATIVE = \"human_ai_collaborative\"\n",
    "\n",
    "@dataclass\n",
    "class HumanExpert:\n",
    "    \"\"\"Human expert with domain knowledge\"\"\"\n",
    "    expert_id: str\n",
    "    name: str\n",
    "    expertise_area: str  # 'vessel_operations', 'yard_management', 'safety', 'planning'\n",
    "    experience_years: int\n",
    "    trust_level: TrustLevel = TrustLevel.MEDIUM\n",
    "    confidence_threshold: float = 0.7  # Minimum AI confidence to auto-approve\n",
    "    \n",
    "    # Human characteristics\n",
    "    risk_tolerance: float = 0.5  # 0=conservative, 1=risk-taking\n",
    "    decision_speed: float = 0.5  # 0=deliberate, 1=fast\n",
    "    learning_rate: float = 0.1  # How quickly human learns from AI\n",
    "    \n",
    "    # Performance tracking\n",
    "    decisions_made: int = 0\n",
    "    ai_agreements: int = 0\n",
    "    successful_overrides: int = 0\n",
    "    \n",
    "    # Knowledge base\n",
    "    domain_knowledge: Dict[str, float] = field(default_factory=dict)\n",
    "    learned_patterns: List[str] = field(default_factory=list)\n",
    "\n",
    "@dataclass\n",
    "class AIRecommendation:\n",
    "    \"\"\"AI recommendation with explanation\"\"\"\n",
    "    recommendation_id: str\n",
    "    recommendation_type: str  # 'crane_assignment', 'schedule_adjustment', 'priority_change'\n",
    "    content: Dict[str, Any]\n",
    "    confidence: float  # 0-1\n",
    "    reasoning: List[str]  # Step-by-step explanation\n",
    "    supporting_data: Dict[str, Any]  # Data backing the recommendation\n",
    "    alternatives: List[Dict[str, Any]]  # Alternative options\n",
    "    risk_assessment: Dict[str, float]  # Risk factors and probabilities\n",
    "    expected_outcome: Dict[str, float]  # Expected results\n",
    "    timestamp: datetime\n",
    "\n",
    "@dataclass\n",
    "class HumanDecision:\n",
    "    \"\"\"Human decision on AI recommendation\"\"\"\n",
    "    decision_id: str\n",
    "    expert_id: str\n",
    "    recommendation_id: str\n",
    "    decision_type: DecisionType\n",
    "    final_action: Dict[str, Any]\n",
    "    reasoning: List[str]  # Human's reasoning\n",
    "    confidence: float  # Human's confidence in decision\n",
    "    time_to_decide: int  # Minutes to make decision\n",
    "    trust_impact: float  # How this decision affects trust in AI\n",
    "    timestamp: datetime\n",
    "\n",
    "@dataclass\n",
    "class CollaborationSession:\n",
    "    \"\"\"A collaboration session between human and AI\"\"\"\n",
    "    session_id: str\n",
    "    expert_id: str\n",
    "    start_time: datetime\n",
    "    end_time: Optional[datetime]\n",
    "    context: str  # Situation description\n",
    "    recommendations: List[AIRecommendation] = field(default_factory=list)\n",
    "    decisions: List[HumanDecision] = field(default_factory=list)\n",
    "    outcomes: Dict[str, Any] = field(default_factory=dict)\n",
    "    satisfaction_score: Optional[float] = None\n",
    "\n",
    "@dataclass\n",
    "class ExplainableAI:\n",
    "    \"\"\"Explainable AI system for transparent recommendations\"\"\"\n",
    "    ai_id: str\n",
    "    model_type: str  # 'optimization', 'prediction', 'classification'\n",
    "    capabilities: List[str]  # What the AI can do\n",
    "    \n",
    "    # Explainability components\n",
    "    feature_importance: Dict[str, float] = field(default_factory=dict)\n",
    "    decision_rules: List[str] = field(default_factory=list)\n",
    "    uncertainty_estimates: Dict[str, float] = field(default_factory=dict)\n",
    "    \n",
    "    # Learning and adaptation\n",
    "    human_feedback_history: List[Dict[str, Any]] = field(default_factory=list)\n",
    "    performance_metrics: Dict[str, float] = field(default_factory=dict)\n",
    "    adaptation_rate: float = 0.05\n",
    "\n",
    "print(\"✅ Human-AI Partnership data structures defined!\")"
   ]
  },
