    "    ax8.legend()\n",
    "    \n",
    "    # 9. Expert Specialization Performance\n",
    "    ax9 = axes[2, 2]\n",
    "    \n",
    "    # Group by expertise area\n",
    "    expertise_performance = {}\n",
    "    for expert_id, expert_system in experts.items():\n",
    "        expertise = expert_system.expert.expertise_area\n",
    "        expert_decisions = df_decisions[df_decisions['expert_id'] == expert_id]\n",
