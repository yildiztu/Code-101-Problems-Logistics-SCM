    "def analyze_collaboration_results(sessions: List[CollaborationSession], \n",
    "                               experts: Dict[str, HumanExpertSystem],\n",
    "                               xai_system: TerminalXAI):\n",
    "    \"\"\"Analyze human-AI collaboration results\"\"\"\n",
    "    \n",
    "    print(\"\\n📊 HUMAN-AI COLLABORATION ANALYSIS\")\n",
    "    print(\"=\" * 40)\n",
    "    \n",
    "    if not sessions:\n",
    "        print(\"❌ No sessions to analyze\")\n",
    "        return\n",
    "    \n",
    "    # Convert to DataFrames for analysis\n",
    "    decisions_data = []\n",
    "    outcomes_data = []\n",
    "    \n",
    "    for session in sessions:\n",
    "        for decision in session.decisions:\n",
    "            decisions_data.append({\n",
    "                'session_id': session.session_id,\n",
    "                'expert_id': decision.expert_id,\n",
    "                'decision_type': decision.decision_type.value,\n",
    "                'confidence': decision.confidence,\n",
    "                'time_to_decide': decision.time_to_decide,\n",
    "                'trust_impact': decision.trust_impact\n",
    "            })\n",
    "        \n",
    "        for decision_id, outcome in session.outcomes.items():\n",
    "            outcomes_data.append({\n",
    "                'session_id': session.session_id,\n",
    "                'decision_id': decision_id,\n",
    "                'success': outcome['success'],\n",
    "                'efficiency': outcome['efficiency'],\n",
    "                'safety_score': outcome['safety_score'],\n",
    "                'cost_efficiency': outcome['cost_efficiency'],\n",
    "                'overall_performance': outcome['overall_performance']\n",
    "            })\n",
    "    \n",
    "    df_decisions = pd.DataFrame(decisions_data)\n",
    "    df_outcomes = pd.DataFrame(outcomes_data)\n",
    "    \n",
    "    # Decision type analysis\n",
    "    print(\"\\n🎯 DECISION TYPE DISTRIBUTION:\")\n",
    "    decision_counts = df_decisions['decision_type'].value_counts()\n",
    "    for decision_type, count in decision_counts.items():\n",
    "        percentage = (count / len(df_decisions)) * 100\n",
    "        print(f\"  {decision_type}: {count} ({percentage:.1f}%)\")\n",
    "    \n",
    "    # Expert performance analysis\n",
    "    print(\"\\n👥 EXPERT PERFORMANCE ANALYSIS:\")\n",
    "    expert_performance = df_decisions.groupby('expert_id').agg({\n",
    "        'confidence': 'mean',\n",
    "        'time_to_decide': 'mean',\n",
    "        'trust_impact': 'mean'\n",
    "    }).round(3)\n",
    "    \n",
    "    for expert_id, performance in expert_performance.iterrows():\n",
    "        expert = experts[expert_id].expert\n",
    "        print(f\"  {expert.name}:\")\n",
    "        print(f\"    Confidence: {performance['confidence']:.3f}\")\n",
    "        print(f\"    Avg Decision Time: {performance['time_to_decide']:.1f} min\")\n",
    "        print(f\"    Trust Impact: {performance['trust_impact']:.3f}\")\n",
    "        print(f\"    Trust Level: {expert.trust_level.value}\")\n",
    "        print(f\"    AI Agreements: {expert.ai_agreements}/{expert.decisions_made} ({expert.ai_agreements/expert.decisions_made:.1%})\")\n",
    "    \n",
    "    # Success analysis by decision type\n",
    "    print(\"\\n✅ SUCCESS RATE BY DECISION TYPE:\")\n",
    "    \n",
    "    # Merge decisions and outcomes\n",
    "    df_combined = pd.merge(df_decisions, df_outcomes, on='session_id')\n",
    "    \n",
    "    success_by_type = df_combined.groupby('decision_type')['success'].mean()\n",
    "    for decision_type, success_rate in success_by_type.items():\n",
    "        print(f\"  {decision_type}: {success_rate:.3f}\")\n",
    "    \n",
    "    # Satisfaction analysis\n",
    "    print(\"\\n😊 SATISFACTION ANALYSIS:\")\n",
    "    satisfaction_scores = [s.satisfaction_score for s in sessions]\n",
    "    print(f\"  Average Satisfaction: {np.mean(satisfaction_scores):.3f}\")\n",
    "    print(f\"  Satisfaction Std Dev: {np.std(satisfaction_scores):.3f}\")\n",
    "    print(f\"  Min Satisfaction: {np.min(satisfaction_scores):.3f}\")\n",
    "    print(f\"  Max Satisfaction: {np.max(satisfaction_scores):.3f}\")\n",
    "    \n",
    "    # AI learning analysis\n",
    "    print(\"\\n🧠 AI LEARNING ANALYSIS:\")\n",
    "    feedback_history = xai_system.xai.human_feedback_history\n",
    "    if feedback_history:\n",
    "        print(f\"  Total Feedback Events: {len(feedback_history)}\")\n",
    "        \n",
    "        # Analyze trust impact trends\n",
    "        trust_impacts = [f['trust_impact'] for f in feedback_history]\n",
    "        avg_trust_impact = np.mean(trust_impacts)\n",
    "        print(f\"  Average Trust Impact: {avg_trust_impact:.3f}\")\n",
    "        \n",
    "        # Feature importance changes\n",
    "        print(f\"  Current Feature Importance:\")\n",
    "        for feature, importance in xai_system.xai.feature_importance.items():\n",
    "            print(f\"    {feature}: {importance:.3f}\")\n",
    "    \n",
    "    # Performance metrics\n",
    "    print(\"\\n📈 PERFORMANCE METRICS:\")\n",
    "    if not df_outcomes.empty:\n",
    "        print(f\"  Overall Success Rate: {df_outcomes['success'].mean():.3f}\")\n",
    "        print(f\"  Average Efficiency: {df_outcomes['efficiency'].mean():.3f}\")\n",
    "        print(f\"  Average Safety Score: {df_outcomes['safety_score'].mean():.3f}\")\n",
    "        print(f\"  Average Cost Efficiency: {df_outcomes['cost_efficiency'].mean():.3f}\")\n",
    "        print(f\"  Average Overall Performance: {df_outcomes['overall_performance'].mean():.3f}\")\n",
    "    \n",
    "    return df_decisions, df_outcomes, df_combined\n",
    "\n",
    "# Analyze collaboration results\n",
    "df_decisions, df_outcomes, df_combined = analyze_collaboration_results(sessions, collab_system.experts, collab_system.xai_system)"
   ]
