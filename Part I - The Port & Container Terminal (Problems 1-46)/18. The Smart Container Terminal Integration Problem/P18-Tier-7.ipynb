    "class HumanExpertSystem:\n",
    "    \"\"\"Human expert with domain knowledge and decision-making capabilities\"\"\"\n",
    "    \n",
    "    def __init__(self, expert: HumanExpert):\n",
    "        self.expert = expert\n",
    "        \n",
    "        # Initialize domain knowledge based on experience\n",
    "        self._initialize_domain_knowledge()\n",
    "    \n",
    "    def _initialize_domain_knowledge(self):\n",
    "        \"\"\"Initialize expert's domain knowledge based on experience\"\"\"\n",
    "        \n",
    "        # Knowledge based on expertise area and experience\n",
    "        if self.expert.expertise_area == 'vessel_operations':\n",
    "            self.expert.domain_knowledge = {\n",
    "                'vessel_handling': min(1.0, self.expert.experience_years / 20),\n",
    "                'berth_optimization': min(1.0, self.expert.experience_years / 15),\n",
    "                'cargo_priority': min(1.0, self.expert.experience_years / 10),\n",
    "                'weather_impact': min(1.0, self.expert.experience_years / 12)\n",
    "            }\n",
    "        elif self.expert.expertise_area == 'yard_management':\n",
    "            self.expert.domain_knowledge = {\n",
    "                'crane_coordination': min(1.0, self.expert.experience_years / 15),\n",
    "                'block_optimization': min(1.0, self.expert.experience_years / 18),\n",
    "                'container_stacking': min(1.0, self.expert.experience_years / 12),\n",
    "                'equipment_maintenance': min(1.0, self.expert.experience_years / 10)\n",
    "            }\n",
    "        elif self.expert.expertise_area == 'safety':\n",
    "            self.expert.domain_knowledge = {\n",
    "                'risk_assessment': min(1.0, self.expert.experience_years / 8),\n",
    "                'safety_protocols': min(1.0, self.expert.experience_years / 10),\n",
    "                'emergency_response': min(1.0, self.expert.experience_years / 12),\n",
    "                'regulatory_compliance': min(1.0, self.expert.experience_years / 15)\n",
    "            }\n",
    "        else:  # planning\n",
    "            self.expert.domain_knowledge = {\n",
    "                'strategic_planning': min(1.0, self.expert.experience_years / 12),\n",
    "                'resource_allocation': min(1.0, self.expert.experience_years / 10),\n",
    "                'demand_forecasting': min(1.0, self.expert.experience_years / 15),\n",
    "                'cost_optimization': min(1.0, self.expert.experience_years / 8)\n",
    "            }\n",
    "    \n",
    "    def evaluate_ai_recommendation(self, recommendation: AIRecommendation, context: Dict[str, Any]) -> HumanDecision:\n",
    "        \"\"\"Evaluate AI recommendation and make decision\"\"\"\n",
    "        \n",
    "        # Start decision timer\n",
    "        decision_start = time.time()\n",
    "        \n",
    "        # Analyze recommendation based on domain knowledge\n",
    "        domain_relevance = self._assess_domain_relevance(recommendation)\n",
    "        \n",
    "        # Evaluate reasoning quality\n",
    "        reasoning_quality = self._evaluate_reasoning(recommendation.reasoning)\n",
    "        \n",
    "        # Assess risk factors\n",
    "        risk_assessment = self._assess_risks(recommendation.risk_assessment, context)\n",
    "        \n",
    "        # Consider confidence and trust\n",
    "        trust_factor = self._calculate_trust_factor(recommendation.confidence)\n",
    "        \n",
    "        # Make decision\n",
    "        decision_score = (domain_relevance * 0.3 + \n",
    "                          reasoning_quality * 0.25 + \n",
    "                          (1 - risk_assessment) * 0.25 + \n",
    "                          trust_factor * 0.2)\n",
    "        \n",
    "        # Determine decision type\n",
    "        if recommendation.confidence >= self.expert.confidence_threshold and decision_score > 0.8:\n",
    "            decision_type = DecisionType.AI_SUGGESTED_HUMAN_APPROVED\n",
    "            final_action = recommendation.content\n",
    "            human_reasoning = [\"AI recommendation aligns with my expertise and experience\"]\n",
    "            confidence = recommendation.confidence\n",
    "            trust_impact = 0.1  # Positive impact\n",
    "        \n",
    "        elif decision_score > 0.6:\n",
    "            decision_type = DecisionType.AI_SUGGESTED_HUMAN_MODIFIED\n",
    "            final_action = self._modify_recommendation(recommendation, context)\n",
    "            human_reasoning = [\"AI recommendation is good but needs adjustment based on my experience\"]\n",
    "            confidence = min(0.95, recommendation.confidence + 0.1)\n",
    "            trust_impact = 0.05  # Slightly positive\n",
    "        \n",
    "        elif decision_score > 0.4:\n",
    "            decision_type = DecisionType.HUMAN_AI_COLLABORATIVE\n",
    "            final_action = self._collaborative_decision(recommendation, context)\n",
    "            human_reasoning = [\"Need to combine AI insights with my domain knowledge\"]\n",
    "            confidence = 0.75\n",
    "            trust_impact = 0.0  # Neutral\n",
    "        \n",
    "        else:\n",
    "            decision_type = DecisionType.HUMAN_ONLY\n",
    "            final_action = self._make_human_decision(context)\n",
    "            human_reasoning = [\"AI recommendation doesn't account for critical factors I'm aware of\"]\n",
    "            confidence = 0.80\n",
    "            trust_impact = -0.1  # Negative impact\n",
    "        \n",
    "        # Calculate decision time\n",
    "        decision_time = int((time.time() - decision_start) * 60)  # Convert to minutes\n",
    "        \n",
    "        # Update expert statistics\n",
    "        self.expert.decisions_made += 1\n",
    "        if decision_type in [DecisionType.AI_SUGGESTED_HUMAN_APPROVED, DecisionType.AI_SUGGESTED_HUMAN_MODIFIED]:\n",
    "            self.expert.ai_agreements += 1\n",
    "        \n",
    "        # Update trust level\n",
    "        self._update_trust_level(trust_impact)\n",
    "        \n",
    "        return HumanDecision(\n",
    "            decision_id=f\"dec_{datetime.now().strftime('%Y%m%d_%H%M%S')}\",\n",
    "            expert_id=self.expert.expert_id,\n",
    "            recommendation_id=recommendation.recommendation_id,\n",
    "            decision_type=decision_type,\n",
    "            final_action=final_action,\n",
    "            reasoning=human_reasoning,\n",
    "            confidence=confidence,\n",
    "            time_to_decide=decision_time,\n",
    "            trust_impact=trust_impact,\n",
    "            timestamp=datetime.now()\n",
    "        )\n",
    "    \n",
    "    def _assess_domain_relevance(self, recommendation: AIRecommendation) -> float:\n",
    "        \"\"\"Assess how relevant the recommendation is to expert's domain\"\"\"\n",
    "        \n",
    "        if recommendation.recommendation_type == 'crane_assignment' and self.expert.expertise_area == 'yard_management':\n",
    "            return self.expert.domain_knowledge.get('crane_coordination', 0.5)\n",
    "        elif recommendation.recommendation_type == 'schedule_optimization' and self.expert.expertise_area == 'planning':\n",
    "            return self.expert.domain_knowledge.get('strategic_planning', 0.5)\n",
    "        elif 'vessel' in str(recommendation.content) and self.expert.expertise_area == 'vessel_operations':\n",
    "            return self.expert.domain_knowledge.get('vessel_handling', 0.5)\n",
    "        elif 'risk' in str(recommendation.risk_assessment) and self.expert.expertise_area == 'safety':\n",
    "            return self.expert.domain_knowledge.get('risk_assessment', 0.5)\n",
    "        else:\n",
    "            return 0.5  # Moderate relevance for other cases\n",
    "    \n",
    "    def _evaluate_reasoning(self, reasoning: List[str]) -> float:\n",
    "        \"\"\"Evaluate the quality of AI reasoning\"\"\"\n",
    "        \n",
    "        # Check reasoning completeness\n",
    "        completeness = min(1.0, len(reasoning) / 5)  # Expect at least 5 reasoning points\n",
    "        \n",
    "        # Check for quantitative reasoning\n",
    "        quantitative_score = sum(1 for r in reasoning if any(char.isdigit() for char in r)) / len(reasoning)\n",
    "        \n",
    "        # Check for domain-specific terms\n",
    "        domain_terms = ['vessel', 'crane', 'block', 'priority', 'risk', 'safety', 'schedule']\n",
    "        domain_score = sum(1 for r in reasoning if any(term in r.lower() for term in domain_terms)) / len(reasoning)\n",
    "        \n",
    "        return (completeness * 0.4 + quantitative_score * 0.3 + domain_score * 0.3)\n",
    "    \n",
    "    def _assess_risks(self, risk_assessment: Dict[str, float], context: Dict[str, Any]) -> float:\n",
    "        \"\"\"Assess risk factors based on expert knowledge\"\"\"\n",
    "        \n",
    "        total_risk = sum(risk_assessment.values()) / len(risk_assessment) if risk_assessment else 0\n",
    "        \n",
    "        # Adjust based on expert's risk tolerance\n",
    "        if self.expert.risk_tolerance > 0.7:  # Risk-taking\n",
    "            total_risk *= 0.8\n",
    "        elif self.expert.risk_tolerance < 0.3:  # Conservative\n",
    "            total_risk *= 1.2\n",
    "        \n",
    "        return min(1.0, total_risk)\n",
    "    \n",
    "    def _calculate_trust_factor(self, ai_confidence: float) -> float:\n",
    "        \"\"\"Calculate trust factor based on AI confidence and expert's trust level\"\"\"\n",
    "        \n",
    "        # Map trust level to numeric value\n",
    "        trust_values = {\n",
    "            TrustLevel.VERY_LOW: 0.1,\n",
    "            TrustLevel.LOW: 0.3,\n",
    "            TrustLevel.MEDIUM: 0.5,\n",
    "            TrustLevel.HIGH: 0.7,\n",
    "            TrustLevel.VERY_HIGH: 0.9\n",
    "        }\n",
    "        \n",
    "        trust_value = trust_values[self.expert.trust_level]\n",
    "        \n",
    "        # Combine AI confidence and trust\n",
    "        return (ai_confidence * 0.6 + trust_value * 0.4)\n",
    "    \n",
    "    def _modify_recommendation(self, recommendation: AIRecommendation, context: Dict[str, Any]) -> Dict[str, Any]:\n",
    "        \"\"\"Modify AI recommendation based on expert knowledge\"\"\"\n",
    "        \n",
    "        modified_action = recommendation.content.copy()\n",
    "        \n",
    "        # Apply expert-specific modifications\n",
    "        if self.expert.expertise_area == 'safety':\n",
    "            # Add safety margin\n",
    "            if 'risk_level' in modified_action:\n",
    "                if modified_action['risk_level'] == 'low':\n",
    "                    modified_action['risk_level'] = 'medium'\n",
    "                elif modified_action['risk_level'] == 'medium':\n",
    "                    modified_action['risk_level'] = 'high'\n",
    "            \n",
    "            modified_action['safety_measures'] = 'enhanced_monitoring'\n",
    "        \n",
    "        elif self.expert.expertise_area == 'yard_management':\n",
    "            # Optimize for crane utilization\n",
    "            if 'available_cranes' in modified_action:\n",
    "                modified_action['crane_optimization'] = 'load_balancing'\n",
    "        \n",
    "        return modified_action\n",
    "    \n",
    "    def _collaborative_decision(self, recommendation: AIRecommendation, context: Dict[str, Any]) -> Dict[str, Any]:\n",
    "        \"\"\"Make collaborative decision combining AI and human insights\"\"\"\n",
    "        \n",
    "        collaborative_action = recommendation.content.copy()\n",
    "        \n",
    "        # Add human insights\n",
    "        collaborative_action['human_insights'] = 'applied'\n",
    "        collaborative_action['ai_insights'] = 'considered'\n",
    "        collaborative_action['decision_approach'] = 'collaborative'\n",
    "        \n",
    "        return collaborative_action\n",
    "    \n",
    "    def _make_human_decision(self, context: Dict[str, Any]) -> Dict[str, Any]:\n",
    "        \"\"\"Make decision based purely on human expertise\"\"\"\n",
    "        \n",
    "        # Simplified human decision logic\n",
    "        if self.expert.expertise_area == 'vessel_operations':\n",
    "            return {\n",
    "                'action': 'Prioritize vessel operations based on captain communication',\n",
    "                'decision_source': 'human_expertise',\n",
    "                'reasoning': 'Vessel captain indicated special requirements'\n",
    "            }\n",
    "        elif self.expert.expertise_area == 'safety':\n",
    "            return {\n",
    "                'action': 'Implement enhanced safety protocols',\n",
    "                'decision_source': 'human_expertise',\n",
    "                'reasoning': 'Weather patterns suggest increased risk'\n",
    "            }\n",
    "        else:\n",
    "            return {\n",
    "                'action': 'Follow standard operating procedures',\n",
    "                'decision_source': 'human_expertise',\n",
    "                'reasoning': 'Current conditions within normal parameters'\n",
    "            }\n",
    "    \n",
    "    def _update_trust_level(self, trust_impact: float):\n",
    "        \"\"\"Update trust level based on decision outcome\"\"\"\n",
    "        \n",
    "        # Simple trust level update logic\n",
    "        if trust_impact > 0.05:  # Positive impact\n",
    "            if self.expert.trust_level == TrustLevel.VERY_LOW:\n",
    "                self.expert.trust_level = TrustLevel.LOW\n",
    "            elif self.expert.trust_level == TrustLevel.LOW:\n",
    "                self.expert.trust_level = TrustLevel.MEDIUM\n",
    "            elif self.expert.trust_level == TrustLevel.MEDIUM:\n",
    "                self.expert.trust_level = TrustLevel.HIGH\n",
    "            elif self.expert.trust_level == TrustLevel.HIGH:\n",
    "                self.expert.trust_level = TrustLevel.VERY_HIGH\n",
    "        elif trust_impact < -0.05:  # Negative impact\n",
    "            if self.expert.trust_level == TrustLevel.VERY_HIGH:\n",
    "                self.expert.trust_level = TrustLevel.HIGH\n",
    "            elif self.expert.trust_level == TrustLevel.HIGH:\n",
    "                self.expert.trust_level = TrustLevel.MEDIUM\n",
    "            elif self.expert.trust_level == TrustLevel.MEDIUM:\n",
    "                self.expert.trust_level = TrustLevel.LOW\n",
    "            elif self.expert.trust_level == TrustLevel.LOW:\n",
    "                self.expert.trust_level = TrustLevel.VERY_LOW\n",
    "    \n",
    "    def learn_from_outcome(self, decision: HumanDecision, outcome_success: bool):\n",
    "        \"\"\"Learn from decision outcome\"\"\"\n",
    "        \n",
    "        if outcome_success:\n",
    "            self.expert.successful_overrides += 1\n",
    "            \n",
    "            # Update confidence threshold\n",
    "            if decision.decision_type == DecisionType.AI_SUGGESTED_HUMAN_APPROVED:\n",
    "                self.expert.confidence_threshold = max(0.5, self.expert.confidence_threshold - 0.01)\n",
    "            elif decision.decision_type == DecisionType.HUMAN_ONLY:\n",
    "                self.expert.confidence_threshold = min(0.9, self.expert.confidence_threshold + 0.02)\n",
    "        \n",
    "        # Add to learned patterns\n",
    "        pattern = f\"{decision.decision_type.value}_{'success' if outcome_success else 'failure'}\"\n",
    "        if pattern not in self.expert.learned_patterns:\n",
    "            self.expert.learned_patterns.append(pattern)\n",
    "\n",
    "print(\"✅ Human Expert System defined!\")"
   ]
  },
