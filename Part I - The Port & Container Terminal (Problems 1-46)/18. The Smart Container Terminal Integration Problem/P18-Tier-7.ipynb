   "source": [
    "class HumanAICollaborationSystem:\n",
    "    \"\"\"Human-AI collaboration system for terminal operations\"\"\"\n",
    "    \n",
    "    def __init__(self, num_experts: int = 5):\n",
    "        self.num_experts = num_experts\n",
    "        self.xai_system = TerminalXAI(\"terminal_xai_001\")\n",
    "        self.experts: Dict[str, HumanExpertSystem] = {}\n",
    "        self.collaboration_sessions: List[CollaborationSession] = []\n",
    "        self.current_time = datetime.now()\n",
    "        \n",
    "        # System metrics\n",
    "        total_decisions = 0\n",
    "        ai_agreements = 0\n",
    "        human_overrides = 0\n",
    "        collaboration_outcomes = []\n",
    "        \n",
    "        # Initialize experts\n",
    "        self._initialize_experts()\n",
    "    \n",
    "    def _initialize_experts(self):\n",
    "        \"\"\"Initialize human experts with different specializations\"\"\"\n",
    "        print(f\"👥 Initializing {self.num_experts} human experts...\")\n",
    "        \n",
    "        expertise_areas = ['vessel_operations', 'yard_management', 'safety', 'planning', 'vessel_operations']\n",
    "        names = ['Sarah Chen', 'Marco Rodriguez', 'Elena Petrov', 'David Kim', 'Lisa Johnson']\n",
    "        \n",
    "        for i in range(self.num_experts):\n",
    "            expert = HumanExpert(\n",
    "                expert_id=f\"expert_{i+1}\",\n",
    "                name=names[i],\n",
    "                expertise_area=expertise_areas[i],\n",
    "                experience_years=np.random.randint(5, 25),\n",
    "                trust_level=np.random.choice([TrustLevel.MEDIUM, TrustLevel.HIGH, TrustLevel.VERY_HIGH]),\n",
    "                confidence_threshold=np.random.uniform(0.6, 0.85),\n",
    "                risk_tolerance=np.random.uniform(0.3, 0.8),\n",
    "                decision_speed=np.random.uniform(0.4, 0.9)\n",
    "            )\n",
    "            \n",
    "            expert_system = HumanExpertSystem(expert)\n",
    "            self.experts[expert.expert_id] = expert_system\n",
    "        \n",
    "        print(f\"✅ Initialized {len(self.experts)} experts:\")\n",
    "        for expert_id, expert_system in self.experts.items():\n",
    "            expert = expert_system.expert\n",
    "            print(f\"   - {expert.name} ({expert.expertise_area}, {expert.experience_years} years, Trust: {expert.trust_level.value})\")\n",
    "    \n",
    "    def create_collaboration_session(self, context: Dict[str, Any]) -> CollaborationSession:\n",
    "        \"\"\"Create a new collaboration session\"\"\"\n",
    "        \n",
    "        session = CollaborationSession(\n",
    "            session_id=f\"session_{datetime.now().strftime('%Y%m%d_%H%M%S')}\",\n",
    "            expert_id=np.random.choice(list(self.experts.keys())),\n",
    "            start_time=self.current_time,\n",
    "            end_time=None,\n",
    "            context=context.get('description', 'Terminal operations decision')\n",
    "        )\n",
    "        \n",
    "        return session\n",
    "    \n",
    "    def run_collaboration_session(self, session: CollaborationSession, context: Dict[str, Any]) -> CollaborationSession:\n",
    "        \"\"\"Run a complete collaboration session\"\"\"\n",
    "        \n",
    "        print(f\"\\n🤝 Running Collaboration Session {session.session_id}\")\n",
    "        print(f\"   Expert: {self.experts[session.expert_id].expert.name}\")\n",
    "        print(f\"   Context: {session.context}\")\n",
    "        \n",
    "        expert_system = self.experts[session.expert_id]\n",
    "        \n",
    "        # Generate AI recommendations\n",
    "        recommendations = []\n",
    "        \n",
    "        # Recommendation 1: Crane assignment\n",
    "        if 'crane_assignment' in context or np.random.random() < 0.7:\n",
    "            crane_context = {\n",
    "                'vessel_priority': context.get('vessel_priority', np.random.choice([1, 2, 3])),\n",
    "                'available_cranes': context.get('available_cranes', np.random.randint(3, 8)),\n",
    "                'weather_conditions': context.get('weather_conditions', np.random.choice(['normal', 'poor', 'severe'])),\n",
    "                'crew_experience': context.get('crew_experience', np.random.randint(1, 15)),\n",
    "                'truck_congestion': context.get('truck_congestion', np.random.uniform(0.3, 0.9))\n",
    "            }\n",
    "            \n",
    "            crane_rec = self.xai_system.generate_crane_assignment_recommendation(crane_context)\n",
    "            recommendations.append(crane_rec)\n",
    "        \n",
    "        # Recommendation 2: Schedule optimization\n",
    "        if 'schedule_optimization' in context or np.random.random() < 0.6:\n",
    "            schedule_context = {\n",
    "                'current_schedule': context.get('current_schedule', []),\n",
    "                'bottlenecks': context.get('bottlenecks', [f\"bottleneck_{i}\" for i in range(np.random.randint(0, 5))]),\n",
    "                'optimization_goal': context.get('optimization_goal', 'minimize_delay')\n",
    "            }\n",
    "            \n",
    "            schedule_rec = self.xai_system.generate_schedule_optimization_recommendation(schedule_context)\n",
    "            recommendations.append(schedule_rec)\n",
    "        \n",
    "        session.recommendations = recommendations\n",
    "        \n",
    "        # Process each recommendation\n",
    "        decisions = []\n",
    "        \n",
    "        for recommendation in recommendations:\n",
    "            print(f\"\\n📋 Processing AI Recommendation:\")\n",
    "            print(f\"   Type: {recommendation.recommendation_type}\")\n",
    "            print(f\"   Confidence: {recommendation.confidence:.2f}\")\n",
    "            print(f\"   Action: {recommendation.content.get('action', 'N/A')}\")\n",
    "            \n",
    "            # Get human decision\n",
    "            decision = expert_system.evaluate_ai_recommendation(recommendation, context)\n",
    "            decisions.append(decision)\n",
    "            \n",
    "            print(f\"   Human Decision: {decision.decision_type.value}\")\n",
    "            print(f\"   Human Confidence: {decision.confidence:.2f}\")\n",
    "            print(f\"   Time to Decide: {decision.time_to_decide} minutes\")\n",
    "            \n",
    "            # AI learns from feedback\n",
    "            self.xai_system.learn_from_feedback(recommendation, decision)\n",
    "        \n",
    "        session.decisions = decisions\n",
    "        \n",
    "        # Simulate outcomes\n",
    "        outcomes = self._simulate_outcomes(decisions)\n",
    "        session.outcomes = outcomes\n",
    "        \n",
    "        # Update expert learning\n",
    "        for decision in decisions:\n",
    "            outcome_success = outcomes.get(decision.decision_id, {}).get('success', True)\n",
    "            expert_system.learn_from_outcome(decision, outcome_success)\n",
    "        \n",
    "        # Calculate satisfaction score\n",
    "        session.satisfaction_score = self._calculate_satisfaction_score(session)\n",
    "        \n",
    "        session.end_time = self.current_time\n",
    "        \n",
    "        print(f\"\\n📊 Session Results:\")\n",
    "        print(f\"   Satisfaction Score: {session.satisfaction_score:.2f}\")\n",
    "        print(f\"   AI Agreement Rate: {sum(1 for d in decisions if d.decision_type in [DecisionType.AI_SUGGESTED_HUMAN_APPROVED, DecisionType.AI_SUGGESTED_HUMAN_MODIFIED]) / len(decisions):.2%}\")\n",
    "        \n",
    "        return session\n",
    "    \n",
    "    def _simulate_outcomes(self, decisions: List[HumanDecision]) -> Dict[str, Any]:\n",
    "        \"\"\"Simulate outcomes of human decisions\"\"\"\n",
    "        \n",
    "        outcomes = {}\n",
    "        \n",
    "        for decision in decisions:\n",
    "            # Simulate success based on decision type and confidence\n",
    "            if decision.decision_type == DecisionType.AI_SUGGESTED_HUMAN_APPROVED:\n",
    "                success_probability = decision.confidence * 0.9\n",
    "            elif decision.decision_type == DecisionType.AI_SUGGESTED_HUMAN_MODIFIED:\n",
    "                success_probability = decision.confidence * 0.85\n",
    "            elif decision.decision_type == DecisionType.HUMAN_AI_COLLABORATIVE:\n",
    "                success_probability = decision.confidence * 0.88\n",
    "            elif decision.decision_type == DecisionType.HUMAN_ONLY:\n",
    "                success_probability = decision.confidence * 0.75\n",
    "            else:  # AI_ONLY\n",
    "                success_probability = decision.confidence * 0.82\n",
    "            \n",
    "            success = np.random.random() < success_probability\n",
    "            \n",
    "            # Calculate performance metrics\n",
    "            if success:\n",
    "                efficiency = np.random.uniform(0.8, 1.0)\n",
    "                safety_score = np.random.uniform(0.85, 1.0)\n",
    "                cost_efficiency = np.random.uniform(0.75, 0.95)\n",
    "            else:\n",
    "                efficiency = np.random.uniform(0.5, 0.8)\n",
    "                safety_score = np.random.uniform(0.7, 0.9)\n",
    "                cost_efficiency = np.random.uniform(0.6, 0.8)\n",
    "            \n",
    "            outcomes[decision.decision_id] = {\n",
    "                'success': success,\n",
    "                'efficiency': efficiency,\n",
    "                'safety_score': safety_score,\n",
    "                'cost_efficiency': cost_efficiency,\n",
    "                'overall_performance': (efficiency + safety_score + cost_efficiency) / 3\n",
    "            }\n",
    "        \n",
    "        return outcomes\n",
    "    \n",
    "    def _calculate_satisfaction_score(self, session: CollaborationSession) -> float:\n",
    "        \"\"\"Calculate satisfaction score for the session\"\"\"\n",
    "        \n",
    "        if not session.decisions:\n",
    "            return 0.5\n",
    "        \n",
    "        # Factors affecting satisfaction\n",
    "        outcomes = session.outcomes\n",
    "        \n",
    "        # Performance factor\n",
    "        performance_scores = [outcome.get('overall_performance', 0.5) for outcome in outcomes.values()]\n",
    "        avg_performance = np.mean(performance_scores)\n",
    "        \n",
    "        # Agreement factor (human satisfaction with AI)\n",
    "        ai_agreements = sum(1 for d in session.decisions if d.decision_type in [DecisionType.AI_SUGGESTED_HUMAN_APPROVED, DecisionType.AI_SUGGESTED_HUMAN_MODIFIED])\n",
    "        agreement_rate = ai_agreements / len(session.decisions)\n",
    "        \n",
    "        # Time efficiency factor\n",
    "        avg_decision_time = np.mean([d.time_to_decide for d in session.decisions])\n",
    "        time_efficiency = max(0, 1 - avg_decision_time / 30)  # 30 minutes is considered slow\n",
    "        \n",
    "        # Confidence factor\n",
    "        avg_confidence = np.mean([d.confidence for d in session.decisions])\n",
    "        \n",
    "        # Calculate weighted satisfaction score\n",
    "        satisfaction = (avg_performance * 0.4 + \n",
    "                       agreement_rate * 0.3 + \n",
    "                       time_efficiency * 0.2 + \n",
    "                       avg_confidence * 0.1)\n",
    "        \n",
    "        return satisfaction\n",
    "    \n",
    "    def run_simulation(self, num_sessions: int):\n",
    "        \"\"\"Run multiple collaboration sessions\"\"\"\n",
    "        print(f\"🚀 Running Human-AI Collaboration Simulation with {num_sessions} sessions...\")\n",
    "        \n",
    "        start_time = time.time()\n",
    "        \n",
    "        for i in range(num_sessions):\n",
    "            # Generate context\n",
    "            context = self._generate_session_context(i)\n",
    "            \n",
    "            # Create and run session\n",
    "            session = self.create_collaboration_session(context)\n",
    "            completed_session = self.run_collaboration_session(session, context)\n",
    "            \n",
    "            self.collaboration_sessions.append(completed_session)\n",
    "            \n",
    "            # Update time\n",
    "            self.current_time += timedelta(hours=1)\n",
    "            \n",
    "            # Progress update\n",
    "            if (i + 1) % 10 == 0:\n",
    "                print(f\"  ⏰ Session {i + 1}/{num_sessions} completed\")\n",
    "        \n",
    "        end_time = time.time()\n",
    "        \n",
    "        print(f\"✅ Simulation completed in {end_time - start_time:.2f} seconds\")\n",
    "        print(f\"📊 Completed {len(self.collaboration_sessions)} collaboration sessions\")\n",
    "        \n",
    "        return self.collaboration_sessions\n",
    "    \n",
    "    def _generate_session_context(self, session_index: int) -> Dict[str, Any]:\n",
    "        \"\"\"Generate context for a collaboration session\"\"\"\n",
    "        \n",
    "        # Vary context based on session index to create different scenarios\n",
    "        scenario_type = session_index % 4\n",
    "        \n",
    "        if scenario_type == 0:  # Normal operations\n",
    "            return {\n",
    "                'description': 'Routine terminal operations',\n",
    "                'vessel_priority': np.random.choice([1, 2]),\n",
    "                'available_cranes': np.random.randint(4, 7),\n",
    "                'weather_conditions': 'normal',\n",
    "                'crew_experience': np.random.randint(5, 15)\n",
    "            }\n",
    "        elif scenario_type == 1:  # High priority vessel\n",
    "            return {\n",
    "                'description': 'High priority vessel arrival',\n",
    "                'vessel_priority': 3,\n",
    "                'available_cranes': np.random.randint(2, 5),\n",
    "                'weather_conditions': np.random.choice(['normal', 'poor']),\n",
    "                'crew_experience': np.random.randint(3, 12),\n",
    "                'priority_vessels': 2\n",
    "            }\n",
    "        elif scenario_type == 2:  # Weather disruption\n",
    "            return {\n",
    "                'description': 'Weather-related disruption',\n",
    "                'vessel_priority': np.random.choice([1, 2]),\n",
    "                'available_cranes': np.random.randint(2, 4),\n",
    "                'weather_conditions': np.random.choice(['poor', 'severe']),\n",
    "                'crew_experience': np.random.randint(2, 10),\n",
    "                'crane_assignment': True\n",
    "            }\n",
    "        else:  # Schedule optimization\n",
    "            return {\n",
    "                'description': 'Schedule optimization needed',\n",
    "                'bottlenecks': [f\"bottleneck_{i}\" for i in range(np.random.randint(2, 6))],\n",
    "                'optimization_goal': 'minimize_delay',\n",
    "                'schedule_optimization': True,\n",
    "                'current_schedule': 'suboptimal'\n",
    "            }\n",
    "\n",
    "print(\"✅ Human-AI Collaboration System defined!\")"
   ]
  },
