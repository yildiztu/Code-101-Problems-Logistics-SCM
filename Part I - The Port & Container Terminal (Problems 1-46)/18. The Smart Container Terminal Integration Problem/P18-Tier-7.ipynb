   "source": [
    "class TerminalXAI:\n",
    "    \"\"\"Explainable AI for terminal operations\"\"\"\n",
    "    \n",
    "    def __init__(self, ai_id: str):\n",
    "        self.xai = ExplainableAI(\n",
    "            ai_id=ai_id,\n",
    "            model_type=\"optimization\",\n",
    "            capabilities=[\"crane_assignment\", \"schedule_optimization\", \"risk_assessment\", \"priority_ranking\"]\n",
    "        )\n",
    "        \n",
    "        # Initialize feature importance (learned from historical data)\n",
    "        self.xai.feature_importance = {\n",
    "            'vessel_priority': 0.25,\n",
    "            'crane_availability': 0.20,\n",
    "            'weather_conditions': 0.15,\n",
    "            'truck_congestion': 0.12,\n",
    "            'block_utilization': 0.10,\n",
    "            'crew_experience': 0.08,\n",
    "            'equipment_age': 0.06,\n",
    "            'time_of_day': 0.04\n",
    "        }\n",
    "        \n",
    "        # Initialize decision rules\n",
    "        self.xai.decision_rules = [\n",
    "            \"IF vessel_priority = high AND crane_availability < 30% THEN prioritize vessel_operations\",\n",
    "            \"IF weather_conditions = severe AND crew_experience < 2 years THEN increase safety_margin\",\n",
    "            \"IF truck_congestion > 80% AND time_of_day = peak THEN reassign trucks to less_congested_blocks\",\n",
    "            \"IF block_utilization > 90% THEN activate overflow_procedures\"\n",
    "        ]\n",
    "    \n",
    "    def generate_crane_assignment_recommendation(self, context: Dict[str, Any]) -> AIRecommendation:\n",
    "        \"\"\"Generate crane assignment recommendation with explanation\"\"\"\n",
    "        \n",
    "        # Extract key factors\n",
    "        vessel_priority = context.get('vessel_priority', 2)\n",
    "        available_cranes = context.get('available_cranes', 6)\n",
    "        weather_conditions = context.get('weather_conditions', 'normal')\n",
    "        crew_experience = context.get('crew_experience', 5)\n",
    "        \n",
    "        # Calculate recommendation using weighted scoring\n",
    "        score = 0\n",
    "        reasoning = []\n",
    "        \n",
    "        # Factor 1: Vessel priority\n",
    "        if vessel_priority == 3:  # High priority\n",
    "            score += self.xai.feature_importance['vessel_priority'] * 100\n",
    "            reasoning.append(f\"High vessel priority (score: +{self.xai.feature_importance['vessel_priority'] * 100:.1f})\")\n",
    "        elif vessel_priority == 2:  # Medium priority\n",
    "            score += self.xai.feature_importance['vessel_priority'] * 50\n",
    "            reasoning.append(f\"Medium vessel priority (score: +{self.xai.feature_importance['vessel_priority'] * 50:.1f})\")\n",
    "        \n",
    "        # Factor 2: Crane availability\n",
    "        crane_utilization = (6 - available_cranes) / 6\n",
    "        if available_cranes >= 4:\n",
    "            score += self.xai.feature_importance['crane_availability'] * 80\n",
    "            reasoning.append(f\"Good crane availability: {available_cranes}/6 cranes (score: +{self.xai.feature_importance['crane_availability'] * 80:.1f})\")\n",
    "        elif available_cranes >= 2:\n",
    "            score += self.xai.feature_importance['crane_availability'] * 40\n",
    "            reasoning.append(f\"Limited crane availability: {available_cranes}/6 cranes (score: +{self.xai.feature_importance['crane_availability'] * 40:.1f})\")\n",
    "        else:\n",
    "            score -= self.xai.feature_importance['crane_availability'] * 20\n",
    "            reasoning.append(f\"Critical crane shortage: {available_cranes}/6 cranes (score: -{self.xai.feature_importance['crane_availability'] * 20:.1f})\")\n",
    "        \n",
    "        # Factor 3: Weather conditions\n",
    "        if weather_conditions == 'severe':\n",
    "            score -= self.xai.feature_importance['weather_conditions'] * 30\n",
    "            reasoning.append(f\"Severe weather conditions (score: -{self.xai.feature_importance['weather_conditions'] * 30:.1f})\")\n",
    "        elif weather_conditions == 'poor':\n",
    "            score -= self.xai.feature_importance['weather_conditions'] * 15\n",
    "            reasoning.append(f\"Poor weather conditions (score: -{self.xai.feature_importance['weather_conditions'] * 15:.1f})\")\n",
    "        else:\n",
    "            reasoning.append(f\"Normal weather conditions (no score adjustment)\")\n",
    "        \n",
    "        # Factor 4: Crew experience\n",
    "        if crew_experience >= 5:\n",
    "            score += self.xai.feature_importance['crew_experience'] * 20\n",
    "            reasoning.append(f\"Experienced crew: {crew_experience} years (score: +{self.xai.feature_importance['crew_experience'] * 20:.1f})\")\n",
    "        elif crew_experience >= 2:\n",
    "            reasoning.append(f\"Moderate crew experience: {crew_experience} years (no score adjustment)\")\n",
    "        else:\n",
    "            score -= self.xai.feature_importance['crew_experience'] * 10\n",
    "            reasoning.append(f\"Inexperienced crew: {crew_experience} years (score: -{self.xai.feature_importance['crew_experience'] * 10:.1f})\")\n",
    "        \n",
    "        # Calculate confidence\n",
    "        confidence = min(1.0, max(0.3, score / 100))\n",
    "        \n",
    "        # Generate recommendation\n",
    "        if score > 70:\n",
    "            recommendation = \"PROCEED with standard crane assignment\"\n",
    "            risk_level = \"low\"\n",
    "        elif score > 40:\n",
    "            recommendation = \"PROCEED with enhanced monitoring\"\n",
    "            risk_level = \"medium\"\n",
    "        else:\n",
    "            recommendation = \"POSTPONE or seek alternative assignment\"\n",
    "            risk_level = \"high\"\n",
    "        \n",
    "        # Generate alternatives\n",
    "        alternatives = [\n",
    "            {\n",
    "                \"option\": \"Use backup crane\",\n",
    "                \"impact\": \"+10% delay, -20% risk\",\n",
    "                \"confidence\": confidence * 0.8\n",
    "            },\n",
    "            {\n",
    "                \"option\": \"Rechedule to off-peak hours\",\n",
    "                \"impact\": \"+25% delay, -40% risk\",\n",
    "                \"confidence\": confidence * 0.9\n",
    "            }\n",
    "        ]\n",
    "        \n",
    "        # Risk assessment\n",
    "        risk_factors = {\n",
    "            \"equipment_failure\": max(0, (1 - available_cranes/6) * 0.3),\n",
    "            \"weather_delay\": 0.1 if weather_conditions == 'normal' else 0.4 if weather_conditions == 'poor' else 0.7,\n",
    "            \"crew_error\": max(0, (5 - crew_experience) * 0.05),\n",
    "            \"congestion_delay\": 0.2 if context.get('truck_congestion', 0.5) > 0.8 else 0.1\n",
    "        }\n",
    "        \n",
    "        # Expected outcomes\n",
    "        expected_outcomes = {\n",
    "            \"completion_probability\": confidence,\n",
    "            \"estimated_delay_minutes\": max(0, (100 - score) * 0.5),\n",
    "            \"cost_efficiency\": score / 100,\n",
    "            \"safety_score\": 1.0 - sum(risk_factors.values()) / len(risk_factors)\n",
    "        }\n",
    "        \n",
    "        return AIRecommendation(\n",
    "            recommendation_id=f\"rec_{datetime.now().strftime('%Y%m%d_%H%M%S')}\",\n",
    "            recommendation_type=\"crane_assignment\",\n",
    "            content={\n",
    "                \"action\": recommendation,\n",
    "                \"risk_level\": risk_level,\n",
    "                \"priority_vessels\": context.get('priority_vessels', 0),\n",
    "                \"available_cranes\": available_cranes\n",
    "            },\n",
    "            confidence=confidence,\n",
    "            reasoning=reasoning,\n",
    "            supporting_data={\n",
    "                \"feature_importance\": self.xai.feature_importance,\n",
    "                \"decision_rules_applied\": [rule for rule in self.xai.decision_rules if \n",
    "                                        'vessel_priority' in rule and vessel_priority == 3],\n",
    "                \"historical_performance\": 0.87\n",
    "            },\n",
    "            alternatives=alternatives,\n",
    "            risk_assessment=risk_factors,\n",
    "            expected_outcome=expected_outcomes,\n",
    "            timestamp=datetime.now()\n",
    "        )\n",
    "    \n",
    "    def generate_schedule_optimization_recommendation(self, context: Dict[str, Any]) -> AIRecommendation:\n",
    "        \"\"\"Generate schedule optimization recommendation\"\"\"\n",
    "        \n",
    "        # Extract context\n",
    "        current_schedule = context.get('current_schedule', [])\n",
    "        bottlenecks = context.get('bottlenecks', [])\n",
    "        optimization_goal = context.get('optimization_goal', 'minimize_delay')\n",
    "        \n",
    "        reasoning = [\n",
    "            \"Analyzing current schedule for optimization opportunities\",\n",
    "            f\"Found {len(bottlenecks)} potential bottlenecks\",\n",
    "            f\"Optimization goal: {optimization_goal}\"\n",
    "        ]\n",
    "        \n",
    "        # Simple optimization analysis\n",
    "        if len(bottlenecks) > 3:\n",
    "            recommendation = \"MAJOR schedule restructuring recommended\"\n",
    "            confidence = 0.85\n",
    "            reasoning.append(\"Multiple bottlenecks indicate need for major restructuring\")\n",
    "        elif len(bottlenecks) > 1:\n",
    "            recommendation = \"MINOR schedule adjustments recommended\"\n",
    "            confidence = 0.75\n",
    "            reasoning.append(\"Limited bottlenecks can be resolved with minor adjustments\")\n",
    "        else:\n",
    "            recommendation = \"MAINTAIN current schedule\"\n",
    "            confidence = 0.90\n",
    "            reasoning.append(\"Current schedule is optimal\")\n",
    "        \n",
    "        # Generate alternatives\n",
    "        alternatives = [\n",
    "            {\n",
    "                \"option\": \"Rebalance workload across cranes\",\n",
    "                \"impact\": \"-15% bottlenecks, +5% efficiency\",\n",
    "                \"confidence\": confidence * 0.8\n",
    "            },\n",
    "            {\n",
    "                \"option\": \"Adjust task priorities\",\n",
    "                \"impact\": \"-20% bottlenecks, +10% delay\",\n",
    "                \"confidence\": confidence * 0.9\n",
    "            }\n",
    "        ]\n",
    "        \n",
    "        return AIRecommendation(\n",
    "            recommendation_id=f\"sched_{datetime.now().strftime('%Y%m%d_%H%M%S')}\",\n",
    "            recommendation_type=\"schedule_optimization\",\n",
    "            content={\n",
    "                \"action\": recommendation,\n",
    "                \"bottlenecks_found\": len(bottlenecks),\n",
    "                \"optimization_potential\": min(0.4, len(bottlenecks) * 0.1)\n",
    "            },\n",
    "            confidence=confidence,\n",
    "            reasoning=reasoning,\n",
    "            supporting_data={\n",
    "                \"schedule_analysis\": \"completed\",\n",
    "                \"optimization_algorithm\": \"genetic_algorithm\",\n",
    "                \"historical_improvements\": \"12-18%\"\n",
    "            },\n",
    "            alternatives=alternatives,\n",
    "            risk_assessment={\n",
    "                \"disruption_risk\": 0.2 if len(bottlenecks) > 1 else 0.05,\n",
    "                \"implementation_complexity\": 0.6 if len(bottlenecks) > 3 else 0.3\n",
    "            },\n",
    "            expected_outcome={\n",
    "                \"delay_reduction\": len(bottlenecks) * 0.05,\n",
    "                \"efficiency_gain\": len(bottlenecks) * 0.03,\n",
    "                \"implementation_time\": len(bottlenecks) * 15  # minutes\n",
    "            },\n",
    "            timestamp=datetime.now()\n",
    "        )\n",
    "    \n",
    "    def learn_from_feedback(self, recommendation: AIRecommendation, human_decision: HumanDecision):\n",
    "        \"\"\"Learn from human feedback to improve recommendations\"\"\"\n",
    "        \n",
    "        feedback = {\n",
    "            'recommendation_id': recommendation.recommendation_id,\n",
    "            'human_decision': human_decision.decision_type.value,\n",
    "            'human_confidence': human_decision.confidence,\n",
    "            'ai_confidence': recommendation.confidence,\n",
    "            'trust_impact': human_decision.trust_impact,\n",
    "            'timestamp': human_decision.timestamp\n",
    "        }\n",
    "        \n",
    "        self.xai.human_feedback_history.append(feedback)\n",
    "        \n",
    "        # Adapt feature importance based on feedback\n",
    "        if human_decision.decision_type in [DecisionType.AI_SUGGESTED_HUMAN_APPROVED, \n",
    "                                         DecisionType.AI_SUGGESTED_HUMAN_MODIFIED]:\n",
    "            # Human agreed with AI direction - strengthen current weights\n",
    "            adaptation_factor = self.xai.adaptation_rate * human_decision.trust_impact\n",
    "        elif human_decision.decision_type == DecisionType.HUMAN_ONLY:\n",
    "            # Human overrode AI - adjust weights\n",
    "            adaptation_factor = -self.xai.adaptation_rate * abs(human_decision.trust_impact)\n",
    "        else:\n",
    "            adaptation_factor = 0\n",
    "        \n",
    "        # Apply adaptation (simplified)\n",
    "        if adaptation_factor != 0:\n",
    "            # Slightly adjust the most relevant feature\n",
    "            if 'vessel_priority' in recommendation.reasoning[0]:\n",
    "                self.xai.feature_importance['vessel_priority'] *= (1 + adaptation_factor)\n",
    "            elif 'crane_availability' in recommendation.reasoning[0]:\n",
    "                self.xai.feature_importance['crane_availability'] *= (1 + adaptation_factor)\n",
    "        \n",
    "        # Normalize feature importance\n",
    "        total = sum(self.xai.feature_importance.values())\n",
    "        for feature in self.xai.feature_importance:\n",
    "            self.xai.feature_importance[feature] /= total\n",
    "\n",
    "print(\"✅ Terminal XAI system defined!\")"
   ]
