    "    \n",
    "    # 8. AI Agreement Rate Over Time\n",
    "    ax8 = axes[2, 1]\n",
    "    \n",
    "    # Calculate AI agreement rate over sessions\n",
    "    ai_agreement_rates = []\n",
    "    for session in sessions:\n",
    "        ai_agreements = sum(1 for d in session.decisions if d.decision_type in [DecisionType.AI_SUGGESTED_HUMAN_APPROVED, DecisionType.AI_SUGGESTED_HUMAN_MODIFIED])\n",
    "        agreement_rate = ai_agreements / len(session.decisions) if session.decisions else 0\n",
    "        ai_agreement_rates.append(agreement_rate)\n",
    "    \n",
    "    session_numbers = list(range(1, len(ai_agreement_rates) + 1))\n",
