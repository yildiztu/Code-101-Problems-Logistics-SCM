    "# Initialize the optimizer with Mediterranean Container Terminal parameters\n",
    "optimizer = EquipmentOptimizer(\n",
    "    equipment_types=EQUIPMENT_TYPES,\n",
    "    budget_m=180.0,  # $180 million budget\n",
    "    required_capacity=2400,  # 2,400 moves per day\n",
    "    num_blocks=2,  # 2-block terminal\n",
    "    discount_rate=0.15,  # 15% discount rate\n",
    "    planning_years=20  # 20-year planning horizon\n",
    ")\n",
    "\n",
    "# Generate all feasible solutions\n",
    "print(\"Generating feasible equipment configurations...\")\n",
    "feasible_solutions = optimizer.generate_feasible_solutions()\n",
    "print(f\"Found {len(feasible_solutions)} feasible solutions\")\n",
    "\n",
    "# Find Pareto-optimal solutions\n",
    "print(\"\\nIdentifying Pareto-optimal solutions...\")\n",
    "pareto_solutions = optimizer.find_pareto_optimal(feasible_solutions)\n",
    "print(f\"Found {len(pareto_solutions)} Pareto-optimal solutions\")\n",
    "\n",
    "# Rank all solutions\n",
    "ranked_solutions = optimizer.rank_solutions(feasible_solutions)\n",
    "\n",
    "# Display top solutions\n",
    "print(\"\\n=== TOP 5 RANKED SOLUTIONS ===\")\n",
    "for i, sol in enumerate(ranked_solutions[:5]):\n",
    "    print(f\"\\nRank {i+1}: {sol['equipment_type']} - {sol['num_units']} units\")\n",
    "    print(f\"  NPV Cost: ${sol['npv_cost_m']:.1f}M\")\n",
    "    print(f\"  Daily Capacity: {sol['daily_capacity']:,} moves\")\n",
    "    print(f\"  Stacking Capacity: {sol['stacking_capacity']} levels\")\n",
    "    print(f\"  Flexibility Score: {sol['flexibility_score']:.3f}\")\n",
    "    print(f\"  Weighted Score: {sol['weighted_score']:.3f}\")"
   ]
