    "@dataclass\n",
    "class EquipmentType:\n",
    "    \"\"\"Container handling equipment type with characteristics\"\"\"\n",
    "    name: str\n",
    "    capital_cost_m: float  # Capital cost in millions\n",
    "    annual_op_cost_m: float  # Annual operating cost in millions\n",
    "    productivity_mph: float  # Productivity in moves per hour\n",
    "    stacking_capacity: int  # Stacking capacity (containers high)\n",
    "    flexibility_index: float  # Flexibility index (0-1)\n",
    "    electric_ratio: float  # Ratio of electric-powered units (0-1)\n",
    "\n",
    "# Define equipment types based on the source material\n",
    "EQUIPMENT_TYPES = {\n",
    "    'RTG': EquipmentType(\n",
    "        name='RTG',\n",
    "        capital_cost_m=12.0,\n",
    "        annual_op_cost_m=0.8,\n",
    "        productivity_mph=22,\n",
    "        stacking_capacity=5,\n",
    "        flexibility_index=0.8,\n",
    "        electric_ratio=0.3  # 30% electric/hybrid\n",
    "    ),\n",
    "    'RMG': EquipmentType(\n",
    "        name='RMG',\n",
    "        capital_cost_m=15.0,\n",
    "        annual_op_cost_m=0.6,\n",
    "        productivity_mph=30,\n",
    "        stacking_capacity=7,\n",
    "        flexibility_index=0.3,\n",
    "        electric_ratio=1.0  # 100% electric\n",
    "    ),\n",
    "    'SC': EquipmentType(\n",
    "        name='Straddle',\n",
    "        capital_cost_m=4.0,\n",
    "        annual_op_cost_m=1.2,\n",
    "        productivity_mph=18,\n",
    "        stacking_capacity=3,\n",
    "        flexibility_index=0.9,\n",
    "        electric_ratio=0.2  # 20% electric/hybrid\n",
    "    )\n",
    "}\n",
    "\n",
    "print(\"Equipment Types Defined:\")\n",
    "for eq_type, eq in EQUIPMENT_TYPES.items():\n",
    "    print(f\"{eq.name}: Capital ${eq.capital_cost_m}M, Annual Op ${eq.annual_op_cost_m}M, \"\n",
    "          f\"{eq.productivity_mph} moves/hour, Flexibility {eq.flexibility_index}\")"
   ]
