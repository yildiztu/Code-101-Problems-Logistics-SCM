   "source": [
    "class EquipmentOptimizer:\n",
    "    \"\"\"Multi-objective equipment selection optimizer using Pareto optimization\"\"\"\n",
    "    \n",
    "    def __init__(self, equipment_types: Dict[str, EquipmentType], \n",
    "                 budget_m: float, required_capacity: int, \n",
    "                 num_blocks: int, discount_rate: float = 0.15,\n",
    "                 planning_years: int = 20):\n",
    "        self.equipment_types = equipment_types\n",
    "        self.budget_m = budget_m\n",
    "        self.required_capacity = required_capacity\n",
    "        self.num_blocks = num_blocks\n",
    "        self.discount_rate = discount_rate\n",
    "        self.planning_years = planning_years\n",
    "        \n",
    "    def calculate_npv_cost(self, eq_type: EquipmentType, num_units: int) -> float:\n",
    "        \"\"\"Calculate Net Present Value of total cost of ownership\"\"\"\n",
    "        capital_cost = eq_type.capital_cost_m * num_units\n",
    "        \n",
    "        # Calculate NPV of operating costs over planning horizon\n",
    "        annual_op_cost = eq_type.annual_op_cost_m * num_units\n",
    "        npv_op_cost = sum(annual_op_cost / ((1 + self.discount_rate) ** t) \n",
    "                        for t in range(1, self.planning_years + 1))\n",
    "        \n",
    "        return capital_cost + npv_op_cost\n",
    "    \n",
    "    def calculate_daily_capacity(self, eq_type: EquipmentType, num_units: int) -> int:\n",
    "        \"\"\"Calculate daily container handling capacity\"\"\"\n",
    "        # Assume 16 productive hours per day (24/7 operations with maintenance breaks)\n",
    "        productive_hours_per_day = 16\n",
    "        return int(eq_type.productivity_mph * num_units * productive_hours_per_day)\n",
    "    \n",
    "    def calculate_total_stacking_capacity(self, eq_type: EquipmentType, num_units: int) -> int:\n",
    "        \"\"\"Calculate total stacking capacity across all blocks\"\"\"\n",
    "        # Simplified: each unit serves one block with its stacking capacity\n",
    "        return eq_type.stacking_capacity * min(num_units, self.num_blocks)\n",
    "    \n",
    "    def calculate_flexibility_score(self, eq_type: EquipmentType, num_units: int) -> float:\n",
    "        \"\"\"Calculate overall flexibility score\"\"\"\n",
    "        # Flexibility increases with more units but has diminishing returns\n",
    "        base_flexibility = eq_type.flexibility_index\n",
    "        quantity_factor = 1 - np.exp(-num_units / 5.0)  # Diminishing returns\n",
    "        return base_flexibility * quantity_factor\n",
    "    \n",
    "    def generate_feasible_solutions(self) -> List[Dict]:\n",
    "        \"\"\"Generate all feasible equipment configurations\"\"\"\n",
    "        solutions = []\n",
    "        \n",
    "        # Define reasonable ranges for equipment quantities\n",
    "        max_units_per_type = {\n",
    "            'RTG': 25,\n",
    "            'RMG': 20, \n",
    "            'SC': 40\n",
    "        }\n",
    "        \n",
    "        # Generate solutions for each equipment type (single-type selection)\n",
    "        for eq_name, eq_type in self.equipment_types.items():\n",
    "            max_units = max_units_per_type[eq_name]\n",
    "            \n",
    "            for num_units in range(1, max_units + 1):\n",
    "                # Calculate objectives\n",
    "                npv_cost = self.calculate_npv_cost(eq_type, num_units)\n",
    "                daily_capacity = self.calculate_daily_capacity(eq_type, num_units)\n",
    "                stacking_capacity = self.calculate_total_stacking_capacity(eq_type, num_units)\n",
    "                flexibility = self.calculate_flexibility_score(eq_type, num_units)\n",
    "                \n",
    "                # Check constraints\n",
    "                if npv_cost <= self.budget_m and daily_capacity >= self.required_capacity:\n",
    "                    solutions.append({\n",
    "                        'equipment_type': eq_name,\n",
    "                        'num_units': num_units,\n",
    "                        'npv_cost_m': npv_cost,\n",
    "                        'daily_capacity': daily_capacity,\n",
    "                        'stacking_capacity': stacking_capacity,\n",
    "                        'flexibility_score': flexibility,\n",
    "                        'capital_cost_m': eq_type.capital_cost_m * num_units,\n",
    "                        'annual_op_cost_m': eq_type.annual_op_cost_m * num_units\n",
    "                    })\n",
    "        \n",
    "        return solutions\n",
    "    \n",
    "    def find_pareto_optimal(self, solutions: List[Dict]) -> List[Dict]:\n",
    "        \"\"\"Identify Pareto-optimal solutions\"\"\"\n",
    "        pareto_optimal = []\n",
    "        \n",
    "        for i, sol_i in enumerate(solutions):\n",
    "            is_dominated = False\n",
    "            \n",
    "            for j, sol_j in enumerate(solutions):\n",
    "                if i == j:\n",
    "                    continue\n",
    "                \n",
    "                # Check if solution j dominates solution i\n",
    "                # (lower cost is better, higher capacity/stacking/flexibility are better)\n",
    "                cost_better = sol_j['npv_cost_m'] <= sol_i['npv_cost_m']\n",
    "                capacity_better = sol_j['daily_capacity'] >= sol_i['daily_capacity']\n",
    "                stacking_better = sol_j['stacking_capacity'] >= sol_i['stacking_capacity']\n",
    "                flexibility_better = sol_j['flexibility_score'] >= sol_i['flexibility_score']\n",
    "                \n",
    "                # At least one objective must be strictly better\n",
    "                strictly_better = (sol_j['npv_cost_m'] < sol_i['npv_cost_m'] or\n",
    "                                 sol_j['daily_capacity'] > sol_i['daily_capacity'] or\n",
    "                                 sol_j['stacking_capacity'] > sol_i['stacking_capacity'] or\n",
    "                                 sol_j['flexibility_score'] > sol_i['flexibility_score'])\n",
    "                \n",
    "                if cost_better and capacity_better and stacking_better and flexibility_better and strictly_better:\n",
    "                    is_dominated = True\n",
    "                    break\n",
    "            \n",
    "            if not is_dominated:\n",
    "                pareto_optimal.append(sol_i)\n",
    "        \n",
    "        return pareto_optimal\n",
    "    \n",
    "    def rank_solutions(self, solutions: List[Dict]) -> List[Dict]:\n",
    "        \"\"\"Rank solutions using a weighted score approach\"\"\"\n",
    "        # Define weights for multi-criteria decision making\n",
    "        weights = {\n",
    "            'cost': 0.35,      # Cost minimization\n",
    "            'capacity': 0.30,    # Capacity maximization\n",
    "            'stacking': 0.20,   # Stacking capacity\n",
    "            'flexibility': 0.15 # Flexibility\n",
    "        }\n",
    "        \n",
    "        # Normalize objectives to 0-1 scale\n",
    "        costs = [sol['npv_cost_m'] for sol in solutions]\n",
    "        capacities = [sol['daily_capacity'] for sol in solutions]\n",
    "        stackings = [sol['stacking_capacity'] for sol in solutions]\n",
    "        flexibilities = [sol['flexibility_score'] for sol in solutions]\n",
    "        \n",
    "        min_cost, max_cost = min(costs), max(costs)\n",
    "        min_cap, max_cap = min(capacities), max(capacities)\n",
    "        min_stack, max_stack = min(stackings), max(stackings)\n",
    "        min_flex, max_flex = min(flexibilities), max(flexibilities)\n",
    "        \n",
    "        for sol in solutions:\n",
    "            # Normalize (cost: lower is better, others: higher is better)\n",
    "            norm_cost = 1 - (sol['npv_cost_m'] - min_cost) / (max_cost - min_cost) if max_cost > min_cost else 1\n",
    "            norm_capacity = (sol['daily_capacity'] - min_cap) / (max_cap - min_cap) if max_cap > min_cap else 1\n",
    "            norm_stacking = (sol['stacking_capacity'] - min_stack) / (max_stack - min_stack) if max_stack > min_stack else 1\n",
    "            norm_flexibility = (sol['flexibility_score'] - min_flex) / (max_flex - min_flex) if max_flex > min_flex else 1\n",
    "            \n",
    "            # Calculate weighted score\n",
    "            sol['weighted_score'] = (weights['cost'] * norm_cost +\n",
    "                                  weights['capacity'] * norm_capacity +\n",
    "                                  weights['stacking'] * norm_stacking +\n",
    "                                  weights['flexibility'] * norm_flexibility)\n",
    "        \n",
    "        return sorted(solutions, key=lambda x: x['weighted_score'], reverse=True)\n",
    "\n",
    "print(\"EquipmentOptimizer class defined successfully\")"
   ]
  },
