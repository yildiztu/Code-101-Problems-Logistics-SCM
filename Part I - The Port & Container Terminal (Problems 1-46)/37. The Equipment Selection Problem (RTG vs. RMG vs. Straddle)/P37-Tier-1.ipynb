    "# What-if Analysis: Exploring the impact of changing key assumptions\n",
    "print(\"=== WHAT-IF SCENARIO ANALYSIS ===\")\n",
    "\n",
    "# Scenario 1: Higher discount rate (higher cost of capital)\n",
    "print(\"\\nScenario 1: Higher Discount Rate (20% vs 15%)\")\n",
    "high_discount_optimizer = EquipmentOptimizer(\n",
    "    equipment_types=EQUIPMENT_TYPES,\n",
    "    budget_m=180,\n",
    "    required_capacity=2400,\n",
    "    num_blocks=2,\n",
    "    discount_rate=0.20,  # Higher discount rate\n",
    "    planning_years=20\n",
    ")\n",
    "\n",
    "high_discount_solutions = high_discount_optimizer.generate_feasible_solutions()\n",
    "high_discount_ranked = high_discount_optimizer.rank_solutions(high_discount_solutions)\n",
    "\n",
    "print(\"Base Case (15% discount):\", f\"{ranked_solutions[0]['equipment_type']} {ranked_solutions[0]['num_units']} units\")\n",
    "print(\"High Discount (20%):\", f\"{high_discount_ranked[0]['equipment_type']} {high_discount_ranked[0]['num_units']} units\")\n",
    "print(\"Cost difference: $\", high_discount_ranked[0]['npv_cost_m'] - ranked_solutions[0]['npv_cost_m'], \"M\")\n",
    "\n",
    "# Scenario 2: Emphasis on environmental sustainability (favor electric equipment)\n",
    "print(\"\\nScenario 2: Environmental Sustainability Focus\")\n",
    "# Modify weights to favor electric equipment\n",
    "env_solutions = []\n",
    "for sol in feasible_solutions:\n",
    "    eq_type = EQUIPMENT_TYPES[sol['equipment_type']]\n",
    "    \n",
    "    # Calculate environmental score\n",
    "    env_score = eq_type.electric_ratio * 0.7 + (1 - eq_type.electric_ratio) * 0.3\n",
    "    \n",
    "    # Recalculate weighted score with environmental emphasis\n",
    "    weights = {\n",
    "        'cost': 0.25,      # Reduced cost emphasis\n",
    "        'capacity': 0.25,    # Reduced capacity emphasis\n",
    "        'stacking': 0.15,   # Reduced stacking emphasis\n",
    "        'environment': 0.35 # High environmental emphasis\n",
    "    }\n",
    "    \n",
    "    # Normalize objectives\n",
    "    costs = [s['npv_cost_m'] for s in feasible_solutions]\n",
    "    capacities = [s['daily_capacity'] for s in feasible_solutions]\n",
    "    env_scores = [EQUIPMENT_TYPES[s['equipment_type']].electric_ratio for s in feasible_solutions]\n",
    "    \n",
    "    min_cost, max_cost = min(costs), max(costs)\n",
    "    min_cap, max_cap = min(capacities), max(capacities)\n",
    "    min_env, max_env = min(env_scores), max(env_scores)\n",
    "    \n",
    "    norm_cost = 1 - (sol['npv_cost_m'] - min_cost) / (max_cost - min_cost) if max_cost > min_cost else 1\n",
    "    norm_capacity = (sol['daily_capacity'] - min_cap) / (max_cap - min_cap) if max_cap > min_cap else 1\n",
    "    norm_env = (eq_type.electric_ratio - min_env) / (max_env - min_env) if max_env > min_env else 1\n",
    "    \n",
    "    sol['env_weighted_score'] = (weights['cost'] * norm_cost +\n",
    "                                  weights['capacity'] * norm_capacity +\n",
    "                                  weights['environment'] * norm_env)\n",
    "    env_solutions.append(sol)\n",
    "\n",
    "env_ranked = sorted(env_solutions, key=lambda x: x['env_weighted_score'], reverse=True)\n",
    "\n",
    "print(\"Base Case Best:\", f\"{ranked_solutions[0]['equipment_type']} {ranked_solutions[0]['num_units']} units\")\n",
    "print(\"Environmental Best:\", f\"{env_ranked[0]['equipment_type']} {env_ranked[0]['num_units']} units\")\n",
