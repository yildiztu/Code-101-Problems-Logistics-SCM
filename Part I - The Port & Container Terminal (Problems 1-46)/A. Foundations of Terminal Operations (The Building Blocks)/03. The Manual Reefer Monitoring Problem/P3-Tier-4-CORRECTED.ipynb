    "import itertools\n",
    "import warnings\n",
    "import random\n",
    "import math\n",
    "import time\n",
    "from collections import deque, namedtuple\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Set visualization style\n",
    "try:\n",
    "    plt.style.use('seaborn-v0_8')\n",
