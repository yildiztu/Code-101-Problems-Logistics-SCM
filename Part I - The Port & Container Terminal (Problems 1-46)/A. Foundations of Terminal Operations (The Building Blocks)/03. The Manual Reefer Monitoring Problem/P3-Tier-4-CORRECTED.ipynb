    "def evaluate_agent(agent, num_episodes=10):\n",
    "    \"\"\"Evaluate the trained agent\"\"\"\n",
    "    print(\"=== AGENT EVALUATION ===\")\n",
    "    \n",
    "    evaluation_rewards = []\n",
    "    evaluation_details = []\n",
    "    \n",
    "    for episode in range(num_episodes):\n",
    "        state = env.reset()\n",
    "        episode_reward = 0\n",
    "        episode_actions = []\n",
    "        \n",
    "        for step in range(len(containers)):\n",
    "            # Choose action (no exploration during evaluation)\n",
    "            q_values = agent.q_network.forward(state.reshape(1, -1))\n",
    "            action = np.argmax(q_values[0])\n    "            \n    "            # Execute action\n",
    "            next_state, reward, done, info = env.step(action)\n    "            \n    "            episode_reward += reward\n",
    "            episode_actions.append(info)\n    "            state = next_state\n    "            \n    "            if done:\n    "                break\n    "        \n    "        evaluation_rewards.append(episode_reward)\n    "        evaluation_details.append(episode_actions)\n    "    \n    "        print(f\"Episode {episode + 1}: Reward = {episode_reward:.2f}, Containers Inspected = {len(episode_actions)}\")\n    "    \n    "    print(f\"\\nEvaluation Results:\")\n    "    print(f\"Average Reward: {np.mean(evaluation_rewards):.2f} (±{np.std(evaluation_rewards):.2f})\")\n    "    print(f\"Max Reward: {np.max(evaluation_rewards):.2f}\")\n    "    print(f\"Min Reward: {np.min(evaluation_rewards):.2f}\")\n    "    \n    "    return evaluation_rewards, evaluation_details"
