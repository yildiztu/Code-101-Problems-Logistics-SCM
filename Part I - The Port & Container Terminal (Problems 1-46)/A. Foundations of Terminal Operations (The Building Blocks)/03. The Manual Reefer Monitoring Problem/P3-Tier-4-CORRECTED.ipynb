   "source": [
    "class ReeferMonitoringEnvironment:\n",
    "    \"\"\"Reinforcement Learning environment for reefer container inspection\"\"\"\n",
    "    \n",
    "    def __init__(self, containers, inspectors, inspection_times):\n",
    "        self.containers = containers\n",
    "        self.inspectors = inspectors\n",
    "        self.inspection_times = inspection_times\n",
    "        \n",
    "        # State space components\n",
    "        self.num_containers = len(containers)\n",
    "        self.num_inspectors = len(inspectors)\n",
    "        \n",
    "        # Action space: (container_id, inspector_id) pairs\n",
    "        self.valid_actions = []\n",
    "        for container_id in range(1, len(containers) + 1):\n",
    "            for inspector_id in range(1, len(inspectors) + 1):\n",
    "                self.valid_actions.append((container_id, inspector_id))\n",
    "        \n",
    "        self.num_actions = len(self.valid_actions)\n",
    "        self.action_to_index = {action: idx for idx, action in enumerate(self.valid_actions)}\n",
    "        self.index_to_action = {idx: action for idx, action in enumerate(self.valid_actions)}\n",
    "        \n",
    "        # Environment state\n",
    "        self.reset()\n",
    "    \n",
    "    def reset(self):\n",
    "        \"\"\"Reset environment to initial state\"\"\"\n",
    "        # Reset inspectors\n",
    "        for inspector in self.inspectors:\n",
    "            inspector.assigned_containers = []\n",
    "            inspector.current_workload = 0\n",
    "        \n",
    "        # Reset container inspection status\n",
    "        self.inspected_containers = set()\n",
    "        self.current_step = 0\n",
    "        self.max_steps = len(self.containers)\n",
    "        \n",
    "        return self.get_state()\n",
    "    \n",
    "    def get_state(self):\n",
    "        \"\"\"Get current state representation\"\"\"\n",
    "        state = []\n",
    "        \n",
    "        # Container features\n",
    "        for container in self.containers:\n",
    "            state.extend([\n",
    "                container.priority / 10.0,  # Normalize priority\n",
    "                container.stack_level / 3.0,   # Normalize stack level\n",
    "                container.location_x / 120.0,  # Normalize position\n",
    "                container.location_y / 120.0,\n",
    "                container.time_since_last_inspection / 4.0,  # Normalize time\n",
    "                1.0 if container.id in self.inspected_containers else 0.0  # Inspection status\n",
    "            ])\n",
    "        \n",
    "        # Inspector features\n",
    "        for inspector in self.inspectors:\n",
    "            state.extend([\n",
    "                inspector.experience_level / 3.0,  # Normalize experience\n",
    "                inspector.current_workload / inspector.capacity_minutes,  # Utilization\n",
    "                len(inspector.assigned_containers) / len(self.containers),  # Assignment ratio\n",
    "            ])\n",
    "        \n",
    "        # Global features\n",
    "        state.extend([\n",
    "            len(self.inspected_containers) / len(self.containers),  # Progress\n",
    "            self.current_step / self.max_steps,  # Time progress\n",
    "        ])\n",
    "        \n",
    "        return np.array(state)\n",
    "    \n",
    "    def is_valid_action(self, container_id, inspector_id):\n",
    "        \"\"\"Check if action is valid\"\"\"\n",
    "        # Check if container is already inspected\n",
    "        if container_id in self.inspected_containers:\n",
    "            return False\n",
    "        \n",
    "        # Check capacity constraint\n",
    "        inspector = next(i for i in self.inspectors if i.id == inspector_id)\n",
    "        inspection = self.inspection_times[(container_id, inspector_id)]\n",
    "        additional_time = inspection.time_minutes + inspection.travel_time\n",
    "        \n",
    "        return inspector.current_workload + additional_time <= inspector.capacity_minutes\n",
    "    \n",
    "    def step(self, action_index):\n",
    "        \"\"\"Execute one step in the environment\"\"\"\n",
    "        container_id, inspector_id = self.index_to_action[action_index]\n",
    "        \n",
    "        # Check if action is valid\n",
    "        if not self.is_valid_action(container_id, inspector_id):\n",
    "            return self.get_state(), -10, True, {}  # Penalty for invalid action\n",
    "        \n",
    "        # Execute action\n",
    "        inspector = next(i for i in self.inspectors if i.id == inspector_id)\n",
    "        container = next(c for c in self.containers if c.id == container_id)\n",
    "        inspection = self.inspection_times[(container_id, inspector_id)]\n",
    "        \n",
    "        # Update state\n",
    "        inspector.assigned_containers.append(container_id)\n",
    "        inspector.current_workload += inspection.time_minutes + inspection.travel_time\n",
    "        self.inspected_containers.add(container_id)\n",
    "        self.current_step += 1\n",
    "        \n",
    "        # Calculate reward\n",
    "        reward = self.calculate_reward(container_id, inspector_id)\n",
    "        \n",
    "        # Check if episode is done\n",
    "        done = len(self.inspected_containers) == len(self.containers)\n",
    "        \n",
    "        info = {\n",
    "            'container_id': container_id,\n",
    "            'inspector_id': inspector_id,\n",
    "            'reward': reward,\n",
    "            'total_inspected': len(self.inspected_containers)\n",
    "        }\n",
    "        \n",
    "        return self.get_state(), reward, done, info\n",
    "    \n    "    "    def calculate_reward(self, container_id, inspector_id):\n",
    "        \"\"\"Calculate reward for action\"\"\"\n",
    "        container = next(c for c in self.containers if c.id == container_id)\n",
    "        inspector = next(i for i in self.inspectors if i.id == inspector_id)\n",
    "        inspection = self.inspection_times[(container_id, inspector_id)]\n",
    "        \n",
    "        # Multi-objective reward\n",
    "        priority_reward = container.priority * 0.4  # Higher priority = higher reward\n",
    "        safety_reward = (4 - inspection.safety_risk_score) * 0.3  # Lower risk = higher reward\n",
    "        efficiency_reward = (240 - inspection.time_minutes - inspection.travel_time) * 0.2  # Faster = higher reward\n",
    "        balance_reward = (1 - abs(inspector.current_workload / inspector.capacity_minutes - 0.5)) * 0.1  # Balanced workload\n",
    "        \n",
    "        return priority_reward + safety_reward + efficiency_reward + balance_reward"
   ]
