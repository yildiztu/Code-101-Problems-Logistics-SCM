   "source": [
    "class DQNAgent:\n",
    "    \"\"\"Deep Q-Network agent for reefer monitoring\"\"\"\n",
    "    \n",
    "    def __init__(self, state_size, action_size, hidden_size=128):\n",
    "        self.state_size = state_size\n",
    "        self.action_size = action_size\n",
    "        self.hidden_size = hidden_size\n",
    "        \n",
    "        # Neural networks\n",
    "        self.q_network = SimpleNeuralNetwork(state_size, hidden_size, action_size)\n",
    "        self.target_network = SimpleNeuralNetwork(state_size, hidden_size, action_size)\n",
    "        \n",
    "        # Initialize target network\n",
    "        self.update_target_network()\n",
    "        \n",
    "        # Experience replay\n",
    "        self.memory = deque(maxlen=10000)\n",
    "        self.batch_size = 32\n",
    "        \n",
    "        # Training parameters\n",
    "        self.gamma = 0.95  # Discount factor\n",
    "        self.epsilon = 1.0  # Exploration rate\n    "        self.epsilon_min = 0.01\n",
    "        self.epsilon_decay = 0.995\n",
    "        \n",
    "        # Training tracking\n",
    "        self.training_loss = []\n",
    "        self.q_values_history = []\n",
    "    \n",
    "    def update_target_network(self):\n",
    "        \"\"\"Update target network weights\"\"\"\n",
    "        self.target_network.W1 = self.q_network.W1.copy()\n",
    "        self.target_network.b1 = self.q_network.b1.copy()\n",
    "        self.target_network.W2 = self.q_network.W2.copy()\n",
    "        self.target_network.b2 = self.q_network.b2.copy()\n",
    "        self.target_network.W3 = self.q_network.W3.copy()\n",
    "        self.target_network.b3 = self.q_network.b3.copy()\n",
    "    \n",
    "    def remember(self, state, action, reward, next_state, done):\n",
    "        \"\"\"Store experience in replay memory\"\"\"\n",
    "        self.memory.append((state, action, reward, next_state, done))\n",
    "    \n",
    "    def act(self, state):\n",
    "        \"\"\"Choose action using epsilon-greedy policy\"\"\"\n",
    "        if np.random.random() <= self.epsilon:\n",
    "            return np.random.choice(self.action_size)\n",
    "        \n",
    "        q_values = self.q_network.forward(state.reshape(1, -1))\n",
    "        return np.argmax(q_values[0])\n",
    "    \n    "    def replay(self):\n",
    "        \"\"\"Train the model on a batch of experiences\"\"\"\n",
    "        if len(self.memory) < self.batch_size:\n",
    "            return\n",
    "        \n",
    "        # Sample random batch from memory\n",
    "        batch = random.sample(self.memory, self.batch_size)\n",
    "        \n",
    "        states = np.array([e[0] for e in batch])\n",
    "        actions = np.array([e[1] for e in batch])\n",
    "        rewards = np.array([e[2] for e in batch])\n",
    "        next_states = np.array([e[3] for e in batch])\n",
    "        dones = np.array([e[4] for e in batch])\n",
    "        \n",
    "        # Get current Q-values\n",
    "        current_q_values = self.q_network.forward(states)\n",
    "        current_q_values_selected = current_q_values[np.arange(self.batch_size), actions]\n",
    "        \n",
    "        # Get next Q-values from target network\n",
    "        next_q_values = self.target_network.forward(next_states)\n",
    "        max_next_q_values = np.max(next_q_values, axis=1)\n",
    "        \n",
    "        # Calculate target Q-values\n",
    "        target_q_values = rewards + (self.gamma * max_next_q_values * (1 - dones))\n",
    "        \n",
    "        # Train the network\n",
    "        loss = self.train_network(states, current_q_values_selected, target_q_values)\n",
    "        \n",
    "        # Decay epsilon\n",
    "        if self.epsilon > self.epsilon_min:\n",
    "            self.epsilon *= self.epsilon_decay\n",
    "        \n",
    "        return loss\n",
    "    \n",
    "    def train_network(self, states, targets, predicted):\n",
    "        \"\"\"Train the neural network\"\"\"\n",
    "        # Simple mean squared error loss\n",
    "        loss = np.mean((predicted - targets) ** 2)\n",
    "        \n",
    "        # Backward pass\n",
    "        self.q_network.backward(states, targets, predicted)\n",
    "        \n",
    "        return loss"
   ]
  },
