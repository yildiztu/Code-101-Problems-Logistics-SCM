    "@dataclass\n",
    "class Container:\n",
    "    \"\"\"Represents a container with human-AI collaboration attributes\"\"\"\n",
    "    id: str\n",
    "    destination_port: str\n",
    "    weight: float  # tons\n",
    "    current_position: Tuple[int, int, int]  # (bay, row, tier)\n",
    "    discharge_sequence: int\n",
    "    # Human-AI enhanced attributes\n",
    "    special_handling: bool = False\n",
    "    hazardous_material: bool = False\n",
    "    priority_level: str = \"normal\"  # normal, high, critical\n",
    "    last_inspection: datetime = None\n",
    "    \n",
    "@dataclass\n",
    "class Position:\n",
    "    \"\"\"Represents a stow position with human-AI considerations\"\"\"\n",
    "    bay: int\n",
    "    row: int\n",
    "    tier: int\n",
    "    accessible: bool = True\n",
    "    max_weight: float = 50.0\n",
    "    occupied: bool = False\n",
    "    # Human-AI enhanced attributes\n",
    "    safety_rating: float = 1.0  # 1.0 = safest, 0.0 = least safe\n",
    "    accessibility_score: float = 1.0  # Human-rated accessibility\n",
    "    maintenance_status: str = \"good\"  # good, fair, poor\n",
    "\n",
    "@dataclass\n",
    "class HumanExpert:\n",
    "    \"\"\"Represents a human expert in the partnership\"\"\"\n",
    "    expert_id: str\n",
    "    name: str\n",
    "    expertise_area: str  # 'safety', 'operations', 'planning', 'engineering'\n",
    "    experience_years: int\n",
    "    confidence_level: float  # Self-confidence in decisions\n",
    "    trust_in_ai: float  # Initial trust in AI partner\n",
    "    decision_history: List[Dict]\n",
    "    \n",
    "@dataclass\n",
    "class AIAgent:\n",
    "    \"\"\"Represents an AI agent in the partnership\"\"\"\n",
    "    agent_id: str\n",
    "    agent_type: str  # 'optimizer', 'analyzer', 'predictor', 'advisor'\n",
    "    confidence_level: float  # AI confidence in recommendations\n",
    "    trust_in_human: float  # Trust in human expert decisions\n",
    "    explainability_level: float  # Ability to explain reasoning\n",
    "    recommendation_history: List[Dict]\n",
    "    \n",
    "@dataclass\n",
    "class PartnershipConfig:\n",
    "    \"\"\"Configuration for Human-AI Partnership\"\"\"\n",
    "    collaboration_threshold: float = 0.7  # Minimum confidence for independent action\n",
    "    trust_update_rate: float = 0.1  # Rate of trust adjustment\n",
    "    learning_rate: float = 0.05  # Rate of mutual learning\n",
    "    authority_allocation: str = \"dynamic\"  # fixed, dynamic, consensus\n",
    "    communication_frequency: int = 300  # seconds\n",
    "\n",
    "@dataclass\n",
    "class CollaborationDecision:\n",
    "    \"\"\"Represents a collaborative decision result\"\"\"\n",
    "    timestamp: datetime\n",
    "    decision_type: str\n",
    "    human_recommendation: Dict\n",
    "    ai_recommendation: Dict\n",
    "    final_decision: Dict\n",
    "    authority: str  # 'human', 'ai', 'collaborative', 'consensus'\n",
    "    confidence_score: float\n",
    "    trust_impact: float\n",
    "    explanation: str"
   ]
