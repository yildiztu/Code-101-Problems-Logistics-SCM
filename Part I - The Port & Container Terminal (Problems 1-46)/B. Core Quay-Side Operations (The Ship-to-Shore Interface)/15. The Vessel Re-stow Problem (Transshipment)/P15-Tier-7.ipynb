    "class HumanExpertSystem:\n",
    "    \"\"\"Human expert decision system with domain expertise\"\"\"\n",
    "    \n",
    "    def __init__(self, expert: HumanExpert, config: PartnershipConfig):\n",
    "        self.expert = expert\n",
    "        self.config = config\n",
    "        self.domain_knowledge = self._initialize_domain_knowledge()\n",
    "        self.decision_patterns = []\n",
    "        \n",
    "    def _initialize_domain_knowledge(self) -> Dict:\n",
    "        \"\"\"Initialize domain knowledge based on expertise area\"\"\"\n",
    "        \n",
    "        knowledge = {\n",
    "            'safety': {\n",
    "                'hazardous_zones': [(1, 1, 2), (3, 1, 2)],  # Areas requiring special care\n",
    "                'weight_limits': {1: 45, 2: 50, 3: 48, 4: 50, 5: 45},  # Bay-specific limits\n",
    "                'inspection_requirements': ['hazardous', 'special_handling'],\n",
    "                'safety_factors': ['temperature', 'vibration', 'accessibility']\n",
    "            },\n",
    "            'operations': {\n",
    "                'peak_hours': [(8, 12), (14, 18)],  # Peak operational hours\n",
    "                'equipment_availability': {'crane1': 0.9, 'crane2': 0.8},\n",
    "                'handling_priorities': ['critical', 'hazardous', 'high', 'normal'],\n",
    "                'efficiency_factors': ['distance', 'accessibility', 'equipment']\n",
    "            },\n",
    "            'planning': {\n",
    "                'port_sequences': {'HKG': [1, 2, 3], 'SHA': [3, 2, 1]},\n",
    "                'bay_capacities': {1: 100, 2: 120, 3: 110, 4: 120, 5: 100},\n",
    "                'optimization_criteria': ['cost', 'time', 'safety', 'efficiency'],\n",
    "                'planning_horizon': 24  # hours\n",
    "            },\n",
    "            'engineering': {\n",
    "                'vessel_stability': {\n",
    "                    'max_weight_difference': 20,  # tons between bays\n",
    "                    'center_of_gravity_limits': (0.4, 0.6)  # Normalized position\n",
    "                },\n",
    "                'structural_limits': {\n",
    "                    'max_tier_weight': 25,  # tons per tier\n",
    "                    'bay_strength_factors': {1: 0.9, 2: 1.0, 3: 1.0, 4: 1.0, 5: 0.9}\n",
    "                }\n",
    "            }\n",
    "        }\n",
    "        \n",
    "        return knowledge.get(self.expert.expertise_area, {})\n",
    "    \n",
    "    def generate_recommendation(self, container: Container, \n",
    "                               available_positions: List[Position], \n",
    "                               ai_recommendation: Optional[Dict] = None) -> Dict:\n",
    "        \"\"\"Generate human expert recommendation with domain knowledge\"\"\"\n",
    "        \n",
    "        # Apply domain expertise\n",
    "        evaluated_positions = []\n",
    "        for position in available_positions:\n",
    "            if position.occupied:\n",
    "                continue\n",
    "            \n",
    "            human_score = self._evaluate_position_human(container, position)\n",
    "            \n",
    "            evaluated_positions.append({\n",
    "                'position': (position.bay, position.row, position.tier),\n",
    "                'human_score': human_score,\n",
    "                'domain_considerations': self._get_domain_considerations(container, position),\n",
    "                'risk_assessment': self._human_risk_assessment(container, position)\n",
    "            })\n",
    "        \n",
    "        # Sort by human score\n",
    "        evaluated_positions.sort(key=lambda x: x['human_score'], reverse=True)\n",
    "        \n",
    "        if not evaluated_positions:\n",
    "            return {\n",
    "                'recommendation': None,\n",
    "                'confidence': 0.0,\n",
    "                'reasoning': ['No suitable positions available'],\n",
    "                'domain_insights': [],\n",
    "                'ai_consideration': self._evaluate_ai_recommendation(ai_recommendation)\n",
    "            }\n",
    "        \n",
    "        best_choice = evaluated_positions[0]\n",
    "        \n",
    "        # Generate human reasoning\n",
    "        human_reasoning = self._generate_human_reasoning(container, best_choice)\n",
    "        \n",
    "        # Evaluate AI recommendation if provided\n",
    "        ai_consideration = self._evaluate_ai_recommendation(ai_recommendation)\n",
    "        \n",
    "        return {\n",
    "            'recommendation': best_choice['position'],\n",
    "            'confidence': min(0.95, best_choice['human_score'] / 10.0),\n",
    "            'reasoning': human_reasoning,\n",
    "            'domain_insights': best_choice['domain_considerations'],\n",
    "            'risk_assessment': best_choice['risk_assessment'],\n",
    "            'ai_consideration': ai_consideration,\n",
    "            'expertise_applied': self.expert.expertise_area\n",
    "        }\n",
    "    \n",
    "    def _evaluate_position_human(self, container: Container, position: Position) -> float:\n",
    "        \"\"\"Evaluate position using human domain expertise\"\"\"\n",
    "        score = 5.0  # Base score\n",
    "        \n",
    "        # Apply expertise-specific evaluation\n",
    "        if self.expert.expertise_area == 'safety':\n",
    "            score += self._safety_evaluation(container, position)\n",
    "        elif self.expert.expertise_area == 'operations':\n",
    "            score += self._operations_evaluation(container, position)\n",
    "        elif self.expert.expertise_area == 'planning':\n",
    "            score += self._planning_evaluation(container, position)\n",
    "        elif self.expert.expertise_area == 'engineering':\n",
    "            score += self._engineering_evaluation(container, position)\n",
    "        \n",
    "        # General human considerations\n",
    "        score += self._general_human_evaluation(container, position)\n",
    "        \n",
    "        return score\n",
    "    \n",
    "    def _safety_evaluation(self, container: Container, position: Position) -> float:\n",
    "        \"\"\"Safety-specific evaluation\"\"\"\n",
    "        score = 0.0\n",
    "        \n",
    "        # Hazardous material considerations\n",
    "        if container.hazardous_material:\n",
    "            if position.safety_rating > 0.8:\n",
    "                score += 3.0\n",
    "            else:\n",
    "                score -= 2.0\n",
    "        \n",
    "        # Safety zone considerations\n",
    "        if position.bay in [1, 3]:  # Assume these are hazardous zones\n",
    "            if container.hazardous_material:\n",
    "                score += 2.0\n",
    "            else:\n",
    "                score -= 1.0\n",
    "        \n",
    "        # Accessibility for emergency response\n",
    "        if position.accessibility_score > 0.8:\n",
    "            score += 1.0\n",
    "        \n",
    "        return score\n",
    "    \n",
    "    def _operations_evaluation(self, container: Container, position: Position) -> float:\n",
    "        \"\"\"Operations-specific evaluation\"\"\"\n",
    "        score = 0.0\n",
    "        \n",
    "        # Handling efficiency\n",
    "        if position.tier == 1:\n",
    "            score += 2.0  # Easier to handle\n",
    "        \n",
    "        # Equipment accessibility\n",
    "        if position.accessibility_score > 0.7:\n",
    "            score += 1.5\n",
    "        \n",
    "        # Distance considerations\n",
    "        distance = abs(position.bay - container.current_position[0])\n",
    "        if distance <= 2:\n",
    "            score += 1.0\n",
    "        elif distance > 4:\n",
    "            score -= 1.0\n",
    "        \n",
    "        return score\n",
    "    \n",
    "    def _planning_evaluation(self, container: Container, position: Position) -> float:\n",
    "        \"\"\"Planning-specific evaluation\"\"\"\n",
    "        score = 0.0\n",
    "        \n",
    "        # Port sequence optimization\n",
    "        if container.destination_port == 'HKG' and position.bay in [1, 2]:\n",
    "            score += 2.0\n",
    "        elif container.destination_port == 'SHA' and position.bay in [3, 4]:\n",
    "            score += 2.0\n",
    "        \n",
    "        # Bay capacity utilization\n",
    "        if position.bay in [2, 4]:  # Higher capacity bays\n",
    "            score += 1.0\n",
    "        \n",
    "        # Discharge sequence consideration\n",
    "        if container.discharge_sequence <= 2 and position.tier == 1:\n",
    "            score += 1.5\n",
    "        \n",
    "        return score\n",
    "    \n",
    "    def _engineering_evaluation(self, container: Container, position: Position) -> float:\n",
    "        \"\"\"Engineering-specific evaluation\"\"\"\n",
    "        score = 0.0\n",
    "        \n",
    "        # Weight distribution\n",
    "        if container.weight <= 20:  # Lighter containers\n",
    "            score += 1.0\n",
    "        elif container.weight > 25:  # Heavy containers\n",
    "            if position.bay in [2, 3, 4]:  # Stronger bays\n",
    "                score += 2.0\n",
    "            else:\n",
    "                score -= 1.0\n",
    "        \n",
    "        # Structural integrity\n",
    "        if position.maintenance_status == 'good':\n",
    "            score += 1.5\n",
    "        elif position.maintenance_status == 'poor':\n",
    "            score -= 2.0\n",
    "        \n",
    "        # Vessel stability\n",
    "        if position.tier <= 2:  # Lower tiers for stability\n",
    "            score += 1.0\n",
    "        \n",
    "        return score\n",
    "    \n",
    "    def _general_human_evaluation(self, container: Container, position: Position) -> float:\n",
    "        \"\"\"General human evaluation factors\"\"\"\n",
    "        score = 0.0\n",
    "        \n",
    "        # Priority considerations\n",
    "        if container.priority_level == 'critical':\n",
    "            score += 2.0\n",
    "        elif container.priority_level == 'high':\n",
    "            score += 1.0\n",
    "        \n",
    "        # Experience-based intuition\n",
    "        experience_factor = min(1.0, self.expert.experience_years / 20)\n",
    "        score += experience_factor * 1.5\n",
    "        \n",
    "        # Contextual understanding\n",
    "        if container.special_handling:\n",
    "            score += 1.0 if position.accessibility_score > 0.8 else -1.0\n",
    "        \n",
    "        return score\n",
    "    \n",
    "    def _get_domain_considerations(self, container: Container, position: Position) -> List[str]:\n",
    "        \"\"\"Get domain-specific considerations\"\"\"\n",
    "        considerations = []\n",
    "        \n",
    "        if self.expert.expertise_area == 'safety':\n",
    "            if container.hazardous_material:\n",
    "                considerations.append(\"Hazardous material requires high-safety position\")\n",
    "            considerations.append(f\"Safety rating: {position.safety_rating:.1f}/1.0\")\n",
    "        \n",
    "        elif self.expert.expertise_area == 'operations':\n",
    "            considerations.append(f\"Handling accessibility: {position.accessibility_score:.1f}/1.0\")\n",
    "            considerations.append(f\"Distance from current: {abs(position.bay - container.current_position[0])} bays\")\n",
    "        \n",
    "        elif self.expert.expertise_area == 'planning':\n",
    "            considerations.append(f\"Port sequence optimization for {container.destination_port}\")\n",
    "            considerations.append(f\"Discharge sequence: {container.discharge_sequence}\")\n",
    "        \n",
    "        elif self.expert.expertise_area == 'engineering':\n",
    "            considerations.append(f\"Weight: {container.weight} tons (bay capacity: {position.max_weight} tons)\")\n",
    "            considerations.append(f\"Structural integrity: {position.maintenance_status}\")\n",
    "        \n",
    "        return considerations\n",
    "    \n",
    "    def _human_risk_assessment(self, container: Container, position: Position) -> Dict:\n",
    "        \"\"\"Human expert risk assessment\"\"\"\n",
    "        \n",
    "        risks = {\n",
    "            'operational_risk': random.uniform(0.15, 0.35),\n",
    "            'safety_risk': random.uniform(0.1, 0.3),\n",
    "            'efficiency_risk': random.uniform(0.05, 0.2),\n",
    "            'contextual_risk': random.uniform(0.1, 0.25),\n",
    "            'overall_risk': 0.0\n",
    "        }\n",
    "        \n",
    "        # Human experts typically assess higher risk due to experience\n",
    "        risks['overall_risk'] = np.mean(list(risks.values())[:-1]) * 1.1\n",
    "        \n",
    "        return risks\n",
    "    \n",
    "    def _generate_human_reasoning(self, container: Container, best_choice: Dict) -> List[str]:\n",
    "        \"\"\"Generate human expert reasoning\"\"\"\n",
    "        reasoning = []\n",
    "        \n",
    "        reasoning.append(f\"Based on {self.expert.experience_years} years of {self.expert.expertise_area} experience\")\n",
    "        \n",
    "        # Add expertise-specific reasoning\n",
    "        if self.expert.expertise_area == 'safety':\n",
    "            reasoning.append(\"Safety considerations take precedence over efficiency\")\n",
    "            if container.hazardous_material:\n",
    "                reasoning.append(\"Hazardous materials require dedicated handling areas\")\n",
    "        \n",
    "        elif self.expert.expertise_area == 'operations':\n",
    "            reasoning.append(\"Operational efficiency balanced with safety requirements\")\n",
