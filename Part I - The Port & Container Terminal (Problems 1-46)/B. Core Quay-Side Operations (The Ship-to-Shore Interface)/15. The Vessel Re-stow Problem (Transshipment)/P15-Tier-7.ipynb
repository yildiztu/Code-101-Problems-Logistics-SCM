    "class CollaborativeDecisionEngine:\n",
    "    \"\"\"Engine for human-AI collaborative decision making\"\"\"\n",
    "    \n",
    "    def __init__(self, config: PartnershipConfig):\n",
    "        self.config = config\n",
    "        self.decision_history = []\n",
    "        self.trust_metrics = {\n",
    "            'human_trust_in_ai': [],\n",
    "            'ai_trust_in_human': [],\n",
    "            'collaboration_success': []\n",
    "            'agreement_rate': []\n",
    "        }\n",
    "        \n",
    "    def make_collaborative_decision(self, container: Container, \n",
    "                                   available_positions: List[Position],\n",
    "                                   human_expert: HumanExpert,\n",
    "                                   ai_agent: AIAgent,\n",
    "                                   explainable_ai: ExplainableAI,\n",
    "                                   human_system: HumanExpertSystem) -> CollaborationDecision:\n",
    "        \"\"\"Make collaborative decision between human and AI\"\"\"\n",
    "        \n",
    "        # Get recommendations from both partners\n",
    "        ai_recommendation = explainable_ai.generate_recommendation(container, available_positions)\n",
    "        human_recommendation = human_system.generate_recommendation(\n",
    "            container, available_positions, ai_recommendation\n",
    "        )\n",
    "        \n",
    "        # Determine decision authority based on configuration\n",
    "        authority = self._determine_authority(\n",
    "            human_recommendation, ai_recommendation, human_expert, ai_agent\n",
    "        )\n",
    "        \n",
    "        # Make final decision\n",
    "        final_decision = self._make_final_decision(\n",
    "            authority, human_recommendation, ai_recommendation\n",
    "        )\n",
    "        \n",
    "        # Calculate confidence and trust impact\n",
    "        confidence_score = self._calculate_collaborative_confidence(\n",
    "            human_recommendation, ai_recommendation, authority\n",
    "        )\n",
    "        \n",
    "        trust_impact = self._calculate_trust_impact(\n",
    "            human_recommendation, ai_recommendation, final_decision\n",
    "        )\n",
    "        \n",
    "        # Generate explanation\n",
    "        explanation = self._generate_collaborative_explanation(\n",
    "            authority, human_recommendation, ai_recommendation, final_decision\n",
    "        )\n",
    "        \n",
    "        # Create collaboration decision\n",
    "        decision = CollaborationDecision(\n",
    "            timestamp=datetime.now(),\n",
    "            decision_type='container_assignment',\n",
    "            human_recommendation=human_recommendation,\n",
    "            ai_recommendation=ai_recommendation,\n",
    "            final_decision=final_decision,\n",
    "            authority=authority,\n",
    "            confidence_score=confidence_score,\n",
    "            trust_impact=trust_impact,\n",
    "            explanation=explanation\n",
    "        )\n",
    "        \n",
    "        # Update trust metrics\n",
    "        self._update_trust_metrics(decision, human_expert, ai_agent)\n",
    "        \n",
    "        # Store decision\n",
    "        self.decision_history.append(decision)\n",
    "        \n",
    "        return decision\n",
    "    \n",
    "    def _determine_authority(self, human_rec: Dict, ai_rec: Dict, \n",
    "                             human_expert: HumanExpert, ai_agent: AIAgent) -> str:\n",
    "        \"\"\"Determine who has decision authority\"\"\"\n",
    "        \n",
    "        if self.config.authority_allocation == 'fixed':\n",
    "            return 'collaborative'  # Always collaborative\n",
    "        \n",
    "        elif self.config.authority_allocation == 'dynamic':\n",
    "            # Dynamic authority based on confidence and trust\n",
    "            human_confidence = human_rec['confidence']\n",
    "            ai_confidence = ai_rec['confidence']\n",
    "            \n",
    "            # Consider trust levels\n",
    "            human_trust = human_expert.trust_in_ai\n",
    "            ai_trust = ai_agent.trust_in_human\n",
    "            \n",
    "            # Authority logic\n",
    "            if (human_confidence > self.config.collaboration_threshold and \n",
    "                human_expert.experience_years > 10):\n",
    "                return 'human'\n",
    "            elif (ai_confidence > self.config.collaboration_threshold and \n",
    "                  ai_trust > 0.8):\n",
    "                return 'ai'\n",
    "            else:\n",
    "                return 'collaborative'\n",
    "        \n",
    "        elif self.config.authority_allocation == 'consensus':\n",
    "            # Check if recommendations align\n",
    "            if (human_rec['recommendation'] == ai_rec['recommendation'] and \n",
    "                human_rec['recommendation'] is not None):\n",
    "                return 'consensus'\n",
    "            else:\n",
    "                return 'collaborative'\n",
    "        \n",
    "        return 'collaborative'  # Default\n",
    "    \n",
    "    def _make_final_decision(self, authority: str, \n",
    "                             human_rec: Dict, ai_rec: Dict) -> Dict:\n",
    "        \"\"\"Make final decision based on authority\"\"\"\n",
    "        \n",
    "        if authority == 'human':\n",
    "            return {\n",
    "                'position': human_rec['recommendation'],\n",
    "                'confidence': human_rec['confidence'],\n",
    "                'reasoning': human_rec['reasoning'],\n",
    "                'source': 'human_expert'\n",
    "            }\n",
    "        elif authority == 'ai':\n",
    "            return {\n",
    "                'position': ai_rec['recommendation'],\n",
    "                'confidence': ai_rec['confidence'],\n",
    "                'reasoning': ai_rec['reasoning'],\n",
    "                'source': 'ai_agent'\n",
    "            }\n",
    "        elif authority == 'consensus':\n",
    "            return {\n",
    "                'position': human_rec['recommendation'],\n",
    "                'confidence': (human_rec['confidence'] + ai_rec['confidence']) / 2,\n",
    "                'reasoning': human_rec['reasoning'] + ai_rec['reasoning'],\n",
    "                'source': 'human_ai_consensus'\n",
    "            }\n",
    "        else:  # collaborative\n",
    "            # Weighted collaborative decision\n",
    "            if human_rec['recommendation'] and ai_rec['recommendation']:\n",
    "                # If both have recommendations, use weighted average\n",
    "                human_weight = 0.6  # Slightly favor human in collaboration\n",
    "                ai_weight = 0.4\n",
    "                \n",
    "                # For simplicity, choose human recommendation with AI insights\n",
    "                return {\n",
    "                    'position': human_rec['recommendation'],\n",
    "                    'confidence': (human_weight * human_rec['confidence'] + \n",
    "                                 ai_weight * ai_rec['confidence']),\n",
    "                    'reasoning': human_rec['reasoning'] + ['AI insights considered'],\n",
    "                    'source': 'human_ai_collaboration'\n",
    "                }\n",
    "            else:\n",
    "                # Fallback to whichever has a recommendation\n",
    "                if human_rec['recommendation']:\n",
    "                    return self._make_final_decision('human', human_rec, ai_rec)\n",
    "                else:\n",
    "                    return self._make_final_decision('ai', human_rec, ai_rec)\n",
    "    \n",
    "    def _calculate_collaborative_confidence(self, human_rec: Dict, \n",
    "                                           ai_rec: Dict, authority: str) -> float:\n",
    "        \"\"\"Calculate confidence in collaborative decision\"\"\"\n",
    "        \n",
    "        if authority == 'consensus':\n",
    "            return min(0.95, (human_rec['confidence'] + ai_rec['confidence']) / 2 * 1.2)\n",
    "        elif authority == 'collaborative':\n",
    "            return min(0.90, (human_rec['confidence'] + ai_rec['confidence']) / 2 * 1.1)\n",
    "        elif authority == 'human':\n",
    "            return human_rec['confidence']\n",
    "        elif authority == 'ai':\n",
    "            return ai_rec['confidence']\n",
    "        else:\n",
    "            return 0.5  # Default confidence\n",
    "    \n",
    "    def _calculate_trust_impact(self, human_rec: Dict, ai_rec: Dict, \n",
    "                                final_decision: Dict) -> float:\n",
    "        \"\"\"Calculate impact on trust levels\"\"\"\n",
    "        \n",
    "        # Positive trust impact if decision is confident and well-reasoned\n",
    "        trust_impact = final_decision['confidence'] * 0.1\n",
    "        \n",
    "        # Additional impact if reasoning is comprehensive\n",
    "        if len(final_decision['reasoning']) > 3:\n",
    "            trust_impact += 0.05\n",
    "        \n",
    "        return trust_impact\n",
    "    \n",
    "    def _generate_collaborative_explanation(self, authority: str, \n",
    "                                           human_rec: Dict, ai_rec: Dict, \n",
    "                                           final_decision: Dict) -> str:\n",
    "        \"\"\"Generate explanation for collaborative decision\"\"\"\n",
    "        \n",
    "        explanation = f\"\"\"Collaborative Decision Analysis:\n",
    "\n",
    "**Decision Authority**: {authority.title()}\n",
    "**Final Decision**: Position {final_decision['position']}\n",
    "**Confidence Level**: {final_decision['confidence']:.1%}\n",
    "**Decision Source**: {final_decision['source'].replace('_', ' ').title()}\n",
    "\n",
    "**Human Expert Input**:\n",
    "\"\"\"\n",
    "        \n",
    "        # Add human reasoning\n",
    "        for i, reason in enumerate(human_rec['reasoning'][:2], 1):\n",
    "            explanation += f\"{i}. {reason}\\n\"\n",
    "        \n",
    "        explanation += f\"\\n**AI Agent Input**:\\n\"\n",
    "        \n",
    "        # Add AI reasoning\n",
    "        for i, reason in enumerate(ai_rec['reasoning'][:2], 1):\n",
    "            explanation += f\"{i}. {reason}\\n\"\n",
    "        \n",
    "        # Add collaboration insights\n",
    "        if authority == 'collaborative':\n",
    "            explanation += f\"\\n**Collaboration Insights**: Human expertise combined with AI analytics for optimal decision\\n\"\n",
    "        elif authority == 'consensus':\n",
    "            explanation += f\"\\n**Consensus Achievement**: Both human and AI independently reached the same conclusion\\n\"\n",
    "        \n",
    "        return explanation\n",
    "    \n",
    "    def _update_trust_metrics(self, decision: CollaborationDecision, \n",
    "                             human_expert: HumanExpert, ai_agent: AIAgent):\n",
    "        \"\"\"Update trust metrics based on decision outcome\"\"\"\n",
    "        \n",
    "        # Update trust levels\n",
    "        human_expert.trust_in_ai += decision.trust_impact * self.config.trust_update_rate\n",
    "        human_expert.trust_in_ai = max(0.0, min(1.0, human_expert.trust_in_ai))\n",
    "        \n",
    "        ai_agent.trust_in_human += decision.trust_impact * self.config.trust_update_rate\n",
    "        ai_agent.trust_in_human = max(0.0, min(1.0, ai_agent.trust_in_human))\n",
    "        \n",
    "        # Record trust metrics\n",
    "        self.trust_metrics['human_trust_in_ai'].append(human_expert.trust_in_ai)\n",
    "        self.trust_metrics['ai_trust_in_human'].append(ai_agent.trust_in_human)\n",
    "        \n",
    "        # Calculate agreement rate\n",
    "        agreement = 1.0 if decision.authority == 'consensus' else 0.0\n",
    "        self.trust_metrics['agreement_rate'].append(agreement)\n",
    "        \n",
    "        # Calculate collaboration success\n",
    "        success = decision.confidence_score * decision.trust_impact\n",
    "        self.trust_metrics['collaboration_success'].append(success)"
   ]
