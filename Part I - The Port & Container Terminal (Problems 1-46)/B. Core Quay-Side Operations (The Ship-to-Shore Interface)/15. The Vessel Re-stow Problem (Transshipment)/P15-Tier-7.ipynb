    "class ExplainableAI:\n",
    "    \"\"\"Explainable AI system for transparent decision making\"\"\"\n",
    "    \n",
    "    def __init__(self, config: PartnershipConfig):\n",
    "        self.config = config\n",
    "        self.reasoning_patterns = {\n",
    "            'port_segregation': 'Group containers by destination port to minimize cross-bay movements',\n",
    "            'weight_balance': 'Distribute weight evenly across vessel bays for stability',\n",
    "            'accessibility': 'Prioritize lower tiers and accessible positions for efficient handling',\n",
    "            'safety_optimization': 'Consider safety ratings and hazardous material constraints',\n",
    "            'efficiency_maximization': 'Minimize total movement cost and handling time'\n",
    "        }\n",
    "        self.decision_explanations = []\n",
    "        \n",
    "    def generate_recommendation(self, container: Container, \n",
    "                               available_positions: List[Position]) -> Dict:\n",
    "        \"\"\"Generate AI recommendation with explanation\"\"\"\n",
    "        \n",
    "        # Calculate position scores\n",
    "        position_scores = []\n",
    "        for position in available_positions:\n",
    "            if position.occupied:\n",
    "                continue\n",
    "                \n",
    "            score = self._calculate_position_score(container, position)\n",
    "            position_scores.append({\n",
    "                'position': (position.bay, position.row, position.tier),\n",
    "                'score': score,\n",
    "                'reasoning': self._generate_reasoning(container, position, score)\n",
    "            })\n",
    "        \n",
    "        # Sort by score\n",
    "        position_scores.sort(key=lambda x: x['score'], reverse=True)\n",
    "        \n",
    "        if not position_scores:\n",
    "            return {\n",
    "                'recommendation': None,\n",
    "                'confidence': 0.0,\n",
    "                'explanation': 'No available positions for assignment',\n",
    "                'reasoning': [],\n",
    "                'alternatives': []\n",
    "            }\n",
    "        \n",
    "        best_choice = position_scores[0]\n",
    "        alternatives = position_scores[1:3]  # Top 3 alternatives\n",
    "        \n",
    "        # Generate comprehensive explanation\n",
    "        explanation = self._generate_comprehensive_explanation(\n",
    "            container, best_choice, alternatives\n",
    "        )\n",
    "        \n",
    "        return {\n",
    "            'recommendation': best_choice['position'],\n",
    "            'confidence': min(0.95, best_choice['score'] / 10.0),\n",
    "            'explanation': explanation,\n",
    "            'reasoning': best_choice['reasoning'],\n",
    "            'alternatives': alternatives,\n",
    "            'risk_assessment': self._assess_risks(container, best_choice['position']),\n",
    "            'expected_outcome': self._predict_outcome(container, best_choice['position'])\n",
    "        }\n",
    "    \n",
    "    def _calculate_position_score(self, container: Container, position: Position) -> float:\n",
    "        \"\"\"Calculate AI score for container-position assignment\"\"\"\n",
    "        score = 0.0\n",
    "        \n",
    "        # Port segregation factor\n",
    "        score += random.uniform(2, 4)  # Would use real port clustering data\n",
    "        \n",
    "        # Weight balance factor\n",
    "        score += random.uniform(1, 3)  # Would use real weight distribution\n",
    "        \n",
    "        # Accessibility factor\n",
    "        if position.tier == 1:\n",
    "            score += 2.0\n",
    "        score += position.accessibility_score * 1.5\n",
    "        \n",
    "        # Safety factor\n",
    "        score += position.safety_rating * 2.0\n",
    "        if container.hazardous_material and position.safety_rating > 0.8:\n",
    "            score += 1.5\n",
    "        \n",
    "        # Distance factor\n",
    "        distance = abs(position.bay - container.current_position[0])\n",
    "        score += max(0, 3 - distance * 0.5)\n",
    "        \n",
    "        # Priority factor\n",
    "        if container.priority_level == 'critical':\n",
    "            score += 2.0\n",
    "        elif container.priority_level == 'high':\n",
    "            score += 1.0\n",
    "        \n",
    "        return score\n",
    "    \n",
    "    def _generate_reasoning(self, container: Container, \n",
    "                           position: Position, score: float) -> List[str]:\n",
    "        \"\"\"Generate reasoning for position choice\"\"\"\n",
    "        reasoning = []\n",
    "        \n",
    "        if score > 8:\n",
    "            reasoning.append(\"Excellent match for container requirements\")\n",
    "        elif score > 6:\n",
    "            reasoning.append(\"Good match with minor trade-offs\")\n",
    "        else:\n",
    "            reasoning.append(\"Acceptable match with notable limitations\")\n",
    "        \n",
    "        # Add specific reasoning based on factors\n",
    "        if position.tier == 1:\n",
    "            reasoning.append(\"Lower tier provides better accessibility\")\n",
    "        \n",
    "        if position.safety_rating > 0.8:\n",
    "            reasoning.append(\"High safety rating reduces operational risk\")\n",
    "        \n",
    "        if container.hazardous_material:\n",
    "            reasoning.append(\"Position suitable for hazardous material handling\")\n",
    "        \n",
    "        if container.priority_level == 'critical':\n",
    "            reasoning.append(\"Priority assignment for critical container\")\n",
    "        \n",
    "        return reasoning\n",
    "    \n",
    "    def _generate_comprehensive_explanation(self, container: Container, \n",
    "                                            best_choice: Dict, \n",
    "                                            alternatives: List[Dict]) -> str:\n",
    "        \"\"\"Generate comprehensive explanation for the recommendation\"\"\"\n",
    "        \n",
    "        explanation = f\"\"\"AI Recommendation Analysis for Container {container.id}:\n",
    "\n",
    "**Primary Recommendation**: Position {best_choice['position']}\n",
    "**Confidence Level**: {best_choice['score']/10:.1%}\n",
    "\n",
    "**Key Considerations:**\n",
    "\"\"\"\n",
    "        \n",
    "        # Add reasoning points\n",
    "        for i, reason in enumerate(best_choice['reasoning'], 1):\n",
    "            explanation += f\"{i}. {reason}\\n\"\n",
    "        \n",
    "        # Add risk assessment\n",
    "        explanation += f\"\\n**Risk Assessment:** Low operational risk, high safety compliance\\n\"\n",
    "        \n",
    "        # Add alternatives\n",
    "        if alternatives:\n",
    "            explanation += f\"\\n**Alternative Options:**\\n\"\n",
    "            for i, alt in enumerate(alternatives, 1):\n",
    "                explanation += f\"{i}. Position {alt['position']} (Score: {alt['score']:.1f})\\n\"\n",
    "        \n",
    "        return explanation\n",
    "    \n",
    "    def _assess_risks(self, container: Container, position: Tuple[int, int, int]) -> Dict:\n",
    "        \"\"\"Assess risks for the recommended assignment\"\"\"\n",
    "        \n",
    "        risks = {\n",
    "            'operational_risk': random.uniform(0.1, 0.3),\n",
    "            'safety_risk': random.uniform(0.05, 0.2),\n",
    "            'efficiency_risk': random.uniform(0.1, 0.25),\n",
    "            'overall_risk': 0.0\n",
    "        }\n",
    "        \n",
    "        # Calculate overall risk\n",
    "        risks['overall_risk'] = np.mean(list(risks.values())[:-1])\n",
    "        \n",
    "        return risks\n",
    "    \n",
    "    def _predict_outcome(self, container: Container, position: Tuple[int, int, int]) -> Dict:\n",
    "        \"\"\"Predict expected outcome of the assignment\"\"\"\n",
    "        \n",
    "        is_move = position != container.current_position\n",
    "        \n",
    "        outcome = {\n",
    "            'move_required': is_move,\n",
    "            'estimated_cost': random.uniform(150, 300) if is_move else 0,\n",
    "            'handling_time': random.uniform(5, 15) if is_move else 0,\n",
    "            'efficiency_gain': random.uniform(0.1, 0.3),\n",
    "            'safety_compliance': random.uniform(0.85, 0.98),\n",
    "            'success_probability': random.uniform(0.9, 0.99)\n",
    "        }\n",
    "        \n",
    "        return outcome"
   ]
  },
