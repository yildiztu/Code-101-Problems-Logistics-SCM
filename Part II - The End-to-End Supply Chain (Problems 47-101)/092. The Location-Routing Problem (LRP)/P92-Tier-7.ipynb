    "        \n    ",
    "        # Learning insights\n    ",
    "        print(f\"\\nLearning Insights:\")\n    ",
    "        print(f\"  Human strategic preferences evolved through {final_solution.interaction_history[2]} iterations\")\n    ",
    ",
    "        if final_solution.human_modifications['preferences_updated']:\n    ",
    "            print(f\"  Human learned to value resilience more (preference weight increased)\")\n    ",
    "        \n    ",
    "        return {\n    ",
    "            'cost_improvement': cost_improvement,\n    ",
    "            'carbon_improvement': carbon_improvement,\n    ",
    "            'resilience_improvement': resilience_improvement,\n    ",
