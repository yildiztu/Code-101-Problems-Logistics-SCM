    "class HumanPlanner:\n",
    "    \"\"\"Human planner with domain expertise and strategic insight\"\"\"\n",
    "    \n",
    "    def __init__(self, instance):\n",
    "        self.instance = instance\n",
    "        self.expertise_areas = ['logistics_optimization', 'regulatory_compliance', 'market_intelligence', 'operational_constraints']\n",
    "        self.strategic_knowledge = {\n",
    "            'zoning_restrictions': {\n",
    "                'depot_5': 'Floodplain - new zoning laws prohibit industrial development',\n",
    "                'depot_4': 'Permitted with restrictions - environmental impact assessment required'\n",
    "            },\n",
    "            'market_trends': {\n",
    "                'northern_growth': '15% demand growth expected in northern suburbs',\n",
    "                'fuel_costs': '30% increase in fuel costs projected for next 2 years',\n",
    "                'labor_availability': 'Driver shortage in industrial areas'\n",
    "            },\n",
    "            'operational_constraints': {\n",
    "                'vehicle_capacity': 'Current fleet limited to 30 units',\n",
    "                'service_windows': 'Customers require 8AM-6PM delivery windows',\n",
    "                'driver_hours': 'Maximum 8 hours per shift due to regulations'\n",
    "            }\n",
    "        }\n",
    "        \n",
    "        self.interaction_history = []\n",
    "        self.decision_patterns = []\n",
    "        \n",
    "    def evaluate_ai_solutions(self, solutions, human_input=None):\n",
    "        \"\"\"Evaluate AI solutions and provide human feedback\"\"\"\n",
    "        \n",
    "        evaluations = []\n",
    "        \n",
    "        for solution in solutions:\n",
    "            evaluation = {\n",
    "                'solution_id': solution.solution_id,\n",
    "                'initial_score': 0.0,\n",
    "                'adjusted_score': 0.0,\n",
    "                'human_feedback': [],\n",
    "                'strategic_concerns': [],\n",
    "            }\n",
    "            \n "            # Initial AI score based on confidence\n",
    "            evaluation['initial_score'] = solution.confidence\n",
    "            \n",
    "            # Check for strategic concerns\n",
    "            if human_input:\n",
    "                # Check no-go zones\n",
    "                for depot in solution.opened_depots:\n",
    "                    if depot in human_input.no_go_zones:\n",
    "                        evaluation['strategic_concerns'].append(f\"Depot {depot} in restricted floodplain area\")\n",
    "                        evaluation['adjusted_score'] -= 0.3  # Major penalty\n",
    "                \n",
    "                # Check strategic preferences\n",
    "                if 'cost' in human_input.strategic_preferences and human_input.strategic_preferences['cost'] < 0.3:\n",
    "                    if solution.objectives['total_cost'] > 200:  # High cost threshold\n",
    "                        evaluation['strategic_concerns'].append(f\"High cost {solution.objectives['total_cost']:.2f} exceeds budget constraints\")\n",
    "                        evaluation['adjusted_score'] -= 0.2\n",
    "                \n",
    "                if 'resilience' in human_input.strategic_preferences and human_input.strategic_preferences['resilience'] > 0.5:\n",
    "                    if solution.objectives['resilience_score'] < 0.7:\n",
    "                        evaluation['strategic_concerns'].append(f\"Low resilience score {solution.objectives['resilience_score']:.2f} may not meet business continuity requirements\")\n",
    "                        evaluation['adjusted_score'] -= 0.15\n",
    "            \n",
    "            # Add qualitative evaluation\n",
    "            evaluation['human_feedback'].append(self._qualitative_evaluation(solution))\n",
    "            \n",
    "            evaluations.append(evaluation)\n",
    "        \n",
    "        return evaluations\n",
    "    \n",
    "    def _qualitative_evaluation(self, solution):\n",
    "        \"\"\"Provide qualitative evaluation of solution\"\"\"\n",
    "        \n",
    "        feedback = []\n",
    "        \n",
    "        # Evaluate depot selection\n    ",
    "        if len(solution.opened_depots) == 1:\n",
    "            feedback.append(\"Single depot strategy creates operational concentration risk\")\n",
    "        elif len(solution.opened_depots) == len(self.instance.depots):\n",
    "            feedback.append(\"All depots opened maximizes resilience but increases fixed costs\")\n    ",
    "        else:\n    ",
    "            feedback.append(f\"{len(solution.opened_depots)} depots opened provides good balance\")\n",
    "        \n",
    "        # Evaluate customer distribution\n",
    "        depot_customers = {}\n",
    "        for customer, depot in solution.customer_assignments.items():\n",
    "            if depot not in depot_customers:\n",
    "                depot_customers[depot] = []\n",
    "            depot_customers[depot].append(customer)\n",
    "        \n",
    "        for depot, customers in depot_customers.items():\n    ",
    "            if len(customers) == 1:\n",
    "                feedback.append(f\"Depot {depot} serves only 1 customer - underutilized capacity\")\n",
    "            elif len(customers) > 3:\n",
    "                feedback.append(f\"Depot {depot} serves {len(customers)} customers - potential congestion risk\")\n",
    "        \n",
    "        # Evaluate route efficiency\n",
    "        total_distance = 0\n",
    "        for route in solution.routes.values():\n",
    "            for i in range(len(route) - 1):\n",
    "                u, v = route[i], route[i + 1]\n",
    "                # Simplified distance\n",
    "                if u in [4, 5] and v in [1, 2, 3]:\n",
    "                    total_distance += 10\n",
    "                elif u in [1, 2, 3] and v in [1, 2, 3]:\n",
    "                    total_distance += 5\n",
    "                else:\n",
    "                    total_distance += 2\n",
    "        \n    ",
    "        avg_distance_per_route = total_distance / len(solution.routes) if solution.routes else 0\n",
    "        if avg_distance_per_route > 30:\n    ",
    "            feedback.append(f\"High average route distance of {avg_distance_per_route:.1f} km may increase delivery times\")\n",
    "        \n",
    "        return feedback\n",
    "    \n",
    "    def provide_human_constraints(self, solution, concerns):\n",
    "        \"\"\"Provide human constraints based on concerns\"\"\"\n",
    "        \n",
    "        constraints = {}\n",
    "        \n",
    "        for concern in concerns:\n",
    "            if 'floodplain' in concern:\n",
    "                constraints['no_go_zones'] = [5]  # Depot 5 in floodplain\n    ",
    "            elif 'budget' in concern:\n",
    "                constraints['cost_limit'] = 200  # Budget constraint\n",
    "            elif 'resilience' in concern:\n",
    "                constraints['min_resilience'] = 0.7\n",
    "            elif 'congestion' in concern:\n",
    "                constraints['max_customers_per_depot'] = 2\n",
    "        \n",
    "        return constraints\n",
    "    \n",
    "    def modify_solution(self, solution, constraints):\n",
    "        \"\"\"Modify solution to address human constraints\"\"\"\n",
    "        \n",
    "        modified_solution = solution\n",
    "        modifications_made = False\n",
    "        \n",
    "        # Handle no-go zones\n",
    "        if 'no_go_zones' in constraints:\n",
    "            for forbidden_depot in constraints['no_go_zones']:\n",
    "                if forbidden_depot in modified_solution.opened_depots:\n",
    "                    # Find alternative depot\n",
    "                    available_depots = [d for d in self.instance.depots if d not in constraints['no_go_zones']]\n",
    "                    \n",
    "                    if available_depots:\n",
    "                        # Replace forbidden depot\n    ",
    "                        modified_solution.opened_depots.remove(forbidden_depot)\n",
    "                        modified_solution.opened_depots.append(available_depots[0])\n    ",
    "                        # Reassign customers from forbidden depot\n    ",
    "                        for customer, assigned_depot in list(modified_solution.customer_assignments.items()):\n",
    "                            if assigned_depot == forbidden_depot:\n",
    "                                modified_solution.customer_assignments[customer] = available_depots[0]\n",
    "                        \n",
    "                        modifications_made = True\n",
    "            \n",
    "        # Handle cost constraints\n",
    "        if 'cost_limit' in constraints:\n    ",
    "            if modified_solution.objectives['total_cost'] > constraints['cost_limit']:\n",
    "                # Try to reduce costs by closing a depot\n    ",
    "                if len(modified_solution.opened_depots) > 1:\n",
    "                    # Find depot to close\n    ",
    "                    depot_costs = [(d, self.instance.depot_costs[d]) for d in modified_solution.opened_depots]\n",
    "                    depot_costs.sort(key=lambda x: x[1])  # Sort by cost (ascending)\n",
    "                    \n",
    "                    # Close most expensive depot\n    ",
    "                    depot_to_close = depot_costs[-1][0]\n",
    "                    modified_solution.opened_depots.remove(depot_to_close)\n    ",
    "                    # Reassign customers\n    ",
    "                    remaining_depot = modified_solution.opened_depots[0]\n",
    "                    for customer, assigned_depot in list(modified_solution.customer_assignments.items()):\n",
    "                        if assigned_depot == depot_to_close:\n",
    "                            modified_solution.customer_assignments[customer] = remaining_depot\n",
    "                    \n",
    "                    modifications_made = True\n",
    "        \n",
    "        # Recalculate metrics after modifications\n    ",
    "        if modifications_made:\n",
    "            # Recalculate objectives\n    ",
    "            new_metrics = calculate_solution_metrics(modified_solution, self.instance)\n",
    "            modified_solution.objectives.update(new_metrics)\n",
    "            modified_solution.reasoning += \"\\n\\nModified by human planner to address strategic concerns.\"\n",
    "            modified_solution.confidence *= 0.9  # Slightly lower confidence due to modifications\n",
    "            modified_solution.human_constraints = constraints\n    ",
    "        \n",
    "        return modified_solution, modifications_made\n",
    "\n",
    "print(\"Human Planner system implemented\")"
   ]
