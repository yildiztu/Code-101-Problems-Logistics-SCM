    "@dataclass\n",
    "class LRPInstance:\n",
    "    \"\"\"Data class for Location-Routing Problem instance\"\"\"\n",
    "    customers: List[int]\n",
    "    depots: List[int]\n",
    "    vehicles: List[int]\n",
    "    depot_costs: Dict[int, float]\n",
    "    demands: Dict[int, float]\n",
    "    vehicle_capacity: float\n",
    "    travel_costs: Dict[Tuple[int, int], float]\n",
    "    \n",
    "    def get_all_nodes(self):\n",
    "        return self.customers + self.depots\n",
    "\n",
    "@dataclass\n",
    "class Solution:\n",
    "    \"\"\"Solution to LRP with multiple objectives\"\"\"\n",
    "    solution_id: str\n",
    "    opened_depots: List[int]\n",
    "    customer_assignments: Dict[int, int]\n",
    "    routes: Dict[int, List[int]]\n",
    "    objectives: Dict[str, float]  # cost, carbon, resilience, etc.\n",
    "    reasoning: str\n",
    "    confidence: float\n",
    "    human_constraints: Dict[str, any]\n",
    "\n",
    "@dataclass\n",
    "class HumanInput:\n",
    "    \"\"\"Human strategic input and constraints\"\"\"\n",
    "    no_go_zones: List[int]  # Depot locations that cannot be used\n",
    "strategic_preferences: Dict[str, float]  # Weight preferences for objectives\n",
    "qualitative_factors: Dict[str, str]  # Qualitative considerations\n",
    "confidence_threshold: float  # Minimum confidence for AI solutions\n",
    "iteration_count: int = 0\n",
    "\n",
    "@dataclass\n",
    "class HumanAISolution:\n",
    "    \"\"\"Jointly created human-AI solution\"\"\"\n",
    "final_solution: Solution\n",
    "ai_proposals: List[Solution]\n",
    "human_modifications: Dict[str, any]\n",
    "collaboration_score: float\n",
    "improvement_made: bool\n",
    "interaction_history: List[str]\n",
    "\n",
    "# Create the concrete example\n",
    "def create_concrete_example():\n",
    "    customers = [1, 2, 3]\n",
    "    depots = [4, 5]\n",
    "    vehicles = [1, 2]\n",
    "    \n",
    "    depot_costs = {4: 100, 5: 120}\n",
    "    demands = {1: 10, 2: 15, 3: 20}\n",
    "    vehicle_capacity = 30\n",
    "    \n",
    "    travel_costs = {\n",
    "        (1, 2): 15, (2, 1): 15,\n",
    "        (1, 3): 20, (3, 1): 20,\n",
    "        (2, 3): 18, (3, 2): 18,\n",
    "        (4, 1): 12, (1, 4): 12,\n",
    "        (4, 2): 14, (2, 4): 14,\n",
    "        (4, 3): 25, (3, 4): 25,\n",
    "        (5, 1): 18, (1, 5): 18,\n",
    "        (5, 2): 16, (2, 5): 16,\n",
    "        (5, 3): 22, (3, 5): 22,\n",
    "        (4, 5): 30, (5, 4): 30,\n",
    "        (1, 1): 0, (2, 2): 0, (3, 3): 0,\n",
    "        (4, 4): 0, (5, 5): 0\n",
    "    }\n",
    "    \n",
    "    return LRPInstance(\n",
    "        customers=customers,\n",
    "        depots=depots,\n",
    "        vehicles=vehicles,\n",
    "        depot_costs=depot_costs,\n",
    "        demands=demands,\n",
    "        vehicle_capacity=vehicle_capacity,\n",
    "        travel_costs=travel_costs\n",
    "    )\n",
    "\n",
    "instance = create_concrete_example()\n",
    "print(f\"LRP Instance created for Human-AI Partnership:\")\n",
    "print(f\"Customers: {instance.customers}\")\n",
    "print(f\"Potential Depots: {instance.depots}\")\n",
    "print(f\"Vehicles: {instance.vehicles}\")\n",
    "print(f\"Vehicle Capacity: {instance.vehicle_capacity}\")"
   ]
