    "        print(f\"  Cost Improvement: ${cost_improvement:.2f} ({cost_improvement/best_initial.objectives['total_cost']*100:.1f}%)\")\n    ",
    "        print(f\"  Carbon Reduction: {carbon_improvement:.1f} kg CO2\")\n    ",
    "        print(f\"  Resilience Improvement: {resilience_improvement:.2f}\")\n    ",
    "        \n    ",
    "        # Analysis of collaboration process\n    ",
    "        print(f\"\\nCollaboration Process Analysis:\")\n    ",
    "        print(f\"  Iterations: {final_solution.interaction_history[2]}\")\n    ",
