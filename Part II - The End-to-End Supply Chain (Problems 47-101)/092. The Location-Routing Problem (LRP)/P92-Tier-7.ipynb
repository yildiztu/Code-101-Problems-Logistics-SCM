    "def calculate_solution_metrics(solution, instance):\n",
    "    \"\"\"Calculate comprehensive metrics for a solution\"\"\"\n",
    "    \n",
    "    if not solution.opened_depots:\n",
    "        return {\n",
    "            'total_cost': float('inf'),\n",
    "            'fixed_cost': 0,\n",
    "            'routing_cost': 0,\n",
    "            'carbon_footprint': float('inf'),\n",
    "            'resilience_score': 0.0,\n",
    "            'service_level': 0.0\n",
    "        }\n",
    "    \n",
    "    # Basic costs\n",
    "    fixed_cost = sum(instance.depot_costs[j] for j in solution.opened_depots)\n",
    "    \n",
    "    routing_cost = 0\n",
    "    for route in solution.routes.values():\n",
    "        for i in range(len(route) - 1):\n",
    "            u, v = route[i], route[i + 1]\n",
    "            routing_cost += instance.travel_costs.get((u, v), float('inf'))\n",
    "    \n",
    "    total_cost = fixed_cost + routing_cost\n",
    "    \n",
    "    # Carbon footprint (simplified model)\n",
    "    carbon_per_km = 0.5  # kg CO2 per km\n",
    "    total_distance = 0\n",
    "    for route in solution.routes.values():\n",
    "        for i in range(len(route) - 1):\n",
    "            u, v = route[i], route[i + 1]\n",
    "            # Simplified distance calculation\n",
    "            if u in [4, 5] and v in [1, 2, 3]:  # Depot to customer\n",
    "                distance = 10  # km\n",
    "            elif u in [1, 2, 3] and v in [1, 2, 3]:  # Customer to customer\n",
    "                distance = 5   # km\n",
    "            else:  # Depot to depot or return\n",
    "                distance = 2   # km\n",
    "            total_distance += distance\n",
    "    \n",
    "    carbon_footprint = total_distance * carbon_per_km\n",
    "    \n",
    "    # Resilience score (based on depot diversity and route redundancy)\n",
    "    depot_diversity = len(solution.opened_depots) / len(instance.depots)\n",
    "    route_redundancy = 1.0 / (1.0 + len(solution.routes))  # More routes = less resilient\n",
    "    resilience_score = 0.6 * depot_diversity + 0.4 * (1 - route_redundancy)\n",
    "    \n",
    "    # Service level (simplified - based on capacity utilization)\n",
    "    total_demand = sum(instance.demands.values())\n",
    "    total_capacity = len(solution.routes) * instance.vehicle_capacity\n",
    "    capacity_utilization = total_demand / total_capacity if total_capacity > 0 else 0\n",
    "    service_level = 1.0 - abs(capacity_utilization - 0.7)  # Optimal around 70% utilization\n",
    "    \n",
    "    return {\n",
    "        'total_cost': total_cost,\n",
    "        'fixed_cost': fixed_cost,\n",
    "        'routing_cost': routing_cost,\n",
    "        'carbon_footprint': carbon_footprint,\n",
    "        'resilience_score': resilience_score,\n",
    "        'service_level': service_level,\n",
    "        'total_distance': total_distance\n",
    "    }\n",
    "\n",
    "def generate_ai_solution_portfolio(instance, num_solutions=5):\n",
    "    \"\"\"Generate multiple AI solutions with different objectives\"\"\"\n",
    "    \n",
    "    solutions = []\n",
    "    \n",
    "    # Solution 1: Minimum Cost\n",
    "    solution1 = Solution(\n",
    "        solution_id=\"min_cost\",\n",
    "        opened_depots=[4],  # Open only cheaper depot\n",
    "        customer_assignments={1: 4, 2: 4, 3: 4},\n",
    "        routes={1: [4, 1, 2, 4], 2: [4, 3, 4]},\n",
    "        objectives={'cost': 0.8, 'carbon': 0.1, 'resilience': 0.1},\n",
    "        reasoning=\"Optimized for minimum total cost by opening only the cheaper depot (J1) and consolidating all customers.\",\n",
    "        confidence=0.85,\n",
    "        human_constraints={}\n",
    "    )\n",
    "    \n",
    "    # Solution 2: Minimum Carbon\n",
    "    solution2 = Solution(\n",
    "        solution_id=\"min_carbon\",\n",
    "        opened_depots=[4, 5],  # Open both depots to reduce travel distance\n",
    "        customer_assignments={1: 4, 2: 4, 3: 5},\n",
    "        routes={1: [4, 1, 2, 4], 2: [5, 3, 5]},\n",
    "        objectives={'cost': 0.2, 'carbon': 0.7, 'resilience': 0.1},\n",
    "        reasoning=\"Minimized carbon footprint by opening both depots to reduce total travel distance, despite higher fixed costs.\",\n",
    "        confidence=0.82,\n",
    "        human_constraints={}\n",
    "    )\n",
    "    \n",
    "    # Solution 3: Maximum Resilience\n",
    "    solution3 = Solution(\n",
    "        solution_id=\"max_resilience\",\n",
    "        opened_depots=[4, 5],  # Both depots for redundancy\n",
    "        customer_assignments={1: 4, 2: 5, 3: 4},  # Balanced assignment\n",
    "        routes={1: [4, 1, 4], 2: [4, 3, 4], 3: [5, 2, 5]},  # More routes for redundancy\n",
    "        objectives={'cost': 0.3, 'carbon': 0.2, 'resilience': 0.5},\n",
    "        reasoning=\"Maximized resilience by using both depots and creating multiple routes, ensuring system can handle disruptions.\",\n",
    "        confidence=0.78,\n",
    "        human_constraints={}\n",
    "    )\n",
    "    \n",
    "    # Solution 4: Balanced Approach\n",
    "    solution4 = Solution(\n",
    "        solution_id=\"balanced\",\n",
    "        opened_depots=[4, 5],\n",
    "        customer_assignments={1: 4, 2: 5, 3: 5},\n",
    "        routes={1: [4, 1, 4], 2: [5, 2, 3, 5]},\n",
    "        objectives={'cost': 0.4, 'carbon': 0.3, 'resilience': 0.3},\n",
    "        reasoning=\"Balanced all objectives - cost, carbon, and resilience - for comprehensive performance.\",\n",
    "        confidence=0.88,\n",
    "        human_constraints={}\n",
    "    )\n",
    "    \n",
    "    # Solution 5: Service Level Focus\n",
    "    solution5 = Solution(\n",
    "        solution_id=\"service_focus\",\n",
    "        opened_depots=[4, 5],\n",
    "        customer_assignments={1: 4, 2: 5, 3: 5},\n",
    "        routes={1: [4, 1, 4], 2: [5, 2, 5], 3: [5, 3, 5]},  # Better capacity utilization\n",
    "        objectives={'cost': 0.3, 'carbon': 0.2, 'resilience': 0.2, 'service_level': 0.3},\n",
    "        reasoning=\"Optimized for service level by ensuring better capacity utilization across all routes.\",\n",
    "        confidence=0.90,\n",
    "        human_constraints={}\n",
    "    )\n",
    "    \n",
    "    # Calculate actual metrics for all solutions\n",
    "    for solution in solutions:\n",
    "        metrics = calculate_solution_metrics(solution, instance)\n",
    "        solution.objectives.update(metrics)\n",
    "    \n",
    "    return solutions\n",
    "\n",
    "print(\"Solution generation functions implemented\")"
   ]
