    "class ExplainableAI:\n",
    "    \"\"\"Explainable AI system for transparent LRP solutions\"\"\"\n",
    "    \n",
    "    def __init__(self, instance):\n",
    "        self.instance = instance\n",
    "        self.solution_history = []\n",
    "        self.explanation_templates = {\n",
    "            'cost_focus': [\n",
    "                \"Selected depot {depot} due to lower fixed cost of ${cost}\",\n",
    "                \"Consolidated customers {customers} to minimize routing overhead\",\n",
    "                \"Trade-off: Higher capacity utilization vs lower fixed costs\"\n",
    "            ],\n",
    "            'carbon_focus': [\n",
    "                \"Opened both depots to reduce total travel distance by {distance_reduction}%\",\n",
    "                \"Carbon footprint reduced to {carbon} kg CO2 through route optimization\",\n",
    "                \"Additional fixed cost of ${extra_cost} justified by environmental benefits\"\n",
    "            ],\n",
    "            'resilience_focus': [\n",
    "                \"Multi-depot strategy provides redundancy against disruptions\",\n",
    "                \"Customer distribution: {distribution} across {num_depots} depots\",\n",
    "                \"Route diversity: {num_routes} independent routes for backup capacity\"\n",
    "            ],\n",
    "            'balanced': [\n",
    "                \"Balanced approach considering multiple objectives\",\n",
    "                \"Cost efficiency: {cost_efficiency}% of theoretical optimum\",\n",
    "                \"Carbon reduction: {carbon_reduction}% vs single depot solution\",\n",
    "                \"Resilience improvement: {resilience_improvement}% vs baseline\"\n",
    "            ]\n",
    "        }\n",
    "    \n",
    "    def generate_explanation(self, solution, metrics):\n",
    "        \"\"\"Generate human-readable explanation for a solution\"\"\"\n",
    "        \n",
    "        # Determine primary objective\n",
    "        primary_objective = max(solution.objectives.items(), key=lambda x: x[1])\n",
    "        \n",
    "        # Select appropriate template\n",
    "        if primary_objective[0] == 'cost':\n",
    "            template = self.explanation_templates['cost_focus']\n",
    "        elif primary_objective[0] == 'carbon':\n",
    "            template = self.explanation_templates['carbon_focus']\n",
    "        elif primary_objective[0] == 'resilience':\n",
    "            template = self.explanation_templates['resilience_focus']\n",
    "        else:\n",
    "            template = self.explanation_templates['balanced']\n",
    "        \n",
    "        # Fill in template with actual values\n",
    "        explanation = solution.reasoning\n",
    "        \n",
    "        # Add quantitative details\n",
    "        explanation += f\"\\n\\nQuantitative Analysis:\\n\"\n",
    "        explanation += f\"- Total Cost: ${metrics['total_cost']:.2f}\\n\"\n",
    "        explanation += f\"- Carbon Footprint: {metrics['carbon_footprint']:.1f} kg CO2\\n\"\n",
    "        explanation += f\"- Resilience Score: {metrics['resilience_score']:.2f}/1.0\\n\"\n",
    "        explanation += f\"- Service Level: {metrics['service_level']:.2%}\\n\"\n",
    "        explanation += f\"- Total Distance: {metrics['total_distance']:.1f} km\\n\"\n",
    "        \n",
    "        # Add comparative analysis\n",
    "        explanation += f\"\\nComparative Advantages:\\n\"\n",
    "        \n",
    "        if primary_objective[0] == 'cost':\n",
    "            explanation += f\"- {metrics['total_cost']:.0f}% lower cost than carbon-focused solution\\n\"\n",
    "            explanation += f\"- {metrics['routing_cost']:.0f}% of total cost from routing (efficient operations)\\n\"\n",
    "        elif primary_objective[0] == 'carbon':\n",
    "            explanation += f\"- {metrics['carbon_footprint']:.0f}% lower carbon footprint than cost-focused solution\\n",
    "            explanation += f\"- Environmental benefits justify {metrics['fixed_cost']:.0f}% higher fixed costs\\n\"\n",
    "        elif primary_objective[0] == 'resilience':\n",
    "            explanation += f\"- {metrics['resilience_score']*100:.0f}% higher resilience than single-depot solutions\\n",
    "            explanation += f\"- System can maintain {len(solution.routes)} routes during disruptions\\n\"\n",
    "        \n",
    "        # Add potential risks\n",
    "        explanation += f\"\\nPotential Considerations:\\n\"\n",
    "        \n",
    "        if len(solution.opened_depots) == 1:\n",
    "            explanation += \"- Single point of failure: all operations depend on one depot\\n\"\n",
    "        else:\n",
    "            explanation += \"- Higher fixed costs but improved redundancy\\n\"\n",
    "        \n",
    "        if metrics['service_level'] < 0.8:\n",
    "            explanation += \"- Service level below optimal range - consider capacity adjustments\\n\"\n",
    "        \n",
    "        if metrics['total_distance'] > 50:\n",
    "            explanation += \"- High total distance may increase fuel costs and delivery times\\n\"\n",
    "        \n",
    "        return explanation\n",
    "    \n",
    "    def visualize_solution_comparison(self, solutions):\n",
    "        \"\"\"Create visual comparison of AI solutions\"\"\"\n",
    "        \n",
    "        fig, ((ax1, ax2), (ax3, ax4)) = plt.subplots(2, 2, figsize=(15, 12))\n",
    "        \n",
    "        # Extract metrics for comparison\n",
    "        solution_ids = [s.solution_id for s in solutions]\n",
    "        costs = [s.objectives['total_cost'] for s in solutions]\n",
    "    "        carbons = [s.objectives['carbon_footprint'] for s in solutions]\n",
    "    "        resilience = [s.objectives['resilience_score'] for s in solutions]\n",
    "    "        service = [s.objectives['service_level'] for s in solutions]\n",
    "    "        \n",
    "        # Plot 1: Cost comparison\n",
    "        bars1 = ax1.bar(solution_ids, costs, alpha=0.7)\n",
    "        ax1.set_ylabel('Total Cost ($)')\n",
    "        ax1.set_title('Cost Comparison Across Solutions')\n",
    "        ax1.grid(True, alpha=0.3)\n",
    "        \n",
    "        # Add value labels on bars\n",
    "        for bar, value in zip(bars1, costs):\n",
    "            height = bar.get_height()\n",
    "            ax1.text(bar.get_x() + bar.get_width()/2., height + max(costs)*0.01,\n",
    "                    f'${value:.0f}', ha='center', va='bottom')\n",
    "        \n",
    "        # Plot 2: Carbon footprint\n",
    "        bars2 = ax2.bar(solution_ids, carbons, alpha=0.7, color='green')\n",
    "        ax2.set_ylabel('Carbon Footprint (kg CO2)')\n",
    "        ax2.set_title('Environmental Impact Comparison')\n",
    "        ax2.grid(True, alpha=0.3)\n",
    "        \n",
    "        # Add value labels\n",
    "        for bar, value in zip(bars2, carbons):\n",
    "            height = bar.get_height()\n",
    "            ax2.text(bar.get_x() + bar.get_width()/2., height + max(carbons)*0.01,\n",
    "                    f'{value:.1f}', ha='center', va='bottom')\n",
    "        \n",
    "        # Plot 3: Resilience score\n",
    "        bars3 = ax3.bar(solution_ids, resilience, alpha=0.7, color='orange')\n",
    "        ax3.set_ylabel('Resilience Score')\n",
    "        ax3.set_title('System Resilience Comparison')\n",
    "        ax3.grid(True, alpha=0.3)\n",
    "        ax3.set_ylim(0, 1)\n",
    "        \n",
    "        # Add value labels\n",
    "        for bar, value in zip(bars3, resilience):\n",
    "            height = bar.get_height()\n",
    "            ax3.text(bar.get_x() + bar.get_width()/2., height + 0.02,\n",
    "                    f'{value:.2f}', ha='center', va='bottom')\n",
    "        \n",
    "        # Plot 4: Service level\n",
    "        bars4 = ax4.bar(solution_ids, [s*100 for s in service], alpha=0.7, color='purple')\n",
    "        ax4.set_ylabel('Service Level (%)')\n",
    "        ax4.set_title('Service Level Performance')\n",
    "        ax4.grid(True, alpha=0.3)\n",
    "        ax4.set_ylim(0, 100)\n",
    "        \n",
    "        # Add value labels\n",
    "        for bar, value in zip(bars4, [s*100 for s in service]):\n",
    "            height = bar.get_height()\n",
    "            ax4.text(bar.get_x() + bar.get_width()/2., height + max([s*100 for s in service])*0.5,\n",
    "                    f'{value:.1f}%', ha='center', va='bottom')\n",
    "        \n",
    "        plt.tight_layout()\n",
    "        plt.show()\n",
    "    \n",
    "    def get_solution_recommendations(self, solution, metrics):\n",
    "        \"\"\"Get recommendations for improving a solution\"\"\"\n",
    "        \n",
    "        recommendations = []\n",
    "        \n",
    "        # Cost recommendations\n",
    "        if metrics['total_cost'] > 300:\n",
    "            recommendations.append({\n",
    "                'category': 'cost',\n",
    "                'priority': 'high',\n",
    "                'action': 'Consider consolidating customers to reduce fixed costs',\n",
    "                'reasoning': f'High total cost of ${metrics[\\'total_cost\\']:.2f} suggests operational inefficiencies'\n",
    "            })\n",
    "        \n",
    "        # Carbon recommendations\n",
    "        if metrics['carbon_footprint'] > 20:\n",
    "            recommendations.append({\n",
    "                'category': 'environmental',\n",
    "                'priority': 'medium',\n",
    "                'action': 'Optimize routes to reduce total travel distance',\n",
    "                'reasoning': f'Carbon footprint of {metrics[\\'carbon_footprint\\']:.1f} kg CO2 could be reduced through better routing'\n",
    "            })\n",
    "        \n",
    "        # Resilience recommendations\n",
