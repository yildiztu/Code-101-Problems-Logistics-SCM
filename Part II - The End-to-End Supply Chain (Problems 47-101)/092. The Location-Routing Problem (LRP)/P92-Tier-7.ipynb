    "class HumanAIPartnership:\n",
    "    \"\"\"Human-AI symbiotic partnership for LRP optimization\"\"\"\n",
    "    \n",
    "    def __init__(self, instance):\n",
    "        self.instance = instance\n",
    "        self.xai = ExplainableAI(instance)\n",
    "        self.human_planner = HumanPlanner(instance)\n",
    "        self.collaboration_history = []\n",
    "        self.learning_insights = {}\n",
    "        \n",
    "    def collaborative_optimization(self, max_iterations=5):\n",
    "        \"\"\"Run the complete human-AI collaborative optimization process\"\"\"\n",
    "        \n",
    "        print(f\"\\n{'='*60}\")\n",
    "        print(f\"HUMAN-AI COLLABORATIVE OPTIMIZATION\")\n",
    "        print(f\"{'='*60}\")\n",
    "        \n",
    "        # Initialize human input\n",
    "        human_input = HumanInput(\n",
    "            no_go_zones=[],  # Initially no restrictions\n",
    "            strategic_preferences={'cost': 0.4, 'carbon': 0.3, 'resilience': 0.3},  # Balanced preferences\n",
    "            qualitative_factors={'market_trend': 'northern_growth', 'regulatory_change': 'zoning_update'},\n",
    "            confidence_threshold=0.7\n",
    "        )\n",
    "        \n",
    "        # Phase 1: AI proposes solutions\n",
    "        print(\"\\nPhase 1: AI Solution Generation\")\n",
    "        ai_solutions = generate_ai_solution_portfolio(self.instance, num_solutions=5)\n",
    "        \n",
    "        # Generate explanations for all solutions\n",
    "        for solution in ai_solutions:\n",
    "            solution.reasoning = self.xai.generate_explanation(solution, solution.objectives)\n",
    "        \n",
    "        print(f\"Generated {len(ai_solutions)} AI solutions:\")\n",
    "        for solution in ai_solutions:\n",
    "            print(f\"  {solution.solution_id}: {solution.objectives['total_cost']:.2f} cost, {solution.objectives['carbon_footprint']:.1f} kg CO2\")\n",
    "        \n",
    "        # Phase 2: Human evaluation\n",
    "        print(\"\\nPhase 2: Human Evaluation and Feedback\")\n",
    "        evaluations = self.human_planner.evaluate_ai_solutions(ai_solutions, human_input)\n",
    "        \n",
    "        print(\"\\nHuman Evaluation Results:\")\n",
    "        for evaluation in evaluations:\n",
    "            print(f\"  {evaluation['solution_id']}: Initial Score {evaluation['initial_score']:.2f}, Adjusted Score {evaluation['adjusted_score']:.2f}\")\n",
    "            if evaluation['strategic_concerns']:\n",
    "                print(f\"    Concerns: {evaluation['strategic_concerns']}\")\n",
    "        \n",
    "        # Phase 3: Iterative refinement\n",
    "        current_solutions = ai_solutions.copy()\n",
    "        collaboration_score = 0.0\n",
    "        improvement_made = False\n",
    "        \n",
    "        for iteration in range(max_iterations):\n",
    "            print(f\"\\nIteration {iteration + 1}: Collaborative Refinement\")\n",
    "            \n",
    "            # Human evaluation of current solutions\n",
    "            evaluations = self.human_planner.evaluate_ai_solutions(current_solutions, human_input)\n",
    "            \n",
    "            # Find solutions with concerns\n    ",
    "            solutions_to_modify = []\n    ",
    "            for evaluation in evaluations:\n",
    "                if evaluation['adjusted_score'] < human_input.confidence_threshold:\n    ",
    "                    solution_id = evaluation['solution_id']\n    ",
    "                    solution = next((s for s in current_solutions if s.solution_id == solution_id), None)\n    ",
    "                    if solution:\n    ",
    "                        concerns = evaluation['strategic_concerns']\n    ",
    "                        constraints = self.human_planner.provide_human_constraints(solution, concerns)\n    ",
    "                        modified_solution, modifications_made = self.human_planner.modify_solution(solution, constraints)\n    ",
    "                        if modifications_made:\n    ",
    "                            # Replace in portfolio\n    ",
    "                            current_solutions = [s for s in current_solutions if s.solution_id != solution_id]\n    ",
    "                            current_solutions.append(modified_solution)\n    ",
    "                            solutions_to_modify.append(solution_id)\n    ",
    "                            print(f\"    Modified {solution_id} to address strategic concerns\")\n    ",
    "                            print(f\"      New cost: {modified_solution.objectives['total_cost']:.2f}\")\n    ",
    "                            improvement_made = True\n    ",
    "            \n",
    "            # Calculate collaboration score\n    ",
    "            avg_confidence = np.mean([s.confidence for s in current_solutions])\n    ",
    "            avg_adjusted_score = np.mean([e['adjusted_score'] for e in evaluations])\n    ",
    "            collaboration_score = avg_confidence * avg_adjusted_score\n    ",
    "            print(f\"  Collaboration Score: {collaboration_score:.3f}\")\n    ",
    "            \n",
    "            if not solutions_to_modify:\n    ",
    "                print(\"  No solutions require modification - human-AI agreement achieved\")\n    ",
    "                break\n    ",
    "            \n",
    "            # Update human input based on learning\n    ",
    "            human_input.iteration_count += 1\n    ",
    "            # Adjust preferences based on interaction patterns\n    ",
    "            if improvement_made:\n    ",
    "                # Human prefers solutions that address their concerns\n    ",
    "                human_input.strategic_preferences['resilience'] += 0.1  # Increased weight on resilience\n    ",
    "                # Normalize preferences\n    ",
    "                total_pref = sum(human_input.strategic_preferences.values())\n    ",
    "                for key in human_input.strategic_preferences:\n    ",
    "                    human_input.strategic_preferences[key] /= total_pref\n    ",
    "            \n    ",
    "        # Phase 4: Final solution selection\n    ",
    "        print(f\"\\nPhase 4: Final Solution Selection\")\n    ",
    "        \n    ",
    "        # Select best solution based on adjusted scores\n    ",
    "        best_evaluation = max(evaluations, key=lambda x: x['adjusted_score'])\n    ",
    "        best_solution = next((s for s in current_solutions if s.solution_id == best_evaluation['solution_id']), None)\n    ",
    "        \n    ",
    "        # Create final human-AI solution\n    ",
    "        final_solution = HumanAISolution(\n    ",
    "            final_solution=best_solution,\n    ",
    "            ai_proposals=ai_solutions,\n    ",
    "            human_modifications={\n    ",
    "                'iteration_count': max_iterations,\n    ",
    "                'concerns_addressed': len([e for e in evaluations if e['adjusted_score'] < 0.7]),\n    ",
    "                'preferences_updated': human_input.iteration_count > 1\n    ",
    "            },\n    ",
    "            collaboration_score=collaboration_score,\n    ",
    "            improvement_made=improvement_made,\n    ",
    "            interaction_history=[\n    ",
    "                f\"AI proposed {len(ai_solutions)} solutions\",\n    ",
    "                f\"Human evaluated and provided feedback\",\n    ",
    "                f\"{max_iterations} iterations of collaborative refinement\"\n    ",
    "            ]\n    ",
    "        )\n    ",
    "        \n    ",
    "        return final_solution\n    ",
    "\n",
    "    def analyze_collaboration_effectiveness(self, final_solution):\n    ",
    "        \"\"\"Analyze the effectiveness of human-AI collaboration\"\"\"\n    ",
    "        \n    ",
    "        print(f\"\\n{'='*60}\")\n    ",
    "        print(f\"COLLABORATION ANALYSIS\")\n    ",
    "        print(f\"{'='*60}\")\n    ",
    "        \n    ",
    "        # Compare with pure AI solution (best initial solution)\n    ",
    "        initial_solutions = generate_ai_solution_portfolio(self.instance, num_solutions=5)\n    ",
    "        best_initial = max(initial_solutions, key=lambda x: x.objectives['total_cost'])\n    ",
    "        \n    ",
    "        # Calculate improvements\n    ",
    "        cost_improvement = best_initial.objectives['total_cost'] - final_solution.final_solution.objectives['total_cost']\n    ",
    "        carbon_improvement = best_initial.objectives['carbon_footprint'] - final_solution.final_solution.objectives['carbon_footprint']\n    ",
    "        resilience_improvement = final_solution.final_solution.objectives['resilience_score'] - best_initial.objectives['resilience_score']\n    ",
    "        \n    ",
    "        print(f\"\\nComparison with Best Pure AI Solution:\")\n    ",
    "        print(f\"  Initial AI Cost: ${best_initial.objectives['total_cost']:.2f}\")\n    ",
