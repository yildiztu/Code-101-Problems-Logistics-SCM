    "            0.1 * supplier.sustainability_score +  # Sustainability\n",
    "            0.1 * supplier.labor_standards +  # Labor standards\n",
    "        )\n",
    "        ethical_scores.append(ethical_score)\n",
    "    \n",
    "    # Sort by ethical score and take top 5\n",
