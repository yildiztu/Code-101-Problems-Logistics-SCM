    "                primary_concerns=[\"product_quality\", \"service_reliability\", \"value_for_money\"],\n",
    "                secondary_concerns=[\"ethical_sourcing\", \"product_safety\"],\n",
    "                veto_power=False\n",
    "            )\n",
    "        }\n",
    "    \n",
    "    def evaluate_ethical_compliance(self, suppliers: List[Supplier]) -> Tuple[Dict[int, Dict], Dict]:\n",
    "        \"\"\"\"Evaluate suppliers against ethical constraints\"\"\"\n",
    "        compliance_scores = {}\n",
    "        violation_penalties = {}\n",
    "        \n",
    "        for supplier in suppliers:\n",
    "            supplier_id = supplier.id\n    \n",
    "            compliance_scores[supplier_id] = {}\n",
    "            violation_penalties[supplier_id] = 0.0\n    "            \n",
    "            for constraint in self.ethical_constraints:\n",
    "                value = self._get_supplier_constraint_value(supplier, constraint)\n",
    "                \n",
    "                if constraint.constraint_type == \"hard\":\n",
    "                    if value > constraint.threshold:  # Violation - exclude supplier\n    "                        violation_penalties[supplier_id] = float('inf')\n    "                        compliance_scores[supplier_id][constraint.name] = 0.0\n",
    "                    else:\n    "                        compliance_scores[supplier_id][constraint.name] = 1.0\n    "                \n",
    "                elif constraint.constraint_type == \"soft\":\n",
    "                    if value < constraint.threshold:  # Shortfall - apply penalty\n    "                        penalty = (constraint.threshold - value) * constraint.penalty_weight\n",
    "                        violation_penalties[supplier_id] += penalty\n    "                        compliance_scores[supplier_id][constraint.name] = value / constraint.threshold\n",
    "                    else:\n    "                        compliance_scores[supplier_id][constraint.name] = 1.0\n    "                \n",
    "                elif constraint.constraint_type == \"weighted\":\n",
    "                    if value > constraint.threshold:  # Excess - apply penalty\n    "                        excess_penalty = (value - constraint.threshold) / constraint.threshold * constraint.penalty_weight\n    "                        violation_penalties[supplier_id] += excess_penalty\n    "                        compliance_scores[supplier_id][constraint.name] = max(0, 1 - value / constraint.threshold)\n    "                \n",
    "        \n",
    "        return compliance_scores, violation_penalties\n",
    "    \n",
    "    def _get_supplier_constraint_value(self, supplier: Supplier, constraint: EthicalConstraint) -> float:\n",
    "        \"\"\"Get supplier value for a specific ethical constraint\"\"\"\n",
    "        if constraint.name == \"child_labor_prohibition\":\n",
    "            return 1.0 - supplier.human_rights_compliance  # Invert for violation\n",
    "        elif constraint.name == \"living_wage_compliance\":\n",
    "            return supplier.labor_standards  # Direct compliance score\n",
    "        elif constraint.name == \"carbon_footprint_limit\":\n",
    "            return supplier.sustainability_score  # Environmental performance\n",
    "        elif constraint.name == \"community_investment\":\n",
    "            return supplier.community_investment  # Community engagement\n",
    "        elif constraint.name == \"gender_diversity\":\n",
    "            return supplier.gender_diversity  # Gender diversity\n",
    "        elif constraint.name == \"fair_trade_practices\":\n",
    "            return supplier.fair_trade_practices  # Fair trade certification\n",
    "        else:\n",
    "            return 0.5  # Default value\n",
    "    \n",
    "    def calculate_stakeholder_value(self, allocation: Dict[int, Dict], \n",
    "                              compliance_scores: Dict[int, Dict], \n",
    "                              violation_penalties: Dict[int, float]) -> Dict[str, float]:\n",
    "        \"\"\"\"Calculate stakeholder value for allocation\"\"\"\n",
    "        stakeholder_values = {\n",
    "            'shareholder': 0.0,\n",
    "            'environmental': 0.0,\n",
    "            'community': 0.0,\n",
    "            'worker': 0.0,\n",
    "        }\n",
    "        \n",
    "        # Calculate total demand (simplified)\n",
    "        total_demand = 100000  # Simplified total demand\n",
    "        \n",
    "        for supplier_id, supplier_alloc in allocation.items():\n",
    "            supplier = self.suppliers[supplier_id]\n",
    "            \n",
    "            # Calculate total quantity allocated\n    "            total_quantity = sum(supplier_alloc.values())\n",
    "            quantity_weight = total_quantity / total_demand\n    "            \n    "            # Economic value (shareholders)\n    "            economic_value = (1 - supplier.cost_score) * quantity_weight\n    "            stakeholder_values['shareholder'] += economic_value * self.stakeholder_weights[1]['weight']\n    "            \n    "            # Environmental value (environmental stakeholders)\n    "            environmental_value = supplier.sustainability_score * quantity_weight\n    "            stakeholder_values['environmental'] += environmental_value * self.stakeholder_weights[2]['weight']\n    "            \n    "            # Community value (community stakeholders)\n    "            community_value = supplier.community_investment * quantity_weight\n    "            stakeholder_values['community'] += community_value * self.stakeholder_weights[3]['weight']\n    "            \n    "            # Worker value (worker stakeholders)\n    "            worker_value = supplier.labor_standards * quantity_weight\n    "            stakeholder_values['worker'] += worker_value * self.stakeholder_weights[4]['weight']\n    "        \n",
    "        # Customer value (customer stakeholders)\n",
    "        customer_value = sum(\n",
    "            (self.suppliers[supplier_id].quality_score * sum(supplier_alloc.values()) / total_demand) \n",
    "            for supplier_id, supplier_alloc in allocation.items()\n",
    "        )\n    "        stakeholder_values['customer'] += customer_value * self.stakeholder_weights[5]['weight']\n",
    "        \n",
    "        return stakeholder_values\n",
    "    \n",
    "    def calculate_economic_performance(self, allocation: Dict[int, Dict], \n",
    "                                violation_penalties: Dict[int, float]) -> float:\n",
    "        \"\"\"\"Calculate economic performance with ethical penalties\"\"\"\n",
    "        total_cost = 0\n",
    "        total_quantity = 0\n    "        \n",
    "        for supplier_id, supplier_alloc in allocation.items():\n    "            supplier = self.suppliers[supplier_id]\n    "            \n    "            # Fixed cost\n    "            fixed_cost = 10000  # Simplified fixed cost per supplier\n    "            total_cost += fixed_cost\n    "            \n    "            # Variable cost\n    "            for product_id, quantity in supplier_alloc.items():\n    "                unit_cost = 50 * (2 - supplier.cost_score)  # Invert cost score for actual cost\n    "                total_cost += quantity * unit_cost\n    "                total_quantity += quantity\n    "        \n    "        # Apply ethical penalties\n",
    "        total_ethical_penalty = sum(penalty for penalty in violation_penalties.values())\n    "        \n    "        # Normalize economic performance\n    "        max_reasonable_cost = total_cost / total_quantity if total_quantity > 0 else 1000000\n    "        \n    "        economic_performance = 1 / (1 + (total_cost + total_ethical_penalty) / max_reasonable_cost)\n    "        \n    "        return max(0, economic_performance)\n    "    \n",
    "    def stakeholder_weighted_optimization(self, suppliers: List[Supplier], \n",
    "                                demands: Dict[str, int]) -> Dict[str, Any]:\n",
    "        \"\"\"\"Perform stakeholder-weighted optimization with ethical constraints\"\"\"\n",
    "        \n",
    "        # Filter feasible suppliers (no hard violations)\n    "    feasible_suppliers = []\n    "    for supplier in suppliers:\n    "        if self.evaluate_ethical_compliance([supplier])[1][supplier.id]['child_labor_prohibition'] == 1.0:\n    "            feasible_suppliers.append(supplier)\n    "    \n    "    if not feasible_suppliers:\n    "        raise ValueError(\"No ethical suppliers available\")\n    "    "        \n    "    # Perform optimization among feasible suppliers\n    "    optimal_allocation = self._optimize_allocation(\n    "        feasible_suppliers, demands, \n    "        lambda allocation: self._calculate_objective_function(allocation, demands)\n    "    )\n    "    \n    "    # Generate comprehensive report\n    "    ethical_assessment = self._generate_ethical_impact_report(optimal_allocation)\n    "    \n    "    return {\n    "        'allocation': optimal_allocation,\n    "        'compliance_scores': self.evaluate_ethical_compliance(feasible_suppliers)[0],\n    "        'stakeholder_values': self.calculate_stakeholder_value(optimal_allocation, \n    "                                                   self.evaluate_ethical_compliance(feasible_suppliers)[1],\n    "                                                   violation_penalties),\n    "        'ethical_assessment': ethical_assessment\n    "    }\n    "    \n    "    def _optimize_allocation(self, suppliers: List[Supplier], \n",
    "                           demands: Dict[str, int], \n    "                           objective_function) -> Dict[int, Dict]:\n",
    "        \"\"\"\"Optimize allocation using greedy approach with ethical constraints\"\"\"\n    "        \n    "        # Sort suppliers by ethical score (weighted combination)\n    "        supplier_scores = []\n    "        for supplier in suppliers:\n    "            \n    "            # Calculate ethical score\n    "            ethical_score = (\n    "                0.3 * (1 - supplier.cost_score) +  # Cost (inverted)\n    "                0.3 * supplier.quality_score +  # Quality\n    "                0.2 * supplier.delivery_reliability +  # Reliability\n    "                0.1 * supplier.sustainability_score +  # Sustainability\n    "                0.1 * supplier.labor_standards +  # Labor standards\n    "            )\n    "            \n    "            supplier_scores.append((supplier, ethical_score))\n    "        \n    "        # Sort by ethical score (descending)\n    "        supplier_scores.sort(key=lambda x: x[1], reverse=True)\n",
    "        \n    "        # Greedy allocation with ethical checking\n    "        allocation = {}\n    "        remaining_demands = {product: demand for product, demand in demands.items()}\n    "        \n    "        for supplier, ethical_score in supplier_scores:\n    "            supplier_allocation = {}\n    "            \n    "            for product_id in list(remaining_demands.keys()):\n    "                if remaining_demands[product_id] > 0:\n    "                    max_capacity = int(supplier.capacity_utilization * 10000)  # Simplified capacity\n    "                    allocated = min(remaining_demands[product_id], max_capacity)\n    "                    \n    "                    if allocated > 0:\n    "                        supplier_allocation[product_id] = allocated\n    "                        remaining_demands[product_id] -= allocated\n    "            \n    "            if supplier_allocation:\n    "                allocation[supplier.id] = supplier_allocation\n    "        \n    "        return allocation\n    "    \n    "    def _calculate_objective_function(self, allocation: Dict[int, Dict], \n    "                            demands: Dict[str, int]) -> float:\n    "        \"\"\"\"Calculate objective function value for allocation\"\"\"\n    "        \n    "        # Calculate economic performance\n    "        economic_performance = self.calculate_economic_performance(allocation, {})\n    "        \n",
    "        # Calculate stakeholder value\n    "        compliance_scores, violation_penalties = self.evaluate_ethical_compliance(\n    "            [self.suppliers[s_id] for s_id in allocation.keys()]\n    "        )\n    "        stakeholder_values = self.calculate_stakeholder_value(allocation, compliance_scores, violation_penalties)\n    "        \n    "        # Weighted stakeholder value\n    "        total_stakeholder_value = sum(stakeholder_values.values())\n    "        \n    "        # Return objective function (higher is better)\n    "        return total_stakeholder_value * economic_performance\n    "    \n    "    def _generate_ethical_impact_report(self, allocation: Dict[int, Dict]) -> Dict[str, Any]:\n",
    "        \"\"\"\"Generate comprehensive ethical impact assessment\"\"\"\n    "        \n    "        total_demand = 100000  # Simplified total demand\n",
    "        \n    "        report = {\n    "            'total_suppliers_selected': len(allocation),\n    "            'ethical_compliance': {},\n    "            'stakeholder_impact': {},\n    "            'social_impact_metrics': {},\n    "            'environmental_impact': {},\n",
    "        }\n    "        \n    "        # Calculate compliance scores\n    "        compliance_scores, violation_penalties = self.evaluate_ethical_compliance(\n    "            [self.suppliers[s_id] for s_id in allocation.keys()]\n    "        )\n    "        \n    "        # Aggregate compliance scores\n    "        for constraint_name in self.ethical_constraints:\n    "            scores = [cs[supplier_id][constraint_name] for supplier_id in compliance_scores]\n    "            if scores:\n    "                report['ethical_compliance'][constraint_name] = {\n    "                    'average_score': np.mean(scores),\n    "                    'compliance_rate': np.mean([1 if s >= 0.8 else 0 for s in scores]),\n    "                    'suppliers_compliant': len([1 for s in scores if s >= 0.8]),\n    "                    'suppliers_non_compliant': len([1 for s in scores if s < 0.8]),\n    "                }\n    "        \n    "        # Calculate stakeholder impact\n    "        stakeholder_values = self.calculate_stakeholder_value(allocation, compliance_scores, violation_penalties)\n    "        \n    "        for stakeholder_type, value in stakeholder_values.items():\n    "            report['stakeholder_impact'][stakeholder_type] = {\n    "                'total_value': value,\n    "                'percentage': value / sum(stakeholder_values.values()) * 100,\n    "                'rating': self._rate_performance(value / sum(stakeholder_values.values())\n    "            }\n    "        \n    "        # Calculate social impact metrics\n    "        total_workers_affected = 0\n    "        total_women_affected = 0\n    "        total_community_investment = 0\n    "        \n    "        for supplier_id, supplier_alloc in allocation.items():\n    "            supplier = self.suppliers[supplier_id]\n    "            \n    "            # Estimate workers affected (simplified)\n    "            workers_affected = int(supplier.capacity_utilization * 500)  # Approximate workforce\n    "            women_affected = int(supplier.gender_diversity * workers_affected)\n    "            community_investment = supplier.community_investment * 1000000  # Approximate annual investment\n    "            \n    "            total_workers_affected += workers_affected\n    "            total_women_affected += women_affected\n    "            total_community_investment += community_investment\n    "        \n    "        report['social_impact_metrics'] = {\n    "            'total_workers_affected': total_workers_affected,\n    "            'women_affected': total_women_affected,\n    "            'women_percentage': total_women_affected / total_workers_affected * 100 if total_workers_affected > 0 else 0,\n    "            'total_community_investment': total_community_investment,\n    "        }\n    "        \n    "        # Calculate environmental impact\n    "        total_carbon_footprint = 0\n    "        total_renewable_energy = 0\n    "        \n    "        for supplier_id, supplier_alloc in allocation.items():\n    "            supplier = self.suppliers[supplier_id]\n    "            \n    "            # Estimate carbon footprint (simplified)\n    "            carbon_footprint = supplier.sustainability_score * 1000 * total_demand / 100000\n    "            renewable_energy = supplier.sustainability_score * 0.7 * 1000  # Approximate renewable energy usage\n    "            \n    "            total_carbon_footprint += carbon_footprint\n    "            total_renewable_energy += renewable_energy\n    "        \n    "        report['environmental_impact'] = {\n    "            'total_carbon_footprint': total_carbon_footprint,\n    "            'renewable_energy_percentage': total_renewable_energy / (total_carbon_footprint + total_renewable_energy) * 100,\n    "            'carbon_intensity': total_carbon_footprint / total_demand if total_demand > 0 else 0,\n    "        }\n    "        \n    "        return report\n    "    \n",
    "    def _rate_performance(self, value: float, max_value: float = 1.0) -> str:\n    "        \"\"\"Rate performance on a 0-1 scale\"\"\"\n    "        if value >= 0.9:\n    "            return \"Outstanding\"\n",
    "        elif value >= 0.8:\n    "            return \"Excellent\"\n",
    "        elif value >= 0.7:\n    "            \"Very Good\"\n",
    "        elif value >= 0.6:\n    "            \"Good\"\n",
    "        elif value >= 0.5:\n    "            \"Fair\"\n",
    "        else:\n    "            \"Poor\"\n",
    "\n",
    "print(\"Value-Aligned Supplier Selector defined with ethical framework\")"
   ]
