    "                threshold=0.8,  # 80% of living wage\n    "                penalty_weight=50.0,\n    "                priority=EthicalPriority.LABOR_STANDARDS,\n    "                description=\"Suppliers must pay living wages to all workers\",\n",
    "                measurement_method=\"compliance_rate\",\n",
