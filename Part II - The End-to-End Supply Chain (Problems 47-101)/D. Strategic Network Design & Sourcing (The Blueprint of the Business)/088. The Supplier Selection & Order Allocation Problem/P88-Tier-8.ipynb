    "    \"\"\"Create professional visualizations for value-aligned supplier selection\"\"\"\n",
    "    \n",
    "    fig, axes = plt.subplots(2, 2, figsize=(16, 12))\n",
    "    fig.suptitle('Value-Aligned & Ethical Framework - Comprehensive Analysis', \n",
