    "                threshold=0.0,  # Zero tolerance\n    \n",
    "                penalty_weight=float('inf'),  # Immediate exclusion\n    "                priority=EthicalPriority.HUMAN_RIGHTS,\n    "                description=\"Zero tolerance for child labor in supply chain\",\n",
    "                measurement_method=\"compliance_rate\",\n",
    "                data_source=\"supplier_report\"\n",
    "            ),\n",
