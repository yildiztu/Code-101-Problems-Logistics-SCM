    "# Define ethical framework data structures\n",
    "class EthicalPriority(Enum):\n",
    "    \"\"\"Ethical priority levels for constraint evaluation\"\"\"\n",
    "    HUMAN_RIGHTS = 1\n",
    "    ENVIRONMENTAL = 2\n",
    "    LABOR_STANDARDS = 3\n",
    "    COMMUNITY_IMPACT = 4\n",
    "    FAIR_TRADE = 5\n",
    "    ECONOMIC_VIABILITY = 6\n",
    "\n",
    "@dataclass\n",
    "class EthicalConstraint:\n",
    "    \"\"\"Ethical constraint definition with evaluation criteria\"\"\"\n",
    "    name: str\n",
    "    constraint_type: str  # 'hard', 'soft', 'weighted'\n",
    "    threshold: float\n",
    "    penalty_weight: float\n",
    "    priority: EthicalPriority\n",
    "    description: str\n",
    "    measurement_method: str  # 'compliance_rate', 'score', 'percentage', 'count'\n",
    "    data_source: str  # 'supplier_report', 'third_party_audit', 'self_assessment'\n",
    "\n",
    "@dataclass\n",
    "class Stakeholder:\n",
    "    \"\"\"Stakeholder definition with preferences and influence\"\"\"\n",
    "    id: int\n",
    "    name: str\n",
    "    category: str  # 'shareholder', 'environmental', 'community', 'worker', 'customer'\n",
    "    weight: float  # Influence weight in decision making (0-1)\n",
    "primary_concerns: List[str]\n",
    "secondary_concerns: List[str]\n",
    "veto_power: bool  # Ability to veto decisions\n",
    "\n",
    "@dataclass\n",
    "class Supplier:\n",
    "    \"\"\"\"Supplier with comprehensive ethical and performance data\"\"\"\n",
    "    id: int\n",
    "    name: str\n",
    "    # Performance metrics\n",
    "    cost_score: float  # Normalized (0-1, lower is better)\n",
    "    quality_score: float  # Normalized (0-1, higher is better)\n",
    "    delivery_reliability: float  # Normalized (0-1, higher is better)\n",
    "    financial_stability: float  # Normalized (0-1, higher is better)\n",
    "    innovation_capability: float  # Normalized (0-1, higher is better)\n",
    "    \n",
    "    # Ethical metrics\n",
    "    sustainability_score: float  # Environmental performance (0-1, higher is better)\n",
    "    labor_standards: float  # Labor practices (0-1, higher is better)\n",
    "human_rights_compliance: float  # Human rights record (0-1, higher is better)\n",
    "community_investment: float  # Community engagement (0-1, higher is better)\n",
    "fair_trade_practices: float  # Fair trade certification (0-1, higher is better)\n",
    "gender_diversity: float  # Gender diversity in leadership (0-1, higher is better)\n",
    "geographic_diversity: float  # Geographic distribution (0-1, higher is better)\n",
    "small_business_support: float  # Support for SMEs (0-1, higher is better)\n",
    "    \n",
    "    # Capacity and relationship\n",
    "capacity_utilization: float  # Current capacity usage (0-1, higher is better)\n",
    "relationship_strength: float  # Relationship quality (0-1, higher is better)\n",
    "regulatory_compliance: float  # Regulatory compliance (0-1, higher is better)\n",
    "\n",
    "class ValueAlignedSupplierSelector:\n",
    "    \"\"\"\"Value-aligned supplier selection with ethical framework\"\"\"\n",
    "    \n",
