    "# Import required libraries for mathematical optimization\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from pulp import *\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Set plotting style\n",
    "plt.style.use('default')\n",
    "sns.set_palette(\"husl\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Define problem data structures\n",
    "class SupplierSelectionData:\n",
    "    \"\"\"Data structure for supplier selection problem\"\"\"\n",
    "    \n",
    "    def __init__(self):\n",
    "        # Define suppliers\n",
    "        self.suppliers = {\n",
    "            1: {\n",
    "                'name': 'Supplier 1',\n",
    "                'fixed_cost': 10000,\n",
    "                'quality': 0.85,\n",
    "                'reliability': 0.90,\n",
    "                'sustainability': 0.75,\n",
    "                'capacities': {1: 10000, 2: 8000},  # Product A, Product B\n",
    "                'costs': {1: 50, 2: 52}\n",
    "            },\n",
    "            2: {\n",
    "                'name': 'Supplier 2',\n",
    "                'fixed_cost': 15000,\n",
    "                'quality': 0.80,\n",
    "                'reliability': 0.85,\n",
    "                'sustainability': 0.80,\n",
    "                'capacities': {1: 15000, 2: 12000},\n",
    "                'costs': {1: 45, 2: 47}\n",
    "            },\n",
    "            3: {\n",
    "                'name': 'Supplier 3',\n",
    "                'fixed_cost': 8000,\n",
    "                'quality': 0.90,\n",
    "                'reliability': 0.95,\n",
    "                'sustainability': 0.85,\n",
    "                'capacities': {1: 8000, 2: 6000},\n",
    "                'costs': {1: 55, 2: 57}\n",
    "            }\n",
    "        }\n",
    "        \n",
    "        # Define products and demands\n",
    "        self.products = {\n",
    "            1: {'name': 'Product A', 'demand': 12000},\n",
    "            2: {'name': 'Product B', 'demand': 8000}\n",
    "        }\n",
    "        \n",
    "        # Define constraints\n",
    "        self.min_suppliers = 1\n",
    "        self.max_suppliers = 3\n",
    "        \n",
    "        # Define weights for multi-objective optimization\n",
    "        self.weights = {\n",
    "            'cost': 0.4,\n",
    "            'quality': 0.4,\n",
    "            'reliability': 0.1,\n",
    "            'sustainability': 0.1\n",
    "        }\n",
    "\n",
    "# Initialize problem data\n",
    "data = SupplierSelectionData()\n",
    "print(f\"Problem initialized with {len(data.suppliers)} suppliers and {len(data.products)} products\")"
   ]
