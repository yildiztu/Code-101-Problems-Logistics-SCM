    "# Mathematical formulation and solution using pulp\n",
    "def solve_supplier_selection_mip(data):\n",
    "    \"\"\"Solve supplier selection problem using mixed-integer programming\"\"\"\n",
    "    \n",
    "    # Create problem instance\n",
    "    prob = LpProblem(\"Supplier_Selection_and_Order_Allocation\", LpMinimize)\n",
    "    \n",
    "    # Decision variables\n",
    "    # y_i: binary variable for supplier selection\n",
    "    y = {}\n",
    "    for i in data.suppliers:\n",
    "        y[i] = LpVariable(f\"y_{i}\", cat='Binary')\n",
    "    \n",
    "    # x_ij: continuous variable for order quantity\n",
    "    x = {}\n",
    "    for i in data.suppliers:\n",
    "        for j in data.products:\n",
    "            x[(i,j)] = LpVariable(f\"x_{i}_{j}\", lowBound=0)\n",
    "    \n",
    "    # Objective function: Minimize total cost\n",
    "    # Fixed costs + Variable costs\n",
    "    total_cost = (\n",
    "        lpSum(data.suppliers[i]['fixed_cost'] * y[i] for i in data.suppliers) +\n",
    "        lpSum(data.suppliers[i]['costs'][j] * x[(i,j)] \n",
    "              for i in data.suppliers for j in data.products)\n",
    "    )\n",
    "    \n",
    "    prob += total_cost\n",
    "    \n",
    "    # Constraints\n",
    "    \n",
    "    # 1. Demand satisfaction\n",
    "    for j in data.products:\n",
    "        prob += lpSum(x[(i,j)] for i in data.suppliers) >= data.products[j]['demand']\n",
    "    \n",
    "    # 2. Supplier capacity constraints\n",
    "    for i in data.suppliers:\n",
    "        for j in data.products:\n",
    "            prob += x[(i,j)] <= data.suppliers[i]['capacities'][j] * y[i]\n",
    "    \n",
    "    # 3. Supplier selection bounds\n",
    "    prob += lpSum(y[i] for i in data.suppliers) >= data.min_suppliers\n",
    "    prob += lpSum(y[i] for i in data.suppliers) <= data.max_suppliers\n",
    "    \n",
    "    # Solve the problem\n",
    "    print(\"Solving MIP optimization problem...\")\n",
    "    prob.solve(PULP_CBC_CMD(msg=False))\n",
    "    \n",
    "    # Extract solution\n",
    "    solution = {\n",
    "        'status': LpStatus[prob.status],\n",
    "        'objective_value': value(prob.objective),\n",
    "        'selected_suppliers': [],\n",
    "        'allocations': {},\n",
    "        'total_cost_by_supplier': {},\n",
    "        'quality_metrics': {}\n",
    "    }\n",
    "    \n",
    "    # Extract selected suppliers and allocations\n",
    "    for i in data.suppliers:\n",
    "        if value(y[i]) > 0.5:  # Supplier selected\n",
    "            solution['selected_suppliers'].append(i)\n",
    "            solution['allocations'][i] = {}\n",
    "            total_quantity = 0\n",
    "            supplier_cost = data.suppliers[i]['fixed_cost']\n",
    "            \n",
    "            for j in data.products:\n",
    "                quantity = value(x[(i,j)])\n",
    "                if quantity > 0.01:  # Non-zero allocation\n",
    "                    solution['allocations'][i][j] = quantity\n",
    "                    total_quantity += quantity\n",
    "                    supplier_cost += quantity * data.suppliers[i]['costs'][j]\n",
    "            \n",
    "            solution['total_cost_by_supplier'][i] = supplier_cost\n",
    "            solution['quality_metrics'][i] = {\n",
    "                'quality_score': data.suppliers[i]['quality'],\n",
    "                'total_quantity': total_quantity\n",
    "            }\n",
    "    \n",
    "    # Calculate weighted average quality\n",
    "    total_quantity = sum(metrics['total_quantity'] for metrics in solution['quality_metrics'].values())\n",
    "    if total_quantity > 0:\n",
    "        weighted_quality = sum(\n",
    "            metrics['quality_score'] * metrics['total_quantity'] \n",
    "            for metrics in solution['quality_metrics'].values()\n",
    "        ) / total_quantity\n",
    "        solution['weighted_average_quality'] = weighted_quality\n",
    "    else:\n",
    "        solution['weighted_average_quality'] = 0\n",
    "    \n",
    "    return solution, prob\n",
    "\n",
    "# Solve the problem\n",
    "solution, prob = solve_supplier_selection_mip(data)\n",
    "print(f\"Solution status: {solution['status']}\")\n",
    "print(f\"Total cost: ${solution['objective_value']:,.2f}\")\n",
    "print(f\"Selected suppliers: {solution['selected_suppliers']}\")\n",
    "print(f\"Weighted average quality: {solution['weighted_average_quality']:.1%}\")"
   ]
  },
