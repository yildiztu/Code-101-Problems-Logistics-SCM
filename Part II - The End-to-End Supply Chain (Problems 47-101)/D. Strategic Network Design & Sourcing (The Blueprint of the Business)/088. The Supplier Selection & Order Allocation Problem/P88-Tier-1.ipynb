    "# Mathematical verification and comparison with theoretical bounds\n",
    "def verify_optimality_and_bounds(solution, data):\n",
    "    \"\"\"Verify solution optimality and compare with theoretical bounds\"\"\"\n",
    "    \n",
    "    print(\"=\"*80)\n",
    "    print(\"OPTIMALITY VERIFICATION AND THEORETICAL BOUNDS\")\n",
    "    print(\"=\"*80)\n",
    "    \n",
    "    # 1. Calculate theoretical lower bounds\n",
    "    print(\"\\n1. THEORETICAL LOWER BOUNDS:\")\n",
    "    print(\"-\" * 40)\n",
    "    \n",
    "    # Cost lower bound (ignoring fixed costs and using cheapest supplier)\n",
    "    min_variable_costs = {}\n",
    "    for j in data.products:\n",
    "        min_cost = min(data.suppliers[i]['costs'][j] for i in data.suppliers)\n",
    "        min_variable_costs[j] = min_cost * data.products[j]['demand']\n",
    "    \n",
    "    total_variable_cost_lower_bound = sum(min_variable_costs.values())\n",
    "    print(f\"Variable cost lower bound: ${total_variable_cost_lower_bound:,.2f}\")\n",
    "    \n",
    "    # Fixed cost lower bound (minimum number of suppliers)\n",
    "    min_fixed_costs = sorted([data.suppliers[i]['fixed_cost'] for i in data.suppliers])[:data.min_suppliers]\n",
    "    total_fixed_cost_lower_bound = sum(min_fixed_costs)\n",
    "    print(f\"Fixed cost lower bound: ${total_fixed_cost_lower_bound:,.2f}\")\n",
    "    \n",
    "    total_cost_lower_bound = total_variable_cost_lower_bound + total_fixed_cost_lower_bound\n",
    "    print(f\"Total cost lower bound: ${total_cost_lower_bound:,.2f}\")\n",
    "    \n",
    "    # 2. Calculate theoretical upper bounds\n",
    "    print(\"\\n2. THEORETICAL UPPER BOUNDS:\")\n",
    "    print(\"-\" * 40)\n",
    "    \n",
    "    # Cost upper bound (using most expensive supplier)\n",
    "    max_variable_costs = {}\n",
    "    for j in data.products:\n",
    "        max_cost = max(data.suppliers[i]['costs'][j] for i in data.suppliers)\n",
    "        max_variable_costs[j] = max_cost * data.products[j]['demand']\n",
    "    \n",
    "    total_variable_cost_upper_bound = sum(max_variable_costs.values())\n",
    "    print(f\"Variable cost upper bound: ${total_variable_cost_upper_bound:,.2f}\")\n",
    "    \n",
    "    # Fixed cost upper bound (maximum number of suppliers)\n",
    "    max_fixed_costs = sorted([data.suppliers[i]['fixed_cost'] for i in data.suppliers], reverse=True)[:data.max_suppliers]\n",
    "    total_fixed_cost_upper_bound = sum(max_fixed_costs)\n",
    "    print(f\"Fixed cost upper bound: ${total_fixed_cost_upper_bound:,.2f}\")\n",
    "    \n",
    "    total_cost_upper_bound = total_variable_cost_upper_bound + total_fixed_cost_upper_bound\n",
    "    print(f\"Total cost upper bound: ${total_cost_upper_bound:,.2f}\")\n",
    "    \n",
    "    # 3. Solution quality assessment\n",
    "    print(\"\\n3. SOLUTION QUALITY ASSESSMENT:\")\n",
    "    print(\"-\" * 40)\n",
    "    \n",
    "    actual_cost = solution['objective_value']\n",
    "    lower_bound_gap = (actual_cost - total_cost_lower_bound) / total_cost_lower_bound * 100\n",
    "    upper_bound_gap = (total_cost_upper_bound - actual_cost) / total_cost_upper_bound * 100\n",
    "    \n",
    "    print(f\"Actual solution cost: ${actual_cost:,.2f}\")\n",
    "    print(f\"Gap from lower bound: {lower_bound_gap:.1f}%\")\n",
    "    print(f\"Gap from upper bound: {upper_bound_gap:.1f}%\")\n",
    "    \n",
    "    # 4. Constraint satisfaction verification\n",
    "    print(\"\\n4. CONSTRAINT SATISFACTION VERIFICATION:\")\n",
    "    print(\"-\" * 40)\n",
    "    \n",
    "    # Demand satisfaction\n",
    "    demand_satisfied = True\n",
    "    for j in data.products:\n",
    "        demand = data.products[j]['demand']\n",
    "        supplied = sum(solution['allocations'].get(i, {}).get(j, 0) for i in solution['selected_suppliers'])\n",
    "        if supplied < demand - 0.01:  # Allow small numerical tolerance\n",
    "            demand_satisfied = False\n",
    "            print(f\"  ❌ Product {j} demand not satisfied: {supplied:.0f} < {demand:.0f}\")\n",
    "        else:\n",
    "            print(f\"  ✅ Product {j} demand satisfied: {supplied:.0f} >= {demand:.0f}\")\n",
    "    \n",
    "    # Capacity constraints\n",
    "    capacity_satisfied = True\n",
    "    for i in solution['selected_suppliers']:\n",
    "        for j in data.products:\n",
    "            allocated = solution['allocations'][i].get(j, 0)\n",
    "            capacity = data.suppliers[i]['capacities'][j]\n",
    "            if allocated > capacity + 0.01:  # Allow small numerical tolerance\n",
    "                capacity_satisfied = False\n",
    "                print(f\"  ❌ Supplier {i} Product {j} capacity exceeded: {allocated:.0f} > {capacity:.0f}\")\n",
    "            else:\n",
    "                print(f\"  ✅ Supplier {i} Product {j} capacity respected: {allocated:.0f} <= {capacity:.0f}\")\n",
    "    \n",
    "    # Supplier count constraints\n",
    "    supplier_count = len(solution['selected_suppliers'])\n",
    "    count_satisfied = (data.min_suppliers <= supplier_count <= data.max_suppliers)\n",
    "    if count_satisfied:\n",
    "        print(f\"  ✅ Supplier count constraint satisfied: {supplier_count} suppliers [{data.min_suppliers}, {data.max_suppliers}]\")\n",
    "    else:\n",
    "        print(f\"  ❌ Supplier count constraint violated: {supplier_count} suppliers [{data.min_suppliers}, {data.max_suppliers}]\")\n",
    "    \n",
    "    # Overall feasibility\n",
    "    if demand_satisfied and capacity_satisfied and count_satisfied:\n",
    "        print(\"\\n✅ All constraints satisfied - Solution is FEASIBLE\")\n",
    "    else:\n",
    "        print(\"\\n❌ Some constraints violated - Solution is INFEASIBLE\")\n",
    "    \n",
    "    return {\n",
    "        'lower_bound': total_cost_lower_bound,\n",
    '        'upper_bound': total_cost_upper_bound,\n",
    "        'actual_cost': actual_cost,\n",
    "        'lower_bound_gap': lower_bound_gap,\n",
    "        'upper_bound_gap': upper_bound_gap,\n",
    "        'feasible': demand_satisfied and capacity_satisfied and count_satisfied\n",
    "    }\n",
    "\n",
    "# Verify solution optimality\n",
    "verification_results = verify_optimality_and_bounds(solution, data)"
   ]
