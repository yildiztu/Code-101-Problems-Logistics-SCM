    "class EthicalPrinciple(Enum):\n",
    "    EQUITY = \"equity\"  # Fair and equal treatment\n",
    "    SUSTAINABILITY = \"sustainability\"  # Environmental responsibility\n",
    "    TRANSPARENCY = \"transparency\"  # Open and explainable operations\n",
    "    PRIVACY = \"privacy\"  # Protection of personal data\n",
    "    SAFETY = \"safety\"  # Well-being of stakeholders\n",
    "    ACCOUNTABILITY = \"accountability\"  # Responsibility for actions\n",
    "\n",
    "@dataclass\n",
    "class Stakeholder:\n",
    "    \"\"\"Stakeholder in the VRPTW system\"\"\"\n",
    "    id: str\n",
    "    name: str\n",
    "    type: str  # customer, driver, community, environment, regulator, investor\n",
    "    utility_weights: Dict[str, float]  # weights for different outcomes\n",
    "    priorities: List[str]\n",
    "    constraints: List[str]\n",
    "    satisfaction_score: float = 0.0\n",
    "\n",
    "@dataclass\n",
    "class EthicalConstraint:\n",
    "    \"\"\"Ethical constraint for VRPTW optimization\"\"\"\n",
    "    id: str\n",
    "    principle: EthicalPrinciple\n",
    "    description: str\n",
    "    constraint_type: str  # hard_constraint, soft_constraint, preference\n",
    "    metric_formula: str\n",
    "    target_value: float\n",
    "    tolerance: float\n",
    "    penalty_weight: float\n",
    "\n",
    "@dataclass\n",
    "class BiasMetric:\n",
    "    \"\"\"Metric for measuring and detecting bias\"\"\"\n",
    "    id: str\n",
    "    name: str\n",
    "    metric_type: str  # demographic, geographic, temporal, service\n",
    "    calculation_method: str\n",
    "    threshold: float\n",
    "    current_value: float = 0.0\n",
    "    historical_values: List[float] = None\n",
    "\n",
    "    def __post_init__(self):\n",
    "        if self.historical_values is None:\n",
    "            self.historical_values = []\n",
    "\n",
    "@dataclass\n",
    "class EthicalVRPTW:\n",
    "    \"\"\"Ethical VRPTW optimization system\"\"\"\n",
    "    constraints: List[EthicalConstraint]\n",
    "    stakeholders: List[Stakeholder]\n",
    " bias_metrics: List[BiasMetric]\n",
    "    audit_history: List[Dict]\n",
    "    compliance_score: float = 0.0\n",
    "    transparency_level: float = 0.0\n",
    "    social_impact_score: float = 0.0"
   ]
  },
