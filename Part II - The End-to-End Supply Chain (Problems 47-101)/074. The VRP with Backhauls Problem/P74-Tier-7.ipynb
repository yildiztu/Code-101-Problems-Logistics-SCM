    "class HumanAIPartnership:\n",
    "    \"\"\"Human-AI symbiotic partnership system\"\"\"\n",
    "    \n",
    "    def __init__(self, instance: VRPBInstance):\n",
    "        self.instance = instance\n",
    "        self.ai_system = ExplainableAI(instance)\n",
    "        self.human_experts = {}\n",
    "        self.trust_metrics = {}\n",
    "        self.interaction_history = []\n",
    "        self.partnership_start_time = datetime.now()\n",
    "        \n",
    "        self._initialize_human_experts()\n",
    "        self._initialize_trust_metrics()\n",
    "        \n",
    "        print(f\"🤝 Human-AI Partnership initialized for {instance.num_customers} customers\")\n",
    "        print(f\"👥 Human Experts: {len(self.human_experts)}\")\n",
    "        print(f\"🤖 AI System: Version {self.ai_system.model_version}\")\n",
    "    \n",
    "    def _initialize_human_experts(self):\n",
    "        \"\"\"Initialize human experts with different expertise areas\"\"\"\n",
    "        experts_config = [\n",
    "            {\n",
    "                \"expert_id\": \"EXP_001\",\n",
    "                \"name\": \"Sarah Martinez\",\n",
    "                \"expertise_areas\": [\"route_optimization\", \"weather_impact\", \"emergency_response\"],\n",
    "                \"experience_years\": 15,\n",
    "                \"decision_style\": DecisionStyle.BALANCED,\n",
    "                \"risk_tolerance\": 0.6,\n",
    "                \"confidence_threshold\": 0.7,\n",
    "                \"local_knowledge\": {\n",
    "                    \"warehouse_locations\": {\"P45\": \"elevated_warehouse\", \"P46\": \"ground_level\"},\n",
    "                    \"traffic_patterns\": {\"morning_rush\": \"7-9am\", \"evening_rush\": \"5-7pm\"},\n",
    "                    \"weather_impacts\": {\"hurricane\": \"severe_delays\", \"snow\": \"moderate_delays\"}\n",
    "                }\n",
    "            },\n",
    "            {\n",
    "                \"expert_id\": \"EXP_002\",\n",
    "                \"name\": \"Michael Chen\",\n",
    "                \"expertise_areas\": [\"capacity_planning\", \"cost_optimization\", \"vehicle_maintenance\"],\n",
    "                \"experience_years\": 12,\n",
    "                \"decision_style\": DecisionStyle.ANALYTICAL,\n",
    "                \"risk_tolerance\": 0.4,\n",
    "                \"confidence_threshold\": 0.8,\n",
    "                \"local_knowledge\": {\n",
    "                    \"vehicle_capabilities\": {\"V07\": \"high_capacity\", \"V12\": \"fuel_efficient\"},\n",
    "                    \"cost_factors\": {\"fuel_prices\": \"rising\", \"labor_costs\": \"stable\"}\n",
    "                }\n",
    "            },\n",
    "            {\n",
    "                \"expert_id\": \"EXP_003\",\n",
    "                \"name\": \"Emily Rodriguez\",\n",
    "                \"expertise_areas\": [\"customer_service\", \"time_windows\", \"special_requirements\"],\n",
    "                \"experience_years\": 8,\n",
    "                \"decision_style\": DecisionStyle.CONSERVATIVE,\n",
    "                \"risk_tolerance\": 0.3,\n",
    "                \"confidence_threshold\": 0.9,\n",
    "                \"local_knowledge\": {\n",
    "                    \"customer_preferences\": {\"high_value\": \"priority_service\", \"regular\": \"standard_service\"},\n",
    "                    \"service_constraints\": {\"time_sensitivity\": \"high\", \"flexibility\": \"low\"}\n",
    "                }\n",
    "            },\n",
    "            {\n",
    "                \"expert_id\": \"EXP_004\",\n",
    "                \"name\": \"David Kim\",\n",
    "                \"expertise_areas\": [\"sustainability\", \"environmental_impact\", \"regulatory_compliance\"],\n",
    "                \"experience_years\": 20,\n",
    "                \"decision_style\": DecisionStyle.INTUITIVE,\n",
    "                \"risk_tolerance\": 0.7,\n",
    "                \"confidence_threshold\": 0.6,\n",
    "                \"local_knowledge\": {\n",
    "                    \"environmental_zones\": {\"residential\": \"noise_restrictions\", \"commercial\": \"standard\"},\n",
    "                    \"sustainability_goals\": {\"carbon_reduction\": \"priority\", \"waste_reduction\": \"secondary\"}\n",
    "                }\n",
    "            }\n",
    "        ]\n",
    "        \n",
    "        for config in experts_config:\n",
    "            expert = HumanExpert(**config)\n",
    "            self.human_experts[expert.expert_id] = expert\n",
    "    \n",
    "    def _initialize_trust_metrics(self):\n",
    "        \"\"\"Initialize trust metrics for each expert\"\"\"\n",
    "        for expert_id in self.human_experts.keys():\n",
    "            self.trust_metrics[expert_id] = TrustMetrics(\n",
    "                competence_trust=0.5,\n",
    "                integrity_trust=0.5,\n",
    "                benevolence_trust=0.5,\n",
    "                predictability_trust=0.5,\n",
    "                overall_trust=0.5,\n",
    "                interaction_count=0,\n",
    "                successful_collaborations=0,\n",
    "                last_updated=datetime.now()\n",
    "            )\n",
    "    \n",
    "    def collaborative_decision_making(self, problem_context: str, \n",
    "                                     current_conditions: Dict[str, Any],\n",
    "                                     expert_id: str) -> PartnershipInteraction:\n",
    "        \"\"\"Execute collaborative decision making between human and AI\"\"\"\n",
    "        \n",
    "        interaction_id = f\"int_{int(time.time())}\"\n",
    "        expert = self.human_experts[expert_id]\n",
    "        \n",
    "        # AI generates recommendation\n",
    "        ai_recommendation = self.ai_system.generate_recommendation(problem_context, current_conditions)\n",
    "        \n",
    "        # Human evaluates and decides\n",
    "        human_decision = self._human_decision_process(expert, ai_recommendation, current_conditions)\n",
    "        \n",
    "        # Determine agreement and calculate outcomes\n",
    "        agreement = self._determine_agreement(ai_recommendation, human_decision)\n",
    "        human_confidence = self._calculate_human_confidence(expert, ai_recommendation, current_conditions)\n",
    "        outcome_quality = self._evaluate_outcome_quality(human_decision, current_conditions)\n",
    "        \n",
    "        # Update trust metrics\n",
    "        trust_change = self._update_trust_metrics(expert_id, agreement, outcome_quality)\n",
    "        \n",
    "        # Generate learning insights\n",
    "        learning_insights = self._generate_learning_insights(ai_recommendation, human_decision, agreement)\n",
    "        \n",
    "        # Create interaction record\n",
    "        interaction = PartnershipInteraction(\n",
    "            interaction_id=interaction_id,\n",
    "            timestamp=datetime.now(),\n",
    "            problem_context=problem_context,\n",
    "            ai_recommendation=ai_recommendation,\n",
    "            human_decision=human_decision,\n",
    "            agreement=agreement,\n",
    "            human_confidence=human_confidence,\n",
    "            outcome_quality=outcome_quality,\n",
    "            trust_change=trust_change,\n",
    "            learning_insights=learning_insights\n",
    "        )\n",
    "        \n",
    "        self.interaction_history.append(interaction)\n",
    "        expert.decision_history.append({\n",
    "            \"timestamp\": datetime.now(),\n",
    "            \"problem_context\": problem_context,\n",
    "            \"decision\": human_decision,\n",
    "            \"confidence\": human_confidence\n",
    "        })\n",
    "        \n",
    "        return interaction\n",
    "    \n",
    "    def _human_decision_process(self, expert: HumanExpert, \n",
    "                                ai_recommendation: AIRecommendation,\n",
    "                                current_conditions: Dict[str, Any]) -> Dict[str, Any]:\n",
    "        \"\"\"Simulate human decision making process\"\"\"\n",
    "        \n",
    "        # Evaluate AI confidence against human threshold\n",
    "        if ai_recommendation.confidence_score < expert.confidence_threshold:\n",
    "            # Low AI confidence - human takes more active role\n",
    "            if expert.decision_style == DecisionStyle.CONSERVATIVE:\n",
    "                # Conservative expert prefers safer options\n",
    "                human_decision = {\n",
    "                    \"action\": \"modify\",\n",
    "                    \"modified_solution\": self._apply_conservative_modifications(ai_recommendation.recommended_solution, expert),\n",
    "                    \"reasoning\": \"Applied safety-first approach due to low AI confidence\"\",\n",
    "                    \"local_knowledge_applied\": True\n",
    "                }\n",
    "            elif expert.decision_style == DecisionStyle.ANALYTICAL:\n",
    "                # Analytical expert examines alternatives\n",
    "                best_alternative = self._select_best_alternative(ai_recommendation.alternatives, expert)\n",
    "                human_decision = {\n",
    "                    \"action\": \"alternative\",\n",
    "                    \"selected_alternative\": best_alternative,\n",
    "                    \"reasoning\": \"Selected alternative based on cost-benefit analysis\",\n",
    "                    \"local_knowledge_applied\": False\n",
    "                }\n",
    "            else:\n",
    "                # Other styles - moderate modification\n",
    "                human_decision = {\n",
    "                    \"action\": \"accept_with_modification\",\n",
    "                    \"modified_solution\": self._apply_moderate_modifications(ai_recommendation.recommended_solution, expert),\n",
    "                    \"reasoning\": \"Accepted AI recommendation with minor adjustments\",\n",
    "                    \"local_knowledge_applied\": True\n",
    "                }\n",
    "        else:\n",
    "            # High AI confidence - human more likely to accept\n",
    "            if expert.risk_tolerance > 0.6 and \"hurricane\" in problem_context.lower():\n",
    "                # High risk tolerance but hurricane scenario - apply local knowledge\n",
    "                human_decision = {\n",
    "                    \"action\": \"manual_override\",\n",
    "                    \"manual_solution\": self._apply_hurricane_knowledge(ai_recommendation.recommended_solution, expert),\n",
    "                    \"reasoning\": \"Applied hurricane-specific local knowledge (Sarah Martinez scenario)\",\n",
    "                    \"local_knowledge_applied\": True\n",
    "                }\n",
    "            else:\n",
    "                # Accept AI recommendation\n",
    "                human_decision = {\n",
    "                    \"action\": \"accept\",\n",
    "                    \"accepted_solution\": ai_recommendation.recommended_solution,\n",
    "                    \"reasoning\": \"AI recommendation meets confidence threshold and risk tolerance\",\n",
    "                    \"local_knowledge_applied\": False\n",
    "                }\n",
    "        \n",
    "        return human_decision\n",
    "    \n",
    "    def _apply_hurricane_knowledge(self, ai_solution: Dict[str, Any], expert: HumanExpert) -> Dict[str, Any]:\n",
    "        \"\"\"Apply hurricane-specific local knowledge (Sarah Martinez scenario)\"\"\"\n",
    "        modified_solution = ai_solution.copy()\n",
    "        \n",
    "        # Sarah knows P45 is elevated warehouse - prioritize it in pickups\n",
    "        route = modified_solution[\"route\"].copy()\n",
    "        \n",
    "        # Find P45 in pickups and move it earlier\n",
    "        pickup_positions = [i for i, customer in enumerate(route) \n",
    "                           if customer > len(self.instance.delivery_indices)]\n",
    "        \n",
    "        if pickup_positions:\n",
    "            p45_position = None\n",
    "            for pos in pickup_positions:\n",
    "                if route[pos] == 45:  # P45 in pickup indices\n",
    "                    p45_position = pos\n",
    "                    break\n",
    "            \n",
    "            if p45_position and p45_position > 0:\n",
    "                # Move P45 earlier in the route\n    ",
    "                p45 = route.pop(p45_position)\n",
    "                route.insert(pickup_positions[0], p45)  # Insert at first pickup position\n",
    "                modified_solution[\"route\"] = route\n",
    "                modified_solution[\"total_distance\"] += 2.0  # Slight distance increase\n",
    "                modified_solution[\"special_modification\"] = \"Prioritized P45 (elevated warehouse) due to hurricane\"\n",
    "        \n",
    "        return modified_solution\n",
    "    \n",
    "    def _apply_conservative_modifications(self, ai_solution: Dict[str, Any], expert: HumanExpert) -> Dict[str, Any]:\n",
    "        \"\"\"Apply conservative modifications to AI solution\"\"\"\n",
    "        modified_solution = ai_solution.copy()\n",
    "        \n",
    "        # Conservative approach: reduce route complexity\n",
    "        route = modified_solution[\"route\"]\n",
    "        if len(route) > 6:\n",
    "            # Split route to reduce complexity\n",
    "            modified_solution[\"route\"] = route[:len(route)//2]\n",
    "            modified_solution[\"additional_vehicle_required\"] = True\n",
    "            modified_solution[\"reasoning\"] = \"Split route to reduce complexity and risk\"\n",
    "        \n",
    "        return modified_solution\n",
    "    \n",
    "    def _apply_moderate_modifications(self, ai_solution: Dict[str, Any], expert: HumanExpert) -> Dict[str, Any]:\n",
    "        \"\"\"Apply moderate modifications to AI solution\"\"\"\n",
    "        modified_solution = ai_solution.copy()\n",
    "        \n",
    "        # Moderate approach: minor adjustments\n",
    "        route = modified_solution[\"route\"]\n",
    "        if len(route) > 4:\n",
    "            # Swap adjacent customers for better flow\n",
    "            route[2], route[3] = route[3], route[2]\n",
    "            modified_solution[\"route\"] = route\n",
    "            modified_solution[\"total_distance\"] += 0.5\n",
    "        \n",
    "        return modified_solution\n",
    "    \n",
    "    def _select_best_alternative(self, alternatives: List[Dict[str, Any]], expert: HumanExpert) -> Dict[str, Any]:\n",
    "        \"\"\"Select best alternative based on expert preferences\"\"\"\n",
    "        if not alternatives:\n",
    "            return {}\n",
    "        \n",
    "        # Analytical expert selects based on quantitative factors\n",
    "        best_alternative = alternatives[0]\n",
    "        min_distance = float('inf')\n",
    "        \n",
    "        for alt in alternatives:\n",
    "            if \"total_distance\" in alt and alt[\"total_distance\"] < min_distance:\n",
    "                min_distance = alt[\"total_distance\"]\n",
    "                best_alternative = alt\n",
    "        \n",
    "        return best_alternative\n",
    "    \n",
    "    def _determine_agreement(self, ai_recommendation: AIRecommendation, human_decision: Dict[str, Any]) -> bool:\n",
    "        \"\"\"Determine if human agrees with AI recommendation\"\"\"\n",
    "        action = human_decision.get(\"action\", \"accept\")\n",
    "        \n",
    "        if action == \"accept\":\n",
    "            return True\n",
    "        elif action == \"alternative\":\n",
    "            return False\n",
    "        elif action == \"modify\" or action == \"manual_override\":\n",
    "            return False\n",
    "        else:\n",
    "            return False\n",
    "    \n",
    "    def _calculate_human_confidence(self, expert: HumanExpert, \n",
    "                                   ai_recommendation: AIRecommendation,\n",
    "                                   current_conditions: Dict[str, Any]) -> float:\n",
    "        \"\"\"Calculate human confidence in decision\"\"\"\n",
    "        base_confidence = 0.8\n",
    "        \n",
    "        # Adjust confidence based on AI confidence\n",
    "        if ai_recommendation.confidence_score < 0.5:\n",
    "            base_confidence -= 0.2\n",
    "        elif ai_recommendation.confidence_score > 0.8:\n",
    "            base_confidence += 0.1\n",
    "        \n    ",
    "        # Adjust based on uncertainty factors\n",
    "        uncertainty_penalty = len(ai_recommendation.uncertainty_factors) * 0.1\n",
    "        base_confidence -= uncertainty_penalty\n",
    "        \n",
    "        # Adjust based on local knowledge availability\n",
    "        if current_conditions.get(\"requires_local_knowledge\", False):\n",
    "            base_confidence += 0.1\n",
    "        \n",
    "        return max(0.1, min(1.0, base_confidence))\n",
    "    \n",
    "    def _evaluate_outcome_quality(self, decision: Dict[str, Any], conditions: Dict[str, Any]) -> float:\n",
    "        \"\"\"Evaluate the quality of the decision outcome\"\"\"\n",
    "        base_quality = 0.8\n",
    "        \n",
    "        # Quality based on action type\n",
    "        action = decision.get(\"action\", \"accept\")\n",
    "        if action == \"accept\":\n",
    "            base_quality = 0.85\n",
    "        elif action == \"manual_override\":\n",
    "            if \"hurricane\" in conditions.get(\"problem_type\", \"\").lower():\n",
    "                base_quality = 0.95  # High quality for hurricane scenario\n",
    "            else:\n",
    "                base_quality = 0.75\n",
    "        elif action == \"modify\":\n",
    "            base_quality = 0.80\n",
    "        \n",
    "        return base_quality\n",
    "    \n",
    "    def _update_trust_metrics(self, expert_id: str, agreement: bool, outcome_quality: float) -> float:\n",
    "        \"\"\"Update trust metrics based on interaction outcome\"\"\"\n",
    "        trust_metrics = self.trust_metrics[expert_id]\n",
    "        \n",
    "        # Update interaction counts\n",
    "        trust_metrics.interaction_count += 1\n",
    "        if agreement and outcome_quality > 0.7:\n",
    "            trust_metrics.successful_collaborations += 1\n",
    "        \n",
    "        # Calculate trust changes\n",
    "        if agreement and outcome_quality > 0.8:\n",
    "            # Positive interaction\n",
    "            trust_change = 0.05\n",
    "        elif not agreement and outcome_quality < 0.5:\n",
    "            # Disagreement with poor outcome\n",
    "            trust_change = -0.03\n",
    "        else:\n",
    "            # Neutral or mixed outcome\n",
    "            trust_change = 0.01\n",
    "        \n",
    "        # Update trust dimensions\n",
    "        if outcome_quality > 0.7:\n",
    "            trust_metrics.competence_trust = min(1.0, trust_metrics.competence_trust + trust_change * 0.4)\n",
    "            trust_metrics.integrity_trust = min(1.0, trust_metrics.integrity_trust + trust_change * 0.3)\n",
    "            trust_metrics.benevolence_trust = min(1.0, trust_metrics.benevolence_trust + trust_change * 0.2)\n",
    "            trust_metrics.predictability_trust = min(1.0, trust_metrics.predictability_trust + trust_change * 0.1)\n",
    "        \n",
    "        # Update overall trust\n",
    "        trust_metrics.overall_trust = (\n",
    "            trust_metrics.competence_trust * 0.4 +\n",
    "            trust_metrics.integrity_trust * 0.3 +\n",
    "            trust_metrics.benevolence_trust * 0.2 +\n",
    "            trust_metrics.predictability_trust * 0.1\n",
    "        )\n",
    "        \n",
    "        trust_metrics.last_updated = datetime.now()\n",
    "        \n",
    "        return trust_change\n",
    "    \n",
    "    def _generate_learning_insights(self, ai_recommendation: AIRecommendation, \n",
    "                                 human_decision: Dict[str, Any], \n",
    "                                 agreement: bool) -> List[str]:\n",
    "        \"\"\"Generate learning insights from the interaction\"\"\"\n",
    "        insights = []\n",
    "        \n",
    "        if not agreement:\n",
    "            insights.append(f\"Human disagreed with AI confidence {ai_recommendation.confidence_score:.2f}\")\n",
    "            insights.append(\"AI reasoning needs improvement in identified areas\")\n",
    "            \n",
    "            if human_decision.get(\"local_knowledge_applied\", False):\n",
    "                insights.append(\"Human decision independent of local knowledge\")\n",
    "            else:\n",
    "                insights.append(\"Local knowledge was crucial for decision\")\n",
    "        else:\n",
    "            insights.append(f\"Human accepted AI recommendation with confidence {ai_recommendation.confidence_score:.2f}\")\n",
    "            insights.append(\"AI reasoning was sufficient for human approval\")\n",
    "        \n",
    "        if ai_recommendation.uncertainty_factors:\n",
    "            insights.append(f\"Uncertainty factors identified: {', '.join(ai_recommendation.uncertainty_factors)}\")\n",
    "        \n",
    "        return insights\n",
    "\n",
    "print(\"✅ Human-AI Partnership system implemented\")"
   ]
  },
