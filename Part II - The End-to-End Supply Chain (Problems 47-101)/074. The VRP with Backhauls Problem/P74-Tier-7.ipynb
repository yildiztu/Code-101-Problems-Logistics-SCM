    "class DecisionStyle(Enum):\n",
    "    \"\"\"Human decision making styles\"\"\"\n",
    "    CONSERVATIVE = \"conservative\"\n",
    "    BALANCED = \"balanced\"\n",
    "    AGGRESSIVE = \"aggressive\"\n",
    "    ANALYTICAL = \"analytical\"\n",
    "    INTUITIVE = \"intuitive\"\n",
    "\n",
    "@dataclass\n",
    "class VRPBInstance:\n",
    "    \"\"\"Data class for VRP with Backhauls problem instance\"\"\"\n",
    "    num_deliveries: int\n",
    "    num_pickups: int\n",
    "    delivery_demands: List[float]\n",
    "    pickup_demands: List[float]\n",
    "    capacity: float\n",
    "    distance_matrix: np.ndarray\n",
    "    \n",
    "    def __post_init__(self):\n",
    "        self.num_customers = self.num_deliveries + self.num_pickups\n",
    "        self.delivery_indices = list(range(1, self.num_deliveries + 1))\n",
    "        self.pickup_indices = list(range(self.num_deliveries + 1, \n",
    "                                         self.num_deliveries + self.num_pickups + 1))\n",
    "        self.all_customer_indices = self.delivery_indices + self.pickup_indices\n",
    "\n",
    "@dataclass\n",
    "class AIRecommendation:\n",
    "    \"\"\"AI recommendation with explainable reasoning\"\"\"\n",
    "    recommendation_id: str\n",
    "problem_type: str\n",
    "recommended_solution: Dict[str, Any]\n",
    "confidence_score: float\n",
    "reasoning: List[str]\n",
    "alternatives: List[Dict[str, Any]]\n",
    "data_sources: List[str]\n",
    "uncertainty_factors: List[str]\n",
    "ethical_considerations: List[str]\n",
    "timestamp: datetime\n",
    "\n",
    "@dataclass\n",
    "class HumanExpert:\n",
    "    \"\"\"Human expert with domain expertise and decision style\"\"\"\n",
    "    expert_id: str\n",
    "    name: str\n",
    "    expertise_areas: List[str]\n",
    "    experience_years: int\n",
    "    decision_style: DecisionStyle\n",
    "    risk_tolerance: float\n",
    "    confidence_threshold: float\n",
    "    local_knowledge: Dict[str, Any]\n",
    "decision_history: List[Dict[str, Any]] = field(default_factory=list)\n",
    "\n",
    "@dataclass\n",
    "class TrustMetrics:\n",
    "    \"\"\"Trust metrics between human and AI\"\"\"\n",
    "competence_trust: float\n",
    "integrity_trust: float\n",
    "benevolence_trust: float\n",
    "predictability_trust: float\n",
    "overall_trust: float\n",
    "interaction_count: int\n",
    "successful_collaborations: int\n",
    "last_updated: datetime\n",
    "\n",
    "@dataclass\n",
    "class PartnershipInteraction:\n",
    "    \"\"\"Record of human-AI collaboration\"\"\"\n",
    "interaction_id: str\n",
    "timestamp: datetime\n",
    "problem_context: str\n",
    "ai_recommendation: AIRecommendation\n",
    "human_decision: Dict[str, Any]\n",
    "agreement: bool\n",
    "human_confidence: float\n",
    "outcome_quality: float\n",
    "trust_change: float\n",
    "learning_insights: List[str]\n",
    "\n",
    "print(\"✅ Human-AI partnership data structures defined\")"
   ]
