    "class Agent:\n",
    "    \"\"\"Base class for all agents in the multi-agent system\"\"\"\n",
    "    \n",
    "    def __init__(self, agent_id: str, agent_type: AgentType, instance: VRPPDInstance):\n",
    "        self.agent_id = agent_id\n",
    "        self.agent_type = agent_type\n",
    "        self.instance = instance\n",
    "        self.message_queue = deque()\n",
    "        self.neighbors = []  # Connected agents\n",
    "        self.knowledge_base = {}\n",
    "        self.learning_history = []\n",
    "        self.performance_metrics = {}\n",
    "        self.active = True\n",
    "        \n",
    "    def send_message(self, receiver_id: str, message_type: str, content: Any, priority: int = 1):\n",
    "        \"\"\"Send message to another agent\"\"\"\n",
    "        message = Message(\n",
    "            sender_id=self.agent_id,\n",
    "            receiver_id=receiver_id,\n",
    "            message_type=message_type,\n",
    "            content=content,\n",
    "            timestamp=time.time(),\n",
    "            priority=priority\n",
    "        )\n",
    "        return message\n",
    "    \n",
    "    def receive_message(self, message: Message):\n",
    "        \"\"\"Receive and process message\"\"\"\n",
    "        self.message_queue.append(message)\n",
    "        self.process_message(message)\n",
    "    \n",
    "    def process_message(self, message: Message):\n",
    "        \"\"\"Process incoming message (to be overridden by subclasses)\"\"\"\n",
    "        pass\n",
    "    \n",
    "    def update_knowledge(self, key: str, value: Any):\n",
    "        \"\"\"Update agent's knowledge base\"\"\"\n",
    "        self.knowledge_base[key] = {\n",
    "            'value': value,\n",
    "            'timestamp': time.time(),\n",
    "            'source': 'self'\n",
    "        }\n",
    "    \n",
    "    def get_knowledge(self, key: str) -> Any:\n",
    "        \"\"\"Retrieve knowledge from knowledge base\"\"\"\n",
    "        return self.knowledge_base.get(key, {}).get('value')\n",
    "\n",
    "class VehicleAgent(Agent):\n",
    "    \"\"\"Autonomous vehicle agent with routing and bidding capabilities\"\"\"\n",
    "    \n",
    "    def __init__(self, agent_id: str, vehicle_id: int, instance: VRPPDInstance):\n",
    "        super().__init__(agent_id, AgentType.VEHICLE, instance)\n",
    "        self.vehicle_id = vehicle_id\n",
    "        self.current_position = instance.depot_start\n",
    "        self.current_load = 0\n",
    "        self.current_route = [instance.depot_start]\n",
    "        self.assigned_requests = []\n",
    "        self.completion_history = []\n",
    "        self.bidding_strategy = 'cost_minimization'  # Can be learned/adapted\n",
    "        self.reputation_score = 50.0  # Initial reputation\n",
    "        \n",
    "        # Performance metrics\n",
    "        self.performance_metrics = {\n",
    "            'total_distance': 0.0,\n",
    "            'completed_requests': 0,\n",
    "            'on_time_rate': 1.0,\n",
    "            'avg_completion_time': 0.0,\n",
    "            'revenue': 0.0\n",
    "        }\n",
    "    \n",
    "    def calculate_route_distance(self, route: List[int]) -> float:\n",
    "        \"\"\"Calculate total distance of a route\"\"\"\n",
    "        if len(route) < 2:\n",
    "            return 0.0\n",
    "        total_distance = 0.0\n",
    "        for i in range(len(route) - 1):\n",
    "            total_distance += self.instance.distances[route[i]][route[i + 1]]\n",
    "        return total_distance\n",
    "    \n",
    "    def can_serve_request(self, request: Dict[str, Any]) -> bool:\n",
    "        \"\"\"Check if vehicle can serve the request\"\"\"\n",
    "        pickup_demand = request.get('pickup_demand', 0)\n",
    "        delivery_demand = request.get('delivery_demand', 0)\n",
    "        \n",
    "        # Check capacity constraint\n",
    "        if self.current_load + pickup_demand + delivery_demand > self.instance.vehicle_capacity:\n",
    "            return False\n",
    "        \n",
    "        # Check if pickup and delivery can be added to current route\n",
    "        # Simplified check - in practice would be more complex\n",
    "        return len(self.current_route) < 10  # Limit route length\n",
    "    \n",
    "    def calculate_bid(self, request: Dict[str, Any]) -> Bid:\n",
    "        \"\"\"Calculate bid for customer request\"\"\"\n",
    "        \n",
    "        # Calculate base cost\n",
    "        pickup_location = request['pickup_location']\n",
    "        delivery_location = request['delivery_location']\n",
    "        \n",
    "        # Distance from current position to pickup\n",
    "        distance_to_pickup = self.instance.distances[self.current_position][pickup_location]\n",
    "        \n",
    "        # Distance from pickup to delivery\n",
    "        pickup_to_delivery = self.instance.distances[pickup_location][delivery_location]\n",
    "        \n",
    "        # Distance from delivery back to depot\n",
    "        delivery_to_depot = self.instance.distances[delivery_location][self.instance.depot_end]\n",
    "        \n",
    "        total_distance = distance_to_pickup + pickup_to_delivery + delivery_to_depot\n",
    "        \n",
    "        # Calculate bid price (lower is better for customer)\n",
    "        # Base price plus adjustments\n",
    "        base_price = total_distance * 2.0\n",
    "        \n",
    "        # Reputation adjustment (better reputation = lower price)\n",
    "        reputation_adjustment = base_price * (1.0 - self.reputation_score / 100.0)\n",
    "        \n",
    "        # Load adjustment (higher load = higher price)\n",
    "        load_factor = self.current_load / self.instance.vehicle_capacity\n",
    "        load_adjustment = base_price * load_factor * 0.2\n",
    "        \n",
    "        bid_price = base_price + reputation_adjustment + load_adjustment\n",
    "        \n",
    "        # Estimate completion time\n",
    "        average_speed = 30.0  # km/h\n",
    "        estimated_time = total_distance / average_speed * 60  # minutes\n",
    "        \n",
    "        # Confidence score based on experience\n",
    "        confidence = min(1.0, self.reputation_score / 50.0)\n",
    "        \n",
    "        # Create simple route plan\n",
    "        route_plan = [self.current_position, pickup_location, delivery_location, self.instance.depot_end]\n",
    "        \n",
    "        return Bid(\n",
    "            agent_id=self.agent_id,\n",
    "            request_id=request['request_id'],\n",
    "            bid_price=bid_price,\n",
    "            estimated_completion_time=estimated_time,\n",
    "            confidence_score=confidence,\n",
    "            route_plan=route_plan,\n",
    "            timestamp=time.time()\n",
    "        )\n",
    "    \n",
    "    def execute_request(self, request: Dict[str, Any]):\n",
    "        \"\"\"Execute pickup and delivery request\"\"\"\n",
    "        pickup_location = request['pickup_location']\n",
    "        delivery_location = request['delivery_location']\n",
    "        pickup_demand = request.get('pickup_demand', 0)\n",
    "        delivery_demand = request.get('delivery_demand', 0)\n",
    "        \n",
    "        # Update route\n",
    "        if self.current_position != pickup_location:\n",
    "            self.current_route.append(pickup_location)\n",
    "        \n",
    "        self.current_route.append(delivery_location)\n",
    "        \n",
    "        # Update load\n",
    "        self.current_load += pickup_demand\n",
    "        self.current_load += delivery_demand\n",
    "        \n",
    "        # Update position\n",
    "        self.current_position = delivery_location\n",
    "        \n",
    "        # Update metrics\n",
    "        route_distance = self.calculate_route_distance(self.current_route)\n",
    "        self.performance_metrics['total_distance'] += route_distance\n",
    "        self.performance_metrics['completed_requests'] += 1\n",
    "        \n",
    "        # Update completion history\n    \n",
    "    def update_reputation(self, performance_rating: float):\n",
    "        \"\"\"Update reputation based on performance\"\"\"\n",
    "        # Exponential moving average for reputation\n",
    "        alpha = 0.1  # Learning rate\n",
    "        self.reputation_score = (1 - alpha) * self.reputation_score + alpha * performance_rating * 100\n",
    "        self.reputation_score = max(0, min(100, self.reputation_score))\n",
    "    \n",
    "    def process_message(self, message: Message):\n",
    "        \"\"\"Process incoming messages\"\"\"\n",
    "        if message.message_type == 'auction_announcement':\n",
    "            # Participate in auction\n",
    "            request = message.content\n",
    "            if self.can_serve_request(request):\n",
    "                bid = self.calculate_bid(request)\n",
    "                # Send bid to coordinator\n",
    "                coordinator_id = next((n for n in self.neighbors if n.startswith('coordinator')), None)\n",
    "                if coordinator_id:\n",
    "                    bid_message = self.send_message(coordinator_id, 'bid_submission', bid, priority=2)\n",
    "                    # In a real system, this would be sent through communication layer\n",
    "                    self.update_knowledge('last_bid', bid)\n",
    "        \n",
    "        elif message.message_type == 'auction_result':\n",
    "            # Handle auction result\n",
    "            result = message.content\n",
    "            if result.get('winner_agent_id') == self.agent_id:\n",
    "                # Won the auction\n",
    "                request = result['request']\n",
    "                self.execute_request(request)\n",
    "                self.update_knowledge('current_request', request)\n",
    "                \n",
    "        elif message.message_type == 'reputation_update':\n",
    "            # Update reputation\n",
    "            performance_rating = message.content.get('performance_rating', 0.5)\n",
    "            self.update_reputation(performance_rating)\n",
    "\n",
    "class CustomerAgent(Agent):\n",
    "    \"\"\"Customer agent representing pickup and delivery requirements\"\"\"\n",
    "    \n",
    "    def __init__(self, agent_id: str, customer_id: int, instance: VRPPDInstance):\n",
    "        super().__init__(agent_id, AgentType.CUSTOMER, instance)\n",
    "        self.customer_id = customer_id\n",
    "        self.pending_requests = []\n",
    "        self.satisfaction_score = 50.0\n",
    "        self.budget = random.uniform(50, 200)\n",
    "        self.preferences = {\n",
    "            'price_sensitivity': random.uniform(0.3, 0.9),\n",
    "            'time_sensitivity': random.uniform(0.3, 0.9),\n",
    "            'quality_preference': random.uniform(0.5, 1.0)\n",
    "        }\n",
    "    \n",
    "    def create_request(self) -> Dict[str, Any]:\n",
    "        \"\"\"Create a new pickup and delivery request\"\"\"\n",
    "        # Random pickup and delivery locations\n",
    "        pickup_idx = random.choice(self.instance.pickups)\n",
    "        delivery_idx = pickup_idx + self.instance.num_pairs\n",
    "        \n",
    "        # Random demand\n",
    "        pickup_demand = random.randint(1, self.instance.vehicle_capacity // 2)\n",
    "        delivery_demand = -pickup_demand\n",
    "        \n",
    "        request = {\n",
    "            'request_id': f\"req_{self.agent_id}_{len(self.pending_requests)}\",\n",
    "            'customer_id': self.customer_id,\n",
    "            'pickup_location': pickup_idx,\n",
    "            'delivery_location': delivery_idx,\n",
    "            'pickup_demand': pickup_demand,\n",
    "            'delivery_demand': delivery_demand,\n",
    "            'budget': self.budget,\n",
    "            'preferences': self.preferences,\n",
    "            'created_time': time.time(),\n",
    "            'status': 'pending'\n",
    "        }\n",
    "        \n",
    "        self.pending_requests.append(request)\n",
    "        return request\n",
    "    \n",
    "    def evaluate_bid(self, bid: Bid) -> float:\n",
    "        \"\"\"Evaluate bid and return utility score\"\"\"\n",
    "        request = next((req for req in self.pending_requests if req['request_id'] == bid.request_id), None)\n",
    "        \n",
    "        if not request:\n",
    "            return 0.0\n",
    "        \n",
    "        # Multi-criteria evaluation\n",
    "        price_score = 1.0 - (bid.bid_price / request['budget'])  # Lower price is better\n",
    "        price_score = max(0, price_score)\n",
    "        \n",
    "        time_score = 1.0 - (bid.estimated_completion_time / 120)  # Faster is better\n",
    "        time_score = max(0, time_score)\n",
    "        \n",
    "        quality_score = bid.confidence_score\n",
    "        \n",
    "        # Weighted combination based on preferences\n",
    "        total_score = (\n",
    "            self.preferences['price_sensitivity'] * price_score +\n",
    "            self.preferences['time_sensitivity'] * time_score +\n",
    "            self.preferences['quality_preference'] * quality_score\n",
    "        )\n",
    "        \n",
    "        return total_score\n",
    "    \n",
    "    def process_message(self, message: Message):\n",
    "        \"\"\"Process incoming messages\"\"\"\n",
    "        if message.message_type == 'auction_result':\n",
    "            # Handle auction result\n",
    "            result = message.content\n",
    "            request_id = result.get('request_id')\n",
    "            \n",
    "            # Update request status\n",
    "            for req in self.pending_requests:\n",
    "                if req['request_id'] == request_id:\n",
    "                    if result.get('winner_agent_id'):\n",
    "                        req['status'] = 'assigned'\n",
    "                        req['assigned_agent'] = result['winner_agent_id']\n",
    "                        req['assigned_bid'] = result['winning_bid']\n",
    "                        \n",
    "                        # Update satisfaction based on bid quality\n",
    "                        winning_bid = result['winning_bid']\n",
    "                        utility = self.evaluate_bid(winning_bid)\n",
    "                        self.satisfaction_score = 0.7 * self.satisfaction_score + 0.3 * utility * 100\n",
    "                    else:\n",
    "                        req['status'] = 'failed_auction'\n",
    "                    break\n",
    "\n",
    "class CoordinatorAgent(Agent):\n",
    "    \"\"\"Coordinator agent managing auctions and system optimization\"\"\"\n",
    "    \n",
    "    def __init__(self, agent_id: str, instance: VRPPDInstance):\n",
    "        super().__init__(agent_id, AgentType.COORDINATOR, instance)\n",
    "        self.active_auctions = {}\n",
    "        self.auction_history = []\n",
    "        self.market_clearing_price = 10.0  # Base market price\n",
    "        self.system_metrics = {\n",
    "            'total_requests': 0,\n",
    "            'successful_auctions': 0,\n",
    "            'failed_auctions': 0,\n",
    "            'average_price': 0.0,\n",
    "            'system_utilization': 0.0\n",
    "        }\n",
    "    \n",
    "    def run_auction(self, request: Dict[str, Any], bidding_agents: List[VehicleAgent], \n",
    "                  customer_agent: CustomerAgent, auction_duration: float = 30.0) -> Dict[str, Any]:\n",
    "        \"\"\"Run auction for a customer request\"\"\"\n",
    "        \n",
    "        request_id = request['request_id']\n",
    "        \n",
    "        # Initialize auction\n",
    "        self.active_auctions[request_id] = {\n",
    "            'request': request,\n",
    "            'bids': [],\n",
    "            'start_time': time.time(),\n",
    "            'end_time': time.time() + auction_duration,\n",
    "            'customer_agent': customer_agent.agent_id\n",
    "        }\n",
    "        \n",
    "        # Announce auction to vehicle agents\n",
    "        for vehicle_agent in bidding_agents:\n",
    "            if vehicle_agent.active:\n",
    "                announcement = self.send_message(vehicle_agent.agent_id, 'auction_announcement', request, priority=3)\n",
    "                # In a real system, this would be sent through communication layer\n",
    "                vehicle_agent.receive_message(announcement)\n",
    "        \n",
    "        # Wait for bids (simplified - in real system would be asynchronous)\n",
    "        time.sleep(0.1)  # Simulate waiting for bids\n",
    "        \n",
    "        # Collect bids (simplified collection)\n",
    "        auction = self.active_auctions[request_id]\n",
    "        \n",
    "        # In a real implementation, bids would be collected through message passing\n",
    "        # For now, we'll simulate bid collection\n",
    "        for vehicle_agent in bidding_agents:\n",
    "            if vehicle_agent.active and vehicle_agent.can_serve_request(request):\n",
    "                bid = vehicle_agent.calculate_bid(request)\n",
    "                auction['bids'].append(bid)\n",
    "        \n",
    "        # Evaluate bids and select winner\n",
    "        winning_bid = None\n    \n",
    "        if auction['bids']:\n",
    "            # Customer evaluates bids\n",
    "            bid_scores = []\n",
    "            for bid in auction['bids']:\n",
    "                score = customer_agent.evaluate_bid(bid)\n",
    "                bid_scores.append((bid, score))\n",
    "            \n",
    "            # Select highest scoring bid\n",
    "            if bid_scores:\n",
    "                bid_scores.sort(key=lambda x: x[1], reverse=True)\n",
    "                winning_bid = bid_scores[0][0]\n",
    "        \n",
    "        # Create auction result\n",
    "        result = {\n",
    "            'request_id': request_id,\n",
    "            'request': request,\n",
    "            'winning_bid': winning_bid,\n",
    "            'winner_agent_id': winning_bid.agent_id if winning_bid else None,\n",
    "            'all_bids': auction['bids'],\n",
    "            'auction_time': time.time() - auction['start_time']\n",
    "            'customer_agent': customer_agent.agent_id\n",
    "        }\n",
    "        \n",
    "        # Update metrics\n",
    "        self.system_metrics['total_requests'] += 1\n",
    "        if winning_bid:\n",
    "            self.system_metrics['successful_auctions'] += 1\n",
    "            self.system_metrics['average_price'] = (\n",
    "                (self.system_metrics['average_price'] * (self.system_metrics['successful_auctions'] - 1) + winning_bid.bid_price) /\n",
    "                self.system_metrics['successful_auctions']\n",
    "            )\n",
    "        else:\n",
    "            self.system_metrics['failed_auctions'] += 1\n",
    "        \n",
    "        # Clean up auction\n",
    "        del self.active_auctions[request_id]\n",
    "        self.auction_history.append(result)\n",
    "        \n",
    "        return result\n",
    "    \n",
    "    def process_message(self, message: Message):\n",
    "        \"\"\"Process incoming messages\"\"\"\n",
    "        if message.message_type == 'bid_submission':\n",
    "            # Handle bid submission\n",
    "            bid = message.content\n",
    "            auction_id = bid.request_id\n",
    "            \n",
    "            if auction_id in self.active_auctions:\n",
    "                self.active_auctions[auction_id]['bids'].append(bid)\n",
    "        \n",
    "        elif message.message_type == 'new_request':\n",
    "            # Handle new customer request\n",
    "            request = message.content['request']\n",
    "            customer_agent = message.content['customer_agent']\n",
    "            \n",
    "            # Get list of active vehicle agents\n",
    "            vehicle_agents = [agent for agent in self.neighbors \n",
    "                            if agent.agent_type == AgentType.VEHICLE]\n",
    "            \n",
    "            # Run auction\n",
    "            result = self.run_auction(request, vehicle_agents, customer_agent)\n",
    "            \n",
    "            # Notify winner and customer\n",
    "            if result['winner_agent_id']:\n",
    "                # Notify winning vehicle agent\n",
    "                winner_agent = next((agent for agent in vehicle_agents if agent.agent_id == result['winner_agent_id']), None)\n",
    "                if winner_agent:\n",
    "                    result_message = self.send_message(result['winner_agent_id'], 'auction_result', result, priority=3)\n",
    "                    winner_agent.receive_message(result_message)\n",
    "            \n",
    "            # Notify customer agent\n",
    "            customer_agent_obj = next((agent for agent in self.neighbors if agent.agent_id == customer_agent.agent_id), None)\n",
    "            if customer_agent_obj:\n",
    "                result_message = self.send_message(customer_agent.agent_id, 'auction_result', result, priority=3)\n",
    "                customer_agent_obj.receive_message(result_message)\n",
    "\n",
    "print(\"Multi-Agent System classes defined\")"
   ]
