    "        system = MultiAgentSystem(ma_instance)\n    "        \n    "        # Apply scenario conditions\n    "        if scenario_name == 'vehicle_failure':\n    "            # Disable 25% of vehicles\n    "            vehicle_agents = [agent for agent in system.agents.values() if agent.agent_type == AgentType.VEHICLE]\n    "            num_to_disable = int(len(vehicle_agents) * 0.25)\n    "            \n    "            for i in range(num_to_disable):\n    "                vehicle_agents[i].active = False\n    "                \n    "            print(f\"  Disabled {num_to_disable} vehicles\")\n    "            \n    "        elif scenario_name == 'high_demand':\n    "            # Generate 50% more requests\n    "            print(\"  Generating high demand scenario...\")\n    "            system.generate_customer_requests(45)  # 50% more than normal\n    "            \n    "        elif scenario_name == 'communication_failure':\n    "            # Simulate communication issues\n    "            print(\"  Simulating communication failures...\")\n    "            # In a real system, this would affect message delivery\n    "            pass  # Simplified for demonstration\n    "        \n    "        # Run simulation for scenario\n    "        scenario_results = system.run_simulation(duration_steps=50)\n    "        \n    "        # Analyze scenario results\n    "        if scenario_results:\n    "            final_result = scenario_results[-1]\n    "            \n    "            # Calculate resilience metrics\n    "            normal_performance = 100.0  # Baseline performance\n    "            \n    "            if scenario_name == 'normal':\n    "                normal_performance = final_result['completed_requests']\n    "            \n    "            performance_ratio = (final_result['completed_requests'] / normal_performance) * 100 if normal_performance > 0 else 0\n    "            \n    "            results[scenario_name] = {\n    "                'final_metrics': final_result,\n    "                'performance_ratio': performance_ratio,\n    "                'resilience_score': performance_ratio,\n    "                'scenario_results': scenario_results\n    "            }\n    "            \n    "            print(f\"  Performance ratio: {performance_ratio:.1f}%\")\n    "            print(f\"  Final completed requests: {final_result['completed_requests']}\")\n    "            print(f\"  System utilization: {final_result['system_utilization']:.1f}%\")\n    "        \n    "    return results\n",
