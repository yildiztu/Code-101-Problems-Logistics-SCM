    "def analyze_multi_agent_results(results: List[Dict[str, Any]]) -> Dict[str, Any]:\n",
    "    \"\"\"Analyze multi-agent system performance\"\"\"\n",
    "    \n",
    "    if not results:\n",
    "        return {'error': 'No results to analyze'}\n",
    "    \n",
    "    # Extract time series data\n",
    "    times = [r['system_time'] for r in results]\n",
    "    total_requests = [r['total_requests'] for r in results]\n",
    "    completed_requests = [r['completed_requests'] for r in results]\n",
    "    total_distance = [r['total_distance'] for r in results]\n",
    "    active_vehicles = [r['active_vehicles'] for r in results]\n",
    "    utilization = [r['system_utilization'] for r in results]\n",
    "    avg_reputation = [r['average_reputation'] for r in results]\n",
    "    avg_satisfaction = [r['average_satisfaction'] for r in results]\n",
    "    \n",
    "    # Calculate key metrics\n",
    "    final_result = results[-1]\n",
    "    \n",
    "    # Auction efficiency\n",
    "    auction_efficiency = (final_result['completed_requests'] / max(1, final_result['total_requests'])) * 100\n",
    "    \n",
    "    # System performance\n",
    "    avg_completion_time = np.mean(total_distance) / max(1, np.mean(active_vehicles)) if active_vehicles else 0\n",
    "    \n",
    "    # Agent performance\n",
    "    final_reputation = final_result['average_reputation']\n",
    "    final_satisfaction = final_result['average_satisfaction']\n",
    "    \n",
    "    # Learning/adaptation indicators\n",
    "    reputation_trend = avg_reputation[-1] - avg_reputation[0] if len(avg_reputation) > 1 else 0\n",
    "    satisfaction_trend = avg_satisfaction[-1] - avg_satisfaction[0] if len(avg_satisfaction) > 1 else 0\n",
    "    \n",
    "    return {\n",
    "        'final_metrics': final_result,\n",
    "        'auction_efficiency': auction_efficiency,\n",
    "        'avg_completion_time': avg_completion_time,\n",
    "        'final_reputation': final_reputation,\n",
    "        'final_satisfaction': final_satisfaction,\n",
    "        'reputation_trend': reputation_trend,\n",
    "        'satisfaction_trend': satisfaction_trend,\n",
