    "class MultiAgentSystem:\n",
    "    \"\"\"Main multi-agent system orchestrating all agents\"\"\"\n",
    "    \n",
    "    def __init__(self, instance: VRPPDInstance):\n",
    "        self.instance = instance\n",
    "        self.agents = {}\n",
    "        self.system_time = 0.0\n",
    "        self.simulation_running = False\n",
    "        self.performance_history = []\n",
    "        \n",
    "        # Initialize agents\n",
    "        self._initialize_agents()\n",
    "        \n",
    "        # Establish communication network\n",
    "        self._establish_communication_network()\n",
    "    \n",
    "    "    def _initialize_agents(self):\n",
    "        \"\"\"Initialize all agents in the system\"\"\"\n",
    "        \n",
    "        # Create vehicle agents\n",
    "        for vehicle_id in self.instance.vehicles:\n",
    "            agent_id = f\"vehicle_{vehicle_id}\"\n",
    "            vehicle_agent = VehicleAgent(agent_id, vehicle_id, self.instance)\n",
    "            self.agents[agent_id] = vehicle_agent\n",
    "        \n",
    "        # Create customer agents\n",
    "        num_customers = 20\n",
    "        for customer_id in range(num_customers):\n",
    "            agent_id = f\"customer_{customer_id}\"\n",
    "            customer_agent = CustomerAgent(agent_id, customer_id, self.instance)\n",
    "            self.agents[agent_id] = customer_agent\n",
    "        \n",
    "        # Create coordinator agents\n",
    "        num_coordinators = 3\n",
    "        for coord_id in range(num_coordinators):\n",
    "            agent_id = f\"coordinator_{coord_id}\"\n",
    "            coordinator_agent = CoordinatorAgent(agent_id, self.instance)\n",
    "            self.agents[agent_id] = coordinator_agent\n",
    "    \n",
    "    def _establish_communication_network(self):\n",
    "        \"\"\"Establish communication connections between agents\"\"\"\n",
    "        \n",
    "        # Connect all agents to all coordinators\n",
    "        coordinator_agents = [agent for agent in self.agents.values() if agent.agent_type == AgentType.COORDINATOR]\n",
    "        \n",
    "        for agent_id, agent in self.agents.items():\n",
    "            # Connect to all coordinators\n",
    "            agent.neighbors = [coord.agent_id for coord in coordinator_agents]\n",
    "            \n",
    "            # Coordinators also know about each other\n",
    "            if agent.agent_type == AgentType.COORDINATOR:\n",
    "                agent.neighbors.extend([coord.agent_id for coord in coordinator_agents if coord.agent_id != agent_id])\n",
    "    \n",
    "    def generate_customer_requests(self, num_requests: int = 50):\n",
    "        \"\"\"Generate customer requests in the system\"\"\"\n",
    "        \n",
    "        customer_agents = [agent for agent in self.agents.values() if agent.agent_type == AgentType.CUSTOMER]\n",
    "        coordinator_agents = [agent for agent in self.agents.values() if agent.agent_type == AgentType.COORDINATOR]\n",
    "        \n",
    "        generated_requests = []\n",
    "        \n",
    "        for _ in range(num_requests):\n",
    "            # Select random customer agent\n",
    "            customer_agent = random.choice(customer_agents)\n",
    "            \n",
    "            # Create request\n",
    "            request = customer_agent.create_request()\n",
    "            generated_requests.append(request)\n",
    "            \n",
    "            # Select random coordinator\n",
    "            coordinator = random.choice(coordinator_agents)\n",
    "            \n",
    "            # Send request to coordinator\n",
    "            message = coordinator.send_message(\n",
    "                coordinator.agent_id, \n",
    "                'new_request', \n",
    "                {'request': request, 'customer_agent': customer_agent}, \n",
    "                priority=2\n",
    "            )\n",
    "            \n",
    "            # Process message (in real system, this would be asynchronous)\n",
    "            coordinator.receive_message(message)\n",
    "        \n",
    "        return generated_requests\n",
    "    \n",
    "    def run_simulation_step(self) -> Dict[str, Any]:\n",
    "        \"\"\"Run one step of the multi-agent simulation\"\"\"\n",
    "        \n",
    "        self.system_time += 1.0\n",
    "        \n",
    "        # Generate new requests occasionally\n",
    "        if random.random() < 0.1:  # 10% chance per step\n",
    "            new_requests = self.generate_customer_requests(random.randint(1, 5))\n",
    "        \n",
    "        # Collect system metrics\n",
    "        total_requests = 0\n",
    "        completed_requests = 0\n",
    "        total_distance = 0.0\n",
    "        active_vehicles = 0\n",
    "        \n",
    "        for agent in self.agents.values():\n",
    "            if agent.agent_type == AgentType.VEHICLE:\n",
    "                if agent.active:\n",
    "                    active_vehicles += 1\n    \n",
    "                    total_distance += agent.performance_metrics['total_distance']\n",
    "                    completed_requests += agent.performance_metrics['completed_requests']\n",
    "            \n",
    "            elif agent.agent_type == AgentType.COORDINATOR:\n",
    "                total_requests += agent.system_metrics['total_requests']\n",
    "                completed_requests += agent.system_metrics['successful_auctions']\n",
    "        \n",
    "        # Calculate system utilization\n",
    "        total_capacity = active_vehicles * self.instance.vehicle_capacity\n",
    "        total_load = sum(agent.current_load for agent in self.agents.values() if agent.agent_type == AgentType.VEHICLE)\n",
    "        system_utilization = (total_load / total_capacity * 100) if total_capacity > 0 else 0\n",
    "        \n",
    "        # Create performance snapshot\n",
    "        performance_snapshot = {\n",
    "            'system_time': self.system_time,\n",
    "            'total_requests': total_requests,\n",
    "            'completed_requests': completed_requests,\n",
    "            'total_distance': total_distance,\n",
    "            'active_vehicles': active_vehicles,\n",
    "            'system_utilization': system_utilization,\n",
    "            'average_reputation': np.mean([agent.reputation_score for agent in self.agents.values() \n",
    "                                       if agent.agent_type == AgentType.VEHICLE]),\n",
    "            'average_satisfaction': np.mean([agent.satisfaction_score for agent in self.agents.values() \n",
    "                                       if agent.agent_type == AgentType.CUSTOMER])\n",
    "        }\n",
    "        \n",
    "        self.performance_history.append(performance_snapshot)\n",
    "        \n",
    "        return performance_snapshot\n",
    "    \n",
    "    def run_simulation(self, duration_steps: int = 100) -> List[Dict[str, Any]]:\n",
    "        \"\"\"Run the multi-agent simulation for specified duration\"\"\"\n",
    "        \n",
    "        print(f\"Running Multi-Agent System Simulation for {duration_steps} steps...\")\n",
    "        \n",
    "        # Generate initial requests\n",
    "        print(\"Generating initial customer requests...\")\n",
    "        initial_requests = self.generate_customer_requests(30)\n",
    "        print(f\"Generated {len(initial_requests)} initial requests\")\n",
    "        \n",
    "        simulation_results = []\n",
    "        \n",
    "        for step in range(duration_steps):\n",
    "            result = self.run_simulation_step()\n",
    "            simulation_results.append(result)\n",
    "            \n",
    "            if step % 20 == 0:  # Report every 20 steps\n",
    "                print(f\"Step {step:3d}: Requests = {result['total_requests']}, \"\n",
    "                      f\"Completed = {result['completed_requests']}, \"\n",
    "                      f\"Vehicles = {result['active_vehicles']}, \"\n",
    "                      f\"Utilization = {result['system_utilization']:.1f}%\")\n",
    "        \n",
    "        return simulation_results\n",
    "\n",
    "print(\"Multi-Agent System class defined\")"
   ]
  },
