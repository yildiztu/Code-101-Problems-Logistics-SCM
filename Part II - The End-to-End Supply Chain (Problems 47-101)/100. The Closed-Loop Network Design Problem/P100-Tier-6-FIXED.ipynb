    "def run_ecosystem_simulation(ecosystem: AutonomousEcosystem, duration_minutes: int = 5):\n",
    "    \"\"\"Run autonomous ecosystem simulation\"\"\"\n",
    "    \n",
    "    print(f\"Running Autonomous Ecosystem Simulation for {duration_minutes} minutes...\")\n",
    "    print(\"=\" * 60)\n",
    "    \n",
    "    simulation_data = {\n",
    "        'timestamps': [],\n",
    "        'agent_decisions': [],\n",
    "        'market_conditions': [],\n",
    "        'contract_negotiations': [],\n",
    "        'emergent_behaviors': [],\n",
    "        'ecosystem_metrics': []\n",
    "    }\n",
    "    \n",
    "    start_time = time.time()\n",
    "    \n",
    "    for minute in range(duration_minutes):\n",
    "        for second in range(60):\n",
    "            current_time = time.time()\n",
    "            \n",
    "            # Run agent decisions\n",
    "            decisions = ecosystem.run_agent_decisions()\n",
    "            \n",
    "            # Run market mechanism\n",
    "            ecosystem.run_market_mechanism(decisions)\n",
    "            \n",
    "            # Run contract negotiations (every 15 seconds)\n",
    "            if second % 15 == 0:\n",
    "                negotiations = ecosystem.run_contract_negotiations()\n",
    "            else:\n",
    "                negotiations = []\n",
    "            \n",
    "            # Detect emergent behaviors (every 30 seconds)\n",
    "            if second % 30 == 0:\n",
    "                behaviors = ecosystem.detect_emergent_behaviors()\n",
    "            else:\n",
    "                behaviors = []\n",
    "            \n",
    "            # Update ecosystem metrics\n",
    "            ecosystem.update_ecosystem_metrics()\n",
    "            \n",
    "            # Collect data\n",
    "            simulation_data['timestamps'].append(current_time)\n",
    "            simulation_data['agent_decisions'].append(decisions)\n",
    "            simulation_data['market_conditions'].append(ecosystem.market.get_market_conditions())\n",
    "            simulation_data['contract_negotiations'].append(negotiations)\n",
    "            simulation_data['emergent_behaviors'].append(behaviors)\n",
    "            simulation_data['ecosystem_metrics'].append(ecosystem.ecosystem_metrics.copy())\n",
    "            \n",
    "            # Print status every minute\n",
    "            if second == 0:\n",
    "                print(f\"Minute {minute + 1}: Price=${ecosystem.market.current_price:.2f}, Agents={len(ecosystem.agents)}, Health={ecosystem.ecosystem_metrics.get('ecosystem_health', 0):.3f}\")\n",
    "                \n",
    "                # Show sample decisions\n",
    "                active_decisions = [d for d in decisions if d['decision'] == 'accept']\n",
    "                print(f\"  Active Decisions: {len(active_decisions)}\")\n",
    "                for decision in active_decisions[:3]:\n",
    "                    opportunity = decision.get('opportunity', {})\n",
    "                    print(f\"    {decision['agent_id']}: {opportunity.get('type', 'unknown')} (confidence: {decision['confidence']:.2f})\")\n",
    "                \n",
    "                # Show market conditions\n",
    "                market = ecosystem.market.get_market_conditions()\n",
    "                print(f\"  Market: Demand={market['demand']:.1f}, Supply={market['supply']:.1f}, Volatility={market['volatility']:.2f}\")\n",
    "                \n",
    "                # Show emergent behaviors\n",
    "                if behaviors:\n",
    "                    print(f\"  Emergent Behaviors: {len(behaviors)}\")\n",
    "                    for behavior in behaviors[:2]:\n",
    "                        print(f\"    {behavior['type'].replace('_', ' ').title()}: {behavior['description']}\")\n",
    "            \n",
    "            time.sleep(0.01)  # Small delay for realistic simulation\n",
    "    \n",
    "    end_time = time.time()\n",
    "    \n",
    "    print(f\"\\nSimulation Summary:\")\n",
    "    print(f\"Duration: {end_time - start_time:.2f} seconds\")\n",
    "    print(f\"Total Updates: {len(simulation_data['timestamps'])}\")\n",
    "    print(f\"Total Agent Decisions: {sum(len(d) for d in simulation_data['agent_decisions'])}\")\n",
    "    print(f\"Total Contract Negotiations: {sum(len(n) for n in simulation_data['contract_negotiations'])}\")\n",
    "    print(f\"Total Emergent Behaviors: {sum(len(b) for b in simulation_data['emergent_behaviors'])}\")\n",
    "    print(f\"Final Market Price: ${ecosystem.market.current_price:.2f}\")\n",
    "    print(f\"Final Ecosystem Health: {ecosystem.ecosystem_metrics.get('ecosystem_health', 0):.3f}\")\n",
    "    \n",
    "    return simulation_data\n",
    "\n",
    "# Run the simulation\n",
    "simulation_data = run_ecosystem_simulation(ecosystem, duration_minutes=3)\n",
    "\n",
    "# Generate final report\n",
    "final_report = ecosystem.generate_ecosystem_report()\n",
    "\n",
    "print(f\"\\nFinal Ecosystem Report:\")\n",
    "print(\"=\" * 30)\n",
    "\n",
    "overview = final_report['system_overview']\n",
