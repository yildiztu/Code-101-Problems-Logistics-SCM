    "def visualize_ecosystem_performance(ecosystem: AutonomousEcosystem, \n",
    "                                  simulation_data: Dict[str, List]):\n",
    "    \"\"\"Visualize ecosystem performance and emergent behaviors\"\"\"\n",
    "    \n",
    "    fig, ((ax1, ax2), (ax3, ax4)) = plt.subplots(2, 2, figsize=(16, 12))\n",
    "    \n",
    "    # Plot 1: Market price evolution\n",
    "    ax1.set_title('Market Price Evolution', fontsize=14, fontweight='bold')\n",
    "    \n",
    "    time_minutes = [(t - simulation_data['timestamps'][0]) / 60 for t in simulation_data['timestamps']]\n",
    "    prices = [conditions['price'] for conditions in simulation_data['market_conditions']]\n",
    "    \n",
    "    ax1.plot(time_minutes, prices, 'b-', linewidth=2)\n",
    "    ax1.set_xlabel('Time (minutes)')\n",
    "    ax1.set_ylabel('Price ($)')\n",
    "    ax1.grid(True, alpha=0.3)\n",
    "    \n",
    "    # Add demand and supply zones\n",
    "    demands = [conditions['demand'] for conditions in simulation_data['market_conditions']]\n",
    "    supplies = [conditions['supply'] for conditions in simulation_data['market_conditions']]\n",
    "    \n",
    "    ax1.fill_between(time_minutes, 0, demands, alpha=0.3, color='red', label='Demand')\n",
    "    ax1.fill_between(time_minutes, 0, supplies, alpha=0.3, color='green', label='Supply')\n",
    "    ax1.legend()\n",
    "    \n",
    "    # Plot 2: Agent decision patterns\n",
    "    ax2.set_title('Agent Decision Patterns', fontsize=14, fontweight='bold')\n",
    "    \n",
    "    # Count decisions by type\n",
    "    accept_decisions = []\n",
    "    wait_decisions = []\n",
    "    \n",
    "    for decisions in simulation_data['agent_decisions']:\n",
    "        accept_count = len([d for d in decisions if d['decision'] == 'accept'])\n",
    "        wait_count = len([d for d in decisions if d['decision'] == 'wait'])\n",
    "        accept_decisions.append(accept_count)\n",
    "        wait_decisions.append(wait_count)\n",
    "    \n",
    "    ax2.plot(time_minutes, accept_decisions, 'g-', linewidth=2, label='Accept')\n",
    "    ax2.plot(time_minutes, wait_decisions, 'r-', linewidth=2, label='Wait')\n",
    "    ax2.set_xlabel('Time (minutes)')\n",
    "    ax2.set_ylabel('Number of Decisions')\n",
    "    ax2.legend()\n",
    "    ax2.grid(True, alpha=0.3)\n",
    "    \n",
    "    # Plot 3: Ecosystem health metrics\n",
    "    ax3.set_title('Ecosystem Health Evolution', fontsize=14, fontweight='bold')\n",
    "    \n",
    "    health_scores = [metrics.get('ecosystem_health', 0) for metrics in simulation_data['ecosystem_metrics']]\n",
    "    market_efficiency = [metrics.get('market_efficiency', 0) for metrics in simulation_data['ecosystem_metrics']]\n",
    "    contract_efficiency = [metrics.get('contract_efficiency', 0) for metrics in simulation_data['ecosystem_metrics']]\n",
    "    \n",
    "    ax3.plot(time_minutes, health_scores, 'b-', linewidth=2, label='Ecosystem Health')\n",
    "    ax3.plot(time_minutes, market_efficiency, 'orange', linewidth=2, label='Market Efficiency')\n",
    "    ax3.plot(time_minutes, contract_efficiency, 'green', linewidth=2, label='Contract Efficiency')\n",
    "    ax3.set_xlabel('Time (minutes)')\n",
    "    ax3.set_ylabel('Score (0-1)')\n",
    "    ax3.set_ylim(0, 1)\n",
    "    ax3.legend()\n",
    "    ax3.grid(True, alpha=0.3)\n",
    "    \n",
    "    # Plot 4: Emergent behavior frequency\n",
    "    ax4.set_title('Emergent Behavior Analysis', fontsize=14, fontweight='bold')\n",
    "    \n",
    "    # Count emergent behaviors by type\n",
    "    behavior_counts = defaultdict(int)\n",
    "    for behaviors in simulation_data['emergent_behaviors']:\n",
    "        for behavior in behaviors:\n",
    "            behavior_counts[behavior['type']] += 1\n",
    "    \n",
    "    if behavior_counts:\n",
    "        behaviors = list(behavior_counts.keys())\n",
    "        counts = list(behavior_counts.values())\n",
    "        \n",
    "        bars = ax4.bar(behaviors, counts, alpha=0.7, color='lightblue')\n",
    "        ax4.set_xlabel('Behavior Type')\n",
    "        ax4.set_ylabel('Frequency')\n",
    "        ax4.set_xticklabels([b.replace('_', ' ').title() for b in behaviors], rotation=45)\n",
    "        ax4.grid(True, alpha=0.3)\n",
    "        \n",
    "        # Add value labels\n",
    "        for bar, count in zip(bars, counts):\n",
    "            height = bar.get_height()\n",
    "            ax4.text(bar.get_x() + bar.get_width()/2., height + max(counts) * 0.01,\n",
    "                    str(count), ha='center', va='bottom', fontsize=10)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "    \n",
    "    # Additional analysis\n",
    "    print(\"\\nEcosystem Performance Analysis:\")\n",
    "    print(\"=\" * 40)\n",
    "    \n",
    "    # Calculate overall performance\n",
    "    final_health = ecosystem.ecosystem_metrics.get('ecosystem_health', 0)\n",
    "    avg_price = np.mean(prices)\n",
    "    price_volatility = np.std(prices)\n",
    "    \n",
    "    print(f\"Overall Performance:\")\n",
    "    print(f\"  Ecosystem Health: {final_health:.3f}\")\n",
    "    print(f\"  Average Market Price: ${avg_price:.2f}\")\n",
    "    print(f\"  Price Volatility: {price_volatility:.2f}\")\n",
    "    \n",
    "    # Agent performance analysis\n",
    "    agent_strategies = defaultdict(int)\n",
    "    total_utility = 0\n",
    "    \n",
    "    for agent in ecosystem.agents:\n",
    "        agent_strategies[agent.strategy] += 1\n",
    "        total_utility += agent.utility\n",
    "    \n",
    "    print(f\"\\nAgent Performance Analysis:\")\n",
    "    print(f\"  Total Agents: {len(ecosystem.agents)}\")\n",
    "    print(f\"  Average Utility: {total_utility / len(ecosystem.agents):.2f}\")\n",
    "    \n",
    "    print(f\"\\nStrategy Distribution:\")\n",
    "    for strategy, count in agent_strategies.items():\n",
    "        percentage = count / len(ecosystem.agents) * 100\n",
    "        print(f\"  {strategy.replace('_', ' ').title()}: {count} ({percentage:.1f}%)\")\n",
    "    \n",
    "    # Market analysis\n",
    "    final_market = ecosystem.market.get_market_conditions()\n",
    "    print(f\"\\nMarket Analysis:\")\n",
    "    print(f\"  Final Price: ${final_market['price']:.2f}\")\n",
    "    print(f\"  Final Demand: {final_market['demand']:.1f}\")\n",
    "    print(f\"  Final Supply: {final_market['supply']:.1f}\")\n",
    "    print(f\"  Market Volatility: {final_market['volatility']:.2f}\")\n",
    "    \n",
    "    # Contract analysis\n",
    "    if ecosystem.contract_net.negotiation_history:\n",
    "        total_contracts = len(ecosystem.contract_net.negotiation_history)\n",
    "        successful_contracts = len([c for c in ecosystem.contract_net.negotiation_history if c.get('winner')])\n",
    "        success_rate = successful_contracts / total_contracts * 100\n",
    "        \n",
    "        avg_bids = np.mean([c['num_bids'] for c in ecosystem.contract_net.negotiation_history])\n",
    "        \n",
    "        print(f\"\\nContract Analysis:\")\n",
    "        print(f\"  Total Contracts: {total_contracts}\")\n",
    "        print(f\"  Successful Contracts: {successful_contracts}\")\n",
    "        print(f\"  Success Rate: {success_rate:.1f}%\")\n",
    "        print(f\"  Average Bids per Contract: {avg_bids:.1f}\")\n",
    "    \n",
    "    # Emergent behavior analysis\n",
    "    total_behaviors = sum(len(b) for b in simulation_data['emergent_behaviors'])\n",
    "    print(f\"\\nEmergent Behavior Analysis:\")\n",
    "    print(f\"  Total Behaviors Detected: {total_behaviors}\")\n",
    "    \n",
    "    if behavior_counts:\n",
    "        print(f\"  Behavior Types: {len(behavior_counts)}\")\n",
    "        for behavior_type, count in behavior_counts.items():\n",
    "            print(f\"    {behavior_type.replace('_', ' ').title()}: {count}\")\n",
    "    \n",
    "    # Assessment\n",
    "    print(f\"\\nOverall Assessment:\")\n",
    "    if final_health > 0.8:\n",
    "        print(f\"Status: EXCELLENT - Ecosystem operating at peak performance\")\n",
    "    elif final_health > 0.7:\n",
    "        print(f\"Status: GOOD - Ecosystem performing well with minor issues\")\n",
