    "print(f\"  Active Contracts: {overview['active_contracts']}\")\n",
    "print(f\"  Market Price: ${overview['market_price']:.2f}\")\n",
    "print(f\"  Ecosystem Health: {overview['ecosystem_health']:.3f}\")\n",
    "\n",
    "agent_analysis = final_report['agent_analysis']\n",
    "print(f\"\\nAgent Analysis:\")\n",
