    "class AgentType(Enum):\n",
    "    \"\"\"Types of autonomous agents in the ecosystem\"\"\"\n",
    "    PRODUCER = \"producer\"\n",
    "    TRANSPORTER = \"transporter\"\n",
    "    RETAILER = \"retailer\"\n",
    "    RECYCLER = \"recycler\"\n",
    "    COORDINATOR = \"coordinator\"\n",
    "\n",
    "@dataclass\n",
    "class AgentCapability:\n",
    "    \"\"\"Agent capability definition\"\"\"\n",
    "    capability_id: str\n",
    "    capability_type: str  # 'production', 'transport', 'storage', 'recycling'\n",
    "    capacity: float\n",
    "    cost_per_unit: float\n",
    "    quality_level: float\n",
    "    availability: float = 1.0  # 0.0 to 1.0\n",
    "\n",
    "@dataclass\n",
    "class AutonomousAgent:\n",
    "    \"\"\"Autonomous agent in the ecosystem\"\"\"\n",
    "    agent_id: str\n",
    "    agent_type: AgentType\n",
    "    location: Tuple[float, float]\n",
    "    capabilities: List[AgentCapability] = field(default_factory=list)\n",
    "    resources: float = 1000.0\n",
    "    utility: float = 0.0\n",
    "    strategy: str = \"profit_maximization\"  # 'profit_maximization', 'market_share', 'sustainability'\n",
    "    learning_rate: float = 0.1\n",
    "    decision_history: List[Dict[str, Any]] = field(default_factory=list)\n",
    "    \n",
    "    def add_capability(self, capability: AgentCapability):\n",
    "        \"\"\"Add a capability to the agent\"\"\"\n",
    "        self.capabilities.append(capability)\n",
    "    \n",
    "    def calculate_utility(self, market_conditions: Dict[str, float]) -> float:\n",
    "        \"\"\"Calculate agent utility based on current conditions\"\"\"\n",
    "        \n",
    "        base_utility = self.resources\n",
    "        \n",
    "        # Adjust based on strategy\n",
    "        if self.strategy == \"profit_maximization\":\n",
    "            profit_potential = sum(cap.capacity * (10 - cap.cost_per_unit) for cap in self.capabilities)\n",
    "            utility = base_utility + profit_potential * 0.5\n",
    "        elif self.strategy == \"market_share\":\n",
    "            market_share_bonus = len(self.capabilities) * 100\n",
    "            utility = base_utility + market_share_bonus\n",
    "        elif self.strategy == \"sustainability\":\n",
    "            sustainability_score = sum(cap.quality_level * cap.capacity for cap in self.capabilities)\n",
    "            utility = base_utility + sustainability_score * 0.3\n",
    "        else:\n",
    "            utility = base_utility\n",
    "        \n",
    "        # Adjust for market conditions\n",
    "        market_demand = market_conditions.get('demand', 1.0)\n",
    "        market_price = market_conditions.get('price', 10.0)\n",
    "        \n",
    "        utility *= market_demand\n",
    "        utility += market_price * len(self.capabilities) * 10\n",
    "        \n",
    "        return utility\n",
    "    \n",
    "    def make_decision(self, opportunities: List[Dict[str, Any]]) -> Dict[str, Any]:\n",
    "        \"\"\"Make autonomous decision based on opportunities\"\"\"\n",
    "        \n",
    "        if not opportunities:\n",
    "            return {\n",
    "                'agent_id': self.agent_id,\n",
    "                'decision': 'wait',\n",
    "                'confidence': 0.5,\n",
    "                'expected_utility': self.utility\n",
    "            }\n",
    "        \n",
    "        best_opportunity = None\n",
    "        best_utility = -float('inf')\n",
    "        \n",
    "        for opportunity in opportunities:\n",
    "            # Calculate expected utility for this opportunity\n",
    "            if opportunity['type'] == 'production':\n",
    "                production_cap = next((cap for cap in self.capabilities if cap.capability_type == 'production'), None)\n",
    "                if production_cap:\n",
    "                    expected_revenue = opportunity['quantity'] * opportunity['price']\n",
    "                    expected_cost = opportunity['quantity'] * production_cap.cost_per_unit\n",
    "                    expected_utility = expected_revenue - expected_cost\n",
    "                else:\n",
    "                    expected_utility = 0\n",
    "            elif opportunity['type'] == 'transport':\n",
    "                transport_cap = next((cap for cap in self.capabilities if cap.capability_type == 'transport'), None)\n",
    "                if transport_cap:\n",
    "                    expected_revenue = opportunity['quantity'] * opportunity['price']\n",
    "                    expected_cost = opportunity['distance'] * transport_cap.cost_per_unit\n",
    "                    expected_utility = expected_revenue - expected_cost\n",
    "                else:\n",
    "                    expected_utility = 0\n",
    "            elif opportunity['type'] == 'recycling':\n",
    "                recycling_cap = next((cap for cap in self.capabilities if cap.capability_type == 'recycling'), None)\n",
    "                if recycling_cap:\n",
    "                    expected_revenue = opportunity['quantity'] * opportunity['price']\n",
    "                    expected_cost = opportunity['quantity'] * recycling_cap.cost_per_unit\n",
    "                    sustainability_bonus = opportunity['quantity'] * 2  # Sustainability bonus\n",
    "                    expected_utility = expected_revenue - expected_cost + sustainability_bonus\n",
    "                else:\n",
    "                    expected_utility = 0\n",
    "            else:\n",
    "                expected_utility = 0\n",
    "            \n",
    "            if expected_utility > best_utility:\n",
    "                best_utility = expected_utility\n",
    "                best_opportunity = opportunity\n",
    "        \n",
    "        if best_opportunity and best_utility > 0:\n",
    "            decision = {\n",
    "                'agent_id': self.agent_id,\n",
    "                'decision': 'accept',\n",
    "                'opportunity': best_opportunity,\n",
    "                'confidence': min(1.0, best_utility / 1000),\n",
    "                'expected_utility': best_utility\n",
    "            }\n",
    "        else:\n",
    "            decision = {\n",
    "                'agent_id': self.agent_id,\n",
    "                'decision': 'wait',\n",
    "                'confidence': 0.5,\n",
    "                'expected_utility': self.utility\n",
    "            }\n",
    "        \n",
    "        self.decision_history.append(decision)\n",
    "        return decision\n",
    "    \n",
    "    def learn_from_outcome(self, actual_utility: float):\n",
    "        \"\"\"Learn from actual outcome and update strategy\"\"\"\n",
    "        \n",
    "        if self.decision_history:\n",
    "            last_decision = self.decision_history[-1]\n",
    "            expected_utility = last_decision.get('expected_utility', self.utility)\n",
    "            \n",
    "            # Calculate prediction error\n",
    "            error = actual_utility - expected_utility\n",
    "            \n",
    "            # Update utility estimate\n",
    "            self.utility = (1 - self.learning_rate) * self.utility + self.learning_rate * actual_utility\n",
    "            \n",
    "            # Adjust strategy based on performance\n",
    "            if error > 100:  # Better than expected\n",
    "                # Reinforce current strategy\n",
    "                pass\n",
    "            elif error < -100:  # Worse than expected\n",
    "                # Consider strategy change\n",
    "                strategies = ['profit_maximization', 'market_share', 'sustainability']\n",
    "                if random.random() < 0.1:  # 10% chance to change strategy\n",
    "                    self.strategy = random.choice([s for s in strategies if s != self.strategy])\n",
    "\n",
    "@dataclass\n",
    "class MarketMechanism:\n",
    "    \"\"\"Market mechanism for resource allocation\"\"\"\n",
    "    market_id: str\n",
    "    current_price: float = 10.0\n",
    "    demand: float = 100.0\n",
    "    supply: float = 100.0\n",
    "    price_history: List[float] = field(default_factory=list)\n",
    "    transaction_history: List[Dict[str, Any]] = field(default_factory=list)\n",
    "    \n",
    "    def update_market_conditions(self, transactions: List[Dict[str, Any]]):\n",
    "        \"\"\"Update market conditions based on transactions\"\"\"\n",
    "        \n",
    "        self.transaction_history.extend(transactions)\n",
    "        \n",
    "        # Calculate new demand and supply\n",
    "        total_demand = sum(t.get('quantity', 0) for t in transactions if t.get('type') == 'bid')\n",
    "        total_supply = sum(t.get('quantity', 0) for t in transactions if t.get('type') == 'ask')\n",
    "        \n",
    "        self.demand = total_demand if total_demand > 0 else self.demand * 0.9  # Decay if no demand\n",
    "        self.supply = total_supply if total_supply > 0 else self.supply * 0.9  # Decay if no supply\n",
    "        \n",
    "        # Update price based on supply-demand balance\n",
    "        if self.supply > 0:\n",
    "            price_pressure = self.demand / self.supply\n",
    "            price_change = (price_pressure - 1.0) * 0.1  # 10% of price pressure\n",
    "            self.current_price *= (1 + price_change)\n",
    "            self.current_price = max(1.0, min(100.0, self.current_price))  # Price bounds\n",
    "        \n",
    "        self.price_history.append(self.current_price)\n",
    "        \n",
    "        # Keep only recent history\n",
    "        if len(self.price_history) > 100:\n",
    "            self.price_history = self.price_history[-100:]\n",
    "    \n",
    "    def get_market_conditions(self) -> Dict[str, float]:\n",
    "        \"\"\"Get current market conditions\"\"\"\n",
    "        return {\n",
    "            'price': self.current_price,\n",
    "            'demand': self.demand,\n",
    "            'supply': self.supply,\n",
    "            'volatility': np.std(self.price_history) if len(self.price_history) > 1 else 0.0\n",
    "        }\n",
    "\n",
    "@dataclass\n",
    "class ContractNetProtocol:\n",
    "    \"\"\"Contract Net Protocol for agent negotiations\"\"\"\n",
    "    protocol_id: str\n",
    "    active_contracts: List[Dict[str, Any]] = field(default_factory=list)\n",
    "    negotiation_history: List[Dict[str, Any]] = field(default_factory=list)\n",
    "    \n",
    "    def initiate_contract(self, initiator_id: str, task: Dict[str, Any], \n",
    "                         potential_contractors: List[str]) -> Dict[str, Any]:\n",
    "        \"\"\"Initiate a contract negotiation\"\"\"\n",
    "        \n",
    "        contract = {\n",
    "            'contract_id': f\"contract_{len(self.active_contracts)}\",\n",
    "            'initiator_id': initiator_id,\n",
    "            'task': task,\n",
    "            'potential_contractors': potential_contractors,\n",
    "            'status': 'announced',\n",
    "            'bids': [],\n",
    "            'winner': None,\n",
    "            'timestamp': time.time()\n",
    "        }\n",
    "        \n",
    "        self.active_contracts.append(contract)\n",
    "        return contract\n",
    "    \n",
    "    def submit_bid(self, contract_id: str, contractor_id: str, bid: Dict[str, Any]):\n",
    "        \"\"\"Submit a bid for a contract\"\"\"\n",
    "        \n",
    "        contract = next((c for c in self.active_contracts if c['contract_id'] == contract_id), None)\n",
    "        if contract and contract['status'] == 'announced':\n",
    "            bid_data = {\n",
    "                'contractor_id': contractor_id,\n",
    "                'bid': bid,\n",
    "                'timestamp': time.time()\n",
    "            }\n",
    "            contract['bids'].append(bid_data)\n",
    "    \n",
    "    def evaluate_bids(self, contract_id: str, evaluation_criteria: str = 'lowest_cost') -> Optional[str]:\n",
    "        \"\"\"Evaluate bids and select winner\"\"\"\n",
    "        \n",
    "        contract = next((c for c in self.active_contracts if c['contract_id'] == contract_id), None)\n",
    "        if not contract or not contract['bids']:\n",
    "            return None\n",
    "        \n",
    "        if evaluation_criteria == 'lowest_cost':\n",
    "            best_bid = min(contract['bids'], key=lambda b: b['bid'].get('cost', float('inf')))\n",
    "        elif evaluation_criteria == 'highest_quality':\n",
    "            best_bid = max(contract['bids'], key=lambda b: b['bid'].get('quality', 0))\n",
    "        elif evaluation_criteria == 'fastest_delivery':\n",
    "            best_bid = min(contract['bids'], key=lambda b: b['bid'].get('delivery_time', float('inf')))\n",
    "        else:\n",
    "            best_bid = contract['bids'][0]  # Default to first bid\n",
    "        \n",
    "        contract['winner'] = best_bid['contractor_id']\n",
    "        contract['status'] = 'awarded'\n",
    "        \n",
    "        # Record negotiation\n",
    "        negotiation_record = {\n",
    "            'contract_id': contract_id,\n",
    "            'num_bids': len(contract['bids']),\n",
    "            'winner': best_bid['contractor_id'],\n",
    "            'winning_bid': best_bid['bid'],\n",
    "            'timestamp': time.time()\n",
    "        }\n",
    "        self.negotiation_history.append(negotiation_record)\n",
    "        \n",
    "        return best_bid['contractor_id']\n",
    "    \n",
    "    def complete_contract(self, contract_id: str):\n",
    "        \"\"\"Complete a contract\"\"\"\n",
    "        \n",
    "        contract = next((c for c in self.active_contracts if c['contract_id'] == contract_id), None)\n",
    "        if contract:\n",
    "            contract['status'] = 'completed'\n",
    "            contract['completion_time'] = time.time()\n",
    "\n",
    "@dataclass\n",
    "class AutonomousEcosystem:\n",
    "    \"\"\"Autonomous self-optimizing ecosystem\"\"\"\n",
    "    ecosystem_id: str\n",
    "    agents: List[AutonomousAgent] = field(default_factory=list)\n",
    "    market: MarketMechanism = field(default_factory=MarketMechanism)\n",
    "    contract_net: ContractNetProtocol = field(default_factory=ContractNetProtocol)\n",
    "    ecosystem_metrics: Dict[str, float] = field(default_factory=dict)\n",
    "    emergent_behaviors: List[Dict[str, Any]] = field(default_factory=list)\n",
    "    \n",
    "    def add_agent(self, agent: AutonomousAgent):\n",
    "        \"\"\"Add an agent to the ecosystem\"\"\"\n",
    "        self.agents.append(agent)\n",
    "    \n",
    "    def generate_opportunities(self) -> List[Dict[str, Any]]:\n",
    "        \"\"\"Generate opportunities for agents\"\"\"\n",
    "        \n",
    "        opportunities = []\n",
    "        market_conditions = self.market.get_market_conditions()\n",
    "        \n",
    "        # Generate production opportunities\n",
    "        for _ in range(np.random.randint(1, 4)):\n",
    "            opportunities.append({\n",
    "                'type': 'production',\n",
    "                'quantity': np.random.uniform(50, 200),\n",
    "                'price': market_conditions['price'] * np.random.uniform(0.8, 1.2),\n",
    "                'quality_requirement': np.random.uniform(0.7, 1.0)\n",
    "            })\n",
    "        \n",
    "        # Generate transport opportunities\n",
    "        for _ in range(np.random.randint(1, 3)):\n",
    "            opportunities.append({\n",
    "                'type': 'transport',\n",
    "                'quantity': np.random.uniform(100, 500),\n",
    "                'price': market_conditions['price'] * np.random.uniform(0.5, 1.5),\n",
    "                'distance': np.random.uniform(10, 100),\n",
    "                'urgency': np.random.uniform(0.5, 1.0)\n",
    "            })\n",
    "        \n",
    "        # Generate recycling opportunities\n",
    "        for _ in range(np.random.randint(1, 2)):\n",
    "            opportunities.append({\n",
    "                'type': 'recycling',\n",
    "                'quantity': np.random.uniform(25, 150),\n",
    "                'price': market_conditions['price'] * np.random.uniform(0.6, 1.1),\n",
    "                'material_type': np.random.choice(['plastic', 'metal', 'paper', 'electronics']),\n",
    "                'recycling_value': np.random.uniform(0.3, 0.8)\n",
    "            })\n",
    "        \n",
    "        return opportunities\n",
    "    \n",
    "    def run_agent_decisions(self) -> List[Dict[str, Any]]:\n",
    "        \"\"\"Run autonomous decision making for all agents\"\"\"\n",
    "        \n",
    "        decisions = []\n",
    "        opportunities = self.generate_opportunities()\n",
    "        market_conditions = self.market.get_market_conditions()\n",
    "        \n",
    "        for agent in self.agents:\n",
    "            # Calculate utility for current conditions\n",
    "            agent.utility = agent.calculate_utility(market_conditions)\n",
    "            \n",
    "            # Make decision\n",
    "            decision = agent.make_decision(opportunities)\n",
    "            decisions.append(decision)\n",
    "            \n",
    "            # If agent accepts opportunity, create transaction\n",
    "            if decision['decision'] == 'accept':\n",
    "                opportunity = decision['opportunity']\n",
    "                transaction = {\n",
    "                    'agent_id': agent.agent_id,\n",
    "                    'type': 'ask' if opportunity['type'] in ['production', 'recycling'] else 'bid',\n",
    "                    'quantity': opportunity['quantity'],\n",
    "                    'price': opportunity['price'],\n",
    "                    'timestamp': time.time()\n",
    "                }\n",
    "                \n",
    "                # Simulate outcome and learning\n",
    "                actual_utility = decision['expected_utility'] * np.random.uniform(0.8, 1.2)\n",
    "                agent.learn_from_outcome(actual_utility)\n",
    "        \n",
    "        return decisions\n",
    "    \n",
    "    def run_market_mechanism(self, decisions: List[Dict[str, Any]]):\n",
    "        \"\"\"Run market mechanism for resource allocation\"\"\"\n",
    "        \n",
    "        transactions = []\n",
    "        \n",
    "        for decision in decisions:\n",
    "            if decision['decision'] == 'accept':\n",
    "                opportunity = decision['opportunity']\n",
    "                transaction = {\n",
    "                    'agent_id': decision['agent_id'],\n",
    "                    'type': 'ask' if opportunity['type'] in ['production', 'recycling'] else 'bid',\n",
    "                    'quantity': opportunity['quantity'],\n",
    "                    'price': opportunity['price'],\n",
    "                    'timestamp': time.time()\n",
    "                }\n",
    "                transactions.append(transaction)\n",
    "        \n",
    "        self.market.update_market_conditions(transactions)\n",
    "    \n",
    "    def run_contract_negotiations(self) -> List[Dict[str, Any]]:\n",
    "        \"\"\"Run contract negotiations using Contract Net Protocol\"\"\"\n",
    "        \n",
    "        negotiations = []\n",
    "        \n",
    "        # Initiate some contracts\n",
    "        for _ in range(np.random.randint(1, 3)):\n",
    "            initiator = np.random.choice(self.agents)\n",
    "            task = {\n",
    "                'type': np.random.choice(['production', 'transport', 'recycling']),\n",
    "                'quantity': np.random.uniform(50, 200),\n",
    "                'requirements': np.random.uniform(0.7, 1.0)\n",
    "            }\n",
    "            \n",
    "            potential_contractors = [a.agent_id for a in self.agents if a.agent_id != initiator.agent_id]\n",
    "            potential_contractors = np.random.choice(potential_contractors, \n",
    "                                                 min(5, len(potential_contractors)), \n",
    "                                                 replace=False).tolist()\n",
    "            \n",
    "            contract = self.contract_net.initiate_contract(initiator.agent_id, task, potential_contractors)\n",
    "            negotiations.append(contract)\n",
    "            \n",
    "            # Simulate bidding\n",
    "            for contractor_id in potential_contractors:\n",
    "                contractor = next((a for a in self.agents if a.agent_id == contractor_id), None)\n",
    "                if contractor:\n",
    "                    bid = {\n",
    "                        'cost': np.random.uniform(100, 1000),\n",
    "                        'quality': np.random.uniform(0.7, 1.0),\n",
    "                        'delivery_time': np.random.uniform(1, 10)\n",
    "                    }\n",
    "                    self.contract_net.submit_bid(contract['contract_id'], contractor_id, bid)\n",
    "            \n",
    "            # Evaluate bids\n",
    "            winner = self.contract_net.evaluate_bids(contract['contract_id'])\n",
    "            if winner:\n",
    "                negotiations[-1]['winner'] = winner\n",
    "        \n",
    "        return negotiations\n",
    "    \n",
    "    def detect_emergent_behaviors(self) -> List[Dict[str, Any]]:\n",
    "        \"\"\"Detect emergent behaviors in the ecosystem\"\"\"\n",
    "        \n",
    "        behaviors = []\n",
    "        \n",
    "        # Analyze agent strategies\n",
    "        strategy_counts = defaultdict(int)\n",
    "        for agent in self.agents:\n",
    "            strategy_counts[agent.strategy] += 1\n",
    "        \n",
    "        # Detect strategy clustering\n",
    "        if len(strategy_counts) > 1:\n",
    "            dominant_strategy = max(strategy_counts, key=strategy_counts.get)\n",
    "            if strategy_counts[dominant_strategy] > len(self.agents) * 0.6:\n",
    "                behaviors.append({\n",
    "                    'type': 'strategy_clustering',\n",
    "                    'description': f\"Majority of agents adopting {dominant_strategy} strategy\",\n",
    "                    'strength': strategy_counts[dominant_strategy] / len(self.agents),\n",
    "                    'timestamp': time.time()\n",
    "                })\n",
    "        \n",
    "        # Analyze market volatility\n",
    "        if len(self.market.price_history) > 10:\n",
    "            volatility = np.std(self.market.price_history[-10:])\n",
    "            if volatility > 5.0:\n",
    "                behaviors.append({\n",
    "                    'type': 'market_volatility',\n",
    "                    'description': \"High market volatility detected\",\n",
    "                    'strength': volatility / 10.0,\n",
    "                    'timestamp': time.time()\n",
    "                })\n",
    "        \n",
    "        # Analyze contract success rate\n",
    "        if len(self.contract_net.negotiation_history) > 5:\n",
    "            recent_contracts = self.contract_net.negotiation_history[-5:]\n",
    "            avg_bids = np.mean([c['num_bids'] for c in recent_contracts])\n",
    "            if avg_bids > 3:\n",
    "                behaviors.append({\n",
    "                    'type': 'competitive_market',\n",
    "                    'description': \"High competition in contract negotiations\",\n",
    "                    'strength': avg_bids / 5.0,\n",
    "                    'timestamp': time.time()\n",
    "                })\n",
    "        \n",
    "        self.emergent_behaviors.extend(behaviors)\n",
    "        return behaviors\n",
    "    \n",
    "    def update_ecosystem_metrics(self):\n",
    "        \"\"\"Update ecosystem performance metrics\"\"\"\n",
    "        \n",
    "        # Calculate agent diversity\n",
    "        agent_types = defaultdict(int)\n",
    "        for agent in self.agents:\n",
    "            agent_types[agent.agent_type.value] += 1\n",
    "        \n",
    "        # Calculate market efficiency\n",
    "        if len(self.market.price_history) > 1:\n",
    "            price_stability = 1.0 / (1.0 + np.std(self.market.price_history))\n",
    "        else:\n",
    "            price_stability = 1.0\n",
    "        \n",
    "        # Calculate contract efficiency\n",
    "        if self.contract_net.negotiation_history:\n",
    "            avg_bids_per_contract = np.mean([c['num_bids'] for c in self.contract_net.negotiation_history])\n",
    "            contract_efficiency = min(1.0, avg_bids_per_contract / 5.0)\n",
    "        else:\n",
    "            contract_efficiency = 0.0\n",
    "        \n",
    "        # Calculate overall ecosystem health\n",
    "        avg_agent_utility = np.mean([agent.utility for agent in self.agents]) if self.agents else 0.0\n",
    "        \n",
    "        self.ecosystem_metrics = {\n",
    "            'total_agents': len(self.agents),\n",
    "            'agent_diversity': len(agent_types) / len(AgentType),\n",
    "            'market_efficiency': price_stability,\n",
    "            'contract_efficiency': contract_efficiency,\n",
    "            'avg_agent_utility': avg_agent_utility,\n",
    "            'emergent_behaviors_count': len(self.emergent_behaviors),\n",
    "            'ecosystem_health': (price_stability + contract_efficiency + avg_agent_utility / 1000) / 3.0\n",
    "        }\n",
    "    \n",
    "    def generate_ecosystem_report(self) -> Dict[str, Any]:\n",
    "        \"\"\"Generate comprehensive ecosystem report\"\"\"\n",
    "        \n",
    "        report = {\n",
    "            'report_timestamp': time.time(),\n",
    "            'ecosystem_id': self.ecosystem_id,\n",
    "            'system_overview': {\n",
    "                'total_agents': len(self.agents),\n",
    "                'active_contracts': len([c for c in self.contract_net.active_contracts if c['status'] == 'awarded']),\n",
    "                'market_price': self.market.current_price,\n",
    "                'ecosystem_health': self.ecosystem_metrics.get('ecosystem_health', 0.0)\n",
    "            },\n",
    "            'agent_analysis': {},\n",
    "            'market_analysis': {},\n",
    "            'contract_analysis': {},\n",
    "            'emergent_behaviors': self.emergent_behaviors[-5:],  # Last 5 behaviors\n",
    "            'ecosystem_metrics': self.ecosystem_metrics,\n",
    "            'recommendations': []\n",
    "        }\n",
    "        \n",
    "        # Agent analysis\n",
    "        agent_types = defaultdict(int)\n",
    "        agent_strategies = defaultdict(int)\n",
    "        total_utility = 0\n",
    "        \n",
    "        for agent in self.agents:\n",
    "            agent_types[agent.agent_type.value] += 1\n",
    "            agent_strategies[agent.strategy] += 1\n",
    "            total_utility += agent.utility\n",
    "        \n",
    "        report['agent_analysis'] = {\n",
    "            'agent_types': dict(agent_types),\n",
    "            'agent_strategies': dict(agent_strategies),\n",
    "            'average_utility': total_utility / len(self.agents) if self.agents else 0,\n",
    "            'total_resources': sum(agent.resources for agent in self.agents)\n",
    "        }\n",
    "        \n",
    "        # Market analysis\n",
    "        report['market_analysis'] = {\n",
    "            'current_price': self.market.current_price,\n",
    "            'demand': self.market.demand,\n",
    "            'supply': self.market.supply,\n",
    "            'price_volatility': np.std(self.market.price_history) if len(self.market.price_history) > 1 else 0,\n",
    "            'total_transactions': len(self.market.transaction_history)\n",
    "        }\n",
    "        \n",
    "        # Contract analysis\n",
    "        if self.contract_net.negotiation_history:\n",
    "            avg_bids = np.mean([c['num_bids'] for c in self.contract_net.negotiation_history])\n",
    "            success_rate = len([c for c in self.contract_net.negotiation_history if c.get('winner')]) / len(self.contract_net.negotiation_history)\n",
    "        else:\n",
    "            avg_bids = 0\n",
    "            success_rate = 0\n",
    "        \n",
    "        report['contract_analysis'] = {\n",
    "            'total_contracts': len(self.contract_net.negotiation_history),\n",
    "            'average_bids_per_contract': avg_bids,\n",
    "            'success_rate': success_rate,\n",
    "            'active_contracts': len([c for c in self.contract_net.active_contracts if c['status'] == 'awarded'])\n",
    "        }\n",
    "        \n",
    "        # Generate recommendations\n",
    "        if self.ecosystem_metrics.get('ecosystem_health', 0) < 0.7:\n",
    "            report['recommendations'].append('Improve ecosystem health through better agent coordination')\n",
    "        \n",
    "        if report['market_analysis']['price_volatility'] > 10:\n",
    "            report['recommendations'].append('Implement market stabilization mechanisms')\n",
    "        \n",
    "        if report['contract_analysis']['success_rate'] < 0.6:\n",
    "            report['recommendations'].append('Improve contract negotiation processes')\n",
    "        \n",
    "        if len(agent_types) < 3:\n",
    "            report['recommendations'].append('Increase agent diversity for better ecosystem resilience')\n",
    "        \n",
    "        return report"
   ]
