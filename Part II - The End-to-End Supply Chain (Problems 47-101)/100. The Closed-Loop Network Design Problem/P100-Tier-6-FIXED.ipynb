    "        print(f\"Status: ACCEPTABLE - Ecosystem functional but needs optimization\")\n",
    "    else:\n",
    "        print(f\"Status: NEEDS IMPROVEMENT - Ecosystem requires significant optimization\")\n",
    "    \n",
    "    # Learning and adaptation\n",
    "    learning_agents = len([a for a in ecosystem.agents if len(a.decision_history) > 0])\n",
    "    print(f\"\\nLearning and Adaptation:\")\n",
    "    print(f\"  Learning Agents: {learning_agents}/{len(ecosystem.agents)} ({learning_agents/len(ecosystem.agents)*100:.1f}%)\")\n",
    "    print(f\"  Average Decisions per Agent: {sum(len(a.decision_history) for a in ecosystem.agents) / len(ecosystem.agents):.1f}\")\n",
    "    \n",
    "    return simulation_data\n",
    "\n",
    "# Visualize ecosystem performance\n",
    "visualize_ecosystem_performance(ecosystem, simulation_data)"
