    "\n",
    "print(f\"\\nAgent Strategies:\")\n",
    "for strategy, count in agent_analysis['agent_strategies'].items():\n",
    "    print(f\"  {strategy.replace('_', ' ').title()}: {count}\")\n",
    "\n",
    "market_analysis = final_report['market_analysis']\n",
    "print(f\"\\nMarket Analysis:\")\n",
    "print(f\"  Current Price: ${market_analysis['current_price']:.2f}\")\n",
    "print(f\"  Demand: {market_analysis['demand']:.1f}\")\n",
    "print(f\"  Supply: {market_analysis['supply']:.1f}\")\n",
    "print(f\"  Price Volatility: {market_analysis['price_volatility']:.2f}\")\n",
    "print(f\"  Total Transactions: {market_analysis['total_transactions']}\")\n",
    "\n",
    "contract_analysis = final_report['contract_analysis']\n",
    "print(f\"\\nContract Analysis:\")\n",
    "print(f\"  Total Contracts: {contract_analysis['total_contracts']}\")\n",
    "print(f\"  Average Bids per Contract: {contract_analysis['average_bids_per_contract']:.1f}\")\n",
