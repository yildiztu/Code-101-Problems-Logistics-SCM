    "class QuantumVRPTWOptimizer:\n",
    "    \"\"\"Quantum optimizer for VRPTW using QAOA\"\"\"\n",
    "    \n",
    "    def __init__(self):\n",
    "        self.max_quantum_size = 20  # Maximum problem size for quantum simulation\n",
    "        self.default_p_layers = 3  # Default number of QAOA layers\n",
    "        self.noise_level = 0.0  # Noise level for quantum simulation\n",
    "        \n",
    "    def create_quantum_instance(self) -> VRPTWInstance:\n",
    "        \"\"\"Create a small-scale VRPTW instance suitable for quantum optimization\"\"\"\n",
    "        \n",
    "        # Create 8 customers for quantum demonstration\n",
    "        customers = [\n",
    "            Customer(id=1, x=10, y=15, demand=25, ready_time=480, due_date=600, service_time=12),\n",
    "            Customer(id=2, x=20, y=10, demand=30, ready_time=540, due_date=660, service_time=15),\n",
    "            Customer(id=3, x=15, y=25, demand=35, ready_time=840, due_date=960, service_time=18),\n",
    "            Customer(id=4, x=25, y=20, demand=20, ready_time=600, due_date=720, service_time=10),\n",
    "            Customer(id=5, x=12, y=8, demand=28, ready_time=720, due_date=840, service_time=14),\n",
    "            Customer(id=6, x=18, y=22, demand=32, ready_time=780, due_date=900, service_time=16),\n",
    "            Customer(id=7, x=8, y=18, demand=26, ready_time=630, due_date=750, service_time=13),\n",
    "            Customer(id=8, x=22, y=12, demand=29, ready_time=690, due_date=810, service_time=11)\n",
    "        ]\n",
    "        \n",
    "        # Create 2 vehicles for quantum demonstration\n",
    "        vehicles = [\n",
    "            Vehicle(id=1, capacity=80),\n",
    "            Vehicle(id=2, capacity=80)\n",
    "        ]\n",
    "        \n",
    "        # Create travel time matrix\n",
    "        locations = [(0, 0)] + [(c.x, c.y) for c in customers]  # depot + customers\n",
    "        n = len(locations)\n",
    "        travel_time_matrix = np.zeros((n, n))\n",
    "        \n",
    "        for i in range(n):\n",
    "            for j in range(n):\n",
    "                if i != j:\n",
    "                    dist = np.sqrt((locations[i][0] - locations[j][0])**2 + \n",
    "                                 (locations[i][1] - locations[j][1])**2)\n",
    "                    travel_time_matrix[i][j] = dist * 2.5  # Convert to minutes\n",
    "        \n",
    "        return VRPTWInstance(customers, vehicles, travel_time_matrix)\n",
    "    \n",
    "    def formulate_qubo(self, instance: VRPTWInstance) -> QUBOFormulation:\n",
    "        \"\"\"Formulate VRPTW as QUBO for quantum optimization\"\"\"\n",
    "        \n",
    "        n_customers = len(instance.customers)\n",
    "        n_vehicles = len(instance.vehicles)\n",
    "        \n",
    "        # Binary variable encoding:\n",
    "        # x[i][j][k] = 1 if customer i is assigned to vehicle j at position k\n",
    "        n_variables = n_customers * n_vehicles * n_customers  # Simplified encoding\n",
    "        \n",
    "        if n_variables > self.max_quantum_size:\n",
    "            # Reduce problem size for quantum simulation\n",
    "            n_variables = self.max_quantum_size\n",
    "            n_customers = min(n_customers, 4)  # Limit to 4 customers\n",
    "        \n",
    "        # Initialize QUBO components\n",
    "        Q_matrix = np.zeros((n_variables, n_variables))\n",
    "        linear_terms = np.zeros(n_variables)\n",
    "        constant_term = 0.0\n",
    "        \n",
    "        # Objective: minimize total distance\n",
    "        for i in range(n_customers):\n",
    "            for j in range(n_vehicles):\n",
    "                for k in range(n_customers):\n",
    "                    var_idx = i * n_vehicles * n_customers + j * n_customers + k\n",
    "                    if var_idx < n_variables:\n",
    "                        # Distance cost (simplified)\n",
    "                        distance_cost = instance.travel_time_matrix[0][i+1] * 0.1\n",
    "                        linear_terms[var_idx] = distance_cost\n",
    "                        \n",
    "                        # Time window penalty\n",
    "                        customer = instance.customers[i]\n",
    "                        window_width = customer.due_date - customer.ready_time\n",
    "                        penalty = 10.0 / (window_width + 1)  # Penalty for narrow windows\n",
    "                        linear_terms[var_idx] += penalty\n",
    "        \n",
    "        # Constraint: each customer assigned exactly once\n",
    "        for i in range(n_customers):\n",
    "            for j1 in range(n_vehicles):\n",
    "                for k1 in range(n_customers):\n",
    "                    for j2 in range(n_vehicles):\n",
    "                        for k2 in range(n_customers):\n",
    "                            if j1 != j2 or k1 != k2:\n",
    "                                idx1 = i * n_vehicles * n_customers + j1 * n_customers + k1\n",
    "                                idx2 = i * n_vehicles * n_customers + j2 * n_customers + k2\n",
    "                                if idx1 < n_variables and idx2 < n_variables:\n",
    "                                    Q_matrix[idx1][idx2] += 5.0  # Penalty for multiple assignments\n",
    "        \n",
    "        # Constraint: vehicle capacity\n",
    "        for j in range(n_vehicles):\n",
    "            for i1 in range(n_customers):\n",
    "                for i2 in range(n_customers):\n",
    "                    if i1 != i2:\n",
    "                        for k1 in range(n_customers):\n",
    "                            for k2 in range(n_customers):\n",
    "                                idx1 = i1 * n_vehicles * n_customers + j * n_customers + k1\n",
    "                                idx2 = i2 * n_vehicles * n_customers + j * n_customers + k2\n",
    "                                if idx1 < n_variables and idx2 < n_variables:\n",
    "                                    demand1 = instance.customers[i1].demand\n",
    "                                    demand2 = instance.customers[i2].demand\n",
    "                                    capacity = instance.vehicles[j].capacity\n",
    "                                    if demand1 + demand2 > capacity:\n",
    "                                        Q_matrix[idx1][idx2] += 8.0  # Capacity violation penalty\n",
    "        \n",
    "        # Create variable mapping\n",
    "        variable_mapping = {}\n",
    "        var_idx = 0\n",
    "        for i in range(n_customers):\n",
    "            for j in range(n_vehicles):\n",
    "                for k in range(n_customers):\n",
    "                    if var_idx < n_variables:\n",
    "                        variable_mapping[var_idx] = f'x_{i}_{j}_{k}'\n",
    "                        var_idx += 1\n",
    "        \n",
    "        # Constraint descriptions\n",
    "        constraints = [\n",
    "            'Each customer assigned exactly once',\n",
    "            'Vehicle capacity constraints',\n",
    "            'Time window satisfaction',\n",
    "            'Route continuity'\n",
    "        ]\n",
    "        \n",
    "        return QUBOFormulation(\n",
    "            Q_matrix=Q_matrix,\n",
    "            linear_terms=linear_terms,\n",
    "            constant_term=constant_term,\n",
    "            variable_mapping=variable_mapping,\n",
    "            n_variables=n_variables,\n",
    "            constraints=constraints\n",
    "        )\n",
    "    \n",
    "    def create_quantum_circuit(self, qubo: QUBOFormulation, p_layers: int = 3) -> QuantumCircuit:\n",
    "        \"\"\"Create QAOA quantum circuit for the QUBO problem\"\"\"\n",
    "        \n",
    "        n_qubits = qubo.n_variables\n",
    "        \n",
    "        # Initialize parameters (can be optimized)\n",
    "        gamma_params = [0.5] * p_layers\n",
    "        beta_params = [0.3] * p_layers\n",
    "        \n",
    "        circuit_depth = 2 * p_layers  # Each layer has gamma and beta rotations\n",
    "        \n",
    "        return QuantumCircuit(\n",
    "            n_qubits=n_qubits,\n",
    "            p_layers=p_layers,\n",
    "            gamma_params=gamma_params,\n",
    "            beta_params=beta_params,\n",
    "            circuit_depth=circuit_depth,\n",
    "            expectation_values=[]\n",
    "        )\n",
    "    \n",
    "    def apply_hadamard_layer(self, state: np.ndarray) -> np.ndarray:\n",
    "        \"\"\"Apply Hadamard layer to create superposition\"\"\"\n",
    "        # Simplified Hadamard transformation\n",
    "        n = len(state)\n",
    "        H = np.ones((n, n)) / np.sqrt(n)\n",
    "        H[np.arange(1, n), 0] = 1.0\n",
    "        H[0, np.arange(1, n)] = 1.0\n",
    "        for i in range(1, n):\n",
    "            for j in range(1, n):\n",
    "                if i != j:\n",
    "                    H[i, j] = 0.0\n",
    "        \n",
    "        return H @ state\n",
    "    \n",
    "    def apply_problem_hamiltonian(self, state: np.ndarray, qubo: QUBOFormulation, gamma: float) -> np.ndarray:\n",
    "        \"\"\"Apply problem Hamiltonian (exp(-i*gamma*C))\"\"\"\n",
    "        # Simplified quantum evolution under problem Hamiltonian\n",
    "        n = len(state)\n",
    "        \n",
    "        # Create diagonal matrix from QUBO\n",
    "        H_problem = np.diag(qubo.linear_terms)\n",
    "        H_problem += qubo.Q_matrix\n",
    "        \n",
    "        # Apply unitary evolution (simplified)\n",
    "        U = np.eye(n) - 1j * gamma * H_problem\n",
    "        \n",
    "        # Normalize to maintain unitarity (simplified)\n",
    "        U = U / np.linalg.norm(U, axis=0)\n",
    "        \n",
    "        return U @ state\n",
    "    \n",
    "    def apply_mixer_hamiltonian(self, state: np.ndarray, beta: float) -> np.ndarray:\n",
    "        \"\"\"Apply mixer Hamiltonian (exp(-i*beta*B))\"\"\"\n",
    "        # Simplified mixer Hamiltonian (X rotations)\n",
    "        n = len(state)\n",
    "        \n",
    "        # Create X rotation matrix\n",
    "        cos_beta = np.cos(beta)\n",
    "        sin_beta = np.sin(beta)\n",
    "        \n",
    "        U_mixer = np.eye(n) * cos_beta\n",
    "        \n",
    "        # Add off-diagonal terms for X rotations (simplified)\n",
    "        for i in range(n):\n",
    "            for j in range(n):\n",
    "                if i != j and abs(i - j) == 1:  # Adjacent qubits\n",
    "                    U_mixer[i, j] = -1j * sin_beta\n",
    "        \n",
    "        return U_mixer @ state\n",
    "    \n",
    "    def simulate_quantum_circuit(self, circuit: QuantumCircuit, qubo: QUBOFormulation) -> np.ndarray:\n",
    "        \"\"\"Simulate quantum circuit execution\"\"\"\n",
    "        \n",
    "        # Initialize quantum state |0...0>\n",
    "        state = np.zeros(2**circuit.n_qubits)\n",
    "        state[0] = 1.0  # |0...0> state\n",
    "        \n",
    "        # Apply Hadamard layer to create superposition\n",
    "        state = self.apply_hadamard_layer(state)\n",
    "        \n",
    "        # Apply QAOA layers\n",
    "        for layer in range(circuit.p_layers):\n",
    "            # Apply problem Hamiltonian\n",
    "            state = self.apply_problem_hamiltonian(state, qubo, circuit.gamma_params[layer])\n",
    "            \n",
    "            # Apply mixer Hamiltonian\n",
    "            state = self.apply_mixer_hamiltonian(state, circuit.beta_params[layer])\n",
    "            \n",
    "            # Add noise simulation\n",
    "            if self.noise_level > 0:\n",
    "                noise = np.random.normal(0, self.noise_level, state.shape)\n",
    "                state = state + noise\n",
    "                # Renormalize\n",
    "                state = state / np.linalg.norm(state)\n",
    "        \n",
    "        return state\n",
    "    \n",
    "    def measure_quantum_state(self, state: np.ndarray) -> Dict:\n",
    "        \"\"\"Measure quantum state and get probabilities\"\"\"\n",
    "        \n",
    "        # Calculate measurement probabilities\n",
    "        probabilities = np.abs(state) ** 2\n",
    "        \n",
    "        # Normalize probabilities\n",
    "        probabilities = probabilities / np.sum(probabilities)\n",
    "        \n",
    "        # Get most likely measurement outcomes\n",
    "        measurement_results = []\n",
    "        \n",
    "        for i in range(min(10, len(probabilities))):\n",
    "            idx = np.argmax(probabilities)\n",
    "            binary_string = format(idx, f'0{int(np.log2(len(state)))}b')\n",
    "            probability = probabilities[idx]\n",
    "            \n",
    "            measurement_results.append({\n",
    "                'binary_string': binary_string,\n",
    "                'probability': probability,\n",
    "                'index': idx\n",
    "            })\n",
    "            \n",
    "            probabilities[idx] = 0  # Remove to find next maximum\n",
    "        \n",
    "        return {\n",
    "            'measurement_results': measurement_results,\n",
    "            'probabilities': probabilities,\n",
    "            'max_probability': max([r['probability'] for r in measurement_results])\n",
    "        }\n",
    "    \n",
    "    def decode_quantum_solution(self, measurement_result: Dict, qubo: QUBOFormulation, instance: VRPTWInstance) -> QuantumSolution:\n",
    "        \"\"\"Decode quantum measurement to VRPTW solution\"\"\"\n",
    "        \n",
    "        binary_string = measurement_result['binary_string']\n",
    "        \n",
    "        # Decode binary string to customer assignments\n",
    "        routes = []\n",
    "        n_customers = len(instance.customers)\n",
    "        n_vehicles = len(instance.vehicles)\n",
    "        \n",
    "        # Simplified decoding (first n_customers bits)\n",
    "        for j in range(n_vehicles):\n",
    "            route = []\n",
    "            for i in range(n_customers):\n",
    "                if i < len(binary_string):\n",
    "                    if binary_string[i] == '1':\n",
    "                        route.append(i + 1)\n",
    "            if route:\n",
    "                routes.append(route)\n",
    "        \n",
    "        # Calculate classical cost\n",
    "        classical_cost = self._calculate_classical_cost(routes, instance)\n",
    "        \n",
    "        # Calculate quantum advantage (simplified)\n",
    "        quantum_advantage = 1.0 - (classical_cost / 200.0)  # Normalized advantage\n",
    "        \n",
    "        # Create quantum state visualization\n",
    "        quantum_state = np.array([int(bit) for bit in binary_string])\n",
    "        \n",
    "        return QuantumSolution(\n",
    "            routes=routes,\n",
    "            quantum_state=quantum_state,\n",
    "            objective_value=classical_cost,\n",
    "            measurement_probabilities=measurement_result['probability'],\n",
    "            classical_cost=classical_cost,\n",
    "            quantum_advantage=quantum_advantage\n",
    "        )\n",
    "    \n",
    "    def _calculate_classical_cost(self, routes: List[List[int]], instance: VRPTWInstance) -> float:\n",
    "        \"\"\"Calculate classical cost of decoded solution\"\"\"\n",
    "        \n",
    "        total_cost = 0.0\n",
    "        \n",
    "        for route in routes:\n",
    "            if route:\n",
    "                # Calculate route distance (simplified)\n",
    "                route_distance = 0.0\n",
    "                prev_location = 0  # depot\n",
    "                \n",
    "                for customer_id in route:\n",
    "                    route_distance += instance.travel_time_matrix[prev_location][customer_id]\n",
    "                    prev_location = customer_id\n",
    "                \n",
    "                # Return to depot\n",
    "                route_distance += instance.travel_time_matrix[prev_location][0]\n",
    "                \n",
    "                total_cost += route_distance\n",
    "        \n",
    "        return total_cost\n",
    "    \n",
    "    def optimize_quantum_parameters(self, qubo: QUBOFormulation, instance: VRPTWInstance) -> Dict:\n",
    "        \"\"\"Optimize quantum circuit parameters\"\"\"\n",
    "        \n",
    "        print(\"Starting quantum parameter optimization...\")\n",
    "        \n",
    "        # Test different parameter combinations\n",
    "        p_values = [1, 2, 3, 4]\n",
    "        gamma_values = [0.3, 0.5, 0.7, 0.9]\n",
    "        beta_values = [0.1, 0.3, 0.5, 0.7]\n",
    "        \n",
    "        best_solution = None\n",
    "        best_cost = float('inf')\n",
    "        optimization_history = []\n",
    "        \n",
    "        for p in p_values:\n",
    "            for gamma in gamma_values:\n",
    "                for beta in beta_values:\n",
    "                    \n",
    "                    # Create quantum circuit with parameters\n",
    "                    circuit = QuantumCircuit(\n",
    "                        n_qubits=qubo.n_variables,\n",
    "                        p_layers=p,\n",
    "                        gamma_params=[gamma] * p,\n",
