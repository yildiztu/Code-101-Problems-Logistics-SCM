    "@dataclass\n",
    "class Customer:\n",
    "    \"\"\"Represents a customer with location, demand, and time window\"\"\"\n",
    "    id: int\n",
    "    x: float  # x-coordinate\n",
    "    y: float  # y-coordinate\n",
    "    demand: float  # demand quantity\n",
    "    ready_time: float  # earliest service time (minutes from start)\n",
    "    due_date: float  # latest service time (minutes from start)\n",
    "    service_time: float  # service duration (minutes)\n",
    "\n",
    "@dataclass\n",
    "class Vehicle:\n",
    "    \"\"\"Represents a vehicle with capacity constraints\"\"\"\n",
    "    id: int\n",
    "    capacity: float\n",
    "    start_location: Tuple[float, float] = (0.0, 0.0)  # depot location\n",
    "\n",
    "@dataclass\n",
    "class VRPTWInstance:\n",
    "    \"\"\"VRPTW problem instance for quantum optimization\"\"\"\n",
    "    customers: List[Customer]\n",
    "    vehicles: List[Vehicle]\n",
    "    travel_time_matrix: np.ndarray\n",
    "    depot: Tuple[float, float] = (0.0, 0.0)\n",
    "\n",
    "@dataclass\n",
    "class QUBOFormulation:\n",
    "    \"\"\"QUBO formulation of VRPTW for quantum optimization\"\"\"\n",
    "    Q_matrix: np.ndarray  # Quadratic coefficient matrix\n",
    "    linear_terms: np.ndarray  # Linear coefficient vector\n",
    "    constant_term: float  # Constant term\n",
    "    variable_mapping: Dict  # Maps binary variables to VRPTW decisions\n",
    "    n_variables: int  # Total number of binary variables\n",
    "    constraints: List[str]  # Constraint descriptions\n",
    "\n",
    "@dataclass\n",
    "class QuantumCircuit:\n",
    "    \"\"\"Quantum circuit for QAOA optimization\"\"\"\n",
    "    n_qubits: int\n",
    "    p_layers: int  # Number of QAOA layers\n",
    "    gamma_params: List[float]  # Problem Hamiltonian parameters\n",
    "    beta_params: List[float]  # Mixer Hamiltonian parameters\n",
    "    circuit_depth: int\n",
    "    expectation_values: List[float]\n",
    "\n",
    "@dataclass\n",
    "class QuantumSolution:\n",
    "    \"\"\"Solution from quantum optimization\"\"\"\n",
    "    routes: List[List[int]]\n",
    "    quantum_state: np.ndarray\n",
    "    objective_value: float\n",
    "    measurement_probabilities: np.ndarray\n",
    "    classical_cost: float\n",
    "    quantum_advantage: float"
   ]
