    "def visualize_quantum_results(quantum_sol: QuantumSolution, opt_results: Dict, \n",
    "                            noise_res: List[Dict], scale_res: List[Dict]):\n",
    "    \"\"\"Create comprehensive visualization of quantum optimization results\"\"\"\n",
    "    \n",
    "    fig, ((ax1, ax2), (ax3, ax4)) = plt.subplots(2, 2, figsize=(16, 12))\n",
    "    \n",
    "    # 1. Quantum solution visualization\n",
    "    colors = ['blue', 'red', 'green', 'orange', 'purple']\n",
    "    \n",
    "    # Plot depot and customers\n",
    "    ax1.scatter(0, 0, c='black', s=200, marker='s', label='Depot', zorder=5)\n",
    "    \n",
    "    for customer in quantum_instance.customers:\n",
    "        ax1.scatter(customer.x, customer.y, c='gray', s=100, marker='o', zorder=4)\n",
    "        ax1.annotate(f\"{customer.id}\", (customer.x+0.5, customer.y+0.5), fontsize=8)\n",
    "    \n",
    "    # Draw quantum routes\n",
    "    for route_idx, route in enumerate(quantum_sol.routes):\n",
    "        if route:\n",
    "            color = colors[route_idx % len(colors)]\n",
    "            prev_x, prev_y = 0, 0\n",
    "            \n",
    "            for customer_id in route:\n",
    "                customer = quantum_instance.customers[customer_id - 1]\n",
    "                ax1.plot([prev_x, customer.x], [prev_y, customer.y], \n",
    "                        color=color, linewidth=2, alpha=0.7)\n",
    "                ax1.scatter(customer.x, customer.y, c=color, s=150, marker='o', zorder=5)\n",
    "                prev_x, prev_y = customer.x, customer.y\n",
    "            \n",
    "            # Return to depot\n",
    "            ax1.plot([prev_x, 0], [prev_y, 0], color=color, linewidth=2, alpha=0.7)\n",
    "    \n",
    "    ax1.set_xlabel('X Coordinate')\n",
    "    ax1.set_ylabel('Y Coordinate')\n",
    "    ax1.set_title(f'Quantum VRPTW Solution\\nCost: {quantum_sol.classical_cost:.2f}, Advantage: {quantum_sol.quantum_advantage:.3f}')\n",
    "    ax1.legend()\n",
    "    ax1.grid(True, alpha=0.3)\n",
    "    \n",
    "    # 2. Parameter optimization results\n",
    "    history = opt_results['optimization_history']\n",
    "    costs = [r['cost'] for r in history]\n",
    "    advantages = [r['quantum_advantage'] for r in history]\n",
    "    \n",
    "    ax2_twin = ax2.twinx()\n",
    "    \n",
    "    line1 = ax2.plot(range(len(costs)), costs, 'b-o', linewidth=2, markersize=6, label='Cost')\n",
    "    line2 = ax2_twin.plot(range(len(advantages)), advantages, 'r-s', linewidth=2, markersize=6, label='Quantum Advantage')\n",
    "    \n",
    "    ax2.set_xlabel('Parameter Combination')\n",
    "    ax2.set_ylabel('Cost', color='blue')\n",
    "    ax2_twin.set_ylabel('Quantum Advantage', color='red')\n",
    "    ax2.set_title('Quantum Parameter Optimization')\n",
    "    ax2.grid(True, alpha=0.3)\n",
    "    ax2.legend(loc='upper left')\n",
    "    ax2_twin.legend(loc='upper right')\n",
