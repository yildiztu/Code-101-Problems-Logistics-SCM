    "@dataclass\n",
    "class DeliveryNode:\n",
    "    \"\"\"Represents a delivery node (customer or MFC)\"\"\"\n",
    "    id: int\n",
    "    x: float\n",
    "    y: float\n",
    "    node_type: str  # 'customer', 'mfc', 'depot'\n",
    "    demand: float = 0.0  # For customers\n",
    "    capacity: float = 0.0  # For MFCs\n",
    "    time_window: Tuple[float, float] = (0.0, 24.0)  # Service hours\n",
    "\n",
    "@dataclass\n",
    "class Vehicle:\n",
    "    \"\"\"Represents a delivery vehicle\"\"\"\n",
    "    id: int\n",
    "    capacity: float\n",
    "    speed: float\n",
    "    cost_per_km: float\n",
    "    vehicle_type: str\n",
    "\n",
    "@dataclass\n",
    "class QuantumQUBO:\n",
    "    \"\"\"Quadratic Unconstrained Binary Optimization formulation\"\"\"\n",
    "    Q_matrix: np.ndarray  # Q matrix for QUBO\n",
    "    linear_terms: np.ndarray  # Linear terms (h vector)\n",
    "    constant: float  # Constant term\n",
    "    num_variables: int\n",
    "    variable_mapping: Dict[str, int]  # Maps variable names to indices\n",
    "\n",
    "class QAOAParameters:\n",
    "    \"\"\"Parameters for Quantum Approximate Optimization Algorithm\"\"\"\n",
    "    p: int  # Number of layers\n",
    "    gamma: List[float]  # Angle parameters for each layer\n",
    "    beta: List[float]  # Mixer parameters for each layer\n",
    "    \n",
    "    def __init__(self, p: int = 2):\n",
    "        self.p = p\n",
    "        self.gamma = [np.pi / (4 * (i + 1)) for i in range(p)]\n",
    "        self.beta = [np.pi / 4 for _ in range(p)]\n",
    "\n",
    "class QuantumOptimizer:\n",
    "    \"\"\"Quantum optimizer using QAOA for delivery routing\"\"\"\n",
    "    \n",
    "    def __init__(self, num_qubits: int = 20):\n",
    "        self.num_qubits = num_qubits\n",
    "        self.quantum_simulator = QuantumSimulator(num_qubits)\n",
    "        self.optimization_history = []\n",
    "        \n",
    "    def create_qubo_formulation(self, nodes: List[DeliveryNode], \n",
    "                                vehicles: List[Vehicle]) -> QuantumQUBO:\n",
    "        \"\"\"Create QUBO formulation for delivery routing problem\"\"\"\n",
    "        \n",
    "        print(f\"Creating QUBO formulation for {len(nodes)} nodes, {len(vehicles)} vehicles\")\n",
    "        \n",
    "        # Define binary variables\n",
    "        # x[i][v][t] = 1 if customer i assigned to vehicle v at time t\n",
    "        num_customers = len([n for n in nodes if n.node_type == 'customer'])\n",
    "        num_vehicles = len(vehicles)\n",
    "        num_time_periods = 4  # Simplified time periods\n",
    "        \n",
    "        total_variables = num_customers * num_vehicles * num_time_periods\n",
    "        \n",
    "        print(f\"Binary variables: {total_variables} (customers × vehicles × time)\")\n",
    "        \n",
    "        # Initialize Q matrix (upper triangular)\n",
    "        Q = np.zeros((total_variables, total_variables))\n",
    "        h = np.zeros(total_variables)  # Linear terms\n",
    "        constant = 0.0\n",
    "        \n",
    "        # Variable mapping\n",
    "        variable_mapping = {}\n",
    "        var_idx = 0\n",
    "        \n",
    "        for i in range(num_customers):\n",
    "            for v in range(num_vehicles):\n",
    "                for t in range(num_time_periods):\n",
    "                    var_name = f\"x_{i}_{v}_{t}\"\n",
    "                    variable_mapping[var_name] = var_idx\n",
    "                    var_idx += 1\n",
    "        \n",
    "        # Build QUBO objective function\n",
    "        # Objective: minimize total cost while satisfying constraints\n",
    "        \n",
    "        # 1. Assignment constraints (each customer assigned to exactly one vehicle)\n",
    "        for i in range(num_customers):\n",
    "            for v in range(num_vehicles):\n",
    "                for t in range(num_time_periods):\n",
    "                    var_idx = variable_mapping[f\"x_{i}_{v}_{t}\"]\n",
    "                    h[var_idx] += 10.0  # Penalty for assignment\n",
    "        \n",
    "        # 2. Capacity constraints (vehicle capacity limits)\n",
    "        for v in range(num_vehicles):\n",
    "            for t in range(num_time_periods):\n",
    "                for i1 in range(num_customers):\n",
    "                    for i2 in range(i1, num_customers):  # Avoid double counting\n",
    "                        idx1 = variable_mapping[f\"x_{i1}_{v}_{t}\"]\n",
    "                        idx2 = variable_mapping[f\"x_{i2}_{v}_{t}\"]\n",
    "                        \n",
    "                        customer1 = next((n for n in nodes if n.node_type == 'customer' and n.id == i1), None)\n",
    "                        customer2 = next((n for n in nodes if n.node_type == 'customer' and n.id == i2), None)\n",
    "                        \n",
    "                        if customer1 and customer2:\n",
    "                            demand_sum = customer1.demand + customer2.demand\n",
    "                            if demand_sum > vehicles[v].capacity:\n",
    "                                Q[idx1, idx2] += 100.0  # Capacity violation penalty\n",
    "        \n",
    "        # 3. Distance costs (minimize travel distance)\n",
    "        for i in range(num_customers):\n",
    "            customer = next((n for n in nodes if n.node_type == 'customer' and n.id == i), None)\n",
    "            if customer:\n",
    "                for v in range(num_vehicles):\n",
    "                    for t in range(num_time_periods):\n",
    "                        var_idx = variable_mapping[f\"x_{i}_{v}_{t}\"]\n",
    "                        \n",
    "                        # Calculate distance from nearest MFC\n",
    "                        mfc = min([n for n in nodes if n.node_type == 'mfc'], \n",
    "                                 key=lambda m: np.sqrt((m.x - customer.x)**2 + (m.y - customer.y)**2))\n",
    "                        distance = np.sqrt((mfc.x - customer.x)**2 + (mfc.y - customer.y)**2)\n",
    "                        \n",
    "                        h[var_idx] += distance * vehicles[v].cost_per_km * 0.1\n",
    "        \n",
    "        # 4. Time window constraints\n",
    "        for i in range(num_customers):\n",
    "            customer = next((n for n in nodes if n.node_type == 'customer' and n.id == i), None)\n",
    "            if customer:\n",
    "                for t in range(num_time_periods):\n",
    "                    if t < customer.time_window[0] or t > customer.time_window[1]:\n",
    "                        for v in range(num_vehicles):\n",
    "                            var_idx = variable_mapping[f\"x_{i}_{v}_{t}\"]\n",
    "                            h[var_idx] += 50.0  # Time window violation penalty\n",
    "        \n",
    "        return QuantumQUBO(Q, h, constant, total_variables, variable_mapping)\n",
    "    \n",
    "    def create_qaoa_circuit(self, qubo: QuantumQUBO, params: QAOAParameters) -> Dict:\n",
    "        \"\"\"Create QAOA quantum circuit\"\"\"\n",
    "        \n",
    "        print(f\"Creating QAOA circuit with {params.p} layers\")\n",
    "        \n",
    "        circuit_info = {\n",
    "            'num_qubits': qubo.num_variables,\n",
    "            'num_layers': params.p,\n",
    "            'gamma_params': params.gamma,\n",
    "            'beta_params': params.beta,\n",
    "            'circuit_depth': params.p * 2  # Each layer has gamma and beta gates\n",
    "        }\n",
    "        \n",
    "        return circuit_info\n",
    "    \n",
    "    def run_qaoa_optimization(self, qubo: QuantumQUBO, params: QAOAParameters) -> Dict:\n",
    "        \"\"\"Run QAOA optimization on quantum simulator\"\"\"\n",
    "        \n",
    "        print(f\"Running QAOA optimization on {qubo.num_variables} qubits...\")\n",
    "        \n",
    "        # Start timing\n",
    "        start_time = time.time()\n",
    "        \n",
    "        # Create QAOA circuit\n",
    "        circuit_info = self.create_qaoa_circuit(qubo, params)\n",
    "        \n",
    "        # Simulate quantum execution\n",
    "        optimization_result = self.quantum_simulator.execute_qaoa(qubo, params)\n",
    "        \n",
    "        # Calculate execution time\n",
    "        execution_time = time.time() - start_time\n",
    "        \n",
    "        result = {\n",
    "            'solution_vector': optimization_result['solution'],\n",
    "            'energy': optimization_result['energy'],\n",
    "            'execution_time': execution_time,\n",
    "            'iterations': optimization_result['iterations'],\n",
    "            'circuit_info': circuit_info,\n",
    "            'convergence_history': optimization_result['convergence_history']\n",
    "        }\n",
    "        \n",
    "        print(f\"QAOA completed in {execution_time:.2f} seconds\")\n",
    "        print(f\"Final energy: {result['energy']:.2f}\")\n",
    "        print(f\"Iterations: {result['iterations']}\")\n",
    "        \n",
    "        return result\n",
    "    \n",
    "    def decode_solution(self, qubo: QuantumQUBO, solution_vector: np.ndarray, \n",
    "                       nodes: List[DeliveryNode], vehicles: List[Vehicle]) -> Dict:\n",
    "        \"\"\"Decode quantum solution into delivery assignments\"\"\"\n",
    "        \n",
    "        print(\"Decoding quantum solution...\")\n",
    "        \n",
    "        assignments = []\n",
    "        num_customers = len([n for n in nodes if n.node_type == 'customer'])\n",
    "        num_vehicles = len(vehicles)\n",
    "        num_time_periods = 4\n",
    "        \n",
    "        for i in range(num_customers):\n",
    "            customer = next((n for n in nodes if n.node_type == 'customer' and n.id == i), None)\n",
    "            if customer:\n",
    "                for v in range(num_vehicles):\n",
    "                    for t in range(num_time_periods):\n",
    "                        var_name = f\"x_{i}_{v}_{t}\"\n",
    "                        if var_name in qubo.variable_mapping:\n",
    "                            var_idx = qubo.variable_mapping[var_name]\n",
    "                            if solution_vector[var_idx] > 0.5:  # Threshold for binary decision\n",
    "                                assignments.append({\n",
    "                                    'customer_id': i,\n",
    "                                    'customer': customer,\n",
    "                                    'vehicle_id': v,\n",
    "                                    'vehicle': vehicles[v],\n",
    "                                    'time_period': t,\n",
    "                                    'assigned': True\n",
    "                                })\n",
    "                                break  # Each customer assigned to only one vehicle/time\n",
    "        \n",
    "        # Calculate solution metrics\n",
    "        total_distance = 0.0\n",
    "        total_cost = 0.0\n",
    "        vehicle_loads = {v.id: 0.0 for v in vehicles}\n",
    "        time_window_violations = 0\n",
    "        \n",
    "        for assignment in assignments:\n",
    "            # Calculate distance\n",
    "            mfc = min([n for n in nodes if n.node_type == 'mfc'], \n",
    "                         key=lambda m: np.sqrt((m.x - assignment['customer'].x)**2 + (m.y - assignment['customer'].y)**2))\n",
    "            distance = np.sqrt((mfc.x - assignment['customer'].x)**2 + (mfc.y - assignment['customer'].y)**2)\n",
    "            total_distance += distance\n",
    "            total_cost += distance * assignment['vehicle'].cost_per_km\n",
    "            vehicle_loads[assignment['vehicle_id']] += assignment['customer'].demand\n",
    "            \n",
    "            # Check time window\n",
    "            if assignment['time_period'] < assignment['customer'].time_window[0] or assignment['time_period'] > assignment['customer'].time_window[1]:\n",
    "                time_window_violations += 1\n",
    "        \n",
    "        # Calculate utilization\n",
    "        utilization = {v.id: (load / v.capacity) * 100 for v, load in vehicle_loads.items()}\n",
    "        \n    "        return {\n",
    "            'assignments': assignments,\n",
    "            'total_distance': total_distance,\n",
    "            'total_cost': total_cost,\n",
    "            'vehicle_utilization': utilization,\n",
    "            'time_window_violations': time_window_violations,\n",
    "            'num_assigned_customers': len(set(a['customer_id'] for a in assignments)),\n",
    "            'solution_quality': 1.0 - (time_window_violations / num_customers) if num_customers > 0 else 1.0\n",
    "        }\n",
    "\n",
    "class QuantumSimulator:\n",
    "    \"\"\"Quantum circuit simulator for QAOA\"\"\"\n",
    "    \n",
    "    def __init__(self, num_qubits: int):\n",
    "        self.num_qubits = num_qubits\n",
    "        self.state_vector = None\n",
    "        \n",
    "    def execute_qaoa(self, qubo: QuantumQUBO, params: QAOAParameters) -> Dict:\n",
    "        \"\"\"Simulate QAOA execution\"\"\"\n",
    "        \n",
    "        print(f\"Simulating quantum execution on {qubo.num_variables} qubits...\")\n",
    "        \n",
    "        # Initialize quantum state (uniform superposition)\n",
    "        state = np.ones(2**qubo.num_variables) / np.sqrt(2**qubo.num_variables)\n",
    "        \n",
    "        # QAOA iterations\n",
    "        convergence_history = []\n",
    "        \n",
    "        for iteration in range(params.p):\n",
    "            # Apply cost unitary (exp(-i*gamma*C))\n",
    "            state = self._apply_cost_unitary(state, qubo, params.gamma[iteration])\n",
    "            \n",
    "            # Apply mixer unitary (exp(-i*beta*B))\n",
    "            state = self._apply_mixer_unitary(state, params.beta[iteration])\n",
    "            \n",
    "            # Calculate energy\n",
    "            energy = self._calculate_energy(state, qubo)\n",
    "            convergence_history.append(energy)\n",
    "            \n",
    "            if iteration % 10 == 0:\n",
    "                print(f\"  Iteration {iteration + 1}/{params.p}: Energy = {energy:.2f}\")\n",
    "        \n",
    "        # Measure final state\n    ",
    "        probabilities = np.abs(state)**2\n",
    "        solution_vector = np.random.choice([0, 1], size=qubo.num_variables, p=[1-probabilities, probabilities])\n",
    "        \n",
    "        # Find best solution\n",
    "        best_energy = float('inf')\n",
    "        best_solution = None\n",
    "        \n",
    "        for _ in range(100):  # Sample multiple times to find best solution\n",
    "            sample = np.random.choice([0, 1], size=qubo.num_variables, p=[1-probabilities, probabilities])\n",
    "            sample_energy = self._calculate_energy_from_binary(sample, qubo)\n    ",
    "            if sample_energy < best_energy:\n",
    "                best_energy = sample_energy\n",
    "                best_solution = sample\n",
    "        \n",
    "        return {\n",
    "            'solution': best_solution,\n",
    "            'energy': best_energy,\n",
    "            'iterations': params.p,\n",
    "            'convergence_history': convergence_history\n",
    "        }\n",
    "    \n",
    "    def _apply_cost_unitary(self, state: np.ndarray, qubo: QuantumQUBO, gamma: float) -> np.ndarray:\n",
    "        \"\"\"Apply cost unitary operator U_C(gamma) = exp(-i*gamma*C)\"\"\"\n",
    "        \n",
    "        # Simplified cost unitary simulation\n    ",
    "        # In real quantum hardware, this would be implemented with quantum gates\n",
    "        # For simulation, we apply a phase rotation based on the QUBO energy\n",
    "        \n",
    "        for i in range(len(state)):\n",
    "            # Calculate energy contribution for this basis state\n",
    "            binary_state = [(i >> j) & 1 for j in range(qubo.num_variables)]\n",
    "            energy = self._calculate_energy_from_binary(binary_state, qubo)\n",
    "            \n",
    "            # Apply phase rotation\n",
    "            phase = -gamma * energy\n",
    "            state[i] *= np.exp(1j * phase)\n",
    "        \n",
    "        return state\n",
    "    \n",
    "    def _apply_mixer_unitary(self, state: np.ndarray, beta: float) -> np.ndarray:\n",
    "        \"\"\"Apply mixer unitary operator U_B(beta) = exp(-i*beta*B)\"\"\"\n",
    "        \n",
    "        # Simplified mixer unitary (Hadamard-like)\n",
    "        # In real quantum hardware, this would be implemented with X and H gates\n",
    "        \n",
    "        # Apply Hadamard-like mixing\n    ",
    "        for i in range(len(state)):\n",
    "            # Simple mixing between basis states\n",
    "            if i % 2 == 0 and i + 1 < len(state):\n",
    "                # Swap amplitudes\n",
    "                state[i], state[i+1] = state[i+1], state[i]\n",
    "            \n",
    "        # Normalize\n",
    "        state = state / np.linalg.norm(state)\n",
    "        \n",
    "        return state\n",
    "    \n",
    "    def _calculate_energy(self, state: np.ndarray, qubo: QuantumQubo) -> float:\n",
    "        \"\"\"Calculate expected energy of quantum state\"\"\"\n",
    ",
    "        energy = 0.0\n",
    "        \n",
    "        for i in range(len(state)):\n",
    "            if abs(state[i]) > 1e-10:  # Skip negligible amplitudes\n",
    "                binary_state = [(i >> j) & 1 for j in range(qubo.num_variables)]\n",
    "                energy += abs(state[i])**2 * self._calculate_energy_from_binary(binary_state, qubo)\n",
    "        \n",
    "        return energy\n",
    "    \n",
    "    def _calculate_energy_from_binary(self, binary_state: List[int], qubo: QuantumQUBO) -> float:\n",
    "        \"\"\"Calculate energy of binary configuration\"\"\"\n",
    "        \n",
    "        energy = qubo.constant\n",
    "        \n",
    "        # Linear terms\n",
    "        for i in range(qubo.num_variables):\n",
    "            energy += binary_state[i] * qubo.linear_terms[i]\n",
    "        \n",
    "        # Quadratic terms\n",
    "        for i in range(qubo.num_variables):\n",
    "            for j in range(qubo.num_variables):\n",
    "                energy += binary_state[i] * binary_state[j] * qubo.Q_matrix[i, j]\n",
    "        \n",
    "        return energy\n",
    "\n",
    "print(\"Quantum Optimization implementation complete\")"
   ]
