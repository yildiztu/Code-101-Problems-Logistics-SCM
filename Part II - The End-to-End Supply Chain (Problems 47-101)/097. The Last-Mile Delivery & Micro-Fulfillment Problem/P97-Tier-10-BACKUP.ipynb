   "source": [
    "@dataclass\n",
    "class Customer:\n",
    "    \"\"\"Represents a customer with behavioral characteristics\"\"\"\n",
    "    id: int\n",
    "    location: Tuple[float, float]\n",
    "    base_demand_pattern: List[float]  # Base demand pattern over 24 hours\n",
    "    price_sensitivity: float  # 0-1 scale (0=insensitive, 1=very sensitive)\n",
    "    time_preference: float  # 0-1 scale (prefers early/late delivery)\n",
    "    loyalty_score: float  # 0-1 scale\n",
    "    responsiveness: float  # How quickly they respond to incentives\n",
    "    demographic_profile: Dict[str, any]\n",
    "\n",
    "@dataclass\n",
    "class DeliveryOption:\n",
    "    \"\"\"Represents a delivery option presented to customer\"\"\"\n",
    "    id: int\n",
    "    delivery_time: float  # Hours from now\n",
    "    price: float\n",
    "convenience_score: float  # 0-1 scale\n",
    "environmental_impact: float  # 0-1 scale (negative is better)\n",
    "capacity_utilization: float  # 0-1 scale\n",
    "    social_proof: List[str]  # Social proof elements\n",
    "\n",
    "@dataclass\n",
    "class IncentiveMechanism:\n",
    "    \"\"\"Represents an incentive mechanism for demand shaping\"\"\"\n",
    "    id: int\n",
    "    name: str\n",
    "    type: str  # 'pricing', 'nudge', 'suggestion', 'gamification'\n",
    "    target_segment: List[str]  # Customer segments to target\n",
    "    incentive_value: float  # Incentive amount or percentage\n",
    "time_window: Tuple[float, float]  # Start and end time\n",
    "expected_impact: float  # Expected demand change\n",
    "implementation_cost: float  # Cost to implement\n",
    "\n",
    "@dataclass\n",
    "MarketShaper:\n",
    "    \"\"\"Proactive demand and market shaping system\"\"\"\n",
    "    id: int\n",
    "city_size: Tuple[float, float]\n",
    "customers: List[Customer]\n",
    "delivery_vehicles: List[Vehicle]\n",
    "incentive_mechanisms: List[IncentiveMechanism]\n",
    "demand_history: List[Dict]\n",
    "market_metrics: Dict[str, float],\n",
    "optimization_history: List[Dict]\n",
    "\n",
    "    def __init__(self, city_size: Tuple[float, float]):\n",
    "        self.id = 1\n",
    "        self.city_size = city_size\n",
    "        self.customers = []\n",
    "        self.delivery_vehicles = []\n",
    "        self.incentive_mechanisms = []\n",
    "        self.demand_history = []\n",
    "        self.market_metrics = {\n",
    "            'total_demand': 0.0,\n",
    "            'peak_demand': 0.0,\n",
    "            'off_peak_demand': 0.0,\n",
    "            'demand_volatility': 0.0,\n",
    "            'customer_satisfaction': 0.0,\n",
    "            'operational_efficiency': 0.0,\n",
    "            'cost_savings': 0.0,\n",
    "        }\n",
    "        \n",
    "    def add_customer(self, customer: Customer):\n",
    "        \"\"\"Add customer to the system\"\"\"\n",
    "        self.customers.append(customer)\n",
    "        \n",
    "    def add_vehicle(self, vehicle: Vehicle):\n",
    "        \"\"\"Add delivery vehicle to the system\"\"\"\n",
    "        self.delivery_vehicles.append(vehicle)\n",
    "        \n",
    "    def add_incentive_mechanism(self, mechanism: IncentiveMechanism):\n",
    "        \"\"\"Add incentive mechanism to the system\"\"\"\n",
    "        self.incentive_mechanisms.append(mechanism)\n",
    "        \n",
    "    def analyze_demand_patterns(self) -> Dict:\n",
    "        \"\"\"Analyze current demand patterns\"\"\"\n",
    "        \n",
    "        # Calculate hourly demand\n",
    "hourly_demand = np.zeros(24)\n",
    "        \n",
    "        for customer in self.customers:\n",
    "            for hour in range(24):\n",
    "                # Base demand pattern with some randomness\n",
    "                base_demand = customer.base_demand_pattern[hour]\n",
    "                noise = random.uniform(-0.2, 0.2)\n    ",
    "                # Customer-specific factors\n",
    "                if hour in [8, 9, 17, 18]:\n",
    "                    hour_demand *= 1.5  # Peak hours\n",
    "                elif hour in [13, 14]:\n",
    "                    hour_demand *= 0.8  # Lunch dip\n",
    "                \n",
    "                hourly_demand *= (1.0 + customer.price_sensitivity * 0.2)  # Price sensitivity\n",
    "                hourly_demand *= (1.0 + customer.time_preference * 0.1)  # Time preference\n",
    "                hourly_demand *= (1.0 + customer.loyalty_score * 0.1)  # Loyalty bonus\n",
    "                \n",
    "                hourly_demand = max(0.1, hourly_demand)  # Minimum demand\n",
    "                hourly_demand *= (1.0 + customer.responsiveness * 0.1)  # Responsiveness\n",
    "                \n",
    "                hourly_demand += random.uniform(-0.5, 0.5)  # Random noise\n",
    "                \n",
    "                hourly_demand = min(5.0, hourly_demand)  # Cap individual demand\n",
    "                hourly_demand = max(0.1, hourly_demand)  # Minimum demand\n",
    "                \n",
    "                hourly_demand[hour] += hourly_demand\n",
    "        \n",
    "        # Calculate metrics\n",
    "        total_demand = np.sum(hourly_demand)\n",
    "        peak_demand = np.max(hourly_demand)\n",
    "        off_peak_demand = np.min(hourly_demand)\n",
    "        demand_volatility = np.std(hourly_demand) / np.mean(hourly_demand) if np.mean(hourly_demand) > 0 else 0\n",
    "        \n",
    "        # Store in history\n",
    "        self.demand_history.append({\n",
    "            'timestamp': datetime.now(),\n",
    "            'hourly_demand': hourly_demand.tolist(),\n",
    "            'total_demand': total_demand,\n",
    "            'peak_demand': peak_demand,\n",
    "            'off_peak_demand': off_peak_demand,\n",
    "            'demand_volatility': demand_volatility\n",
    "        })\n",
    "        \n",
    "        return {\n",
    "            'hourly_demand': hourly_demand.tolist(),\n",
    "            'total_demand': total_demand,\n",
    "            'peak_demand': peak_demand,\n",
    "            'off_peak_demand': off_peak_demand,\n",
    "    'demand_volatility': demand_volatility,\n",
    "        }\n",
    "    \n",
    "    def create_delivery_options(self, customer: Customer) -> List[DeliveryOption]:\n",
    "        \"\"\"Create delivery options for customer\"\"\"\n",
    "        \n",
    "        options = []\n",
    "        \n",
    "        # Calculate distance from nearest MFC\n",
    "        mfc_locations = [(25, 25), (75, 25), (25, 75), (75, 75)]\n",
    "        nearest_mfc = min(mfc_locations, key=lambda m: np.sqrt((m[0] - customer.location[0])**2 + (m[1] - customer.location[1])**2))\n",
    "        distance = np.sqrt((nearest_mfc[0] - customer.location[0])**2 + (nearest_mfc[1] - customer.location[1])**2)\n",
    "        \n",
    "        # Create multiple delivery options\n",
    "delivery_times = [0.5, 1.0, 2.0, 4.0, 8.0, 24.0]  # Hours from now\n",
    "        price_factors = [1.0, 0.9, 0.8, 0.7, 0.6, 0.5]\n",
    "        \n",
    "        for i, (delivery_time, price_factor) in enumerate(zip(delivery_times, price_factors)):\n",
    "            # Calculate base price\n",
    "            base_price = distance * 2.0 * price_factor\n",
    "            \n",
    "            # Adjust for time preference\n",
    "            if delivery_time <= customer.time_preference * 12:  # Customer prefers early\n",
    "                base_price *= 0.9\n",
    "            elif delivery_time >= customer.time_preference * 18:  # Customer prefers late\n",
    "                base_price *= 0.8\n",
    "            \n",
    "            # Calculate convenience score\n",
    "            convenience = 1.0 - (delivery_time / 24.0)\n",
    "            \n",
    "            # Calculate environmental impact\n",
    "            env_impact = 0.1 if delivery_time < 2 else 0.05  # Faster delivery = lower emissions\n",
    "            \n",
    "            # Calculate capacity utilization\n",
    "            capacity_util = 0.5 + random.uniform(-0.2, 0.3)\n",
    "            \n",
    "            option = DeliveryOption(\n",
    "                id=i,\n",
    "                delivery_time=delivery_time,\n",
    "                price=base_price,\n",
    "                convenience_score=convenience,\n",
    "                environmental_impact=env_impact,\n",
    "                capacity_utilization=capacity_util,\n",
    "                social_proof=[\"Fast delivery\", \"Eco-friendly\", \"Popular choice\"],\n",
    "            )\n",
    "            \n",
    "            options.append(option)\n",
    "        \n",
    "        return options\n",
    "    \n",
    "    def apply_incentives(self, customer: Customer) -> Dict:\n",
    "        \"\"\"Apply incentive mechanisms to customer demand\"\"\"\"\n",
    "        \n",
    "        incentive_effects = {}\n",
    "        \n",
    "        for mechanism in self.incentive_mechanisms:\n",
    "            if customer.id in mechanism.target_segment:\n",
    "                # Calculate incentive effect\n",
    "                if mechanism.type == 'pricing':\n",
    "                    if mechanism.expected_impact > 0:\n",
    "                        # Discount incentive\n",
    "                        price_multiplier = 1.0 - mechanism.incentive_value\n",
    "                        time_window_start, time_window_end = mechanism.time_window\n    ",
    "                        # Apply to relevant time periods\n    ",
    "                        for hour in range(int(time_window_start), min(int(time_window_end), 24):\n",
    "                            incentive_effects[f'hour_{hour}'] = price_multiplier\n",
    "                    \n",
    "                elif mechanism.type == 'nudge':\",
    "                    # Nudge towards off-peak or preferred times\n    ",
    "                    nudge_strength = mechanism.expected_impact\n    ",
    "                    # Apply to relevant time periods\n    ",
    "                    time_window_start, time_window_end = mechanism.time_window\n    ",
    "                    for hour in range(int(time_window_start), min(int(time_window_end), 24):\n",
    "                        incentive_effects[f'hour_{hour}'] = 1.0 + nudge_strength\n",
    "                    \n",
    "                elif mechanism.type == 'suggestion':\n",
    "                    # Smart suggestion based on predictive analytics\n",
    "                    suggestion_strength = mechanism.expected_impact\n    ",
    "                    # Apply to all time periods\n    ",
    "                    for hour in range(24):\n",
    "                        incentive_effects[f'hour_{hour}'] = 1.0 + suggestion_strength * 0.1\n",
    "                \n",
    "                elif mechanism.type == 'gamification':\",
    "                    # Gamification elements\n    ",
    "                    gamification_bonus = mechanism.expected_impact * 0.5\n    ",
    "                    # Apply to all time periods\n    ",
    "                    for hour in range(24):\n",
    "                        incentive_effects[f'hour_{hour}'] = 1.0 + gamification_bonus * 0.2\n",
    "                \n",
    "        return incentive_effects\n",
    "\n",
    "    def generate_smart_suggestions(self, customer: Customer) -> List[Dict]:\n",
    "        \"\"\"Generate smart suggestions based on predictive analytics\"\"\"\"\n",
    "        \n",
    "        suggestions = []\n",
    "        \n",
    "        # Analyze customer's demand patterns\n",
    "        if len(self.demand_history) > 5:\n",
    "            recent_demand = [h['hourly_demand'] for h in self.demand_history[-5:]]\n",
    "            avg_demand = np.mean(recent_demand, axis=0)\n",
    "            demand_trend = np.mean([recent_demand[i+1] - recent_demand[i] for i in range(len(recent_demand)-1)])\n",
    "            \n",
    "            # Generate suggestions based on patterns\n",
    "            if demand_trend > 0.1:  # Increasing demand\n",
    "                suggestions.append({\n",
    "                    'type': 'inventory_suggestion',\n    ",
    "                    'message': f\"Your favorite coffee pods are running low (predicted {avg_demand*30:.1f} remaining). Order now for tomorrow morning delivery and save 12%!\",\n    ",
    "                    'confidence': 0.85,\n    "                    'priority': 'high'\n",
    "                })\n",
    "            elif demand_trend < -0.1:  # Decreasing demand\n",
    "                suggestions.append({\n",
    "                    'type': 'consolidation_suggestion',\n    ",
    "                    'message': f\"Consider consolidating your orders with neighbors in your area for better efficiency.\",\n    ",
    "                    'confidence': 0.80,\n    "                    'priority': 'medium'\n",
    "                else:\n",
    "                suggestions.append({\n",
    "                    'type': 'maintenance_suggestion',\n    ",
    "                    'message': f\"Your delivery patterns are stable. Current service level is optimal.\",\n    ",
    "                    'confidence': 0.90,\n    "                    'priority': 'low'\n",
    "                \n",
    "        else:\n",
    "            # Generate generic suggestions based on customer profile\n",
    "            if customer.loyalty_score > 0.7:\n",
    "                suggestions.append({\n",
    "                    'type': 'loyalty_bonus',\n    ",
    "                    'message': f\"As a loyal customer, you qualify for priority service and exclusive discounts!\",\n    ",
    "                    'confidence': 0.90,\n    "                    'priority': 'high'\n",
    "                })\n",
    "            else:\n",
    "                suggestions.append({\n",
    "                    'type': 'standard_service',\n    ",
    "                    'message': f\"Standard delivery service is available for your location.\",\n    ",
    "                    'confidence': 0.75,\n    "                    'priority': 'low'\n",
    "                \n",
    "        return suggestions\n",
    "\n",
    "    def optimize_market_shaping(self, target_efficiency: float = 0.85) -> Dict:\n",
    "        \"\"\"Optimize market shaping strategies\"\"\"\n",
    "        \n",
    "        print(\"Optimizing market shaping strategies...\")\n",
    "        \n",
    "        optimization_results = {\n",
    "            'target_efficiency': target_efficiency,\n",
    "            'incentive_combinations': [],\n",
    '        }\n        \n",
    "        # Test different incentive combinations\n",
    "        pricing_incentives = [0.85, 0.75, 0.65, 0.55]\n",
    "nudge_incentives = [0.2, 0.15, 0.1, 0.05]\n",
    "        \n",
    "        for pricing_discount in pricing_incentives:\n",
    "            for nudge_incentive in nudge_incentives:\n",
    "                # Test this combination\n    ",
    "                temp_results = self._test_incentive_combination(pricing_discount, nudge_incentive)\n",
    "                optimization_results['incentive_combinations'].append({\n",
    'pricing_discount': pricing_discount,\n",
    "                    'nudge_incentive': nudge_incentive,\n",
    "                    'efficiency': temp_results['efficiency'],\n",
    "                    'cost_savings': temp_results['cost_savings'],\n",
    "                })\n",
    "        \n",
    "        # Find optimal combination\n",
    "if optimization_results['incentive_combinations']:\n",
    "            best_combination = max(optimization_results['incentive_combinations'], \n",
    "                                 key=lambda x: x['efficiency'])\n",
    "            \n",
    "            print(f\"\\n🎯 OPTIMAL MARKET SHAPING STRATEGY:\")\n",
    "            print(f\"   Pricing discount: {best_combination['pricing_discount']:.2f}\")\n",
    "            print(f\"   Nudge incentive: {best_combination['nudge_incentive:.2f}\")\",
    "            print(f\"   Expected efficiency: {best_combination['efficiency']:.2f}\")\",
    "            print(f\"   Cost savings: ${best_combination['cost_savings']:,.2f}\")\n",
    "        \n",
    "        return optimization_results\n",
    "    \n",
    "    def _test_incentive_combination(self, pricing_discount: float, nudge_incentive: float) -> Dict:\n",
    "        \"\"\"Test a specific incentive combination\"\"\"\n",
    "        \n",
    "        # Simulate demand response\n",
    "modified_demand = []\n    "        \n",
    "        for customer in self.customers:\n",
    "            customer_demand = customer.base_demand_pattern.copy()\n    "            \n",
    "            # Apply pricing incentive\n",
    "            for hour in range(24):\n",
    "                if hour in range(8, 12):  # Peak morning\n",
    "                    customer_demand[hour] *= (1.0 - pricing_discount)\n",
    "                elif hour in range(17, 21):  # Peak evening\n    ",
    "                    customer_demand[hour] *= (1.0 + pricing_discount * 0.5)\n",
    "                \n",
    "            # Apply nudge incentive\n",
    "            for hour in range(24):\n",
    "                if hour in range(16, 20):  # Peak evening\n    ",
    "                    customer_demand[hour] *= (1.0 + nudge_incentive)\n",
    "                \n",
    "            modified_demand.extend(customer_demand)\n",
    "        \n        # Calculate metrics\n",
    "total_demand = np.sum(modified_demand)\n",
    "    "peak_demand = np.max(modified_demand)\n",
    "off_peak_demand = np.min(modified_demand)\n",
    "        \n",
    "        # Calculate efficiency (inverse of total cost)\n",
    "total_cost = sum([c.cost_per_km * 5 for c in self.delivery_vehicles]) * len(modified_demand) / len(modified_demand)\n",
    "efficiency = 1.0 / total_cost\n    "        \n",
    "        return {\n",
    "            'efficiency': efficiency,\n",
    "            'total_demand': total_demand,\n",
    "            'peak_demand': peak_demand,\n",
    "            'off_peak_demand': off_peak_demand,\n",
    "            'demand_smoothing': (peak_demand - off_peak_demand) / peak_demand if peak_demand > 0 else 0,\n",
    "        }\n",
    \n",
    "    def simulate_market_dynamics(self, num_days: int = 7) -> Dict:\n",
    "        \"\"\"Simulate market dynamics over multiple days\"\"\"\n",
    "        \n",
    "        print(f\"\\n🔄 Simulating {num_days} days of market dynamics...\")\n",
    "        \n",
    "        daily_results = []\n",
    "        \n",
    "        for day in range(num_days):\n",
    "            print(f\"\\n--- Day {day + 1}/{num_days} ---\")\n",
    "            \n",
    "            # Apply market shaping strategies\n",
    "            optimization = self.optimize_market_shaping(target_efficiency=0.85)\n",
    "            \n",
    "            # Simulate customer responses\n",
    "daily_demand = []\n",
    "            customer_satisfaction = []\n",
    "            operational_efficiency = 0.0\n",
    "            cost_savings = 0.0\n    ",
    "            for customer in self.customers:\n",
    "                # Get base demand\n",
    "                base_demand = customer.base_demand.copy()\n",
    "                \n",
    "                # Apply incentives\n",
    "                incentives = self.apply_incentives(customer)\n",
    "                \n",
    "                # Modified demand for this day\n",
    "                daily_demand.extend([base_demand[hour] * incentives.get(f'hour_{hour}', 1.0) for hour in range(24)])\n",
    "                \n",
    "                # Customer satisfaction based on service quality\n",
    "                service_quality = 0.9 - (0.1 * (1.0 - customer.responsiveness))\n",
    "                customer_satisfaction.append(service_quality)\n",
    "                \n",
    "            # Calculate daily metrics\n",
    "            total_daily_demand = np.sum(daily_demand)\n",
    "            peak_daily_demand = np.max(daily_demand)\n",
    "            off_peak_daily_demand = np.min(daily_demand)\n",
    "            daily_efficiency = 1.0 / (total_daily_demand / 1000)  # Simplified efficiency calculation\n",
    "            \n",
    "            # Calculate cost savings\n",
    "            baseline_cost = total_daily_demand * 2.0  # $2 per delivery\n",
    "            actual_cost = baseline_cost * (2.0 - optimization['cost_savings'])\n",
    "            daily_cost_savings = baseline_cost - actual_cost\n    ",
    "            daily_results.append({\n",
    "                'day': day + 1,\n",
    "                'total_demand': total_daily_demand,\n",
    "                'peak_demand': peak_daily_demand,\n",
    "                'off_peak_demand': off_peak_daily_demand,\n",
    "                'customer_satisfaction': np.mean(customer_satisfaction),\n",
    "                'operational_efficiency': daily_efficiency,\n",
    "                'cost_savings': daily_cost_savings,\n",
    "            })\n",
    "        \n",
    "        # Calculate overall metrics\n",
    "        total_demand_all_days = sum([r['total_demand'] for r in daily_results])\n",
    "        avg_satisfaction = np.mean([r['customer_satisfaction'] for r in daily_results])\n",
    "        avg_efficiency = np.mean([r['operational_efficiency'] for r in daily_results])\n",
    "        total_savings = sum([r['cost_savings'] for r in daily_results])\n",
    "        \n",
    "        return {\n",
    "            'daily_results': daily_results,\n",
    "            'total_demand': total_demand_all_days,\n",
    "            'avg_satisfaction': avg_satisfaction,\n",
    "            'avg_efficiency': avg_efficiency,\n",
    "            'total_savings': total_savings,\n",
    "        }\n",
    "\n",
    "print(\"Market Shaping implementation complete\")"
   ]
