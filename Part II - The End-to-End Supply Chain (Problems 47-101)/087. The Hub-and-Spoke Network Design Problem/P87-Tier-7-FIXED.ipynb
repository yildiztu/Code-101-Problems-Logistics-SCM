    "    print(f\"- Neutral feedback: {neutral_feedback}/{total_records} ({neutral_feedback/total_records*100:.1f}%)\")\n",
    "    print(f\"- Negative feedback: {negative_feedback}/{total_records} ({negative_feedback/total_records*100:.1f}%)\")\n",
    "    \n",
    "    # Learning progression\n",
    "    print(f\"\\nLearning Progression:\")\n",
    "    \n",
    "    if len(partnership.performance_history) >= 2:\n",
    "        early_performance = np.mean([p[\"partnership_effectiveness\"] for p in partnership.performance_history[:3]])\n",
    "        late_performance = np.mean([p[\"partnership_effectiveness\"] for p in partnership.performance_history[-3:]])\n",
    "        \n",
    "        learning_improvement = late_performance - early_performance\n",
    "        print(f\"- Early partnership effectiveness: {early_performance:.2f}\")\n",
