    "# Implement Human-AI Collaboration Interface\n",
    "class HumanAICollaborationInterface:\n",
    "    \"\"\"Interactive interface for human-AI collaboration\"\"\"\n",
    "    \n",
    "    def __init__(self, data: HumanAIPartnershipData):\n",
    "        self.data = data\n",
    "        self.ai_selector = ExplainableSupplierSelector(data)\n",
    "        \n",
    "        # Collaboration state\n",
    "        self.current_decisions = {}\n",
    "        self.human_adjustments = {}\n",
    "        self.final_scores = {}\n",
    "        \n",
    "        # Trust and confidence tracking\n",
    "        self.trust_history = {expert_id: [] for expert_id in data.experts}\n",
    "        self.confidence_history = {expert_id: [] for expert_id in data.experts}\n",
    "        self.agreement_history = []\n",
    "        \n",
    "        # Performance tracking\n",
    "        self.performance_metrics = {\n",
    "            'ai_only_performance': [],\n",
    "            'human_only_performance': [],\n",
    "            'collaborative_performance': []\n",
    "            'decision_accuracy': [],\n",
    "            'time_to_decision': []\n",
    "            'trust_evolution': []\n",
    "            'confidence_evolution': []\n",
    "        }\n",
    "    \n",
    "    def generate_ai_recommendations(self, round_num: int) -> Dict[int, Dict]:\n",
    "        \"\"\"Generate AI recommendations with explanations\"\"\"\n",
    "        suppliers = list(self.data.suppliers.values())\n",
    "        predictions, explanations = self.ai_selector.predict_with_explanation(suppliers)\n",
    "        \n",
    "        ai_recommendations = {}\n",
    "        \n",
    "        for i, (supplier, prediction, shap_vals) in enumerate(zip(suppliers, predictions, explanations['shap_values'])):\n",
    "            # Create human-readable explanation\n",
    "            explanation_text = self._generate_human_readable_explanation(\n",
    "                supplier, prediction, shap_vals, self.ai_selector.feature_names\n",
    "            )\n",
    "            \n",
    "            ai_recommendations[supplier.id] = {\n",
    "                'supplier': supplier,\n",
    "                'ai_score': prediction,\n",
    "                'explanation': explanation_text,\n",
    "                'shap_values': shap_vals,\n",
    "                'confidence': self._calculate_prediction_confidence(prediction),\n",
    "                'recommendation': self._generate_recommendation(prediction, shap_vals)\n",
    "            }\n",
    "        \n",
    "        return ai_recommendations\n",
    "    \n",
    "    def _generate_human_readable_explanation(self, supplier: Supplier, prediction: float, \n",
    "                                          shap_vals: List[float], feature_names: List[str]) -> str:\n",
    "        \"\"\"Generate human-readable explanation for AI recommendation\"\"\"\n",
    "        text = f\"AI Score: {prediction:.3f}. Key contributors: \"\n",
    "        \n",
    "        # Sort features by absolute SHAP impact\n",
    "        feature_impacts = list(zip(feature_names, shap_vals))\n",
    "        feature_impacts.sort(key=lambda x: abs(x[1]), reverse=True)\n",
    "        \n",
    "        # Top 3 contributing features\n",
    "        for feature, impact in feature_impacts[:3]:\n",
    "            direction = \"increases\" if impact > 0 else \"decreases\"\n",
    "            text += f\" {feature.replace('_', ' ').title()}: {direction} score by {abs(impact):.3f}.\"\n",
    "        \n",
    "        # Add confidence and recommendation\n",
    "        confidence = self._calculate_prediction_confidence(prediction)\n",
    "        text += f\" Confidence: {confidence:.1%}. \"\n",
    "        \n",
    "        recommendation = self._generate_recommendation(prediction, shap_vals)\n",
    "        text += f\"Recommendation: {recommendation}.\"\n",
    "        \n",
    "        return text\n",
    "    \n",
    "    def _calculate_prediction_confidence(self, prediction: float) -> float:\n",
    "        \"\"\"Calculate confidence in prediction based on model certainty\"\"\"\n",
    "        # Simplified confidence calculation\n",
    "        if prediction > 0.8 or prediction < 0.2:\n",
    "            return 0.9  # High confidence for extreme values\n",
    "        elif prediction > 0.6 or prediction < 0.4:\n",
    "            return 0.7  # Medium confidence\n",
    "        else:\n",
    "            return 0.5  # Lower confidence for middle values\n",
    "    \n",
    "    def _generate_recommendation(self, prediction: float, shap_vals: List[float]) -> str:\n",
    "        \"\"\"Generate recommendation based on prediction and SHAP values\"\"\"\n",
    "        if prediction > 0.75:\n",
    "            return \"Strongly recommended - excellent overall performance\"\n",
    "        elif prediction > 0.6:\n",
    "            return \"Recommended - good performance with minor concerns\"\n",
    "        elif prediction > 0.4:\n",
    "            return \"Consider with caution - moderate performance\"\n",
    "        else:\n",
    "            return \"Not recommended - significant performance issues\"\n",
    "    \n",
    "    def collect_human_feedback(self, ai_recommendations: Dict[int, Dict], \n",
    "                               expert_id: int) -> Dict[int, float]:\n",
    "        \"\"\"Collect feedback from human expert\"\"\"\n",
    "        expert = self.data.experts[expert_id]\n",
    "        human_adjustments = {}\n",
    "        \n",
    "        print(f\"\\nCollecting feedback from {expert.name} (Expert ID: {expert_id})\")\n",
    "        print(f\"Expert trust level: {expert.trust_level:.1%}, Experience: {expert.experience_years} years\")\n",
    "        \n",
    "        for supplier_id, recommendation in ai_recommendations.items():\n",
    "            supplier = recommendation['supplier']\n",
    "            ai_score = recommendation['ai_score']\n",
    "            \n",
    "            # Simulate human expert decision-making\n",
    "            human_adjustment = self._simulate_human_decision(supplier, ai_score, expert)\n",
    "            human_adjustments[supplier_id] = human_adjustment\n",
    "            \n",
    "            # Create feedback record\n",
    "            feedback = HumanFeedback(\n",
    "                supplier_id=supplier_id,\n",
    "                feedback_type=human_adjustment['type'],\n",
    "                adjustment=human_adjustment['value'],\n",
    "                reason=human_adjustment['reason'],\n",
    "                expert_id=expert_id,\n",
    "                timestamp=f\"Round_{len(self.agreement_history)+1}\"\n",
    "            )\n",
    "            \n",
    "            self.data.feedback_history.append(feedback)\n",
    "        \n",
    "        return human_adjustments\n",
    "    \n",
    "    def _simulate_human_decision(self, supplier: Supplier, ai_score: float, \n",
    "                                expert: HumanExpert) -> Dict[str, Any]:\n",
    "        \"\"\"Simulate human expert decision-making process\"\"\"\n",
    "        human_score = ai_score\n",
    "        adjustment_type = 'none'\n",
    "        adjustment_value = 0\n",
    "        reason = \"AI recommendation accepted\"\n",
    "        \n",
    "        # Human expertise factors\n",
    "        if expert.relationship_focus > 0.7 and supplier.relationship_strength > 0.8:\n",
    "            # Expert values strong relationships\n",
    "            human_score += 0.05\n",
    "            adjustment_type = 'relationship_premium'\n",
    "            adjustment_value = 0.05\n",
    "            reason = \"Strong existing relationship with supplier\"\n",
    "        \n",
    "        if expert.risk_tolerance < 0.3 and supplier.geographic_risk > 0.3:\n",
    "            # Risk-averse expert penalizes geographic risk\n",
    "            human_score -= 0.08\n",
    "            adjustment_type = 'risk_concern'\n",
    "            adjustment_value = -0.08\n",
    "            reason = \"Geographic risk concerns due to political instability\"\n",
    "        \n",
    "        if 'innovation' in expert.expertise_areas and supplier.innovation_capability > 0.85:\n",
    "            # Innovation-focused expert rewards innovation\n",
    "            human_score += 0.06\n",
    "            adjustment_type = 'strategic_alignment'\n",
    "            adjustment_value = 0.06\n",
    "            reason = \"High innovation capability aligns with strategic goals\"\n",
    "        \n",
    "        if 'sustainability' in expert.expertise_areas and supplier.sustainability_score < 0.7:\n",
    "            # Sustainability expert penalizes poor environmental performance\n",
    "            human_score -= 0.07\n",
    "            adjustment_type = 'sustainability_concern'\n",
    "            adjustment_value = -0.07\n",
    "            reason = \"Insufficient sustainability credentials\"\n",
    "        \n",
    "        # Add some randomness based on experience\n",
    "        experience_factor = expert.experience_years / 25  # Normalize by 25 years\n",
    "        noise = np.random.normal(0, 0.02 * (1 - experience_factor))\n",
    "        human_score += noise\n",
    "        \n",
    "        # Ensure score is within bounds\n",
    "        human_score = np.clip(human_score, 0, 1)\n",
    "        \n",
    "        return {\n",
    "            'type': adjustment_type,\n",
    "            'value': adjustment_value,\n",
    "            'reason': reason,\n",
    "            'human_score': human_score,\n",
    "            'ai_score': ai_score\n",
    "        }\n",
    "    \n",
    "    def incorporate_human_feedback(self, ai_recommendations: Dict[int, Dict], \n",
    "                                human_adjustments: Dict[int, float]) -> Dict[int, float]:\n",
    "        \"\"\"Incorporate human feedback to adjust AI scores\"\"\"\n",
    "        final_scores = {}\n",
    "        \n",
    "        for supplier_id in ai_recommendations:\n",
    "            ai_score = ai_recommendations[supplier_id]['ai_score']\n",
    "            human_adjustment = human_adjustments[supplier_id]\n",
    "            \n",
    "            # Combine AI and human inputs\n",
    "            if human_adjustment['type'] == 'none':\n",
    "                final_score = ai_score\n",
    "            else:\n",
    "                # Weighted combination based on trust level\n",
    "                expert_id = list(human_adjustments.keys())[0]  # Simplified\n",
    "                trust_level = self.data.experts[expert_id].trust_level\n",
    "                \n",
    "                final_score = (1 - trust_level) * ai_score + trust_level * human_adjustment['human_score']\n",
    "            \n",
    "            final_scores[supplier_id] = final_score\n",
    "        \n",
    "        return final_scores\n",
    "    \n",
    "    def update_model_with_feedback(self, human_adjustments: Dict[int, Dict]):\n",
    "        \"\"\"Update AI model based on human feedback\"\"\"\n",
    "        # Simplified model update - in practice would retrain with new data\n",
    "        for supplier_id, adjustment in human_adjustments.items():\n",
    "            supplier = self.data.suppliers[supplier_id]\n",
    "            \n",
    "            # Create new training example based on human feedback\n",
    "            features = np.array([\n",
    "                supplier.cost_score, supplier.quality_score, supplier.delivery_reliability,\n",
    "                supplier.financial_stability, supplier.innovation_capability,\n",
    "                supplier.sustainability_score, supplier.geographic_risk,\n",
    "                supplier.capacity_utilization, supplier.relationship_strength,\n",
    "                supplier.regulatory_compliance\n",
    "            ])\n",
    "            \n",
    "            # Use human-adjusted score as target\n",
    "            target = adjustment['human_score']\n",
    "            \n",
    "            # Add to training data\n",
    "            self.ai_selector.training_data.append(features)\n",
    "            self.ai_selector.training_targets.append(target)\n",
    "        \n",
    "        # Retrain model (simplified)\n",
    "        self.ai_selector._train_model()\n",
    "    \n",
    "    def calculate_collaboration_metrics(self, ai_recommendations: Dict[int, Dict], \n",
    "                                      human_adjustments: Dict[int, Dict], \n",
    "                                      final_scores: Dict[int, float]) -> Dict[str, float]:\n",
    "        \"\"\"Calculate collaboration metrics for this round\"\"\"\n",
    "        \n",
    "        # Agreement rate (how close AI and human scores are)\n",
    "        agreement_scores = []\n",
    "        for supplier_id in ai_recommendations:\n",
    "            ai_score = ai_recommendations[supplier_id]['ai_score']\n",
    "            human_score = human_adjustments[supplier_id]['human_score']\n",
    "            agreement = 1 - abs(ai_score - human_score)\n",
    "            agreement_scores.append(agreement)\n",
    "        \n",
    "        agreement_rate = np.mean(agreement_scores)\n",
    "        \n",
    "        # Trust evolution (based on agreement and feedback)\n",
    "        for expert_id in self.data.experts:\n",
    "            current_trust = self.data.experts[expert_id].trust_level\n",
    "            trust_change = (agreement_rate - 0.5) * 0.1  # Gradual trust adjustment\n",
    "            new_trust = np.clip(current_trust + trust_change, 0, 1)\n",
    "            self.data.experts[expert_id].trust_level = new_trust\n",
    "            self.trust_history[expert_id].append(new_trust)\n",
    "        \n",
    "        # Confidence evolution\n",
    "        for expert_id in self.data.experts:\n",
    "            current_confidence = self.data.experts[expert_id].confidence_level\n",
    "            confidence_change = (agreement_rate - 0.5) * 0.05\n",
    "            new_confidence = np.clip(current_confidence + confidence_change, 0, 1)\n",
    "            self.data.experts[expert_id].confidence_level = new_confidence\n",
    "            self.confidence_history[expert_id].append(new_confidence)\n",
    "        \n",
    "        return {\n",
    "            'agreement_rate': agreement_rate,\n",
    "            'avg_trust_level': np.mean([e.trust_level for e in self.data.experts.values()]),\n",
    "            'avg_confidence_level': np.mean([e.confidence_level for e in self.data.experts.values()]),\n",
    "            'human_adjustment_rate': len([a for a in human_adjustments.values() if a['type'] != 'none']) / len(human_adjustments)\n",
    "        }\n",
    "\n",
    "print(\"Human-AI Collaboration Interface defined\")"
