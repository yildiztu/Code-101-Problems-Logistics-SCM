    "# Solve the QUBO using quantum-inspired optimization\n",
    "def solve_quantum_agv_problem(qubo_model: QUBOModel, method: str = \"simulated_annealing\"):\n",
    "    \"\"\"Solve the QUBO model using quantum-inspired optimization\"\"\"\n",
    "    \n",
    "    print(f\"\\n{'='*60}\")\n",
    "    print(\"QUANTUM-INSPIRED OPTIMIZATION\")\n",
    "    print(f\"{'='*60}\")\n",
    "    \n",
    "    # Initialize optimizer\n",
    "    optimizer = QuantumOptimizer(method=method)\n",
    "    \n",
    "    print(f\"Optimization method: {method}\")\n",
    "    print(f\"Problem size: {len(qubo_model.variables)} variables\")\n",
    "    \n",
    "    # Solve the problem\n",
    "    start_time = time.time()\n",
    "    solution, objective_value = optimizer.optimize(qubo_model, max_iterations=1000)\n",
    "    end_time = time.time()\n",
    "    \n",
    "    print(f\"\\nOptimization completed in {end_time - start_time:.2f} seconds\")\n",
    "    print(f\"Objective value: {objective_value:.2f}\")\n",
    "    \n",
    "    # Decode solution\n",
    "    decoded_solution = formulator.decode_solution(solution)\n",
    "    \n",
    "    print(f\"\\nSolution Summary:\")\n",
    "    print(f\"  Task Assignments: {len(decoded_solution['assignments'])}\")\n",
    "    print(f\"  Charging Decisions: {len(decoded_solution['charging_decisions'])}\")\n",
    "    \n",
    "    # Display assignments\n",
    "    if decoded_solution['assignments']:\n",
    "        print(f\"\\nTask Assignments:\")\n",
    "        for agv, task in decoded_solution['assignments']:\n",
    "            print(f\"  {agv} -> {task}\")\n",
    "    \n    " + "# Display charging decisions\n",
    "    if decoded_solution['charging_decisions']:\n",
    "        print(f\"\\nCharging Decisions:\")\n",
    "        for agv, station in decoded_solution['charging_decisions']:\n",
    "            print(f\"  {agv} charges at {station}\")\n",
    "    \n",
    "    # Check constraint violations\n",
    "    violations = check_constraint_violations(decoded_solution, quantum_problem)\n",
    "    \n",
    "    if violations:\n",
    "        print(f\"\\nConstraint Violations:\")\n",
    "        for violation in violations:\n",
    "            print(f\"  - {violation}\")\n",
    "    else:\n",
    "        print(f\"\\nAll constraints satisfied!\")\n",
    "    \n    " + "return {\n",
    "        'solution': solution,\n",
    "        'objective_value': objective_value,\n",
    "        'decoded_solution': decoded_solution,\n",
    "        'violations': violations,\n",
    "        'optimization_time': end_time - start_time,\n",
    "        'optimizer': optimizer\n",
    "    }\n",
    "\n",
    "def check_constraint_violations(decoded_solution: Dict[str, Any], problem: QuantumAGVProblem) -> List[str]:\n",
    "    \"\"\"Check for constraint violations in the solution\"\"\"\n",
    "    \n",
    "    violations = []\n",
    "    \n",
    "    # Check assignment constraints (each task assigned to exactly one AGV)\n",
    "    task_assignments = defaultdict(list)\n",
    "    for agv, task in decoded_solution['assignments']:\n",
    "        task_assignments[task].append(agv)\n",
    "    \n",
    "    for task in problem.tasks:\n",
    "        if task not in task_assignments:\n",
    "            violations.append(f\"Task {task} not assigned to any AGV\")\n",
    "        elif len(task_assignments[task]) > 1:\n",
    "            violations.append(f\"Task {task} assigned to multiple AGVs: {task_assignments[task]}\")\n",
    "    \n",
    "    # Check battery constraints (AGV not charging and working simultaneously)\n",
    "    agv_states = defaultdict(list)\n",
    "    for agv, task in decoded_solution['assignments']:\n",
    "        agv_states[agv].append('working')\n",
    "    for agv, station in decoded_solution['charging_decisions']:\n",
    "        agv_states[agv].append('charging')\n",
    "    \n",
    "    for agv in problem.agvs:\n",
    "        if 'working' in agv_states[agv] and 'charging' in agv_states[agv]:\n",
    "            violations.append(f\"AGV {agv} is both working and charging\")\n",
    "    \n",
    "    return violations\n",
    "\n",
    "# Solve using different methods\n",
    "results = {}\n",
