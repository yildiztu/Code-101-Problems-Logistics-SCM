    "# QUBO data structures\n",
    "@dataclass\n",
    "class QUBOVariable:\n",
    "    \"\"\"Binary variable in QUBO formulation\"\"\"\n",
    "    name: str\n",
    "    index: int\n",
    "    description: str\n",
    "\n",
    "@dataclass\n",
    "class QUBOTerm:\n",
    "    \"\"\"Term in QUBO formulation\"\"\"\n",
    "    variables: List[str]  # Variable names\n",
    "    coefficient: float\n",
    "    constraint_type: str = \"objective\"  # objective, penalty\n",
    "\n",
    "@dataclass\n",
    "class QUBOModel:\n",
    "    \"\"\"Complete QUBO model for AGV dispatching\"\"\"\n",
    "    variables: List[QUBOVariable] = field(default_factory=list)\n",
    "    linear_terms: List[QUBOTerm] = field(default_factory=list)\n",
    "    quadratic_terms: List[QUBOTerm] = field(default_factory=list)\n",
    "    penalty_terms: List[QUBOTerm] = field(default_factory=list)\n",
    "    constant_term: float = 0.0\n",
    "    \n",
    "    def get_qubo_matrix(self) -> np.ndarray:\n",
    "        \"\"\"Convert QUBO to matrix form\"\"\"\n",
    "        n = len(self.variables)\n",
    "        Q = np.zeros((n, n))\n",
    "        \n",
    "        # Add linear terms\n",
    "        for term in self.linear_terms:\n",
    "            var_idx = self.get_variable_index(term.variables[0])\n",
    "            Q[var_idx, var_idx] += term.coefficient\n",
    "        \n",
    "        # Add quadratic terms\n",
    "        for term in self.quadratic_terms:\n",
    "            var1_idx = self.get_variable_index(term.variables[0])\n",
    "            var2_idx = self.get_variable_index(term.variables[1])\n",
    "            Q[var1_idx, var2_idx] += term.coefficient\n",
    "            if var1_idx != var2_idx:\n",
    "                Q[var2_idx, var1_idx] += term.coefficient  # Symmetric\n",
    "        \n",
    "        # Add penalty terms\n",
    "        for term in self.penalty_terms:\n",
    "            if len(term.variables) == 1:\n",
    "                var_idx = self.get_variable_index(term.variables[0])\n",
    "                Q[var_idx, var_idx] += term.coefficient\n",
    "            elif len(term.variables) == 2:\n",
    "                var1_idx = self.get_variable_index(term.variables[0])\n",
    "                var2_idx = self.get_variable_index(term.variables[1])\n",
    "                Q[var1_idx, var2_idx] += term.coefficient\n",
    "                if var1_idx != var2_idx:\n",
    "                    Q[var2_idx, var1_idx] += term.coefficient\n",
    "        \n",
    "        return Q\n",
    "    \n",
    "    def get_variable_index(self, var_name: str) -> int:\n",
    "        \"\"\"Get index of variable by name\"\"\"\n",
    "        for i, var in enumerate(self.variables):\n",
    "            if var.name == var_name:\n",
    "                return i\n",
    "        raise ValueError(f\"Variable {var_name} not found\")\n",
    "    \n",
    "    def evaluate_solution(self, solution: np.ndarray) -> float:\n",
    "        \"\"\"Evaluate objective function for given solution\"\"\"\n",
    "        Q = self.get_qubo_matrix()\n",
    "        return solution.T @ Q @ solution + self.constant_term\n",
    "\n",
    "@dataclass\n",
    "class QuantumAGVProblem:\n",
    "    \"\"\"AGV dispatching problem for quantum optimization\"\"\"\n",
    "    agvs: List[str]\n",
    "    tasks: List[str]\n",
    "    locations: List[str]\n",
    "    charging_stations: List[str]\n",
    "    distance_matrix: Dict[Tuple[str, str], float]\n",
    "    energy_matrix: Dict[Tuple[str, str], float]\n",
    "    battery_capacities: Dict[str, float]\n",
    "    \n",
    "# Quantum optimizer class\nclass QuantumOptimizer:\n",
    "    \"\"\"Quantum optimizer for QUBO problems\"\"\"\n",
    "    \n",
    "    def __init__(self, method: str = \"classical\"):\n",
    "        self.method = method\n",
    "        self.optimization_history = []\n",
    "        self.best_solution = None\n",
    "        self.best_value = float('inf')\n",
    "    \n",
    "    def optimize(self, qubo_model: QUBOModel, max_iterations: int = 1000) -> Tuple[np.ndarray, float]:\n",
    "        \"\"\"Optimize QUBO model\"\"\"\n",
    "        \n",
    "        if self.method == \"classical\":\n",
    "            return self._classical_optimization(qubo_model, max_iterations)\n",
    "        elif self.method == \"simulated_annealing\":\n",
    "            return self._simulated_annealing(qubo_model, max_iterations)\n",
    "        else:\n",
    "            return self._classical_optimization(qubo_model, max_iterations)\n",
    "    \n",
    "    def _classical_optimization(self, qubo_model: QUBOModel, max_iterations: int) -> Tuple[np.ndarray, float]:\n",
    "        \"\"\"Classical optimization using brute force or gradient methods\"\"\"\n",
    "        \n",
    "        n = len(qubo_model.variables)\n",
    "        \n",
    "        if n <= 20:  # Brute force for small problems\n",
    "            return self._brute_force_optimization(qubo_model)\n",
    "        else:\n",
    "            return self._gradient_descent_optimization(qubo_model, max_iterations)\n",
    "    \n",
    "    def _brute_force_optimization(self, qubo_model: QUBOModel) -> Tuple[np.ndarray, float]:\n",
    "        \"\"\"Brute force optimization for small problems\"\"\"\n",
    "        \n",
    "        n = len(qubo_model.variables)\n",
    "        best_solution = None\n",
    "        best_value = float('inf')\n",
    "        \n",
    "        # Try all possible binary combinations\n",
    "        for i in range(2**n):\n",
    "            solution = np.array([(i >> j) & 1 for j in range(n)], dtype=float)\n",
    "            value = qubo_model.evaluate_solution(solution)\n",
    "            \n",
    "            if value < best_value:\n",
    "                best_value = value\n",
    "                best_solution = solution.copy()\n",
    "        \n",
    "        return best_solution, best_value\n",
    "    \n",
    "    def _gradient_descent_optimization(self, qubo_model: QUBOModel, max_iterations: int) -> Tuple[np.ndarray, float]:\n",
    "        \"\"\"Gradient descent optimization for larger problems\"\"\"\n",
    "        \n",
    "        n = len(qubo_model.variables)\n",
    "        Q = qubo_model.get_qubo_matrix()\n",
    "        \n",
    "        # Initialize random solution\n",
    "        solution = np.random.random(n)\n",
    "        learning_rate = 0.1\n",
    "        \n",
    "        for iteration in range(max_iterations):\n",
    "            # Compute gradient\n",
    "            gradient = 2 * Q @ solution\n",
    "            \n",
    "            # Update solution\n",
    "            solution -= learning_rate * gradient\n",
    "            \n",
    "            # Project to binary space\n",
    "            solution = np.round(np.clip(solution, 0, 1))\n",
    "            \n",
    "            # Evaluate\n",
    "            value = qubo_model.evaluate_solution(solution)\n",
    "            \n",
    "            # Store best solution\n",
    "            if value < self.best_value:\n",
    "                self.best_value = value\n",
    "                self.best_solution = solution.copy()\n",
    "            \n",
    "            # Add some random perturbation to escape local minima\n",
    "            if iteration % 100 == 0:\n",
    "                perturbation = np.random.random(n) < 0.1\n",
    "                solution = np.where(perturbation, 1 - solution, solution)\n",
    "            \n",
    "            self.optimization_history.append({\n",
    "                'iteration': iteration,\n",
    "                'value': value,\n",
    "                'best_value': self.best_value\n",
    "            })\n",
    "        \n",
    "        return self.best_solution, self.best_value\n",
    "    \n",
    "    def _simulated_annealing(self, qubo_model: QUBOModel, max_iterations: int) -> Tuple[np.ndarray, float]:\n",
    "        \"\"\"Simulated annealing optimization\"\"\"\n",
    "        \n",
    "        n = len(qubo_model.variables)\n",
    "        \n",
    "        # Initialize random solution\n",
    "        current_solution = np.random.randint(0, 2, n).astype(float)\n",
    "        current_value = qubo_model.evaluate_solution(current_solution)\n",
    "        \n",
    "        best_solution = current_solution.copy()\n",
    "        best_value = current_value\n",
    "        \n",
    "        # Simulated annealing parameters\n",
    "        initial_temp = 10.0\n",
    "        final_temp = 0.01\n",
    "        alpha = 0.99  # Cooling rate\n",
    "        \n",
    "        temperature = initial_temp\n",
    "        \n",
    "        for iteration in range(max_iterations):\n",
    "            # Generate neighbor solution\n",
    "            neighbor = current_solution.copy()\n",
    "            flip_idx = np.random.randint(n)\n",
    "            neighbor[flip_idx] = 1 - neighbor[flip_idx]\n",
    "            \n",
    "            neighbor_value = qubo_model.evaluate_solution(neighbor)\n",
    "            \n",
    "            # Accept or reject\n",
    "            delta = neighbor_value - current_value\n",
    "            \n",
    "            if delta < 0 or np.random.random() < np.exp(-delta / temperature):\n",
    "                current_solution = neighbor\n",
    "                current_value = neighbor_value\n",
    "                \n",
    "                if current_value < best_value:\n",
    "                    best_solution = current_solution.copy()\n",
    "                    best_value = current_value\n",
    "            \n",
    "            # Cool down\n",
    "            temperature *= alpha\n",
    "            temperature = max(temperature, final_temp)\n",
    "            \n",
    "            self.optimization_history.append({\n",
    "                'iteration': iteration,\n",
    "                'value': current_value,\n",
    "                'best_value': best_value,\n",
    "                'temperature': temperature\n",
    "            })\n",
    "        \n",
    "        return best_solution, best_value"
   ]
