    "# QUBO formulation for AGV dispatching\n",
    "class AGVQUBOFormulator:\n",
    "    \"\"\"Formulates AGV dispatching problem as QUBO\"\"\"\n",
    "    \n",
    "    def __init__(self, problem: QuantumAGVProblem):\n",
    "        self.problem = problem\n",
    "        self.qubo_model = QUBOModel()\n",
    "        self.variable_counter = 0\n",
    "        \n",
    "    def formulate_qubo(self, penalty_weight: float = 1000.0) -> QUBOModel:\n",
    "        \"\"\"Formulate the complete QUBO model\"\"\"\n",
    "        \n",
    "        print(\"Formulating QUBO model for AGV dispatching...\")\n",
    "        \n",
    "        # Create decision variables\n",
    "        self._create_decision_variables()\n",
    "        \n",
    "        # Add objective function terms\n",
    "        self._add_objective_terms()\n",
    "        \n",
    "        # Add constraint penalty terms\n",
    "        self._add_assignment_constraints(penalty_weight)\n",
    "        self._add_battery_constraints(penalty_weight)\n",
    "        self._add_routing_constraints(penalty_weight)\n",
    "        \n",
    "        print(f\"QUBO formulation complete:\")\n",
    "        print(f\"  Variables: {len(self.qubo_model.variables)}\")\n",
    "        print(f\"  Linear terms: {len(self.qubo_model.linear_terms)}\")\n",
    "        print(f\"  Quadratic terms: {len(self.qubo_model.quadratic_terms)}\")\n",
    "        print(f\"  Penalty terms: {len(self.qubo_model.penalty_terms)}\")\n",
    "        \n",
    "        return self.qubo_model\n",
    "    \n",
    "    def _create_decision_variables(self):\n",
    "        \"\"\"Create binary decision variables\"\"\"\n",
    "        \n",
    "        # Assignment variables: x[i,j] = 1 if task j assigned to AGV i\n",
    "        for agv in self.problem.agvs:\n",
    "            for task in self.problem.tasks:\n",
    "                var_name = f\"x_{agv}_{task}\"\n",
    "                self.qubo_model.variables.append(\n",
    "                    QUBOVariable(var_name, self.variable_counter, f\"Assign task {task} to AGV {agv}\")\n",
    "                )\n",
    "                self.variable_counter += 1\n",
    "        \n",
    "        # Charging variables: c[i,k] = 1 if AGV i charges at station k\n",
    "        for agv in self.problem.agvs:\n",
    "            for station in self.problem.charging_stations:\n",
    "                var_name = f\"c_{agv}_{station}\"\n",
    "                self.qubo_model.variables.append(\n",
    "                    QUBOVariable(var_name, self.variable_counter, f\"AGV {agv} charges at station {station}\")\n",
    "                )\n",
    "                self.variable_counter += 1\n",
    "        \n",
    "        # Route variables: r[i,j,k] = 1 if AGV i travels from location j to k\n",
    "        for agv in self.problem.agvs:\n",
    "            for loc1 in self.problem.locations:\n",
    "                for loc2 in self.problem.locations:\n",
    "                    if loc1 != loc2:\n",
    "                        var_name = f\"r_{agv}_{loc1}_{loc2}\"\n",
    "                        self.qubo_model.variables.append(\n",
    "                            QUBOVariable(var_name, self.variable_counter, f\"AGV {agv} travels from {loc1} to {loc2}\")\n",
    "                        )\n",
    "                        self.variable_counter += 1\n",
    "    \n",
    "    def _add_objective_terms(self):\n",
    "        \"\"\"Add objective function terms (minimize cost)\"\"\"\n",
    "        \n",
    "        print(\"  Adding objective function terms...\")\n",
    "        \n",
    "        # Travel cost terms\n",
    "        for agv in self.problem.agvs:\n",
    "            for task in self.problem.tasks:\n",
    "                # Cost of assigning task to AGV\n",
    "                cost = self._calculate_assignment_cost(agv, task)\n",
    "                \n",
    "                var_name = f\"x_{agv}_{task}\"\n",
    "                self.qubo_model.linear_terms.append(\n",
    "                    QUBOTerm([var_name], cost, \"objective\")\n",
    "                )\n",
    "        \n",
    "        # Charging cost terms\n",
    "        for agv in self.problem.agvs:\n",
    "            for station in self.problem.charging_stations:\n",
    "                # Cost of charging (opportunity cost)\n",
    "                charging_cost = 5.0  # Simplified charging cost\n",
    "                \n",
    "                var_name = f\"c_{agv}_{station}\"\n",
    "                self.qubo_model.linear_terms.append(\n",
    "                    QUBOTerm([var_name], charging_cost, \"objective\")\n",
    "                )\n",
    "    \n",
    "    def _add_assignment_constraints(self, penalty_weight: float):\n",
    "        \"\"\"Add assignment constraints as penalty terms\"\"\"\n",
    "        \n",
    "        print(\"  Adding assignment constraints...\")\n",
    "        \n",
    "        # Each task must be assigned to exactly one AGV\n",
    "        for task in self.problem.tasks:\n",
    "            assignment_vars = [f\"x_{agv}_{task}\" for agv in self.problem.agvs]\n",
    "            \n",
    "            # Sum of assignments should equal 1\n",
    "            # Penalty: (sum(x) - 1)^2 = sum(x)^2 - 2*sum(x) + 1\n",
    "            \n",
    "            # Linear terms: -2*x_i\n",
    "            for var in assignment_vars:\n",
    "                self.qubo_model.penalty_terms.append(\n",
    "                    QUBOTerm([var], -2 * penalty_weight, \"penalty\")\n",
    "                )\n",
    "            \n",
    "            # Quadratic terms: 2*x_i*x_j\n",
    "            for i, var1 in enumerate(assignment_vars):\n",
    "                for var2 in assignment_vars[i+1:]:\n",
    "                    self.qubo_model.penalty_terms.append(\n",
    "                        QUBOTerm([var1, var2], 2 * penalty_weight, \"penalty\")\n",
    "                    )\n",
    "            \n",
    "            # Constant term: +1\n",
    "            self.qubo_model.constant_term += penalty_weight\n",
    "    \n",
    "    def _add_battery_constraints(self, penalty_weight: float):\n",
    "        \"\"\"Add battery constraints as penalty terms\"\"\"\n",
    "        \n",
    "        print(\"  Adding battery constraints...\")\n",
    "        \n",
    "        # AGV cannot be assigned tasks if battery is too low\n",
    "        for agv in self.problem.agvs:\n",
    "            battery_capacity = self.problem.battery_capacities[agv]\n",
    "            min_battery = battery_capacity * 0.2  # 20% minimum\n",
    "            \n",
    "            # If AGV charges, it cannot be assigned tasks (simplified)\n",
    "            for task in self.problem.tasks:\n",
    "                for station in self.problem.charging_stations:\n",
    "                    # Penalty for charging and working simultaneously\n",
    "                    assign_var = f\"x_{agv}_{task}\"\n",
    "                    charge_var = f\"c_{agv}_{station}\"\n",
    "                    \n",
    "                    self.qubo_model.penalty_terms.append(\n",
    "                        QUBOTerm([assign_var, charge_var], penalty_weight, \"penalty\")\n",
    "                    )\n",
    "    \n",
    "    def _add_routing_constraints(self, penalty_weight: float):\n",
    "        \"\"\"Add routing constraints as penalty terms\"\"\"\n",
    "        \n",
    "        print(\"  Adding routing constraints...\")\n",
    "        \n",
    "        # If AGV is assigned a task, it must travel to pickup and dropoff locations\n",
    "        # This is simplified - in practice, would need more complex routing constraints\n",
    "        \n",
    "        for agv in self.problem.agvs:\n",
    "            for task in self.problem.tasks:\n",
    "                assign_var = f\"x_{agv}_{task}\"\n",
    "                \n",
    "                # Simplified routing penalty (encourages route consistency)\n",
    "                # In practice, would need location-specific routing variables\n",
    "                routing_penalty = penalty_weight * 0.1  # Lower weight for routing\n",
    "                \n",
    "                self.qubo_model.penalty_terms.append(\n",
    "                    QUBOTerm([assign_var], routing_penalty, \"penalty\")\n",
    "                )\n",
    "    \n",
    "    def _calculate_assignment_cost(self, agv: str, task: str) -> float:\n",
    "        \"\"\"Calculate cost of assigning task to AGV\"\"\"\n",
    "        \n",
    "        # Simplified cost calculation\n",
    "        # In practice, would consider distance, battery, time windows, etc.\n",
    "        \n",
    "        base_cost = 10.0\n",
    "        \n",
    "        # Add distance cost (simplified)\n",
    "        distance_cost = random.uniform(5, 15)\n",
    "        \n",
    "        # Add battery consideration\n",
    "        battery_level = random.uniform(20, 100)\n",
    "        battery_factor = 1.0 + (100 - battery_level) / 100\n",
    "        \n",
    "        total_cost = (base_cost + distance_cost) * battery_factor\n",
    "        \n",
    "        return total_cost\n",
    "    \n",
    "    def decode_solution(self, solution: np.ndarray) -> Dict[str, Any]:\n",
    "        \"\"\"Decode binary solution to readable format\"\"\"\n",
    "        \n",
    "        assignments = []\n",
    "        charging_decisions = []\n",
    "        \n",
    "        # Decode assignment variables\n",
    "        for agv in self.problem.agvs:\n",
    "            for task in self.problem.tasks:\n",
    "                var_name = f\"x_{agv}_{task}\"\n",
    "                try:\n",
    "                    var_idx = self.qubo_model.get_variable_index(var_name)\n",
    "                    if solution[var_idx] > 0.5:  # Binary threshold\n",
    "                        assignments.append((agv, task))\n",
    "                except ValueError:\n",
    "                    pass  # Variable not found\n",
    "        \n",
