    "@dataclass\n",
    "class TerminalData:\n",
    "    \"\"\"Historical equipment selection data for a terminal\"\"\"\n",
    "    terminal_id: str\n",
    "    annual_teu: float  # Annual TEU throughput\n",
    "    peak_daily_moves: int  # Peak daily container moves\n",
    "    vessel_size_avg: float  # Average vessel size (TEU)\n",
    "    truck_percentage: float  # Percentage of truck traffic\n",
    "    rail_percentage: float  # Percentage of rail traffic\n",
    "    yard_area: float  # Yard area in hectares\n",
    "    stacking_height_limit: int  # Maximum stacking height\n",
    "    automation_level: float  # Automation level (0-1)\n",
    "    energy_cost_kwh: float  # Energy cost per kWh\n",
    "    labor_cost_hour: float  # Labor cost per hour\n",
    "    maintenance_budget: float  # Annual maintenance budget (M$)\n",
    "    expansion_planned: bool  # Expansion planned\n",
    "    environmental_constraints: float  # Environmental constraint severity (0-1)\n",
    "    budget_capex: float  # Capital expenditure budget (M$)\n",
    "    roi_requirement: float  # Required ROI (percentage)\n",
    "    \n",
    "@dataclass\n",
    "class EquipmentDecision:\n",
    "    \"\"\"Historical equipment selection decision\"\"\"\n",
    "    terminal_features: TerminalData\n",
    "    selected_config: str  # Equipment configuration type\n",
    "    performance_score: float  # Performance outcome (0-1)\n",
    "    cost_efficiency: float  # Cost efficiency (0-1)\n",
    "    operational_uptime: float  # Operational uptime (0-1)\n",
    "\n",
    "@dataclass\n",
    "class FederatedConfig:\n",
    "    \"\"\"Configuration for federated learning\"\"\"\n",
    "    num_rounds: int = 15\n",
    "    local_epochs: int = 10\n",
    "    batch_size: int = 32\n",
    "    learning_rate: float = 0.001\n",
    "    validation_split: float = 0.2\n",
    "    \n",
    "# Equipment configuration types\n",
    "EQUIPMENT_CONFIGS = ['RTG_PURE', 'RMG_PURE', 'SC_PURE', 'HYBRID']\n",
    "\n",
    "print(\"Data structures and configuration defined\")\n",
    "print(f\"Equipment configurations: {EQUIPMENT_CONFIGS}\")"
   ]
