    "class SimpleNeuralNetwork:\n",
    "    \"\"\"Simple neural network implementation for federated learning\"\"\"\n",
    "    \n",
    "    def __init__(self, input_dim: int, hidden_dims: List[int], output_dim: int):\n",
    "        self.input_dim = input_dim\n",
    "        self.hidden_dims = hidden_dims\n",
    "        self.output_dim = output_dim\n",
    "        \n",
    "        # Initialize weights and biases\n",
    "        self.weights = []\n",
    "        self.biases = []\n",
    "        \n",
    "        # Input to first hidden layer\n",
    "        self.weights.append(np.random.randn(input_dim, hidden_dims[0]) * 0.1)\n",
    "        self.biases.append(np.zeros(hidden_dims[0]))\n",
    "        \n",
    "        # Hidden layers\n",
    "        for i in range(len(hidden_dims) - 1):\n",
    "            self.weights.append(np.random.randn(hidden_dims[i], hidden_dims[i+1]) * 0.1)\n",
    "            self.biases.append(np.zeros(hidden_dims[i+1]))\n",
    "        \n",
    "        # Last hidden to output layer\n",
    "        self.weights.append(np.random.randn(hidden_dims[-1], output_dim) * 0.1)\n",
    "        self.biases.append(np.zeros(output_dim))\n",
    "        \n",
    "    def relu(self, x: np.ndarray) -> np.ndarray:\n",
    "        \"\"\"ReLU activation function\"\"\"\n",
    "        return np.maximum(0, x)\n",
    "    \n",
    "    def relu_derivative(self, x: np.ndarray) -> np.ndarray:\n",
    "        \"\"\"ReLU derivative for backpropagation\"\"\"\n",
    "        return (x > 0).astype(float)\n",
    "    \n",
    "    def softmax(self, x: np.ndarray) -> np.ndarray:\n",
    "        \"\"\"Softmax activation for output layer\"\"\"\n",
    "        exp_x = np.exp(x - np.max(x, axis=1, keepdims=True))\n",
    "        return exp_x / np.sum(exp_x, axis=1, keepdims=True)\n",
    "    \n",
    "    def forward(self, x: np.ndarray) -> np.ndarray:\n",
    "        \"\"\"Forward propagation\"\"\"\n",
    "        activations = [x]\n",
    "        z = x\n",
    "        \n",
    "        # Hidden layers with ReLU\n",
    "        for i in range(len(self.weights) - 1):\n",
    "            z = np.dot(z, self.weights[i]) + self.biases[i]\n",
    "            z = self.relu(z)\n",
    "            activations.append(z)\n",
    "        \n",
    "        # Output layer with softmax\n",
    "        z = np.dot(z, self.weights[-1]) + self.biases[-1]\n",
    "        z = self.softmax(z)\n",
    "        activations.append(z)\n",
    "        \n",
    "        return activations\n",
    "    \n",
    "    def backward(self, x: np.ndarray, y: np.ndarray, activations: List[np.ndarray], \n",
    "                  learning_rate: float) -> None:\n",
    "        \"\"\"Backward propagation and weight update\"\"\"\n",
    "        # Calculate output layer error\n",
    "        output_error = activations[-1] - y\n",
    "        \n",
    "        # Backpropagate through layers\n",
    "        delta = output_error\n",
    "        \n",
    "        for i in range(len(self.weights) - 1, 0, -1):\n",
    "            # Calculate gradients\n",
    "            dW = np.dot(activations[i].T, delta) / x.shape[0]\n",
    "            dB = np.sum(delta, axis=0) / x.shape[0]\n",
    "            \n",
    "            # Update weights\n",
    "            self.weights[i] -= learning_rate * dW\n",
    "            self.biases[i] -= learning_rate * dB\n",
    "            \n",
    "            # Calculate delta for next layer\n",
    "            if i > 0:\n",
    "                delta = np.dot(delta, self.weights[i].T) * self.relu_derivative(activations[i])\n",
    "        \n",
    "        # Update first layer\n",
    "        dW = np.dot(activations[0].T, delta) / x.shape[0]\n",
    "        dB = np.sum(delta, axis=0) / x.shape[0]\n",
    "        self.weights[0] -= learning_rate * dW\n",
    "        self.biases[0] -= learning_rate * dB\n",
    "    \n",
    "    def predict(self, x: np.ndarray) -> np.ndarray:\n",
    "        \"\"\"Make predictions\"\"\"\n",
    "        activations = self.forward(x)\n",
    "        return activations[-1]\n",
    "    \n",
    "    def copy_weights(self) -> Tuple[List[np.ndarray], List[np.ndarray]]:\n",
    "        \"\"\"Copy current weights and biases\"\"\"\n",
    "        return [w.copy() for w in self.weights], [b.copy() for b in self.biases]\n",
    "    \n",
    "    def set_weights(self, weights: List[np.ndarray], biases: List[np.ndarray]) -> None:\n",
    "        \"\"\"Set weights and biases\"\"\"\n",
    "        self.weights = [w.copy() for w in weights]\n",
    "        self.biases = [b.copy() for b in biases]\n",
    "\n",
    "print(\"SimpleNeuralNetwork class defined successfully\")"
   ]
  },
