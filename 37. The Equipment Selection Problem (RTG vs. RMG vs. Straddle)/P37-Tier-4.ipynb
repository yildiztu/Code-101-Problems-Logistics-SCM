    "class FederatedEquipmentSelector:\n",
    "    \"\"\"Federated learning system for equipment selection\"\"\"\n",
    "    \n",
    "    def __init__(self, config: FederatedConfig):\n",
    "        self.config = config\n",
    "        self.global_model = None\n",
    "        self.client_models = {}\n",
    "        self.client_weights = {}\n",
    "        self.feature_scaler = StandardScaler()\n",
    "        self.label_encoder = LabelEncoder()\n",
    "        self.training_history = []\n",
    "        \n",
    "    def create_base_model(self, input_dim: int) -> SimpleNeuralNetwork:\n",
    "        \"\"\"Create base neural network model\"\"\"\n",
    "        hidden_dims = [128, 64, 32]  # 3 hidden layers\n",
    "        output_dim = len(EQUIPMENT_CONFIGS)\n",
    "        return SimpleNeuralNetwork(input_dim, hidden_dims, output_dim)\n",
    "    \n",
    "    def extract_features(self, terminal_data: TerminalData) -> np.ndarray:\n",
    "        \"\"\"Extract features from terminal data\"\"\"\n",
    "        features = np.array([\n",
    "            terminal_data.annual_teu,\n",
    "            terminal_data.peak_daily_moves,\n",
    "            terminal_data.vessel_size_avg,\n",
    "            terminal_data.truck_percentage,\n",
    "            terminal_data.rail_percentage,\n",
    "            terminal_data.yard_area,\n",
    "            terminal_data.stacking_height_limit,\n",
    "            terminal_data.automation_level,\n",
    "            terminal_data.energy_cost_kwh,\n",
    "            terminal_data.labor_cost_hour,\n",
    "            terminal_data.maintenance_budget,\n",
    "            float(terminal_data.expansion_planned),\n",
    "            terminal_data.environmental_constraints,\n",
    "            terminal_data.budget_capex,\n",
    "            terminal_data.roi_requirement\n",
    "        ])\n",
    "        return features.reshape(1, -1)\n",
    "    \n",
    "    def encode_config(self, config: str) -> int:\n",
    "        \"\"\"Encode equipment configuration\"\"\"\n",
    "        return self.label_encoder.transform([config])[0]\n",
    "    \n",
    "    def decode_config(self, encoded_config: int) -> str:\n",
    "        \"\"\"Decode equipment configuration\"\"\"\n",
    "        return self.label_encoder.inverse_transform([encoded_config])[0]\n",
    "    \n",
    "    def prepare_client_data(self, historical_decisions: List[EquipmentDecision]) -> Tuple[np.ndarray, np.ndarray]:\n",
    "        \"\"\"Prepare training data for a client\"\"\"\n",
    "        features = []\n",
    "        labels = []\n",
    "        \n",
    "        for decision in historical_decisions:\n",
    "            feature_vector = self.extract_features(decision.terminal_features)\n",
    "            features.append(feature_vector[0])\n",
    "            labels.append(self.encode_config(decision.selected_config))\n",
    "        \n",
    "        return np.array(features), np.array(labels)\n",
    "    \n",
    "    def train_local_model(self, client_id: str, \n",
    "                         historical_decisions: List[EquipmentDecision]) -> float:\n",
    "        \"\"\"Train local model for a client\"\"\"\n",
    "        # Prepare data\n",
    "        X, y = self.prepare_client_data(historical_decisions)\n",
    "        \n",
    "        # Split data\n",
    "        X_train, X_val, y_train, y_val = train_test_split(\n",
    "            X, y, test_size=self.config.validation_split, random_state=42\n",
    "        )\n",
    "        \n",
    "        # Create local model (copy of global model)\n",
    "        if self.global_model is None:\n",
    "            # First client - initialize global model\n",
    "            self.global_model = self.create_base_model(X.shape[1])\n",
    "            self.label_encoder.fit(EQUIPMENT_CONFIGS)\n",
    "            \n",
    "            # Fit scaler on all features\n",
    "            all_features = np.array([self.extract_features(d.terminal_features)[0] \n",
    "                                   for d in historical_decisions])\n",
    "            self.feature_scaler.fit(all_features)\n",
    "        \n",
    "        local_model = SimpleNeuralNetwork(X.shape[1], [128, 64, 32], len(EQUIPMENT_CONFIGS))\n",
    "        local_model.set_weights(*self.global_model.copy_weights())\n",
    "        \n",
    "        # Normalize features\n",
    "        X_train_scaled = self.feature_scaler.transform(X_train)\n",
    "        X_val_scaled = self.feature_scaler.transform(X_val)\n",
    "        \n",
    "        # Convert labels to one-hot encoding\n",
    "        y_train_onehot = np.zeros((len(y_train), len(EQUIPMENT_CONFIGS)))\n",
    "        y_train_onehot[np.arange(len(y_train)), y_train] = 1\n",
    "        \n",
    "        # Training loop\n",
    "        best_val_accuracy = 0.0\n",
    "        \n",
    "        for epoch in range(self.config.local_epochs):\n",
    "            # Mini-batch training\n",
    "            for i in range(0, len(X_train_scaled), self.config.batch_size):\n",
    "                batch_end = min(i + self.config.batch_size, len(X_train_scaled))\n",
    "                X_batch = X_train_scaled[i:batch_end]\n",
    "                y_batch = y_train_onehot[i:batch_end]\n",
    "                \n",
    "                # Forward pass\n",
    "                activations = local_model.forward(X_batch)\n",
    "                \n",
    "                # Backward pass\n",
    "                local_model.backward(X_batch, y_batch, activations, self.config.learning_rate)\n",
    "            \n",
    "            # Validation\n",
    "            val_predictions = local_model.predict(X_val_scaled)\n",
    "            val_pred_labels = np.argmax(val_predictions, axis=1)\n",
    "            val_accuracy = accuracy_score(y_val, val_pred_labels)\n",
    "            \n",
    "            if val_accuracy > best_val_accuracy:\n",
    "                best_val_accuracy = val_accuracy\n",
    "        \n",
    "        # Store local model\n",
    "        self.client_models[client_id] = local_model\n",
    "        \n",
    "        # Calculate aggregation weight (validation accuracy * sqrt(data size))\n",
    "        data_size_factor = np.sqrt(len(historical_decisions))\n",
    "        aggregation_weight = best_val_accuracy * data_size_factor\n",
    "        self.client_weights[client_id] = aggregation_weight\n",
    "        \n",
    "        return best_val_accuracy\n",
    "    \n",
    "    def federated_averaging(self) -> None:\n",
    "        \"\"\"Aggregate client models using federated averaging\"\"\"\n",
    "        if not self.client_models:\n",
    "            return\n",
    "        \n",
    "        # Normalize weights\n",
    "        total_weight = sum(self.client_weights.values())\n",
    "        normalized_weights = {k: v / total_weight for k, v in self.client_weights.items()}\n",
    "        \n",
    "        # Get global model weights\n",
    "        global_weights, global_biases = self.global_model.copy_weights()\n",
    "        \n",
    "        # Initialize aggregated weights\n",
    "        aggregated_weights = [np.zeros_like(w) for w in global_weights]\n",
    "        aggregated_biases = [np.zeros_like(b) for b in global_biases]\n",
    "        \n",
    "        # Weighted sum of client models\n",
    "        for client_id, weight in normalized_weights.items():\n",
    "            client_model = self.client_models[client_id]\n",
    "            client_weights, client_biases = client_model.copy_weights()\n",
    "            \n",
    "            for i in range(len(aggregated_weights)):\n",
    "                aggregated_weights[i] += weight * client_weights[i]\n",
    "                aggregated_biases[i] += weight * client_biases[i]\n",
    "        \n",
    "        # Update global model\n",
    "        self.global_model.set_weights(aggregated_weights, aggregated_biases)\n",
    "    \n",
    "    def evaluate_global_model(self, test_data: Dict[str, List[EquipmentDecision]]) -> float:\n",
    "        \"\"\"Evaluate global model on all client test data\"\"\"\n",
    "        total_accuracy = 0.0\n",
    "        total_samples = 0\n",
    "        \n",
    "        for client_id, decisions in test_data.items():\n",
    "            if len(decisions) == 0:\n",
    "                continue\n",
    "                \n",
    "            X_test, y_test = self.prepare_client_data(decisions)\n",
    "            X_test_scaled = self.feature_scaler.transform(X_test)\n",
    "            \n",
    "            predictions = self.global_model.predict(X_test_scaled)\n",
    "            pred_labels = np.argmax(predictions, axis=1)\n",
    "            \n",
    "            accuracy = accuracy_score(y_test, pred_labels)\n",
    "            total_accuracy += accuracy * len(decisions)\n",
    "            total_samples += len(decisions)\n",
    "        \n",
    "        return total_accuracy / total_samples if total_samples > 0 else 0.0\n",
    "    \n",
    "    def predict_equipment(self, terminal_features: TerminalData) -> List[Dict]:\n",
    "        \"\"\"Predict optimal equipment configuration\"\"\"\n",
    "        if self.global_model is None:\n",
    "            raise ValueError(\"Model not trained yet\")\n",
    "        \n",
    "        # Extract and normalize features\n",
    "        features = self.extract_features(terminal_features)\n",
    "        features_scaled = self.feature_scaler.transform(features)\n",
    "        \n",
    "        # Make predictions\n",
    "        predictions = self.global_model.predict(features_scaled)\n",
    "        \n",
    "        # Format results\n",
    "        results = []\n",
    "        for config, prob in zip(EQUIPMENT_CONFIGS, predictions[0]):\n",
    "            strength = self.get_strength_rating(prob)\n",
    "            results.append({\n",
    "                'configuration': config,\n",
    "                'confidence': prob,\n",
    "                'strength': strength\n",
    "            })\n",
    "        \n",
    "        # Sort by confidence\n",
    "        results.sort(key=lambda x: x['confidence'], reverse=True)\n",
    "        return results\n",
    "    \n",
    "    def get_strength_rating(self, probability: float) -> str:\n",
    "        \"\"\"Classify recommendation strength\"\"\"\n",
    "        if probability > 0.7:\n",
    "            return \"STRONG\"\n",
    "        elif probability > 0.5:\n",
    "            return \"MODERATE\"\n",
    "        elif probability > 0.3:\n",
    "            return \"WEAK\"\n",
    "        else:\n",
    "            return \"NOT_RECOMMENDED\"\n",
    "    \n",
    "    def federation_round(self, client_data: Dict[str, List[EquipmentDecision]], \n",
    "                        test_data: Dict[str, List[EquipmentDecision]]) -> float:\n",
    "        \"\"\"Execute one round of federated learning\"\"\"\n",
    "        print(f\"\\n--- Federation Round ---\")\n",
    "        \n",
    "        # Phase 1: Train local models\n",
    "        local_accuracies = {}\n",
    "        for client_id, data in client_data.items():\n",
    "            val_accuracy = self.train_local_model(client_id, data)\n",
    "            local_accuracies[client_id] = val_accuracy\n",
    "            print(f\"Client {client_id}: Validation accuracy = {val_accuracy:.3f}\")\n",
    "        \n",
    "        # Phase 2: Federated averaging\n",
    "        self.federated_averaging()\n",
    "        print(\"Federated averaging completed\")\n",
    "        \n",
    "        # Phase 3: Evaluate global model\n",
    "        global_accuracy = self.evaluate_global_model(test_data)\n",
    "        print(f\"Global model accuracy: {global_accuracy:.3f}\")\n",
    "        \n",
    "        return global_accuracy\n",
    "    \n",
    "    def train_federated_model(self, client_data: Dict[str, List[EquipmentDecision]], \n",
    "                            test_data: Dict[str, List[EquipmentDecision]]) -> List[float]:\n",
    "        \"\"\"Train complete federated model\"\"\"\n",
    "        print(f\"Starting federated learning with {len(client_data)} clients\")\n",
    "        print(f\"Training for {self.config.num_rounds} rounds\")\n",
    "        \n",
    "        accuracies = []\n",
    "        start_time = time.time()\n",
    "        \n",
    "        for round_num in range(self.config.num_rounds):\n",
    "            print(f\"\\n{'='*50}\")\n",
    "            print(f\"Round {round_num + 1}/{self.config.num_rounds}\")\n",
    "            print(f\"{'='*50}\")\n",
    "            \n",
    "            accuracy = self.federation_round(client_data, test_data)\n",
    "            accuracies.append(accuracy)\n",
    "            self.training_history.append({\n",
    "                'round': round_num + 1,\n",
    "                'accuracy': accuracy,\n",
    "                'client_weights': self.client_weights.copy()\n",
    "            })\n",
    "        \n",
    "        end_time = time.time()\n",
    "        print(f\"\\nFederated training completed in {end_time - start_time:.2f} seconds\")\n",
    "        print(f\"Final global accuracy: {accuracies[-1]:.3f}\")\n",
    "        \n",
    "        return accuracies\n",
    "\n",
