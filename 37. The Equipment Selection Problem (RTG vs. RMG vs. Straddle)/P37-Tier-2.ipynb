   "source": [
    "@dataclass\n",
    "class EquipmentConstraints:\n",
    "    \"\"\"Constraints for equipment selection problem\"\"\"\n",
    "    budget_m: float  # Total budget in millions\n",
    "    min_capacity: int  # Minimum daily capacity requirement\n",
    "    num_blocks: int  # Number of container blocks\n",
    "    max_equipment_per_block: int = 5  # Maximum equipment units per block\n",
    "    compatibility_matrix: Dict[str, List[str]] = field(default_factory=dict)  # Equipment compatibility\n",
    "    synergy_requirements: Dict[str, float] = field(default_factory=dict)  # Minimum synergy scores\n",
    "\n",
    "@dataclass\n",
    "class EquipmentDomain:\n",
    "    \"\"\"Domain definition for equipment type\"\"\"\n",
    "    name: str\n",
    "    min_qty: int\n",
    "    max_qty: int\n",
    "    unit_cost_m: float  # Cost per unit in millions\n",
    "    capacity_per_unit: int  # Daily capacity per unit\n",
    "    flexibility_score: float  # Flexibility score (0-1)\n",
    "\n",
    "@dataclass \n",
    "class SearchNode:\n",
    "    \"\"\"Node in the backtracking search tree\"\"\"\n",
    "    assignment: Dict[str, int]  # Partial equipment assignment\n",
    "    remaining_vars: List[Tuple[str, int, int]]  # Remaining (type, min, max) variables\n",
    "    depth: int  # Current depth in search tree\n",
    "    parent_id: Optional[int] = None  # Parent node ID for tree visualization\n",
    "    node_id: int = 0  # Unique node identifier\n",
    "    pruned: bool = False  # Whether this node was pruned\n",
    "    prune_reason: str = \"\"  # Reason for pruning\n",
    "\n",
    "# Define equipment domains based on the source material\n",
    "EQUIPMENT_DOMAINS = {\n",
    "    'RTG': EquipmentDomain(\n",
    "        name='RTG',\n",
    "        min_qty=8,\n",
    "        max_qty=20,\n",
    "        unit_cost_m=12.0,\n",
    "        capacity_per_unit=352,  # 22 moves/hour * 16 hours\n",
    "        flexibility_score=0.8\n",
    "    ),\n",
    "    'RMG': EquipmentDomain(\n",
    "        name='RMG',\n",
    "        min_qty=6,\n",
