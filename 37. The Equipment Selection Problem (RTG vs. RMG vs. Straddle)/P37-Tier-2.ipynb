    "scores = [sol['composite_score'] for sol in solutions]\n",
    "costs = [sol['total_cost'] for sol in solutions]\n",
    "capacities = [sol['total_capacity'] for sol in solutions]\n",
    "\n",
    "scatter = ax3.scatter(costs, capacities, c=scores, s=100, alpha=0.7, cmap='viridis')\n",
    "ax3.set_xlabel('Total Cost (Million $)', fontsize=12)\n",
    "ax3.set_ylabel('Total Capacity (Moves/Day)', fontsize=12)\n",
    "ax3.set_title('Solution Quality Distribution', fontsize=14, fontweight='bold')\n",
    "plt.colorbar(scatter, ax=ax3, label='Composite Score')\n",
    "ax3.grid(True, alpha=0.3)\n",
    "\n",
    "# Highlight top 3 solutions\n",
    "for i, sol in enumerate(solutions[:3]):\n",
    "    ax3.annotate(f\"Top {i+1}\", (sol['total_cost'], sol['total_capacity']), \n",
    "                xytext=(5, 5), textcoords='offset points', fontsize=10, fontweight='bold')\n",
    "\n",
    "# 4. Constraint Satisfaction Analysis\n",
    "ax4 = axes[1, 1]\n",
    "ax4.axis('tight')\n",
    "ax4.axis('off')\n",
    "\n",
    "# Create constraint satisfaction table\n",
    "constraint_data = []\n",
    "for i, sol in enumerate(solutions[:8]):\n",
    "    budget_utilization = sol['total_cost'] / constraints.budget_m\n",
    "capacity_utilization = sol['total_capacity'] / constraints.min_capacity\n",
    "    equipment_density = sol['total_equipment'] / (constraints.num_blocks * constraints.max_equipment_per_block)\n",
