    "class ConstraintPropagationBacktracker:\n",
    "    \"\"\"Backtracking algorithm with constraint propagation for equipment selection\"\"\"\n",
    "    \n",
    "    def __init__(self, equipment_domains: Dict[str, EquipmentDomain], \n",
    "                 constraints: EquipmentConstraints):\n",
    "        self.domains = equipment_domains\n",
    "        self.constraints = constraints\n",
    "        self.solutions = []\n",
    "        self.search_tree = []\n",
    "        self.node_counter = 0\n",
    "        self.pruned_count = 0\n",
    "        self.propagation_count = 0\n",
    "        \n",
    "    def get_equipment_cost(self, eq_type: str, quantity: int) -> float:\n",
    "        \"\"\"Calculate total cost for equipment type and quantity\"\"\"\n",
    "        domain = self.domains[eq_type]\n",
    "        return domain.unit_cost_m * quantity\n",
    "    \n",
    "    def get_equipment_capacity(self, eq_type: str, quantity: int) -> int:\n",
    "        \"\"\"Calculate total capacity for equipment type and quantity\"\"\"\n",
    "        domain = self.domains[eq_type]\n",
    "        return domain.capacity_per_unit * quantity\n",
    "    \n",
    "    def check_consistency(self, assignment: Dict[str, int]) -> bool:\n",
    "        \"\"\"Check if partial assignment satisfies all constraints\"\"\"\n",
    "        # Calculate total cost and capacity from current assignment\n",
    "        total_cost = sum(self.get_equipment_cost(eq, qty) \n",
    "                       for eq, qty in assignment.items())\n",
    "        total_capacity = sum(self.get_equipment_capacity(eq, qty) \n",
    "                           for eq, qty in assignment.items())\n",
    "        \n",
    "        # Check budget constraint\n",
    "        if total_cost > self.constraints.budget_m:\n",
    "            return False\n",
    "        \n",
    "        # Check capacity constraint (only if all equipment types assigned)\n",
    "        if len(assignment) == len(self.domains):\n",
    "            if total_capacity < self.constraints.min_capacity:\n",
    "                return False\n",
    "        \n",
    "        # Check equipment per block constraint\n",
    "        total_equipment = sum(assignment.values())\n",
    "        if total_equipment > self.constraints.max_equipment_per_block * self.constraints.num_blocks:\n",
    "            return False\n",
    "        \n",
    "        return True\n",
    "    \n",
    "    def propagate_domains(self, assignment: Dict[str, int], \n",
    "                         remaining_vars: List[Tuple[str, int, int]]) -> List[Tuple[str, int, int]]:\n",
    "        \"\"\"Apply constraint propagation to reduce variable domains\"\"\"\n",
    "        self.propagation_count += 1\n",
    "        \n",
    "        # Calculate remaining budget\n",
    "        used_budget = sum(self.get_equipment_cost(eq, qty) \n",
    "                        for eq, qty in assignment.items())\n",
    "        remaining_budget = self.constraints.budget_m - used_budget\n",
    "        \n",
    "        # Calculate minimum additional capacity needed (if not all assigned)\n",
    "        current_capacity = sum(self.get_equipment_capacity(eq, qty) \n",
    "                             for eq, qty in assignment.items())\n",
    "        remaining_capacity_needed = max(0, self.constraints.min_capacity - current_capacity)\n",
    "        \n",
    "        propagated_vars = []\n",
    "        \n",
    "        for var in remaining_vars:\n",
    "            eq_type, min_qty, max_qty = var\n",
    "            domain = self.domains[eq_type]\n",
    "            \n",
    "            # Budget propagation: reduce maximum affordable quantity\n",
    "            max_affordable = int(remaining_budget // domain.unit_cost_m)\n",
    "            new_max_qty = min(max_qty, max_affordable)\n",
    "            \n",
    "            # Capacity propagation: ensure minimum capacity can be achieved\n",
    "            if remaining_capacity_needed > 0 and len(remaining_vars) == 1:\n",
    "                # Last variable - must meet remaining capacity requirement\n",
    "                min_needed_qty = int(np.ceil(remaining_capacity_needed / domain.capacity_per_unit))\n",
    "                new_min_qty = max(min_qty, min_needed_qty)\n",
    "            else:\n",
    "                new_min_qty = min_qty\n",
    "            \n",
    "            # Only keep variable if domain is still valid\n",
    "            if new_min_qty <= new_max_qty:\n",
    "                propagated_vars.append((eq_type, new_min_qty, new_max_qty))\n",
    "        \n",
    "        return propagated_vars\n",
    "    \n",
    "    def backtrack(self, assignment: Dict[str, int], \n",
    "                  remaining_vars: List[Tuple[str, int, int]], \n",
    "                  depth: int = 0, parent_id: Optional[int] = None) -> None:\n",
    "        \"\"\"Recursive backtracking search with constraint propagation\"\"\"\n",
    "        \n",
    "        # Create search tree node\n",
    "        node_id = self.node_counter\n",
    "        self.node_counter += 1\n",
    "        \n",
    "        node = SearchNode(\n",
    "            assignment=assignment.copy(),\n",
    "            remaining_vars=remaining_vars.copy(),\n",
    "            depth=depth,\n",
    "            parent_id=parent_id,\n",
    "            node_id=node_id\n",
    "        )\n",
    "        \n",
    "        # Base case: no remaining variables\n",
    "        if not remaining_vars:\n",
    "            if self.check_consistency(assignment):\n",
    "                # Complete solution found\n",
    "                complete_solution = assignment.copy()\n",
    "                complete_solution.update({\n",
    "                    'total_cost': sum(self.get_equipment_cost(eq, qty) \n",
    "                                    for eq, qty in assignment.items()),\n",
    "                    'total_capacity': sum(self.get_equipment_capacity(eq, qty) \n",
    "                                       for eq, qty in assignment.items()),\n",
    "                    'total_equipment': sum(assignment.values())\n",
    "                })\n",
    "                self.solutions.append(complete_solution)\n",
    "            self.search_tree.append(node)\n",
    "            return\n",
    "        \n",
    "        # Apply constraint propagation\n",
    "        propagated_vars = self.propagate_domains(assignment, remaining_vars)\n",
    "        \n",
    "        # Prune if no valid variables remain\n",
    "        if not propagated_vars:\n",
    "            node.pruned = True\n",
    "            node.prune_reason = \"No valid variables after propagation\"\n",
    "            self.pruned_count += 1\n",
    "            self.search_tree.append(node)\n",
    "            return\n",
    "        \n",
    "        # Select first variable (could implement more sophisticated selection heuristics)\n",
    "        var = propagated_vars[0]\n",
    "        eq_type, min_qty, max_qty = var\n",
    "        remaining_after_var = propagated_vars[1:]\n",
    "        \n",
    "        # Try each value in the variable's domain\n",
    "        for qty in range(min_qty, max_qty + 1):\n",
    "            new_assignment = assignment.copy()\n",
    "            new_assignment[eq_type] = qty\n",
    "            \n",
    "            # Check consistency before proceeding\n",
    "            if self.check_consistency(new_assignment):\n",
    "                self.backtrack(new_assignment, remaining_after_var, depth + 1, node_id)\n",
    "        \n",
    "        self.search_tree.append(node)\n",
    "    \n",
    "    def calculate_composite_score(self, solution: Dict[str, int]) -> float:\n",
    "        \"\"\"Calculate composite score for solution ranking\"\"\"\n",
    "        # Extract solution components\n",
    "        equipment_assignment = {k: v for k, v in solution.items() \n",
    "                              if k in self.domains}\n",
    "        total_cost = solution.get('total_cost', 0)\n",
    "        total_capacity = solution.get('total_capacity', 0)\n",
    "        total_equipment = solution.get('total_equipment', 0)\n",
    "        \n",
    "        # Calculate flexibility score\n",
    "        flexibility_score = sum(self.domains[eq].flexibility_score * qty \n",
    "                              for eq, qty in equipment_assignment.items())\n",
    "        flexibility_score /= max(1, total_equipment)\n",
    "        \n",
    "        # Normalize components (0-1 scale, higher is better)\n",
    "        cost_score = max(0, 1 - total_cost / self.constraints.budget_m)  # Lower cost is better\n",
    "        capacity_score = min(1, total_capacity / (self.constraints.min_capacity * 1.5))  # Higher capacity is better\n",
    "        efficiency_score = total_capacity / max(1, total_equipment)  # Moves per equipment unit\n",
    "        \n",
    "        # Weighted composite score\n",
    "        weights = {'cost': 0.3, 'capacity': 0.4, 'flexibility': 0.2, 'efficiency': 0.1}\n",
    "        composite_score = (\n",
    "            weights['cost'] * cost_score +\n",
    "            weights['capacity'] * capacity_score +\n",
    "            weights['flexibility'] * flexibility_score +\n",
    "            weights['efficiency'] * efficiency_score\n",
    "        )\n",
    "        \n",
    "        return composite_score\n",
    "    \n",
    "    def solve(self) -> List[Dict]:\n",
    "        \"\"\"Solve the equipment selection problem\"\"\"\n",
    "        print(\"Starting constraint propagation backtracking search...\")\n",
    "        start_time = time.time()\n",
    "        \n",
    "        # Initialize variables\n",
    "        variables = [(name, domain.min_qty, domain.max_qty) \n",
    "                   for name, domain in self.domains.items()]\n",
    "        \n",
    "        # Start backtracking search\n",
    "        self.backtrack({}, variables)\n",
    "        \n",
    "        # Rank solutions\n",
    "        for solution in self.solutions:\n",
    "            solution['composite_score'] = self.calculate_composite_score(solution)\n",
    "        \n",
    "        ranked_solutions = sorted(self.solutions, \n",
    "                                key=lambda x: x['composite_score'], \n",
    "                                reverse=True)\n",
    "        \n",
    "        end_time = time.time()\n",
    "        \n",
    "        print(f\"Search completed in {end_time - start_time:.3f} seconds\")\n",
    "        print(f\"Explored {self.node_counter} nodes\")\n",
    "        print(f\"Pruned {self.pruned_count} nodes\")\n",
    "        print(f\"Applied constraint propagation {self.propagation_count} times\")\n",
    "        print(f\"Found {len(self.solutions)} feasible solutions\")\n",
    "        \n",
    "        return ranked_solutions\n",
    "\n",
    "print(\"ConstraintPropagationBacktracker class defined successfully\")"
   ]
  },
