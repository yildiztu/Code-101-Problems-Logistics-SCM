    "        f\"{equipment_density:.1%}\",\n",
    "        f\"{sol['composite_score']:.3f}\"\n",
    "    ])\n",
    "\n",
    "table = ax4.table(cellText=constraint_data,\n",
    "                 colLabels=['Rank', 'Budget Used', 'Capacity Met', 'Equipment Density', 'Score'],\n",
    "                 cellLoc='center',\n",
