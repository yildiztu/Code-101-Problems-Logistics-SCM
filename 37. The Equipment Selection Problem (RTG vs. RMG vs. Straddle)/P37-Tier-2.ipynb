    "# Initialize the constraint propagation backtracker\n",
    "constraints = EquipmentConstraints(\n",
    "    budget_m=180.0,  # $180 million budget\n",
    "    min_capacity=2400,  # 2,400 moves per day\n",
    "    num_blocks=8,  # 8 container blocks\n",
    "    max_equipment_per_block=5  # Maximum 5 equipment units per block\n",
    ")\n",
    "\n",
    "backtracker = ConstraintPropagationBacktracker(\n",
    "    equipment_domains=EQUIPMENT_DOMAINS,\n",
    "    constraints=constraints\n",
    ")\n",
    "\n",
    "# Solve the equipment selection problem\n",
    "solutions = backtracker.solve()\n",
    "\n",
    "print(\"\\n=== TOP 5 RANKED SOLUTIONS ===\")\n",
    "for i, solution in enumerate(solutions[:5]):\n",
    "    print(f\"\\nRank {i+1}: Composite Score: {solution['composite_score']:.3f}\")\n",
    "    for eq_type in ['RTG', 'RMG', 'SC']:\n",
    "        if eq_type in solution:\n",
    "            print(f\"  {eq_type}: {solution[eq_type]} units\")\n",
    "    print(f\"  Total Cost: ${solution['total_cost']:.1f}M\")\n",
    "    print(f\"  Total Capacity: {solution['total_capacity']:,} moves/day\")\n",
    "    print(f\"  Total Equipment: {solution['total_equipment']} units\")"
   ]
