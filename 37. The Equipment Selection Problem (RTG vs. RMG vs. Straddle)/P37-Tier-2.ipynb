    "# Visualize search tree and pruning efficiency\n",
    "fig, axes = plt.subplots(2, 2, figsize=(16, 12))\n",
    "fig.suptitle('Constraint Propagation Backtracking Analysis', fontsize=16, fontweight='bold')\n",
    "\n",
    "# 1. Search Tree Depth Distribution\n",
    "ax1 = axes[0, 0]\n",
    "depths = [node.depth for node in backtracker.search_tree]\n",
    "pruned_depths = [node.depth for node in backtracker.search_tree if node.pruned]\n",
    "solution_depths = [node.depth for node in backtracker.search_tree \n",
    "                  if not node.pruned and not node.remaining_vars]\n",
    "\n",
    "ax1.hist(depths, bins=20, alpha=0.7, label='All Nodes', color='skyblue')\n",
    "ax1.hist(pruned_depths, bins=20, alpha=0.7, label='Pruned Nodes', color='red')\n",
    "ax1.hist(solution_depths, bins=20, alpha=0.7, label='Solution Nodes', color='green')\n",
    "ax1.set_xlabel('Search Depth', fontsize=12)\n",
    "ax1.set_ylabel('Number of Nodes', fontsize=12)\n",
    "ax1.set_title('Search Tree Depth Distribution', fontsize=14, fontweight='bold')\n",
    "ax1.legend()\n",
    "ax1.grid(True, alpha=0.3)\n",
    "\n",
    "# 2. Pruning Efficiency Over Time\n",
    "ax2 = axes[0, 1]\n",
    "cumulative_nodes = []\n",
    "cumulative_pruned = []\n",
    "pruned_so_far = 0\n",
    "\n",
    "for i, node in enumerate(backtracker.search_tree):\n",
    "    cumulative_nodes.append(i + 1)\n",
    "    if node.pruned:\n",
    "        pruned_so_far += 1\n",
    "    cumulative_pruned.append(pruned_so_far)\n",
    "\n",
    "ax2.plot(cumulative_nodes, cumulative_pruned, linewidth=2, color='red')\n",
    "ax2.fill_between(cumulative_nodes, cumulative_pruned, alpha=0.3, color='red')\n",
    "ax2.set_xlabel('Nodes Explored', fontsize=12)\n",
    "ax2.set_ylabel('Cumulative Pruned Nodes', fontsize=12)\n",
    "ax2.set_title('Pruning Efficiency During Search', fontsize=14, fontweight='bold')\n",
    "ax2.grid(True, alpha=0.3)\n",
    "\n",
    "# Add pruning efficiency percentage\n",
    "pruning_efficiency = backtracker.pruned_count / backtracker.node_counter * 100\n",
    "ax2.text(0.05, 0.95, f'Pruning Efficiency: {pruning_efficiency:.1f}%', \n",
    "         transform=ax2.transAxes, fontsize=12, verticalalignment='top',\n",
    "         bbox=dict(boxstyle='round', facecolor='wheat', alpha=0.8))\n",
    "\n",
