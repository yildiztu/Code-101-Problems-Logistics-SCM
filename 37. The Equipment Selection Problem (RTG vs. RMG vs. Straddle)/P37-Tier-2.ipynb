    "    'SC': EquipmentDomain(\n",
    "        name='Straddle',\n",
    "        min_qty=16,\n",
    "        max_qty=32,\n",
    "        unit_cost_m=4.0,\n",
    "        capacity_per_unit=288,  # 18 moves/hour * 16 hours\n",
    "        flexibility_score=0.9\n",
    "    )\n",
    "}\n",
    "\n",
    "print(\"Equipment domains and constraints defined successfully\")\n",
    "for eq_name, domain in EQUIPMENT_DOMAINS.items():\n",
    "    print(f\"{domain.name}: {domain.min_qty}-{domain.max_qty} units, \"\n",
    "          f\"${domain.unit_cost_m}M/unit, {domain.capacity_per_unit} capacity/unit\")"
   ]
