    "class ExplainableAISystem:\n",
    "    \"\"\"Explainable AI system for equipment selection\"\"\"\n",
    "    \n",
    "    def __init__(self, config: CentaurConfig):\n",
    "        self.config = config\n",
    "        self.historical_data = self._load_historical_data()\n",
    "        self.global_benchmarks = self._load_global_benchmarks()\n",
    "        self.learning_history = []\n",
    "        \n",
    "    def _load_historical_data(self) -> Dict[str, List[Dict]]:\n",
    "        \"\"\"Load historical equipment selection data\"\"\"\n",
    "        # Simulated historical data from multiple terminals\n",
    "        return {\n",
    "            'RTG_PURE': [\n",
    "                {'terminal': 'Terminal_A', 'cost': 156, 'capacity': 1408, 'flexibility': 0.8, 'satisfaction': 0.7},\n",
    "                {'terminal': 'Terminal_B', 'cost': 180, 'capacity': 1440, 'flexibility': 0.8, 'satisfaction': 0.75},\n",
    "                {'terminal': 'Terminal_C', 'cost': 132, 'capacity': 1376, 'flexibility': 0.8, 'satisfaction': 0.65},\n",
    "            ],\n",
    "            'RMG_PURE': [\n",
    "                {'terminal': 'Terminal_D', 'cost': 162, 'capacity': 1440, 'flexibility': 0.3, 'satisfaction': 0.8},\n",
    "                {'terminal': 'Terminal_E', 'cost': 174, 'capacity': 1488, 'flexibility': 0.3, 'satisfaction': 0.85},\n",
    "                {'terminal': 'Terminal_F', 'cost': 150, 'capacity': 1392, 'flexibility': 0.3, 'satisfaction': 0.7},\n",
    "            ],\n",
    "            'SC_PURE': [\n",
    "                {'terminal': 'Terminal_G', 'cost': 134, 'capacity': 1152, 'flexibility': 0.9, 'satisfaction': 0.6},\n",
    "                {'terminal': 'Terminal_H', 'cost': 142, 'capacity': 1200, 'flexibility': 0.9, 'satisfaction': 0.65},\n",
    "                {'terminal': 'Terminal_I', 'cost': 126, 'capacity': 1088, 'flexibility': 0.9, 'satisfaction': 0.55},\n",
    "            ],\n",
    "            'HYBRID': [\n",
    "                {'terminal': 'Terminal_J', 'cost': 178, 'capacity': 1584, 'flexibility': 0.85, 'satisfaction': 0.9},\n",
    "                {'terminal': 'Terminal_K', 'cost': 192, 'capacity': 1680, 'flexibility': 0.85, 'satisfaction': 0.95},\n",
    "                {'terminal': 'Terminal_L', 'cost': 164, 'capacity': 1488, 'flexibility': 0.85, 'satisfaction': 0.8},\n",
    "            ]\n",
    "        }\n",
    "    \n",
    "    def _load_global_benchmarks(self) -> Dict[str, Dict[str, float]]:\n",
    "        \"\"\"Load global industry benchmarks\"\"\"\n",
    "        return {\n",
    "            'RTG_PURE': {\n",
    "                'avg_cost_per_move': 42.5,\n",
    "                'avg_flexibility': 0.8,\n",
    "                'avg_implementation_time': 12,\n",
    "                'avg_risk': 0.3\n",
    "            },\n",
    "            'RMG_PURE': {\n",
    "                'avg_cost_per_move': 38.2,\n",
    "                'avg_flexibility': 0.3,\n",
    "                'avg_implementation_time': 18,\n",
    "                'avg_risk': 0.5\n",
    "            },\n",
    "            'SC_PURE': {\n",
    "                'avg_cost_per_move': 45.8,\n",
    "                'avg_flexibility': 0.9,\n",
    "                'avg_implementation_time': 8,\n",
    "                'avg_risk': 0.2\n",
    "            },\n",
    "            'HYBRID': {\n",
    "                'avg_cost_per_move': 41.1,\n",
    "                'avg_flexibility': 0.85,\n",
    "                'avg_implementation_time': 15,\n",
    "                'avg_risk': 0.4\n",
    "            }\n",
    "        }\n",
    "    \n",
    "    def analyze_terminal_requirements(self, terminal_params: Dict[str, any]) -> Dict[str, float]:\n",
    "        \"\"\"Analyze terminal requirements and constraints\"\"\"\n",
    "        # Calculate weighted requirements scores\n",
    "        requirements = {\n",
    "            'capacity_priority': min(1.0, terminal_params['annual_teu'] / 3000000),  # Scale to 3M TEU\n",
    "            'flexibility_priority': min(1.0, terminal_params['truck_percentage'] / 0.8),  # High truck traffic needs flexibility\n",
    "            'automation_priority': terminal_params['automation_level'],\n",
    "            'environmental_priority': terminal_params['environmental_constraints'],\n",
    "            'budget_constraint': min(1.0, terminal_params['budget_m'] / 200),  # Scale to $200M\n",
    "            'time_constraint': min(1.0, terminal_params['implementation_months'] / 24)  # Scale to 24 months\n",
    "        }\n",
    "        \n",
    "        return requirements\n",
    "    \n",
    "    def generate_equipment_options(self, terminal_params: Dict[str, any]) -> List[EquipmentOption]:\n",
    "        \"\"\"Generate equipment options based on terminal parameters\"\"\"\n",
    "        options = []\n",
    "        \n",
    "        # RTG PURE option\n",
    "        rtg_units = max(8, int(terminal_params['annual_teu'] / 175000))  # RTG handles ~175K TEU/year\n",
    "        rtg_option = EquipmentOption(\n",
    "            configuration='RTG_PURE',\n",
    "            equipment_details={'RTG': rtg_units, 'RMG': 0, 'SC': 0},\n",
    "            total_cost=rtg_units * 12.0,\n",
    "            annual_capacity=rtg_units * 175000,\n",
    "            flexibility_score=0.8,\n",
    "            automation_level=0.3,\n",
    "            environmental_impact=0.7,  # Medium environmental impact\n",
    "            implementation_time=12,\n",
    "            risk_assessment=0.3\n",
    "        )\n",
    "        \n",
    "        # RMG PURE option\n",
    "        rmg_units = max(6, int(terminal_params['annual_teu'] / 240000))  # RMG handles ~240K TEU/year\n",
    "        rmg_option = EquipmentOption(\n",
    "            configuration='RMG_PURE',\n",
    "            equipment_details={'RTG': 0, 'RMG': rmg_units, 'SC': 0},\n",
    "            total_cost=rmg_units * 15.0,\n",
    "            annual_capacity=rmg_units * 240000,\n",
    "            flexibility_score=0.3,\n",
    "            automation_level=0.8,\n",
    "            environmental_impact=0.2,  # Low environmental impact (electric)\n",
    "            implementation_time=18,\n",
    "            risk_assessment=0.5\n",
    "        )\n",
    "        \n",
    "        # Straddle PURE option\n",
    "        sc_units = max(16, int(terminal_params['annual_teu'] / 144000))  # SC handles ~144K TEU/year\n",
    "        sc_option = EquipmentOption(\n",
    "            configuration='SC_PURE',\n",
    "            equipment_details={'RTG': 0, 'RMG': 0, 'SC': sc_units},\n",
    "            total_cost=sc_units * 4.0,\n",
    "            annual_capacity=sc_units * 144000,\n",
    "            flexibility_score=0.9,\n",
    "            automation_level=0.4,\n",
    "            environmental_impact=0.6,  # Medium-high environmental impact\n",
    "            implementation_time=8,\n",
    "            risk_assessment=0.2\n",
    "        )\n",
    "        \n",
    "        # HYBRID option\n",
    "        hybrid_rtg = max(4, int(terminal_params['annual_teu'] * 0.25 / 175000))\n",
    "        hybrid_rmg = max(2, int(terminal_params['annual_teu'] * 0.25 / 240000))\n",
    "        hybrid_sc = max(6, int(terminal_params['annual_teu'] * 0.5 / 144000))\n",
    "        \n",
    "        hybrid_option = EquipmentOption(\n",
    "            configuration='HYBRID',\n",
    "            equipment_details={'RTG': hybrid_rtg, 'RMG': hybrid_rmg, 'SC': hybrid_sc},\n",
    "            total_cost=hybrid_rtg * 12.0 + hybrid_rmg * 15.0 + hybrid_sc * 4.0,\n",
    "            annual_capacity=hybrid_rtg * 175000 + hybrid_rmg * 240000 + hybrid_sc * 144000,\n",
    "            flexibility_score=0.85,\n",
    "            automation_level=0.6,\n",
    "            environmental_impact=0.4,  # Moderate environmental impact\n",
    "            implementation_time=15,\n",
    "            risk_assessment=0.4\n",
    "        )\n",
    "        \n",
    "        return [rtg_option, rmg_option, sc_option, hybrid_option]\n",
    "    \n",
    "    def calculate_option_scores(self, options: List[EquipmentOption], \n",
    "                           requirements: Dict[str, float]) -> Dict[str, float]:\n",
    "        \"\"\"Calculate scores for equipment options based on requirements\"\"\"\n",
    "        scores = {}\n",
    "        \n",
    "        for option in options:\n",
    "            # Capacity score\n",
    "            capacity_score = min(1.0, option.annual_capacity / 2500000)  # Scale to 2.5M TEU requirement\n",
    "            \n",
    "            # Cost score (lower is better, so invert)\n",
    "            cost_score = max(0.0, 1.0 - option.total_cost / 200)  # Scale to $200M budget\n",
    "            \n",
    "            # Flexibility score\n",
    "            flexibility_score = option.flexibility_score * requirements['flexibility_priority']\n",
    "            \n",
    "            # Automation score\n",
    "            automation_score = option.automation_level * requirements['automation_priority']\n",
    "            \n",
    "            # Environmental score (lower impact is better)\n",
    "            environmental_score = (1.0 - option.environmental_impact) * requirements['environmental_priority']\n",
    "            \n",
    "            # Time score\n",
    "            time_score = max(0.0, 1.0 - option.implementation_time / 24) * requirements['time_constraint']\n",
    "            \n",
    "            # Risk score (lower risk is better)\n",
    "            risk_score = (1.0 - option.risk_assessment)\n",
    "            \n",
    "            # Weighted total score\n",
    "            total_score = (\n",
    "                0.3 * capacity_score +\n",
    "                0.2 * cost_score +\n",
    "                0.2 * flexibility_score +\n",
    "                0.1 * automation_score +\n",
    "                0.1 * environmental_score +\n",
    "                0.05 * time_score +\n",
    "                0.05 * risk_score\n",
    "            )\n",
    "            \n",
    "            scores[option.configuration] = total_score\n",
    "        \n",
    "        return scores\n",
    "    \n",
    "    def generate_reasoning(self, option: EquipmentOption, \n",
    "                           requirements: Dict[str, float], \n",
    "                           scores: Dict[str, float]) -> List[str]:\n",
    "        \"\"\"Generate step-by-step reasoning for equipment recommendation\"\"\"\n",
    "        reasoning = []\n",
    "        \n",
    "        reasoning.append(f\"Step 1: Analyzed terminal requirements\")\n",
    "        reasoning.append(f\"   - Annual TEU requirement: {requirements['capacity_priority']:.1%} of baseline\")\n",
    "        reasoning.append(f\"   - Flexibility priority: {requirements['flexibility_priority']:.1%} (high truck traffic)\")\n",
    "        reasoning.append(f\"   - Automation priority: {requirements['automation_priority']:.1%} (modernization goal)\")\n",
    "        reasoning.append(f\"   - Environmental priority: {requirements['environmental_priority']:.1%} (sustainability focus)\")\n",
    "        \n",
    "        reasoning.append(f\"\\nStep 2: Evaluated {option.configuration} configuration\")\n",
    "        reasoning.append(f\"   - Annual capacity: {option.annual_capacity:,} TEU\")\n",
    "        reasoning.append(f\"   - Total cost: ${option.total_cost:.1f}M\")\n",
    "        reasoning.append(f\"   - Flexibility score: {option.flexibility_score:.2f}\")\n",
    "        reasoning.append(f\"   - Automation level: {option.automation_level:.1%}\")\n",
    "        reasoning.append(f\"   - Environmental impact: {option.environmental_impact:.1%}\")\n",
    "        \n",
    "        reasoning.append(f\"\\nStep 3: Compared with alternatives\")\n",
    "        for config, score in scores.items():\n",
    "            if config != option.configuration:\n",
    "                reasoning.append(f\"   - {config}: score {score:.3f}\")\n",
    "        \n",
    "        reasoning.append(f\"\\nStep 4: Selected {option.configuration} (score: {scores[option.configuration]:.3f})\")\n",
    "        \n",
    "        # Add specific reasoning based on configuration type\n",
    "        if option.configuration == 'HYBRID':\n",
    "            reasoning.append(f\"   - Chosen for balanced approach combining efficiency and flexibility\")\n",
    "            reasoning.append(f\"   - RTG units ({option.equipment_details['RTG']}) provide operational flexibility\")\n",
    "            reasoning.append(f\"   - RMG units ({option.equipment_details['RMG']}) ensure high-density efficiency\")\n",
    "            reasoning.append(f\"   - Straddle units ({option.equipment_details['SC']}) support landside operations\")\n",
    "        elif option.configuration == 'RTG_PURE':\n",
    "            reasoning.append(f\"   - Chosen for maximum flexibility and proven reliability\")\n",
    "        elif option.configuration == 'RMG_PURE':\n",
    "            reasoning.append(f\"   - Chosen for maximum efficiency and environmental benefits\")\n",
    "        elif option.configuration == 'SC_PURE':\n",
    "            reasoning.append(f\"   - Chosen for cost-effectiveness and operational agility\")\n",
    "        \n",
    "        return reasoning\n",
    "    \n    "   def calculate_confidence(self, option: EquipmentOption, \n",
    "                           requirements: Dict[str, float],\n",
    "                           scores: Dict[str, float]) -> float:\n",
    "        \"\"\"Calculate confidence in recommendation\"\"\"\n",
    "        # Base confidence from score dominance\n",
    "        max_score = max(scores.values())\n",
    "        score_dominance = scores[option.configuration] / max_score\n",
    "        \n",
    "        # Historical performance confidence\n",
    "        config_data = self.historical_data.get(option.configuration, [])\n",
    "        if config_data:\n",
    "            avg_satisfaction = np.mean([d['satisfaction'] for d in config_data])\n",
    "            historical_confidence = avg_satisfaction\n",
    "        else:\n",
    "            historical_confidence = 0.5  # Default confidence\n",
    "        \n",
    "        # Benchmark alignment confidence\n",
    "        benchmark = self.global_benchmarks[option.configuration]\n",
    "        alignment_score = 0.0\n",
    "        \n",
    "        # Compare with benchmarks\n    \n",
    "        if option.total_cost / sum(option.equipment_details.values()) <= benchmark['avg_cost_per_move'] * 1.1:\n",
    "            alignment_score += 0.3\n",
    "        if abs(option.flexibility_score - benchmark['avg_flexibility']) <= 0.1:\n",
    "            alignment_score += 0.2\n",
    "        \n",
    "        # Uncertainty penalty\n",
    "        uncertainty_penalty = option.risk_assessment * 0.2\n",
    "        \n",
    "        # Combined confidence\n",
    "        confidence = (\n",
    "            0.4 * score_dominance +\n",
    "            0.3 * historical_confidence +\n",
    "            0.2 * alignment_score -\n",
    "            uncertainty_penalty\n",
    "        )\n",
    "        \n",
    "        return max(0.0, min(1.0, confidence))\n",
    "    \n",
    "    def generate_recommendation(self, terminal_params: Dict[str, any]) -> AIRecommendation:\n",
    "        \"\"\"Generate AI recommendation with explainable reasoning\"\"\"\n",
    "        # Analyze requirements\n",
    "        requirements = self.analyze_terminal_requirements(terminal_params)\n",
    "        \n",
    "        # Generate options\n",
    "        options = self.generate_equipment_options(terminal_params)\n",
    "        \n",
    "        # Calculate scores\n",
    "        scores = self.calculate_option_scores(options, requirements)\n",
    "        \n",
    "        # Select primary option\n",
    "        primary_config = max(scores, key=scores.get)\n",
    "        primary_option = next(opt for opt in options if opt.configuration == primary_config)\n",
    "        \n",
    "        # Generate reasoning\n",
    "        reasoning = self.generate_reasoning(primary_option, requirements, scores)\n",
    "        \n",
    "        # Calculate confidence\n",
    "        confidence = self.calculate_confidence(primary_option, requirements, scores)\n",
    "        \n",
    "        # Generate alternative options\n",
    "        sorted_options = sorted(options, key=lambda x: scores[x.configuration], reverse=True)\n",
    "        alternative_options = [opt for opt in sorted_options[1:3]]  # Top 2 alternatives\n",
    "        \n",
    "        # Generate quantitative analysis\n",
    "        quantitative_analysis = {\n",
    "            'score': scores[primary_config],\n",
    "            'cost_efficiency': primary_option.annual_capacity / primary_option.total_cost,\n",
    "            'flexibility_ratio': primary_option.flexibility_score,\n",
    "            'automation_level': primary_option.automation_level,\n",
    "            'implementation_risk': primary_option.risk_assessment\n",
    "        }\n",
    "        \n",
    "        # Generate sensitivity analysis\n",
    "        sensitivity_analysis = {\n",
    "            'budget_impact': [],\n",
    "            'demand_impact': [],\n",
    "            'flexibility_impact': []\n",
    "        }\n",
    "        \n    ",
    "        # Budget sensitivity\n",
    "        for budget_factor in [0.8, 0.9, 1.0, 1.1, 1.2]:\n",
    "            modified_params = terminal_params.copy()\n",
    "            modified_params['budget_m'] = terminal_params['budget_m'] * budget_factor\n",
    "            modified_options = self.generate_equipment_options(modified_params)\n",
    "            modified_scores = self.calculate_option_scores(modified_options, self.analyze_terminal_requirements(modified_params))\n",
    "            sensitivity_analysis['budget_impact'].append(modified_scores[primary_config])\n",
    "        \n",
    "        # Generate uncertainty estimates\n",
    "        uncertainty_estimates = {\n",
    "            'cost_uncertainty': primary_option.total_cost * 0.1,  # 10% cost uncertainty\n",
    "            'capacity_uncertainty': primary_option.annual_capacity * 0.05,  # 5% capacity uncertainty\n",
    "            'implementation_uncertainty': primary_option.implementation_time * 0.2,  # 20% time uncertainty\n",
    "        }\n",
    "        \n",
    "        return AIRecommendation(\n",
    "            primary_option=primary_option,\n",
    "            confidence_score=confidence,\n",
    "            reasoning=reasoning,\n",
    "            quantitative_analysis=quantitative_analysis,\n",
    "            sensitivity_analysis=sensitivity_analysis,\n",
    "            uncertainty_estimates=uncertainty_estimates,\n",
    "            alternative_options=alternative_options\n",
    "        )\n",
    "    \n",
    "    def learn_from_feedback(self, collaboration: HumanAICollaboration) -> None:\n",
    "        \"\"\"Learn from human-AI collaboration to improve future recommendations\"\"\"\n",
    "        # Store learning outcome\n    ",
    "        self.learning_history.append(collaboration)\n",
    "        \n",
    "        # Simple learning: adjust confidence thresholds based on satisfaction\n",
    "        if collaboration.satisfaction_score > 0.8:\n",
    "            # Human was satisfied, increase confidence in similar recommendations\n",
    "            self.config.confidence_threshold *= 0.95  # Lower threshold\n",
    "        elif collaboration.satisfaction_score < 0.5:\n",
    "            # Human was dissatisfied, decrease confidence threshold\n",
    "            self.config.confidence_threshold *= 1.05  # Raise threshold\n",
    "        \n",
    "        print(f\"AI learned from collaboration: satisfaction {collaboration.satisfaction_score:.2f}, adjusted confidence threshold to {self.config.confidence_threshold:.2f}\")\n",
    "\n",
    "print(\"ExplainableAISystem class defined successfully\")"
