    "@dataclass\n",
    "class EquipmentOption:\n",
    "    \"\"\"Equipment option with comprehensive analysis\"\"\"\n",
    "    configuration: str  # RTG_PURE, RMG_PURE, SC_PURE, HYBRID\n",
    "    equipment_details: Dict[str, int]  # Equipment quantities\n",
    "    total_cost: float  # Total cost in millions\n",
    "    annual_capacity: int  # Annual handling capacity\n",
    "    flexibility_score: float  # Flexibility (0-1)\n",
    "    automation_level: float  # Automation level (0-1)\n",
    "    environmental_impact: float  # Environmental impact (0-1, lower is better)\n",
    "    implementation_time: int  # Implementation time in months\n",
    "    risk_assessment: float  # Implementation risk (0-1)\n",
    "    \n",
    "@dataclass\n",
    "class AIRecommendation:\n",
    "    \"\"\"AI-generated equipment recommendation\"\"\"\n",
    "    primary_option: EquipmentOption\n",
    "    confidence_score: float  # AI confidence in recommendation (0-1)\n",
    "    reasoning: List[str]  # Step-by-step reasoning\n",
    "    quantitative_analysis: Dict[str, float]  # Supporting metrics\n",
    "    sensitivity_analysis: Dict[str, List[float]]  # Parameter sensitivity\n",
    "    uncertainty_estimates: Dict[str, float]  # Uncertainty in estimates\n",
    "    alternative_options: List[EquipmentOption]  # Other viable options\n",
    "\n",
    "@dataclass\n",
    "class HumanExpertise:\n",
    "    \"\"\"Human expert knowledge and contextual factors\"\"\"\n",
    "    expert_name: str\n",
    "    years_experience: int\n",
    "    domain_knowledge: List[str]  # Areas of expertise\n",
    "    contextual_factors: Dict[str, str]  # Local market conditions, etc.\n",
    "    stakeholder_considerations: List[str]  # Stakeholder concerns\n",
    "    strategic_priorities: List[str]  # Strategic goals\n",
    "    risk_tolerance: str  # LOW, MEDIUM, HIGH\n",
    "    qualitative_insights: List[str]  # Expert insights\n",
    "\n",
    "@dataclass\n",
    "class HumanAICollaboration:\n",
    "    \"\"\"Record of human-AI collaboration session\"\"\"\n",
    "    session_id: str\n",
    "    timestamp: datetime\n",
    "    ai_recommendation: AIRecommendation\n",
    "    human_input: HumanExpertise\n",
    "    discussion_points: List[str]  # Key discussion points\n",
    "modifications: Dict[str, str]  # Human modifications to AI analysis\n",
    "    final_decision: EquipmentOption\n",
    "    satisfaction_score: float  # Human satisfaction with process (0-1)\n",
    "    learning_outcomes: List[str]  # What both parties learned\n",
    "\n",
    "@dataclass\n",
    "class CentaurConfig:\n",
    "    \"\"\"Configuration for human-AI centaur system\"\"\"\n",
    "    confidence_threshold: float = 0.7  # Minimum confidence for strong recommendation\n",
    "    uncertainty_tolerance: float = 0.2  # Acceptable uncertainty level\n",
    "    human_weight: float = 0.6  # Weight given to human input in final decision\n",
    "    ai_weight: float = 0.4  # Weight given to AI analysis in final decision\n",
    "    learning_rate: float = 0.1  # Learning rate for system improvement\n",
    "\n",
    "print(\"Human-AI Symbiotic Partnership data structures defined\")\n",
    "print(f\"Centaur configuration: confidence threshold = {CentaurConfig().confidence_threshold}, human weight = {CentaurConfig().human_weight}\")"
   ]
