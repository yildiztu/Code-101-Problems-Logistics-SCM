    "        print(f\"Session Satisfaction: {collaboration.satisfaction_score:.1%}\")\n",
    "        print(f\"Learning Outcomes: {len(collaboration.learning_outcomes)} identified\")\n",
    "        \n",
    "        return collaboration\n",
    "    \n",
    "    def compare_decision_approaches(self, terminal_params: Dict[str, any], \n",
    "                               num_sessions: int = 5) -> Dict[str, List[float]]:\n",
    "        \"\"\"Compare AI-only, human-only, and centaur decision approaches\"\"\"\n",
    "        print(f\"\\n=== COMPARATIVE DECISION ANALYSIS ===\")\n",
    "        print(f\"Running {num_sessions} decision sessions...\")\n",
    "        \n",
    "        ai_scores = []\n",
    "        human_scores = []\n",
    "        centaur_scores = []\n",
    "        \n",
    "        for session in range(num_sessions):\n",
    "            print(f\"\\nSession {session + 1}/{num_sessions}:\")\n",
    "            \n",
    "            # AI-only decision\n",
    "            ai_rec = self.ai_system.generate_recommendation(terminal_params)\n",
    "            ai_score = ai_rec.confidence_score\n",
    "            ai_scores.append(ai_score)\n",
    "            \n",
    "            # Human-only decision\n",
    "            human_opt = self.simulate_human_only_decision(terminal_params)\n",
    "            human_score = 0.75  # Assume 75% human confidence in own decisions\n",
    "            human_scores.append(human_score)\n",
    "            \n",
    "            # Centaur collaborative decision\n",
    "            collaboration = self.collaborative_decision_session(terminal_params, 'terminal_manager')\n    ",
    "            # Calculate centaur score based on decision quality\n    ",
    "            # Simplified: higher satisfaction and better alignment indicates better decision\n",
    "            centaur_score = collaboration.satisfaction_score * 0.9\n",
    "            centaur_scores.append(centaur_score)\n",
    "        \n",
    "        return {\n",
    "            'ai_only': ai_scores,\n",
    "            'human_only': human_scores,\n",
    "            'centaur': centaur_scores\n",
    "        }\n",
